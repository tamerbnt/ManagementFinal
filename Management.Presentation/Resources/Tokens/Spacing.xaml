<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    
    <!-- Doubles (For Width, Height, CornerRadius) -->
    <sys:Double x:Key="Space.XS.Val">4</sys:Double>
    <sys:Double x:Key="Space.SM.Val">8</sys:Double>
    <sys:Double x:Key="Space.MD.Val">16</sys:Double>
    <sys:Double x:Key="Space.LG.Val">24</sys:Double>
    <sys:Double x:Key="Space.XL.Val">32</sys:Double>
    <sys:Double x:Key="Space.XXL.Val">48</sys:Double>

    <!-- Thicknesses (For Margin, Padding) -->
    <!-- Uniform -->
    <Thickness x:Key="Space.XS">4</Thickness>
    <Thickness x:Key="Space.SM">8</Thickness>
    <Thickness x:Key="Space.MD">16</Thickness>
    <Thickness x:Key="Space.LG">24</Thickness>
    <Thickness x:Key="Space.XL">32</Thickness>
    <Thickness x:Key="Space.XXL">48</Thickness>
    
    <!-- Specific Layouts -->
    <Thickness x:Key="Margin.Standard">16</Thickness>
    <Thickness x:Key="Margin.Small">8</Thickness>
    <Thickness x:Key="Padding.Button">16,8</Thickness>
    <Thickness x:Key="Padding.Card">24</Thickness>

</ResourceDictionary>
