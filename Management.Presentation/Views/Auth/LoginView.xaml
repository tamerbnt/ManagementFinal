<UserControl x:Class="Management.Presentation.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Management.Presentation.ViewModels"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:auth="clr-namespace:Management.Presentation.Views.Auth"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
             d:DesignHeight="768" d:DesignWidth="460"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0.4" To="0.8" Duration="0:0:0.8"
                                 AutoReverse="True"/>
            </Storyboard>
            <Style x:Key="LoginInputBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Height" Value="48"/>
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush" Value="#0EA5E9"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#0EA5E9" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Top"
                    Margin="40,32,40,40"
                    Visibility="{Binding IsInitializingApp, Converter={StaticResource InverseBooleanToVisibilityConverter}}">

            <!-- HEADER -->
            <Grid Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="/Assets/luxurya_header_logo.png" Height="64" HorizontalAlignment="Left" Stretch="Uniform"/>
            </Grid>

            <TextBlock Text="Sign in" FontSize="40" FontWeight="ExtraBold" Foreground="#0F172A" Margin="0,0,0,12"/>

            <!-- EXPANSION BANNER -->
            <Border Background="#F0F9FF" BorderBrush="#0EA5E9" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,0,16"
                    Visibility="{Binding IsExpansionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z" Fill="#0EA5E9" Width="14" Height="14" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ExpansionMessage}" Foreground="#1E293B" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- EMAIL -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Email Address" FontSize="12" FontWeight="Medium" Foreground="#374151" Margin="0,0,0,4"/>
                <Border Style="{StaticResource LoginInputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" Fill="#D1D5DB" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="EmailInput" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#111827" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,12,0" CaretBrush="#0EA5E9"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- PASSWORD -->
            <StackPanel Margin="0,0,0,16">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Password" FontSize="12" FontWeight="Medium" Foreground="#374151" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12">
                        <Hyperlink Command="{Binding ForgotPasswordCommand}" Foreground="#0EA5E9" FontWeight="SemiBold" TextDecorations="{x:Null}">Forgot password?</Hyperlink>
                    </TextBlock>
                </Grid>
                <Border Style="{StaticResource LoginInputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.11,13 12,13A2,2 0 0,0 10,15C10,16.11 10.89,17 12,17M18,8H17V6A5,5 0 0,0 12,1A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M9,6A3,3 0 0,1 12,3A3,3 0 0,1 15,6V8H9V6Z" Fill="#D1D5DB" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <PasswordBox x:Name="PasswordInput" Background="Transparent" BorderThickness="0" Foreground="#111827" FontSize="14" VerticalContentAlignment="Center" CaretBrush="#0EA5E9"/>
                            <TextBox x:Name="PasswordTextBox" Background="Transparent" BorderThickness="0" Foreground="#111827" FontSize="14" VerticalContentAlignment="Center" CaretBrush="#0EA5E9" Visibility="Collapsed"/>
                        </Grid>
                        <Button Grid.Column="2" Click="TogglePasswordVisibility_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center" Width="32" Height="32" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button"><Border Background="Transparent"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate>
                            </Button.Template>
                            <Grid Width="18" Height="18">
                                <Path x:Name="EyeOpenIcon" Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Fill="#D1D5DB" Stretch="Uniform"/>
                                <Path x:Name="EyeClosedIcon" Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.22 16.38,18.7L16.81,19.13L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.76 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z" Fill="#D1D5DB" Stretch="Uniform" Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- FACILITY CONTEXT LOCKED -->
            <Border Background="#F1F5F9" CornerRadius="12" Padding="12,8" Margin="0,0,0,24">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Logging into " Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedFacility.Name}" Foreground="#0F172A" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Command="{Binding ChangeFacilityCommand}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,2">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" x:Name="btnBorder">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Change" Foreground="#0EA5E9" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <Path Data="M19,13H7.83L12.71,17.89L11.29,19.31L4,12L11.29,4.69L12.71,6.11L7.83,11H19V13Z" 
                                              Fill="#0EA5E9" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <CheckBox Content="Remember device" IsChecked="{Binding RememberMe}" Foreground="#6B7280" FontSize="13" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

            <!-- ERROR -->
            <Border Background="#FEF2F2" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,12"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Path Data="M13,13H11V7H13M13,17H11V15H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" Fill="#EF4444" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="#B91C1C" FontSize="12" TextWrapping="Wrap" Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- SUBMIT & BRANDING -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordInput}"
                        Width="162" Height="46"
                        HorizontalAlignment="Left"
                        Cursor="Hand"
                        BorderThickness="0"
                        Background="Transparent"
                        Margin="0,0,16,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    CornerRadius="10"
                                    Background="#0EA5E9">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="BtnScale" ScaleX="1.0" ScaleY="1.0" CenterX="80" CenterY="23"/>
                                </Border.RenderTransform>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="btnText" Text="Sign in" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                    <Path x:Name="btnChevron" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="White" Width="10" Height="10" Stretch="Uniform" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="busyBar" IsIndeterminate="True" Width="50" Height="3" Background="Transparent" Foreground="White" BorderThickness="0" Visibility="Collapsed" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                    <Setter TargetName="btnText" Property="Foreground" Value="#9CA3AF"/>
                                    <Setter TargetName="btnChevron" Property="Fill" Value="#9CA3AF"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.05"/><DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleY" To="0.97" Duration="0:0:0.05"/></Storyboard></BeginStoryboard></Trigger.EnterActions>
                                    <Trigger.ExitActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/><DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/></Storyboard></BeginStoryboard></Trigger.ExitActions>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter TargetName="btnText" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="btnChevron" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="busyBar" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- "Powered by From Scratch" -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Powered by" FontSize="10" Foreground="#6B7280" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    <Border Width="110" Height="80" Background="#111827" HorizontalAlignment="Center" Margin="0,4,0,0" ToolTip="Powered by From Scratch">
                        <Border.OpacityMask>
                            <ImageBrush ImageSource="/Assets/from_scratch_logo.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border.OpacityMask>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
