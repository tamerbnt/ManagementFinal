    // 2. Send verification email
    await _supabase.Auth.SendMagicLinkAsync(data.Email);
    
    // 3. Wait for email verification (polling or webhook)
    await WaitForEmailVerification(authResponse.User.Id);
    
    // 4. Create owner profile
    await _supabase.From<Profiles>().InsertAsync(new {
        UserId = authResponse.User.Id,
        FullName = data.FullName,
        Role = "Owner",
        Email = data.Email,
        CreatedAt = DateTime.UtcNow
    });
    
    // 5. Create business record
    var businessId = await _supabase.From<Businesses>().InsertAsync(new {
        Name = data.BusinessName,
        OwnerId = authResponse.User.Id,
        Phone = data.Phone,
        Address = data.Address,
        TimeZone = data.TimeZone
    });
    
    // 6. Link license to owner
    await _supabase.From<Licenses>().UpdateAsync(
        licenseKey: data.LicenseKey,
        new { 
            OwnerId = authResponse.User.Id,
            BusinessId = businessId 
        }
    );
    
    // 7. Create facility records
    foreach (var facility in data.Facilities)
    {
        await _supabase.From<Facilities>().InsertAsync(new {
            BusinessId = businessId,
            Type = facility.Type,
            Name = facility.Name,
            Address = facility.Address,
            Hours = facility.Hours
        });
    }
    
    // 8. Auto-login owner
    await LoginAsync(data.Email, data.Password);
    
    // 9. Navigate to dashboard
    NavigateToDashboard();
}
