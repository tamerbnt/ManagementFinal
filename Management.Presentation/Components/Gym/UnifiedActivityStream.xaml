<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:Management.Presentation.ViewModels.GymHome"
                    xmlns:enums="clr-namespace:Management.Domain.Enums;assembly=Management.Domain">

    <!-- Animation Resources -->
    <Storyboard x:Key="PopInAnimation">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
            <EasingDoubleKeyFrame KeyTime="0" Value="0.8"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.05">
                <EasingDoubleKeyFrame.EasingFunction>
                    <ElasticEase Oscillations="1" Springiness="5" EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
            <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1.0"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
            <EasingDoubleKeyFrame KeyTime="0" Value="0.8"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.05">
                <EasingDoubleKeyFrame.EasingFunction>
                    <ElasticEase Oscillations="1" Springiness="5" EasingMode="EaseOut"/>
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
            <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1.0"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
    </Storyboard>

    <!-- DataTemplate for Member Access -->
    <DataTemplate DataType="{x:Type vm:MemberAccessItem}">
        <Border x:Name="RootBorder" Margin="0,0,0,12" Padding="16" CornerRadius="12" Background="#2A2A2A" BorderThickness="4,0,0,0">
            <Border.RenderTransform>
                <ScaleTransform CenterX="150" CenterY="40"/>
            </Border.RenderTransform>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="#10B981"/> <!-- Default Green -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ResultStatus}" Value="{x:Static enums:AccessResult.Denied}">
                            <Setter Property="BorderBrush" Value="#EF4444"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ResultStatus}" Value="{x:Static enums:AccessResult.Warning}">
                            <Setter Property="BorderBrush" Value="#F59E0B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Ellipse Grid.Column="0" Width="48" Height="48" Margin="0,0,16,0">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding PhotoPath}" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#AAAAAA"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}" FontSize="12" Foreground="#666666" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding DaysRemaining, StringFormat='\{0\} Days Left'}" FontSize="12" Foreground="#10B981" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
            
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource PopInAnimation}"/>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </DataTemplate>

    <!-- DataTemplate for Walk-In -->
    <DataTemplate DataType="{x:Type vm:WalkInItem}">
        <Border Margin="0,0,0,12" Padding="16" CornerRadius="12" Background="#2A2A2A" BorderThickness="4,0,0,0" BorderBrush="#10B981">
            <Border.RenderTransform>
                <ScaleTransform CenterX="150" CenterY="40"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="48" Height="48" Background="#1A10B981" CornerRadius="24" Margin="0,0,16,0">
                    <TextBlock Text="💵" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#AAAAAA"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat=HH:mm:ss}" FontSize="12" Foreground="#666666" VerticalAlignment="Top"/>
            </Grid>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource PopInAnimation}"/>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </DataTemplate>

    <!-- DataTemplate for Sale Item -->
    <DataTemplate DataType="{x:Type vm:SaleItem}">
        <Border Margin="0,0,0,12" Padding="16" CornerRadius="12" Background="#2A2A2A" BorderThickness="4,0,0,0" BorderBrush="#3B82F6">
            <Border.RenderTransform>
                <ScaleTransform CenterX="150" CenterY="40"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="48" Height="48" Background="#1A3B82F6" CornerRadius="24" Margin="0,0,16,0">
                    <TextBlock Text="🛍️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#AAAAAA"/>
                    <TextBlock Text="{Binding MemberName, StringFormat='Attached to: \{0\}'}" FontSize="12" Foreground="#3B82F6" Visibility="{Binding MemberName, Converter={StaticResource StringToVisibilityConverter}}"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat=HH:mm:ss}" FontSize="12" Foreground="#666666" VerticalAlignment="Top"/>
            </Grid>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource PopInAnimation}"/>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </DataTemplate>

</ResourceDictionary>
