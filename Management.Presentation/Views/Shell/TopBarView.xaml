<UserControl x:Class="Management.Presentation.Views.Shell.TopBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter" />
        
        <!-- Redesigned Search Bar Style -->
        <Style x:Key="TopBarSearchTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="40,0,10,0"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <Grid>
                                <!-- Search Icon -->
                                <Path x:Name="SearchIcon"
                                      Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                      Fill="{DynamicResource FacilityAccentBrush}" 
                                      Width="16" Height="16" 
                                      HorizontalAlignment="Left" 
                                      Margin="14,0,0,0" 
                                      VerticalAlignment="Center"/>

                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                
                                <!-- Placeholder -->
                                <TextBlock x:Name="Placeholder" 
                                           Text="{DynamicResource Terminology.TopBar.SearchPlaceholder}" 
                                           Foreground="{DynamicResource TextSecondaryBrush}" 
                                           VerticalAlignment="Center" 
                                           Margin="40,0,0,0" 
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"
                                           FontSize="13"/>
                                
                                <!-- Shortcut Key indicator -->
                                <Border x:Name="ShortcutBox"
                                        Background="{DynamicResource SurfaceBg}" 
                                        CornerRadius="4" 
                                        Padding="6,2" 
                                        VerticalAlignment="Center" 
                                        HorizontalAlignment="Right"
                                        Margin="0,0,10,0"
                                        Opacity="0.8">
                                    <TextBlock Text="{DynamicResource Strings.Shell.K}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>

                                <!-- Loading Spinner -->
                                <Path x:Name="LoadingSpinner"
                                      Visibility="Collapsed"
                                      Data="M12,4V2A10,10 0 0,0 2,12H4A8,8 0 0,1 12,4Z"
                                      Fill="{DynamicResource FacilityAccentBrush}"
                                      Width="16" Height="16"
                                      HorizontalAlignment="Right"
                                      Margin="0,0,10,0"
                                      VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSearchLoading}" Value="True">
                                <Setter TargetName="LoadingSpinner" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ShortcutBox" Property="Visibility" Value="Collapsed"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="SpinSearch">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0" To="360" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="SpinSearch"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="ShortcutBox" Property="Visibility" Value="Collapsed"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width" To="400" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CircleEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width" To="250" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CircleEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SeparatorStroke}" SnapsToDevicePixels="True">
        <Grid Background="Transparent" VerticalAlignment="Stretch" MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Search Bar (left-aligned) -->
                <ColumnDefinition Width="*"/> <!-- Flexible spacer -->
                <ColumnDefinition Width="Auto"/> <!-- Actions (Notifications + Profile) -->
                <ColumnDefinition Width="Auto"/> <!-- Window Controls -->
            </Grid.ColumnDefinitions>

        <!-- Ctrl+K binding handled at MainWindow level -->

        <!-- SEARCH BAR (Expanding Dropdown) -->
        <Grid Grid.Column="0" VerticalAlignment="Center" Margin="32,0,0,0">
            <StackPanel HorizontalAlignment="Left">
                <TextBox x:Name="GlobalSearchBox"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TopBarSearchTextBox}"
                         Loaded="OnSearchTextBoxLoaded">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SubmitSearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                
                <Popup x:Name="SearchPopup" 
                       AllowsTransparency="True"
                       IsOpen="{Binding IsSearchPopupOpen, Mode=TwoWay}"
                       PlacementTarget="{Binding ElementName=GlobalSearchBox}"
                       Placement="Bottom"
                       VerticalOffset="8"
                       StaysOpen="False"
                       PopupAnimation="Fade">
                    <Border Background="{DynamicResource CardBackgroundBrush}" 
                            CornerRadius="14" 
                            BorderThickness="1" 
                            BorderBrush="{DynamicResource BorderBrush}"
                            Width="{Binding ElementName=GlobalSearchBox, Path=ActualWidth}"
                            MinHeight="100"
                            Padding="2"
                            Margin="12">
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level2"/>
                        </Border.Effect>

                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                                <ItemsControl ItemsSource="{Binding SearchResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ExecuteSearchItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{DynamicResource Button.Ghost}"
                                                    Focusable="False"
                                                    Click="OnSearchItemClicked"
                                                    HorizontalContentAlignment="Stretch"
                                                    Height="64"
                                                    Padding="12,8"
                                                    Margin="0,0"
                                                    Cursor="Hand">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="48"/> <!-- Icon Column -->
                                                        <ColumnDefinition Width="*"/> <!-- Title/Subtitle Column -->
                                                        <ColumnDefinition Width="Auto"/> <!-- Category Column -->
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource SurfaceBg}" HorizontalAlignment="Left">
                                                        <Path x:Name="TypeIcon" Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource TextSecondaryBrush}"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="2" Background="{DynamicResource SurfaceBg}" CornerRadius="4" Padding="6,3" VerticalAlignment="Center" Opacity="0.6">
                                                        <TextBlock Text="{Binding Group}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="8" FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>
                                            </Button>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Group}" Value="MEMBERS">
                                                    <Setter TargetName="TypeIcon" Property="Data" Value="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Group}" Value="CLIENTS">
                                                    <Setter TargetName="TypeIcon" Property="Data" Value="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Group}" Value="STAFF">
                                                    <Setter TargetName="TypeIcon" Property="Data" Value="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"/>
                                                    <Setter TargetName="TypeIcon" Property="Fill" Value="{DynamicResource FacilityAccentBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Group}" Value="INVENTORY">
                                                    <Setter TargetName="TypeIcon" Property="Data" Value="M20,6H16V5A2,2 0 0,0 14,3H10A2,2 0 0,0 8,5V6H4A2,2 0 0,0 2,8V19A2,2 0 0,0 4,21H20A2,2 0 0,0 22,19V8A2,2 0 0,0 20,6M10,5H14V6H10V5M20,19H4V8H20V19M12,12A2,2 0 0,1 14,14A2,2 0 0,1 12,16A2,2 0 0,1 10,14A2,2 0 0,1 12,12Z"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Group}" Value="PLANS">
                                                    <Setter TargetName="TypeIcon" Property="Data" Value="M19,3H5C3.89,3 3,3.89 3,5V19C3,20.1 3.89,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.89 20.1,3 19,3M19,19H5V5H19V19M7,10H9V17H7V10M11,7H13V17H11V7M15,13H17V17H15V13Z"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Group}" Value="NAVIGATION">
                                                    <Setter TargetName="TypeIcon" Property="Data" Value="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>
            </StackPanel>
        </Grid>

        <!-- RIGHT: ACTION AREA -->
        <StackPanel Grid.Column="2" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center" 
                    Margin="0,0,32,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <!-- System Status Badge (Online/Offline) -->
            <Border x:Name="StatusBadge" CornerRadius="12" Padding="10,5" Margin="0,0,16,0" VerticalAlignment="Center"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource StatusSuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                        <Setter Property="Fill" Value="{DynamicResource StatusWarningBrush}"/>
                                    </DataTrigger>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.4" Duration="{StaticResource DurationSlow}" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="10" FontWeight="Black">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{DynamicResource Terminology.Global.Online}"/>
                                <Setter Property="Foreground" Value="{DynamicResource StatusSuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                        <Setter Property="Text" Value="{DynamicResource Terminology.Global.Offline}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource StatusWarningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
            
            <!-- HARDWARE STATUS INDICATORS -->
            <StackPanel Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">
                
                <!-- RFID Status -->
                <ContentControl ToolTip="{DynamicResource Terminology.TopBar.Status.Rfid}" Margin="0,0,12,0">
                    <Grid>
                        <Path Data="M2,9A2,2 0 0,1 4,7H20A2,2 0 0,1 22,9V19A2,2 0 0,1 20,21H4A2,2 0 0,1 2,19V9M20,9H4V19H20V9M8,11A1,1 0 0,0 7,12A1,1 0 0,0 8,13A1,1 0 0,0 9,12A1,1 0 0,0 8,11M12,11A1,1 0 0,0 11,12A1,1 0 0,0 12,13A1,1 0 0,0 13,12A1,1 0 0,0 12,11M16,11A1,1 0 0,0 15,12A1,1 0 0,0 16,13A1,1 0 0,0 17,12A1,1 0 0,0 16,11M8,15A1,1 0 0,0 7,16A1,1 0 0,0 8,17A1,1 0 0,0 9,16A1,1 0 0,0 8,15M12,15A1,1 0 0,0 11,16A1,1 0 0,0 12,17A1,1 0 0,0 13,16A1,1 0 0,0 12,15M16,15A1,1 0 0,0 15,16A1,1 0 0,0 16,17A1,1 0 0,0 17,16A1,1 0 0,0 16,15Z" 
                              Width="18" Height="18" Stretch="Uniform"
                              Fill="{DynamicResource TextTertiaryBrush}"> <!-- Default Gray (Offline) -->
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRfidConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource StatusSuccessBrush}"/> <!-- Green (Online) -->
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRfidConnected}" Value="False">
                                             <Setter Property="Fill" Value="{DynamicResource TextTertiaryBrush}"/> <!-- Gray (Offline) -->
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                        <!-- Tiny Status Dot for Offline attention -->
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource StatusErrorBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0" Visibility="Collapsed">
                             <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRfidConnected}" Value="False">
                                            <!-- Optionally show red dot if critical, but for now just graying out is fine or red path -->
                                            <!-- <Setter Property="Visibility" Value="Visible"/> -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                </ContentControl>

                <!-- Cloud Connectivity -->
                <ContentControl ToolTip="{DynamicResource Terminology.TopBar.Status.Cloud}">
                    <Grid>
                        <Path Data="M5.12,5.12C5.9,4.35 6.85,3.73 7.87,3.31C8.9,2.89 10,2.67 11.11,2.67C13.67,2.67 16,3.82 17.6,5.65C19.62,6.38 21,8.32 21,10.5C21,13.55 18.55,16 15.5,16H5.5C2.45,16 0,13.55 0,10.5C0,7.66 2.14,5.33 4.9,5.03C4.94,5.03 5.03,5.08 5.12,5.12M15.5,14C17.43,14 19,12.43 19,10.5C19,8.7 17.64,7.21 15.89,7.03L15.1,6.96L14.78,6.26C14.36,5.33 13.43,4.67 12.33,4.67C10.97,4.67 9.87,5.77 9.87,7.13L9.87,7.56L9.43,7.56C7.8,7.56 6.47,8.87 6.47,10.5C6.47,12.13 7.8,13.43 9.43,13.43L15.5,14" 
                              Width="18" Height="18" Stretch="Uniform"
                              Fill="{DynamicResource StatusSuccessBrush}">
                             <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource StatusSuccessBrush}"/> <!-- Green (Online) -->
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                            <Setter Property="Fill" Value="{DynamicResource StatusErrorBrush}"/> <!-- Red (Offline) -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style> 
                        </Path>
                        <!-- Strike-through for clear offline indication -->
                         <Path Data="M2,2L22,22" Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="2" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Width="18" Height="18" Stretch="Uniform">
                           <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Grid>
                </ContentControl>
            </StackPanel>
            
            <!-- Phase 1: Manual Sync Button -->
            <Button Command="{Binding ManualSyncCommand}"
                    ToolTip="{Binding LastSyncText}"
                    Style="{DynamicResource Button.Ghost}"
                    Padding="8"
                    Width="32" Height="32"
                    Margin="0,0,16,0"
                    VerticalAlignment="Center">
                <Grid>
                    <!-- Sync Icon -->
                    <Path x:Name="SyncIcon"
                          Data="M12,18A6,6 0 0,1 6,12C6,11 6.25,10.03 6.7,9.2L5.24,7.74C4.46,8.97 4,10.43 4,12A8,8 0 0,0 12,20V23L16,19L12,15M12,4V1L8,5L12,9V6A6,6 0 0,1 18,12C18,13 17.75,13.97 17.3,14.8L18.76,16.26C19.54,15.03 20,13.57 20,12A8,8 0 0,0 12,4Z"
                          Fill="{DynamicResource TextSecondaryBrush}"
                          Width="16" Height="16"
                          Stretch="Uniform">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="SpinStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="{StaticResource DurationSlow}"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="SpinStoryboard"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                        <Path.RenderTransform>
                            <RotateTransform CenterX="8" CenterY="8"/>
                        </Path.RenderTransform>
                    </Path>
                </Grid>
            </Button>
            
            <!-- Notifications (Titan Dropdown) -->
            <Grid Margin="0,0,16,0">
                <ToggleButton x:Name="NotifToggle" 
                              Style="{DynamicResource ToggleButton.Ghost}"
                              Padding="6"
                              Width="32" Height="32">
                    <Grid>
                        <Path Data="M12,21A2,2 0 0,0 14,19H10A2,2 0 0,0 12,21M18,15V10C18,6.93 16.36,4.36 13.5,3.68V3A1.5,1.5 0 0,0 12,1.5A1.5,1.5 0 0,0 10.5,3V3.68C7.63,4.36 6,6.92 6,10V15L4,17V18H20V17L18,15Z" 
                              Fill="{DynamicResource TextSecondaryBrush}" 
                              Width="16" Height="16" 
                              Stretch="Uniform" />
                        <!-- Notification Badge -->
                        <Border Background="{DynamicResource StatusErrorBrush}" 
                                Width="8" Height="8" 
                                CornerRadius="4"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="8,-2,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NotificationCount}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>
                </ToggleButton>

                <Popup IsOpen="{Binding IsChecked, ElementName=NotifToggle}" 
                       AllowsTransparency="True"
                       StaysOpen="False" 
                       PlacementTarget="{Binding ElementName=NotifToggle}"
                       Placement="Bottom" 
                       VerticalOffset="12"
                       HorizontalOffset="-134"
                       >
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Padding="0" Width="300"
                            Margin="12"
                            RenderTransformOrigin="0.5,0">
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level2"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleY="0"/>
                                <TranslateTransform Y="-10"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=NotifToggle}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                     From="0" To="1" Duration="{StaticResource DurationNormal}">
                                                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                                     From="-10" To="0" Duration="{StaticResource DurationNormal}">
                                                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="{StaticResource DurationQuick}"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Padding="16,10" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SeparatorStroke}">
                                <Grid>
                                    <TextBlock Text="{DynamicResource Terminology.TopBar.Notifications}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center"/>
                                    <Button Command="{Binding MarkAllAsReadCommand}" 
                                            Style="{DynamicResource Button.Ghost}" 
                                            HorizontalAlignment="Right"
                                            Padding="8,4" Height="Auto">
                                        <TextBlock Text="{DynamicResource Terminology.TopBar.MarkAllAsRead}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" MinHeight="200" MaxHeight="400">
                                <!-- Empty State -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NotificationCount}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Viewbox Width="48" Height="48" Opacity="0.1" Margin="0,0,0,12">
                                        <Path Data="M12,21A2,2 0 0,0 14,19H10A2,2 0 0,0 12,21M18,15V10C18,6.93 16.36,4.36 13.5,3.68V3A1.5,1.5 0 0,0 12,1.5A1.5,1.5 0 0,0 10.5,3V3.68C7.63,4.36 6,6.92 6,10V15L4,17V18H20V17L18,15Z" 
                                              Fill="{DynamicResource TextSecondaryBrush}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="{DynamicResource Terminology.TopBar.AllCaughtUp}" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13" FontWeight="Medium"/>
                                    <TextBlock Text="{DynamicResource Terminology.TopBar.NoNewAlerts}" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Real Notifications List -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Notifications}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{DynamicResource Button.Ghost}" 
                                                        Command="{Binding DataContext.MarkAsReadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalContentAlignment="Stretch" 
                                                        Padding="0" 
                                                        Margin="0,1"
                                                        Cursor="Hand">
                                                    <Border x:Name="NotificationBorder" Padding="16,12" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SurfaceBg}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Type-specific Icon Container -->
                                                            <Border x:Name="IconContainer" Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0" VerticalAlignment="Top">
                                                                <Path x:Name="TypeIcon" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!-- Content Area -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                                                <TextBlock Text="{Binding Message}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxHeight="36" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Timestamp, Converter={StaticResource RelativeTimeConverter}}" 
                                                                           FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                                                            </StackPanel>

                                                            <!-- Unread Indicator -->
                                                            <Ellipse Grid.Column="2" Width="6" Height="6" Fill="{DynamicResource FacilityAccentBrush}" VerticalAlignment="Top" Margin="4,4,0,0">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Success">
                                                        <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource StatusSuccessBackground}"/>
                                                        <Setter TargetName="TypeIcon" Property="Fill" Value="{DynamicResource StatusSuccessBrush}"/>
                                                        <Setter TargetName="TypeIcon" Property="Data" Value="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Error">
                                                        <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource StatusErrorBackground}"/>
                                                        <Setter TargetName="TypeIcon" Property="Fill" Value="{DynamicResource StatusErrorBrush}"/>
                                                        <Setter TargetName="TypeIcon" Property="Data" Value="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Warning">
                                                        <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource StatusWarningBackground}"/>
                                                        <Setter TargetName="TypeIcon" Property="Fill" Value="{DynamicResource StatusWarningBrush}"/>
                                                        <Setter TargetName="TypeIcon" Property="Data" Value="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Info">
                                                        <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource StatusInfoBackground}"/>
                                                        <Setter TargetName="TypeIcon" Property="Fill" Value="{DynamicResource StatusInfoBrush}"/>
                                                        <Setter TargetName="TypeIcon" Property="Data" Value="M11,9H13V7H11V9M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>

            <ToggleButton x:Name="ProfileToggle" 
                          Style="{DynamicResource ToggleButton.Ghost}"
                          Cursor="Hand"
                          Background="Transparent" BorderThickness="0"
                          VerticalAlignment="Center"
                          Padding="4,2"
                          Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <!-- Name + Role -->
                    <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding UserName}" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" 
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding UserRole}" 
                                   Foreground="{DynamicResource TextTertiaryBrush}" 
                                   FontSize="11"/>
                    </StackPanel>
                    
                    <!-- Avatar (Squircle) -->
                    <Border Width="38" Height="38" 
                            CornerRadius="12" 
                            Background="{DynamicResource Brush.Brand.Primary}"
                            VerticalAlignment="Center"
                            BorderThickness="1.5" BorderBrush="{DynamicResource CardBackgroundBrush}">
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level2" />
                        </Border.Effect>
                        <TextBlock Text="{Binding UserInitials}" 
                                   Foreground="White" 
                                   FontSize="14" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </ToggleButton>

            <!-- Profile Popup Menu -->
            <Popup IsOpen="{Binding IsChecked, ElementName=ProfileToggle}" 
                   AllowsTransparency="True"
                   StaysOpen="False" 
                   PlacementTarget="{Binding ElementName=ProfileToggle}"
                   Placement="Bottom" 
                   VerticalOffset="12"
                   HorizontalOffset="-40"
                   >
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Padding="8" Width="200"
                        Margin="12"
                        RenderTransformOrigin="0.5,0">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleY="0"/>
                            <TranslateTransform Y="-10"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=ProfileToggle}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                 From="0" To="1" Duration="{StaticResource DurationNormal}">
                                                    <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                                 From="-10" To="0" Duration="{StaticResource DurationNormal}">
                                                    <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="{StaticResource DurationQuick}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <Button Command="{Binding OpenAccountSettingsCommand}" 
                                Style="{DynamicResource Button.Ghost}"
                                Click="OnProfileMenuItemClicked"
                                HorizontalContentAlignment="Left" 
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                                      Fill="{DynamicResource TextSecondaryBrush}" Width="14" Height="14" Margin="0,0,12,0" Stretch="Uniform"/>
                                <TextBlock Text="{DynamicResource Terminology.Global.Profile}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenSettingsCommand}" 
                                Style="{DynamicResource Button.Ghost}"
                                Click="OnProfileMenuItemClicked"
                                HorizontalContentAlignment="Left" 
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.48,5.32 14.87,5.07L14.49,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.51,2.42L9.13,5.07C8.52,5.32 7.96,5.65 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.35 8.52,18.68 9.13,18.93L9.51,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.49,21.58L14.87,18.93C15.48,18.68 16.04,18.35 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                                      Fill="{DynamicResource TextSecondaryBrush}" Width="14" Height="14" Margin="0,0,12,0" Stretch="Uniform"/>
                                <TextBlock Text="{DynamicResource Terminology.Global.Settings}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>
        </StackPanel>


        <!-- WINDOW CONTROLS (Windows 11 Standard Style) -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right"
                    Margin="0,0,16,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">

            <!-- Bolder Divider Line -->
            <Rectangle Width="2.5" Height="24" Fill="{DynamicResource BorderBrush}" Margin="8,0,16,0"/>
            
            <!-- Minimize -->
            <Button Click="OnMinimize" Width="46" Height="32" Cursor="Hand" ToolTip="{DynamicResource Terminology.Global.Minimize}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <Path Data="M0,0 L10,0" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5" 
                                              Width="10" Height="1" Stretch="Uniform"
                                              VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Maximize / Restore -->
            <Button Click="OnMaximize" Width="46" Height="32" Cursor="Hand" ToolTip="{DynamicResource Terminology.Global.Maximize}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <Path x:Name="IconPath" Data="M0,0 L7,0 L7,7 L0,7 Z M3,3 L10,3 L10,10 L3,10 Z" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2" 
                                              Width="10" Height="10" Stretch="None" 
                                              VerticalAlignment="Center" HorizontalAlignment="Center" SnapsToDevicePixels="True"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                            <Setter TargetName="IconPath" Property="Data" Value="M0,0 L10,0 L10,10 L0,10 Z"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Close -->
            <Button Click="OnClose" Width="46" Height="32" Cursor="Hand" ToolTip="{DynamicResource Terminology.Global.Close}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2" 
                                              Width="10" Height="10" Stretch="None" 
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource StatusErrorBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
        </Grid>
    </Border>
</UserControl>
