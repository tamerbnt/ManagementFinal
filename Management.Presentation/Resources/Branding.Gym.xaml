<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- Identity Layer: GYM FACILITY -->
    
    <!-- Sidebar -->
    <SolidColorBrush x:Key="FacilitySidebarBrush" Color="#0F172A"/>
    
    <!-- Accents -->
    <Color x:Key="FacilityAccentColor">#06B6D4</Color>
    <Color x:Key="FacilityAccentShadowColor">#06B6D4</Color>
    <LinearGradientBrush x:Key="FacilityAccentGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#06B6D4" Offset="0"/>
        <GradientStop Color="#22D3EE" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="FacilityAccentBrush" Color="{StaticResource FacilityAccentColor}"/>
    <SolidColorBrush x:Key="FacilityAccentDimBrush" Color="{StaticResource FacilityAccentColor}" Opacity="0.15"/>
    
    <!-- Contrast Tokens (Safety) -->
    <SolidColorBrush x:Key="OnAccentPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OnAccentSecondary" Color="#E0E7FF"/>

    <!-- Status Backgrounds (Soft) -->
    <SolidColorBrush x:Key="StatusErrorBackground" Color="#FEE2E2"/> <!-- Light Red -->
    <SolidColorBrush x:Key="StatusSuccessBackground" Color="#DCFCE7"/> <!-- Light Green -->
    
    <!-- ElevationColor moved to Theme.Light.xaml and Theme.Dark.xaml to avoid conflicts -->
    
    <!-- Aliases for compatibility/semantic naming -->
    <SolidColorBrush x:Key="AccentBrush" Color="#06B6D4"/>
    <Color x:Key="AccentColor">#06B6D4</Color>
    <SolidColorBrush x:Key="IllustrationBackgroundBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="OverlayBackdropBrush" Color="#80000000"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#0FFFFFFF" Opacity="0.06"/>
    <Color x:Key="AccentLightColor">#E0F2FE</Color>
    
    <!-- Legacy/Alias Tokens (Fix Startup Crash) -->
    <SolidColorBrush x:Key="Brush.Brand.Primary" Color="#06B6D4"/>
    <SolidColorBrush x:Key="Brush.Brand.Primary.Deep" Color="#0F172A"/>
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#06B6D4"/>
    
    <!-- Terminology -->
    <sys:String x:Key="TerminologyLabel">Member</sys:String>
</ResourceDictionary>
