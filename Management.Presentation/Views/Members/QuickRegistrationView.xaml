<UserControl x:Class="Management.Presentation.Views.Members.QuickRegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500"
             FocusManager.FocusedElement="{Binding ElementName=FullNameBox}">



    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="{DynamicResource SizeModalWidth}"
            Padding="{DynamicResource PaddingModal}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Form -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,32">
                <Border Width="64" Height="64" 
                        Background="{DynamicResource Brush.Brand.Primary.Fade}" 
                        CornerRadius="32" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,16">
                    <Path Data="{StaticResource IconMembers}" 
                          Style="{StaticResource Style.Icon.Large}" 
                          Stroke="{DynamicResource Brush.Brand.Primary}" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Border>
                <TextBlock Foreground="{DynamicResource Brush.Text.Primary}"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Title2}">
                            <Setter Property="Text" Value="{DynamicResource Terminology.Members.Add.Title}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenewMode}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource Terminology.Members.Renew.Title}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Foreground="{DynamicResource Brush.Text.Secondary}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
                            <Setter Property="Text" Value="{DynamicResource Terminology.Members.Add.Subtitle}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenewMode}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource Terminology.Members.Renew.Subtitle}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- 2. Form Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,24">
                <StackPanel>
                    <!-- Full Name -->
                    <StackPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource IconMembers}" 
                                  Style="{StaticResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Terminology.Staff.Add.FullName}" Style="{StaticResource FormLabel}"/>
                        </StackPanel>
                        <TextBox x:Name="FullNameBox"
                                 Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource Input.Apple}"
                                 Tag="{DynamicResource Strings.Members.egJohnDoe}"/>
                    </StackPanel>

                    <!-- Phone Number -->
                    <StackPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" 
                                  Style="{StaticResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Terminology.Staff.Add.Phone}" Style="{StaticResource FormLabel}"/>
                        </StackPanel>
                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource Input.Apple}"
                                 Tag="+1 234 567 890"/>
                    </StackPanel>

                    <!-- Card ID / RFID -->
                    <StackPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource IconTag}" 
                                  Style="{StaticResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="Card ID / RFID" Style="{StaticResource FormLabel}"/>
                        </StackPanel>
                        <TextBox Text="{Binding CardId, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource Input.Apple}"
                                 Tag="Scan card or enter ID manually"/>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6" 
                                  Style="{StaticResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Terminology.Staff.Add.Email}" Style="{StaticResource FormLabel}"/>
                        </StackPanel>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource Input.Apple}"
                                 Tag="{DynamicResource Strings.Members.johnexamplecom}"/>
                    </StackPanel>

                    <!-- Gender Selection -->
                    <StackPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="M12 2a5 5 0 1 0 5 5 5 5 0 0 0-5-5z M18 11h-2a1 1 0 0 0-1 1v1a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-1a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h1v1a1 1 0 0 1-1 1H7a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1h-1a1 1 0 0 1-1-1v-1h1a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1z" 
                                  Style="{DynamicResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Terminology.Members.Gender}" Style="{DynamicResource FormLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="{DynamicResource Terminology.Enum.Gender.Male}" 
                                         IsChecked="{Binding Gender, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Male}"
                                         Style="{DynamicResource RadioButton.Apple}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="{DynamicResource Terminology.Enum.Gender.Female}" 
                                         IsChecked="{Binding Gender, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Female}"
                                         Style="{DynamicResource RadioButton.Apple}"
                                         Margin="0,0,16,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Membership Plan -->
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource IconTag}" 
                                  Style="{DynamicResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Terminology.Members.Add.Plan}" Style="{DynamicResource FormLabel}"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding Plans}"
                                  SelectedItem="{Binding SelectedPlan}"
                                  Style="{StaticResource Input.ComboBox}"
                                  IsEditable="False">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                        <TextBlock Text="{Binding Price, StringFormat=' ({0:N2} DA)'}" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Salon Service (Salon Only) -->
                    <StackPanel Margin="0,0,0,16" Visibility="{Binding IsSalonFacility, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource IconTag}" 
                                  Style="{DynamicResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Terminology.Salon.Booking.Service}" Style="{DynamicResource FormLabel}"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding SalonServices}"
                                  SelectedItem="{Binding SelectedSalonService}"
                                  Style="{StaticResource Input.ComboBox}"
                                  IsEditable="False">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                        <TextBlock Text="{Binding BasePrice, StringFormat=' ({0:N2} DA)'}" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 3. Footer Actions -->
            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" 
                        Content="{DynamicResource Terminology.Global.Cancel}" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource Button.Ghost}"
                        Margin="0,0,12,0"
                        Height="48"/>

                <Button Grid.Column="1" 
                        Command="{Binding RegisterCommand}"
                        IsDefault="True"
                        Height="48">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource Button.Primary}">
                            <Setter Property="Content" Value="{DynamicResource Terminology.Members.Add.Action.Register}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenewMode}" Value="True">
                                    <Setter Property="Content" Value="{DynamicResource Terminology.Members.Renew.Action.Save}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Loading Overlay -->
            <Grid Grid.RowSpan="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Panel.ZIndex="1000">
                <Border Background="{DynamicResource Brush.Surface.Glass}" CornerRadius="16"/>
                <ProgressBar Style="{DynamicResource MaterialProgressBar}" 
                             IsIndeterminate="True" 
                             VerticalAlignment="Center" 
                             Width="150" 
                             Height="4"
                             HorizontalAlignment="Center"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
