<UserControl x:Class="Management.Presentation.Views.Shop.LogRestockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             xmlns:local="clr-namespace:Management.Presentation.Views.Shop"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500">
    
    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="480"
            HorizontalAlignment="Center" 
            VerticalAlignment="Center">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <Grid Margin="16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Product Info Card -->
                <RowDefinition Height="*"/>    <!-- Form Fields -->
                <RowDefinition Height="Auto"/> <!-- Footer Actions -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Quick Restock" Style="{StaticResource Title2}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Update your stock levels and costs intelligently." Style="{StaticResource BodyMedium}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 2. Product Summary Card -->
            <Border Grid.Row="1" Background="{DynamicResource SurfaceBgSecondary}" CornerRadius="16" Padding="20" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="{Binding ProductName}" Style="{DynamicResource BodyLarge}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Sku, StringFormat='{}SKU: {0}'}" Style="{DynamicResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding CurrentStock, StringFormat='{}Current: {0} units'}" Style="{DynamicResource BodyMedium}" Foreground="{DynamicResource FacilityAccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding CurrentPrice, StringFormat='{}Price: {0:N2} DA'}" Style="{DynamicResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Form Fields -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                <StackPanel>
                    <!-- Quantity -->
                    <TextBlock Text="Quantity Purchased" Style="{DynamicResource BodyMedium}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource UnderlineTextBox}" 
                             Tag="How many units did you buy?" 
                             FontSize="16" Height="48" Margin="0,0,0,20"/>

                    <!-- Cost & Margin Row -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Unit Cost (DA)" Style="{DynamicResource BodyMedium}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{DynamicResource UnderlineTextBox}" 
                                     Tag="0.00" 
                                     FontSize="16" Height="48"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="New Sale Price (DA)" Style="{DynamicResource BodyMedium}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewSalePrice, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{DynamicResource UnderlineTextBox}" 
                                     Tag="0.00" 
                                     FontSize="16" Height="48"/>
                        </StackPanel>
                    </Grid>

                    <!-- Summary Stats (Calculated) -->
                    <Border Background="{DynamicResource SurfaceBgTertiary}" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Total Investment" Style="{DynamicResource BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding TotalCost, StringFormat='{}{0:N2} DA'}" Style="{DynamicResource BodyMedium}" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Target Margin" Style="{DynamicResource BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Margin, StringFormat='{}{0:F1}%'}" Style="{DynamicResource BodyMedium}" FontWeight="Bold" Foreground="{Binding MarginColor}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Notes -->
                    <TextBlock Text="Purchase Notes" Style="{DynamicResource BodyMedium}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource UnderlineTextBox}" 
                             Tag="Supplier, Batch Number, etc." 
                             AcceptsReturn="True" Height="80" 
                             VerticalContentAlignment="Top" Padding="12" Margin="0,0,0,20"/>
                </StackPanel>
            </ScrollViewer>

            <!-- 4. Footer Actions -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelCommand}" Style="{DynamicResource GhostButton}" Height="48" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Log Purchase" Command="{Binding SubmitCommand}" Style="{DynamicResource PrimaryButton}" Height="48" Margin="8,0,0,0"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
