<UserControl x:Class="Management.Presentation.Views.Restaurant.NewOrderModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="880">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Simple mockup of converters for the demo -->
        <!-- In real prod, these would be in a dedicated ResourceDictionary -->
    </UserControl.Resources>
    
    <Grid Background="{DynamicResource SurfaceBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/> <!-- Menu -->
            <ColumnDefinition Width="320"/> <!-- Slip -->
        </Grid.ColumnDefinitions>

        <!-- Menu Section -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="New Order - Table T1" Style="{StaticResource SectionHeader}"/>
            
            <!-- Categories -->
            <ListBox Grid.Row="1" ItemsSource="{Binding Categories}" 
                     SelectedValue="{Binding SelectedCategory}"
                     Margin="0,16" Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="16,8" CornerRadius="16" Background="{DynamicResource SeparatorStroke}" Margin="0,0,8,0">
                            <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Items Grid -->
            <Grid Grid.Row="2">
                <!-- Shimmer Overlay -->
                <ItemsControl Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemsSource>
                        <x:Array Type="{x:Type sys:Int32}">
                            <sys:Int32>1</sys:Int32><sys:Int32>2</sys:Int32><sys:Int32>3</sys:Int32><sys:Int32>4</sys:Int32>
                            <sys:Int32>5</sys:Int32><sys:Int32>6</sys:Int32><sys:Int32>7</sys:Int32><sys:Int32>8</sys:Int32>
                        </x:Array>
                    </ItemsControl.ItemsSource>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Rectangle Style="{StaticResource ShimmerPlaceholder}" 
                                       Width="120" Height="140" Margin="0,0,12,12"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">
                    <ItemsControl ItemsSource="{Binding FilteredMenuItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.AddItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FlatButtonStyle}"
                                        Width="120" Height="140" Margin="0,0,12,12"
                                        IsEnabled="{Binding IsAvailable}">
                                    <Border Background="{DynamicResource SurfaceBg}" CornerRadius="{StaticResource CornerRadiusSmall}">
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center" Opacity="{Binding IsAvailable, Converter={StaticResource AvailabilityToOpacityConverter}}">
                                                <Rectangle Width="60" Height="60" Fill="{DynamicResource SurfaceBg}" RadiusX="8" RadiusY="8"/>
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                                           HorizontalAlignment="Center" Margin="0,8,0,0" FontSize="12"/>
                                                <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" 
                                                           Foreground="{DynamicResource AccentBrush}" 
                                                           HorizontalAlignment="Center" FontSize="11"/>
                                            </StackPanel>
                                            
                                            <Border Background="{StaticResource OverlayBackdrop}" CornerRadius="{StaticResource CornerRadiusSmall}"
                                                    Visibility="{Binding IsAvailable, Converter={StaticResource InverseBoolToVis}}">
                                                <TextBlock Text="Out of Stock" Foreground="{DynamicResource TextOnAccentBrush}" FontWeight="Bold" 
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Slip Section -->
        <Border Grid.Column="1" Background="{DynamicResource WindowBg}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Current Order" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                <!-- Slip Items -->
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Order.Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Quantity, StringFormat=x{0}}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,0"/>
                                        <Button Style="{StaticResource IconButtonStyle}" Width="24" Height="24"
                                                Command="{Binding DataContext.DecrementItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="M5 12h14" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource IconButtonStyle}" Width="24" Height="24"
                                                Command="{Binding DataContext.IncrementItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Path Data="M12 5v14M5 12h14" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Totals -->
                <StackPanel Grid.Row="2" Margin="0,16">
                    <Grid Margin="0,4">
                        <TextBlock Text="Subtotal" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding Order.Subtotal, StringFormat={}{0:C}}" Foreground="White" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <TextBlock Text="Tax (15%)" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Order.Tax, StringFormat={}{0:C}}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource SeparatorStroke}" Margin="0,8"/>
                    <Grid>
                        <TextBlock Text="Total" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="18"/>
                        <TextBlock Text="{Binding Order.Total, StringFormat={}{0:C}}" Foreground="{DynamicResource FacilityAccentBrush}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <!-- Actions -->
                <Button Grid.Row="3" Content="Send to Kitchen" Style="{StaticResource PrimaryButton}" 
                        Height="48" Command="{Binding SendOrderCommand}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
