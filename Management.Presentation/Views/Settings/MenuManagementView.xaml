<UserControl x:Class="Management.Presentation.Views.Settings.MenuManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Settings"
             xmlns:restaurant="clr-namespace:Management.Presentation.Views.Restaurant"
             xmlns:viewmodels="clr-namespace:Management.Presentation.ViewModels.Settings"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=viewmodels:MenuManagementViewModel}">
    
    <UserControl.Resources>
    </UserControl.Resources>

    <!-- Root: Menu List + Inventory overlay (swaps views via IsInventoryVisible) -->
    <Grid>

        <!-- Root: Menu List + Inventory overlay -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/> <!-- Detail Drawer Column -->
            </Grid.ColumnDefinitions>

            <!-- â•â•â• MENU LIST SCREEN â•â•â• -->
            <Grid Grid.Column="0" Visibility="{Binding IsInventoryVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Filters -->
                    <RowDefinition Height="*"/>    <!-- Grid -->
                </Grid.RowDefinitions>

            <!-- 1. Header Area -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconTag}" 
                          Style="{StaticResource Style.Icon.Large}" 
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Strings.Settings.MenuManagement}" Style="{StaticResource Title.H2}"/>
                        <TextBlock Text="{DynamicResource Strings.Settings.Manageyourrestaurantitems}" 
                                   Foreground="{DynamicResource Brush.Text.Secondary}" 
                                   FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
                       
                <!-- ðŸ”„ View Toggle Button -->
                <Button Grid.Column="1"
                        Command="{Binding ToggleViewCommand}"
                        Width="160" Height="44" Margin="0,0,12,0" 
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Brush.Surface.Background}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <Path Fill="{DynamicResource Brush.Text.Primary}" 
                              Data="{Binding ToggleViewIcon, Converter={StaticResource ResourceLookupConverter}}"
                              Width="16" Height="16" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="{Binding ToggleViewText}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Add Button -->
                <Button Grid.Column="2" 
                        Command="{Binding AddCommand}" 
                        Content="{DynamicResource Strings.Settings.AddNewItem}"
                        Background="{DynamicResource FacilityAccentBrush}"
                        Style="{DynamicResource Button.Primary}" 
                        Height="44" Padding="20,0"/>
            </Grid>

            <!-- 2. Filters & Search (Premium Pills Layout) -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Border Background="{DynamicResource SurfaceBg}" 
                        CornerRadius="12" 
                        Padding="4" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        HorizontalAlignment="Left">
                    
                    <ListBox ItemsSource="{Binding Categories}" 
                             SelectedItem="{Binding SelectedCategoryFilter}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="Height" Value="36"/>
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="Margin" Value="0,0,4,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="PillBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="18"
                                                    Padding="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource FacilityAccentDimBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource FacilityAccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource FacilityAccentDimBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Grid>

                <!-- 3. Grid of Cards (ListBox for Selection Management) -->
                <ListBox Grid.Row="2" 
                         ItemsSource="{Binding FilteredItems}" 
                         SelectedItem="{Binding SelectedItem}"
                         Background="Transparent" 
                         BorderThickness="0" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="CardBorder"
                                                Height="320" Width="240"
                                                Padding="20"
                                                CornerRadius="16"
                                                Margin="0,0,20,20">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource ElevatedCardStyleInteractive}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="140"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- 1. ICON AREA -->
                                                <Grid Grid.Row="0">
                                                    <Border Background="{DynamicResource SurfaceBgTertiary}" CornerRadius="12">
                                                        <Path Data="{StaticResource IconRestaurant}"
                                                              Fill="{DynamicResource TextTertiaryBrush}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Opacity="0.3">
                                                            <Path.Style>
                                                                <Style TargetType="Path" BasedOn="{StaticResource Style.Icon.Hero}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                            <Setter Property="Fill" Value="White"/>
                                                                            <Setter Property="Opacity" Value="0.6"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Border>
                                                    
                                                    <!-- Selection Pill -->
                                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                                                            Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="8,4"
                                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="{DynamicResource Strings.Restaurant.SELECTED}" Style="{StaticResource Micro}" Foreground="{DynamicResource FacilityAccentBrush}" FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>

                                                <!-- 2. CONTENT AREA -->
                                                <StackPanel Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="44">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMedium}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} DA'}" Margin="0,2,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Title3}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Availability -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                        <Ellipse Width="8" Height="8" 
                                                                 Fill="{Binding IsAvailable, Converter={StaticResource BoolToStatusBrushConverter}}" 
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding IsAvailable, Converter={StaticResource BoolToStatusTextConverter}}" 
                                                                   FontSize="12">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                            <Setter Property="Opacity" Value="0.8"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Loading Overlay -->
                <Border Grid.RowSpan="3" Background="{DynamicResource OverlayBrush}" 
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                        CornerRadius="16">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar Style="{StaticResource CircularProgressBar}" IsIndeterminate="True"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- â•â•â• INVENTORY SCREEN (replaces menu list when active) â•â•â• -->
            <restaurant:InventoryView Grid.ColumnSpan="2"
                DataContext="{Binding InventoryVM}"
                Visibility="{Binding DataContext.IsInventoryVisible, RelativeSource={RelativeSource AncestorType=local:MenuManagementView}, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- â•â•â• DRAWER (Side Panel) â•â•â• -->
            <Border x:Name="Drawer" 
                    Grid.Column="1"
                    HorizontalAlignment="Right" 
                    Width="400" 
                    Background="{DynamicResource CardBackgroundBrush}" 
                    BorderBrush="{DynamicResource SeparatorStroke}" 
                    BorderThickness="1,0,0,0"
                    CornerRadius="32,0,0,32">
                <Border.RenderTransform>
                    <TranslateTransform X="400"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="400" To="0" Duration="{StaticResource DurationNormal}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="400" Duration="{StaticResource DurationNormal}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <ContentControl Content="{Binding CurrentDrawerContent}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type viewmodels:MenuItemEditorViewModel}"> 
                            <local:MenuItemEditorView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
