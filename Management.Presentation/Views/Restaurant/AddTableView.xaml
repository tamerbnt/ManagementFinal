<UserControl x:Class="Management.Presentation.Views.Restaurant.AddTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="480" d:DesignWidth="400"
             Background="Transparent">

    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            CornerRadius="{DynamicResource RadiusModal}"
            Padding="32"
            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <StackPanel>

            <!-- HEADER -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                <Border Width="56" Height="56" CornerRadius="16"
                        Background="{DynamicResource FacilityAccentDimBrush}"
                        Margin="0,0,0,14" HorizontalAlignment="Center">
                    <Path Data="{StaticResource Icon.Plus}"
                          Fill="{DynamicResource FacilityAccentBrush}"
                          Width="24" Height="24" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource Strings.Restaurant.AddTable}"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Text.Primary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Strings.Restaurant.Defineanewtableforthefloo}"
                           FontSize="13" Foreground="{DynamicResource Brush.Text.Secondary}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- TABLE NUMBER -->
            <TextBlock Text="{DynamicResource Strings.Restaurant.TableNumber}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,20">
                <TextBox Text="{Binding TableNumber, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource TextBox.Default}"
                         Height="48" FontSize="16" Padding="12,0" VerticalContentAlignment="Center"
                         x:Name="TableNumberBox"/>
                <TextBlock Text="{DynamicResource Strings.Restaurant.egT1B2VIP1}"
                           FontSize="13" IsHitTestVisible="False"
                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                           Margin="12,0,0,0" VerticalAlignment="Center"
                           Visibility="{Binding TableNumber, Converter={StaticResource NullToVisibilityConverter}}"/>
            </Grid>

            <!-- CAPACITY -->
            <TextBlock Text="{DynamicResource Strings.Restaurant.SeatingCapacity}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource SurfaceBgSecondary}"
                    CornerRadius="12" Padding="16,12" Margin="0,0,0,20">
                <Grid>
                    <TextBlock Text="{Binding Capacity, StringFormat='{}{0} seats'}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding DecrementCapacityCommand}"
                                Style="{StaticResource Button.Ghost}"
                                Width="32" Height="32" Padding="0"
                                FontSize="18" FontWeight="Bold" Content="-"/>
                        <TextBlock Text="{Binding Capacity}"
                                   Width="36" TextAlignment="Center"
                                   FontSize="20" FontWeight="ExtraBold"
                                   Foreground="{DynamicResource FacilityAccentBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Command="{Binding IncrementCapacityCommand}"
                                Style="{StaticResource Button.Ghost}"
                                Width="32" Height="32" Padding="0"
                                FontSize="18" FontWeight="Bold" Content="+"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SHAPE -->
            <TextBlock Text="{DynamicResource Strings.Restaurant.TableShape}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,6"/>
            <ListBox ItemsSource="{Binding Shapes}"
                     SelectedItem="{Binding SelectedShape}"
                     BorderThickness="0" Background="Transparent"
                     Margin="0,0,0,28">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,8,0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ShapeBorder"
                                            Background="{DynamicResource SurfaceBgSecondary}"
                                            BorderBrush="{DynamicResource SeparatorStroke}"
                                            BorderThickness="1.5"
                                            CornerRadius="12" Padding="0,10"
                                            Cursor="Hand">
                                        <TextBlock Text="{Binding}" FontSize="13" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   x:Name="ShapeText"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ShapeBorder" Property="Background"
                                                    Value="{DynamicResource FacilityAccentDimBrush}"/>
                                            <Setter TargetName="ShapeBorder" Property="BorderBrush"
                                                    Value="{DynamicResource FacilityAccentBrush}"/>
                                            <Setter TargetName="ShapeText" Property="Foreground"
                                                    Value="{DynamicResource FacilityAccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- SECTION -->
            <TextBlock Text="{DynamicResource Strings.Restaurant.Section}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,6"/>
            <ListBox ItemsSource="{Binding Sections}"
                     SelectedItem="{Binding SelectedSection}"
                     BorderThickness="0" Background="Transparent"
                     Margin="0,0,0,28">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,8,0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="SectionBorder"
                                            Background="{DynamicResource SurfaceBgSecondary}"
                                            BorderBrush="{DynamicResource SeparatorStroke}"
                                            BorderThickness="1.5"
                                            CornerRadius="12" Padding="0,10"
                                            Cursor="Hand">
                                        <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   x:Name="SectionText"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   TextWrapping="NoWrap"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="SectionBorder" Property="Background"
                                                    Value="{DynamicResource FacilityAccentDimBrush}"/>
                                            <Setter TargetName="SectionBorder" Property="BorderBrush"
                                                    Value="{DynamicResource FacilityAccentBrush}"/>
                                            <Setter TargetName="SectionText" Property="Foreground"
                                                    Value="{DynamicResource FacilityAccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- ACTIONS -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource Button.Ghost}"
                        Content="{DynamicResource Terminology.Global.Cancel}"/>
                <Button Grid.Column="2"
                        Command="{Binding ConfirmCommand}"
                        Style="{StaticResource Button.Primary}"
                        Content="{DynamicResource Strings.Restaurant.AddTable}"/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
