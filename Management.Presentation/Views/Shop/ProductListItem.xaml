<UserControl x:Class="Management.Presentation.Views.Shop.ProductListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="240"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             RenderOptions.CachingHint="Cache">

    <UserControl.Resources>
        <converters:StockToBrushConverter x:Key="StockToBrushConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border x:Name="CardBorder"
            Height="{StaticResource SizeProductCardHeight}"
            Padding="20"
            CornerRadius="16"
            Margin="0,0,0,8">

        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource ElevatedCardStyleInteractive}">
                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{Binding ViewDetailsCommand}"/>
        </Border.InputBindings>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource SizeProductImageHeight}"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 1. PRODUCT IMAGE AREA -->
            <Grid Grid.Row="0">
                <Border Background="{DynamicResource SurfaceBgTertiary}"
                        CornerRadius="12">
                    <Path Data="{StaticResource IconShop}"
                          Fill="{DynamicResource TextTertiaryBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Opacity="0.3">
                        <Path.Style>
                            <Style TargetType="Path" BasedOn="{StaticResource Style.Icon.Hero}">
                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Fill" Value="White"/>
                                        <Setter Property="Opacity" Value="0.6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Border>

                <!-- 0. Selection Checkbox (Top Left) -->
                <CheckBox IsChecked="{Binding IsSelected}" 
                          Style="{StaticResource CircularSelectionCheckBoxStyle}"
                          HorizontalAlignment="Left" 
                          VerticalAlignment="Top" 
                          Margin="12"
                          Panel.ZIndex="10"
                          Visibility="{Binding DataContext.IsSelectionMode, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Selection Pill -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                        Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="8,4"
                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{DynamicResource Terminology.Shop.Status.Selected}" Style="{StaticResource Micro}" Foreground="{DynamicResource FacilityAccentBrush}" FontWeight="Bold"/>
                </Border>
            </Grid>

            <!-- 2. CONTENT AREA -->
            <StackPanel Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Top">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="44">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMedium}">
                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} DA', Mode=OneWay}" Margin="0,2,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Title3}">
                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                    <!-- Stock & Actions -->
                    <Grid Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" 
                                    Visibility="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                            <Ellipse Width="8" Height="8" Fill="{Binding StockLevel, Converter={StaticResource StockToBrushConverter}}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding StockStatusText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Actions (Visible on Hover) -->
                        <UniformGrid Columns="2" 
                                     Visibility="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Command="{Binding ModifyProductCommand}" 
                                    Content="{DynamicResource Terminology.Shop.Action.Modify}" 
                                    Height="32" Margin="0,0,4,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource FacilityAccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Command="{Binding OpenRestockCommand}" 
                                    Content="Restock" 
                                    Height="32" Margin="4,0,0,0"
                                    Visibility="{Binding IsRestockVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="White"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </UniformGrid>
                    </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
