<controls:ModernWindow x:Class="Management.Presentation.Views.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Management.Presentation.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:Management.Presentation.Views.Shell"
        xmlns:controls="clr-namespace:Management.Presentation.Resources.Controls"
        xmlns:components="clr-namespace:Management.Presentation.Components.Layout"
        xmlns:settings="clr-namespace:Management.Presentation.Views.Settings"
        xmlns:shared="clr-namespace:Management.Presentation.Views.Shared"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{DynamicResource Strings.Shell.GymOS}"
        MinWidth="1280" MinHeight="720"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="{DynamicResource GlobalFlowDirection}"
        Background="{DynamicResource Brush.Window.Background}">

    <Window.Resources>
        <!-- DataContext Proxy for InputBindings to bypass inheritance issues -->
        <controls:BindingProxy x:Key="MainProxy" Data="{Binding}"/>

        <!-- Sidebar Panel Animation Style -->
        <Style x:Key="SidebarPanelStyle" TargetType="Border">
            <Setter Property="Width" Value="260"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width" 
                                                  To="72" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width" 
                                                  To="260" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <!-- Navigation shortcuts: Ctrl+1 through Ctrl+5 navigate to sidebar items by position -->
        <KeyBinding Key="D1" Modifiers="Ctrl" 
                    Command="{Binding Data.NavigateToIndexCommand, Source={StaticResource MainProxy}}">
            <KeyBinding.CommandParameter>
                <sys:Int32>0</sys:Int32>
            </KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D2" Modifiers="Ctrl" 
                    Command="{Binding Data.NavigateToIndexCommand, Source={StaticResource MainProxy}}">
            <KeyBinding.CommandParameter>
                <sys:Int32>1</sys:Int32>
            </KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D3" Modifiers="Ctrl" 
                    Command="{Binding Data.NavigateToIndexCommand, Source={StaticResource MainProxy}}">
            <KeyBinding.CommandParameter>
                <sys:Int32>2</sys:Int32>
            </KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D4" Modifiers="Ctrl" 
                    Command="{Binding Data.NavigateToIndexCommand, Source={StaticResource MainProxy}}">
            <KeyBinding.CommandParameter>
                <sys:Int32>3</sys:Int32>
            </KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D5" Modifiers="Ctrl" 
                    Command="{Binding Data.NavigateToIndexCommand, Source={StaticResource MainProxy}}">
            <KeyBinding.CommandParameter>
                <sys:Int32>4</sys:Int32>
            </KeyBinding.CommandParameter>
        </KeyBinding>

        <!-- Search focus: Ctrl+F or Ctrl+K -->
        <KeyBinding Key="F" Modifiers="Ctrl"
                    Command="{Binding Data.FocusSearchCommand, Source={StaticResource MainProxy}}"/>
        <KeyBinding Key="K" Modifiers="Ctrl"
                    Command="{Binding Data.FocusSearchCommand, Source={StaticResource MainProxy}}"/>
    </Window.InputBindings>


    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="80"
                          GlassFrameThickness="-1"
                          CornerRadius="16"
                          ResizeBorderThickness="6"
                          UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- Root: Solid background to ground the atmospheric nebula and prevent corner artifacts when AllowsTransparency=False -->
    <Grid x:Name="RootGrid" Background="{DynamicResource Brush.Window.Background}" Focusable="True">
        <Grid x:Name="MainLayoutGrid">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="32"/>
                    <Style.Triggers>
                        <!-- When maximized, we increase margin to 40px to offset the ~8px OS overflow -->
                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                            <Setter Property="Margin" Value="40"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="24"/> 
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border x:Name="SidebarPanel" Grid.Column="0" 
                    Style="{StaticResource SidebarPanelStyle}"
                    CornerRadius="16"
                    Background="{DynamicResource FacilitySidebarBrush}"
                    ClipToBounds="True"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Border.Effect>
                    <StaticResource ResourceKey="Shadow.Level3" />
                </Border.Effect>
                <local:SidebarView DataContext="{Binding}"/>
            </Border>
            
            <!-- RIGHT COLUMN: TopBar + Content -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/> <!-- Consistent Gap -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- TOPBAR PANEL (Elite Glass Style) -->
                <Border Grid.Row="0" CornerRadius="16" Background="{DynamicResource SurfaceBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0.8,0,0" ClipToBounds="False" MinHeight="80" VerticalAlignment="Stretch">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level1" />
                    </Border.Effect>
                    <local:TopBarView DataContext="{Binding TopBar}" VerticalAlignment="Stretch" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Border>
                
                <!-- CONTENT PANEL (Transparent Canvas) -->
                <Border Grid.Row="2" Background="Transparent">
                    <ContentControl Content="{Binding CurrentView}" Focusable="False"/>
                </Border>
            </Grid>
        </Grid>

        <!-- OVERLAYS (Spanning entire window inside RootGrid) -->


        <!-- Connectivity Banner (Global Offline Indicator) -->
        <shared:ConnectivityBanner 
            DataContext="{Binding Connectivity}"
            Panel.ZIndex="1050"/> 

        <ContentControl Content="{Binding Settings}"
                        Panel.ZIndex="1000" 
                        Focusable="False">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <!-- GLOBAL MODAL HOST (Titan Overlay System) -->
        <Grid Panel.ZIndex="1100" IsHitTestVisible="{Binding IsModalOpen}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModalOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Backdrop with Blur -->
            <Border Background="#4D0F172A">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>

            <!-- Modal Content Host -->
            <ContentControl Content="{Binding CurrentModalViewModel}" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"/>
        </Grid>

        <!-- Toast Notification Overlay (Top-Center) -->
        <ItemsControl x:Name="ActiveToasts" 
                      ItemsSource="{Binding ActiveToasts}"
                      VerticalAlignment="Top" 
                      HorizontalAlignment="Center"
                      Margin="0,128,0,0"
                      Panel.ZIndex="9999">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Top"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ToastCard" 
                            Width="380" 
                            CornerRadius="16" 
                            Background="{DynamicResource Brush.Surface.Primary}"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <!-- Entrance Animation: Drop down from -60px and fade in -->
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                                                                 From="-60" To="0" Duration="0:0:0.350">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.250">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <DataTrigger Binding="{Binding IsExiting}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <!-- Exit Animation: Slide up to -60px and fade out -->
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                                                                     From="0" To="-60" Duration="0:0:0.300">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.250">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.RenderTransform>
                            <TranslateTransform Y="-60"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28" Opacity="0.10" Color="Black" Direction="270" ShadowDepth="4"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>   <!-- icon badge -->
                                <ColumnDefinition Width="*"/>      <!-- message -->
                                <ColumnDefinition Width="Auto"/>   <!-- undo button — NEW -->
                                <ColumnDefinition Width="Auto"/>   <!-- X button -->
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: Icon Badge -->
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" VerticalAlignment="Center" Margin="0,0,14,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Success">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Error">
                                                <Setter Property="Background" Value="#FEECEC"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Warning">
                                                <Setter Property="Background" Value="#FFF8E1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Info">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Success">
                                                    <Setter Property="Data" Value="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                                                    <Setter Property="Fill" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Error">
                                                    <Setter Property="Data" Value="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                                                    <Setter Property="Fill" Value="#C62828"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Warning">
                                                    <Setter Property="Data" Value="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
                                                    <Setter Property="Fill" Value="#E65100"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Info">
                                                    <Setter Property="Data" Value="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                                                    <Setter Property="Fill" Value="#1565C0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Border>

                            <!-- Column 2: Message -->
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Message}" 
                                       FontSize="13" 
                                       FontWeight="Medium" 
                                       Foreground="{DynamicResource Brush.Text.Primary}" 
                                       VerticalAlignment="Center" 
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                        <Setter Property="LineHeight" Value="20"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Undo button — Grid.Column="2" -->
                            <Button Grid.Column="2"
                                    Command="{Binding UndoCommand}"
                                    Visibility="{Binding HasUndo,
                                        Converter={StaticResource BoolToVisibilityConverter},
                                        FallbackValue=Collapsed}"
                                    Margin="8,0,4,0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <Border CornerRadius="6"
                                        Padding="10,4"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource Brush.Border.Subtle}">
                                    <TextBlock Text="{Binding UndoLabel}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Primary}"/>
                                </Border>
                            </Button>

                            <!-- X dismiss button — Grid.Column="3" -->
                            <Button Grid.Column="3"
                                    Command="{Binding DismissCommand}" 
                                    Width="24" Height="24" 
                                    Background="Transparent" 
                                    BorderThickness="0" 
                                    VerticalAlignment="Center"
                                    Margin="4,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Background="Transparent">
                                            <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                                  Fill="{DynamicResource Brush.Text.Primary}" 
                                                  Stretch="Uniform" 
                                                  Width="10" Height="10" 
                                                  Opacity="0.35"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</controls:ModernWindow>
