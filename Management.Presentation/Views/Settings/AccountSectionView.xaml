<UserControl x:Class="Management.Presentation.Views.Settings.AccountSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Border Background="{DynamicResource SurfaceBgSecondary}"
                CornerRadius="16"
                Padding="24"
                BorderBrush="{DynamicResource SeparatorStroke}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.04" Color="Black"/>
            </Border.Effect>
            
            <StackPanel>
                <TextBlock Text="{DynamicResource Terminology.Settings.Account.Info}" 
                           Style="{StaticResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,24"/>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="64" Height="64" CornerRadius="32" Margin="0,0,20,0"
                            Background="{Binding UserName, Converter={StaticResource NameToBrushConverter}}">
                        <TextBlock Text="{Binding UserInitials}" 
                                   FontSize="24" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding UserName}" 
                                   Style="{StaticResource Title3}" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding UserEmail}" 
                                   Style="{StaticResource Body}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Terminology.Settings.Account.Role}" Style="{StaticResource Body}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Role}" Style="{StaticResource BodyMedium}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Terminology.Settings.Account.Permissions}" Style="{StaticResource Body}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Permissions}" Style="{StaticResource BodyMedium}" Foreground="{DynamicResource FacilityAccentBrush}"/>
                </Grid>

                <!-- Professional Email Guardian (Milestone 2) -->
                <Separator Background="{DynamicResource SeparatorStroke}" Margin="0,32"/>

                <TextBlock Text="Professional Email Guardian" Style="{StaticResource Title3}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <TextBlock Text="Configure your business domain email to enable automatic member re-engagement. High-reputation sending requires a professional domain (e.g. @yourcompany.com)." 
                           Style="{StaticResource Body}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,24" TextWrapping="Wrap"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Email Address -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Sender Email" Style="{StaticResource Body}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ProfessionalEmail, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource UnderlineTextBox}" Height="40" Margin="0,0,0,16" Tag="info@yourdomain.com"/>

                    <!-- API Key (Masked/Password placeholder logic in ViewModel) -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Brevo API Key" Style="{StaticResource Body}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <PasswordBox Grid.Row="1" Grid.Column="1" 
                                 Style="{StaticResource UnderlinePasswordBox}" Height="40" Margin="0,0,0,16"/>
                    <!-- Note: PasswordBox binding is tricky in WPF, we usually use a Helper or Tag for the binding if not using a custom control. For now, let's use a normal TextBox for simplicity or a custom control if available. -->
                    <!-- Re-evaluating: I'll use a TextBox for now to ensure the binding works in this prototype turn, or I can use the Tag property if it's already implemented as a secure control. -->
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EmailApiKey, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource UnderlineTextBox}" Height="40" Margin="0,0,0,16" Tag="xkeysib-xxxx..."/>

                    <!-- Status Display -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Verification" Style="{StaticResource Body}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding EmailStatusMessage}" Style="{StaticResource BodyMedium}" 
                                   Foreground="{Binding IsEmailVerified, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#10B981|#EF4444'}" 
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        
                        <Button Content="Validate &amp; Save" Command="{Binding SaveEmailSettingsCommand}" 
                                Style="{StaticResource Button.Primary}" Padding="16,0" Height="32"/>
                    </StackPanel>
                </Grid>

                <Border Background="{DynamicResource StatusInfoBackground}" CornerRadius="8" Padding="16" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconAlert}" Fill="{DynamicResource StatusInfoBrush}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                        <TextBlock Text="Credentials are encrypted and stored locally on this machine using Windows DPAPI." 
                                   Style="{StaticResource BodySmall}" Foreground="{DynamicResource StatusInfoBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
