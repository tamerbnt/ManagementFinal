<UserControl x:Class="Management.Presentation.Views.Members.CreateMemberView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="{DynamicResource WindowBg}">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. HEADER -->
        <Border Grid.Row="0" 
                Padding="{StaticResource PaddingCard}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Style="{StaticResource Title2}" Text="{DynamicResource Terminology.Members.Add.Title}" Foreground="{DynamicResource TextPrimaryBrush}"/>
        </Border>

        <!-- 2. SCROLLABLE FORM -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="{StaticResource PaddingCard}" 
                        MaxWidth="800" 
                        HorizontalAlignment="Stretch">

                <!-- A. PHOTO UPLOAD -->
                <TextBlock Text="{DynamicResource Terminology.Members.Add.ProfilePhoto}" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>

                <Border Style="{StaticResource GlobalDragDropUploadZoneStyle}"
                        Height="{StaticResource SizeUploadZoneHeight}"
                        AllowDrop="True">
                    <Grid>
                        <!-- Empty State -->
                        <StackPanel VerticalAlignment="Center" 
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding ProfileImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                            <Path Data="{StaticResource IconUpload}"
                                  Fill="{DynamicResource TextTertiaryBrush}"
                                  Style="{StaticResource Style.Icon.Hero}" 
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,16"/>
                            <TextBlock Text="{DynamicResource Terminology.Members.Add.DragDrop}" 
                                       Style="{StaticResource BodySecondary}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Filled State -->
                        <Grid Visibility="{Binding ProfileImage, Converter={StaticResource NullToVisibilityConverter}}">
                            <!-- FIX: Hardcoded Radius 20 for Geometry -->
                            <Image Source="{Binding ProfileImage}" 
                                   Stretch="UniformToFill">
                                <Image.Clip>
                                    <RectangleGeometry Rect="0,0,200,200" RadiusX="20" RadiusY="20"/>
                                </Image.Clip>
                            </Image>

                            <Button Style="{StaticResource IconButtonStyle}"
                                    Command="{Binding RemovePhotoCommand}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="{StaticResource MarginSmall}"
                                    Background="{DynamicResource SurfaceBg}"
                                    Opacity="0.9">
                                <Path Data="{StaticResource IconClose}" 
                                      Fill="{DynamicResource TextPrimaryBrush}" 
                                      Style="{StaticResource Style.Icon.Small}"/>
                            </Button>
                        </Grid>

                        <Button Command="{Binding BrowsePhotoCommand}"
                                Style="{StaticResource InvisibleClickableButtonStyle}"
                                Visibility="{Binding ProfileImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </Grid>
                </Border>

                <!-- B. PERSONAL INFORMATION -->
                <TextBlock Text="{DynamicResource Terminology.Members.Add.PersonalInfo}" 
                           Style="{StaticResource Title3}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="{StaticResource MarginSectionVertical}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <!-- Hardcoded Gap -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <!-- Hardcoded Gap -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="{DynamicResource Terminology.Staff.Add.FullName}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource UnderlineTextBox}"/>
                    </StackPanel>

                    <!-- ... (Remaining fields identical) ... -->

                </Grid>

                <!-- ... (Sections C & D) ... -->

            </StackPanel>
        </ScrollViewer>

        <!-- 3. FOOTER -->
        <Border Grid.Row="2" 
                Padding="{StaticResource PaddingCard}"
                Background="{DynamicResource SurfaceBg}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Terminology.Global.Cancel}"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="{StaticResource MarginSmallRight}"/>

                <Button Content="{DynamicResource Terminology.Members.Add.Action.Save}"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        MinWidth="{StaticResource SizeButtonMinWidth}"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
