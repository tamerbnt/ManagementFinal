<UserControl x:Class="Management.Presentation.Views.FinanceAndStaff.StaffList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <!-- Shared converters used from App.xaml -->
    </UserControl.Resources>

    <Grid>
        <!-- Grid View Layout -->
        <ListBox ItemsSource="{Binding FilteredStaffMembers}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0,0,12,0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True"
                 SelectedItem="{Binding SelectedStaff, Mode=TwoWay}"
                 Visibility="{Binding ViewMode, Converter={StaticResource EqualToVisibilityConverter}, ConverterParameter=Grid}">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,20,20" Width="260">
                        <!-- Shadow Border -->
                        <Border CornerRadius="20" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.1" Color="Black"/>
                            </Border.Effect>
                        </Border>

                        <!-- Content Border -->
                        <Border x:Name="GridCard" 
                                Background="White" 
                                CornerRadius="20" 
                                Padding="24"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                              Command="{Binding DataContext.OpenStaffDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Avatar -->
                            <Grid>
                                <Ellipse Width="96" Height="96" x:Name="AvatarPlaceholder" 
                                         Fill="{Binding FullName, Converter={StaticResource NameToBrushConverter}}"/>
                                <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialConverter}}" 
                                           Foreground="White" FontWeight="Bold" FontSize="32"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Name -->
                            <TextBlock Text="{Binding FullName}" 
                                       Style="{StaticResource BodyMedium}" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       TextAlignment="Center"
                                       Margin="0,16,0,4"
                                       x:Name="NameTextGrid"/>

                            <!-- Role Badge & Edit Action -->
                            <Grid Margin="{StaticResource MarginTextVertical}">
                                <ContentControl Content="{Binding Role}"
                                                Style="{StaticResource GlobalRoleBadgeStyle}"
                                                HorizontalAlignment="Left"
                                                x:Name="RoleBadgeGrid"/>
                                
                                <Button Style="{StaticResource IconButtonStyle}" 
                                        Command="{Binding DataContext.EditStaffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Right">
                                    <Path x:Name="EditIconGrid" Data="{StaticResource IconEdit}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource BrandPrimaryBrush}"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
                    
                    <DataTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GridCard" Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="GridCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="GridCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="GridCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="GridCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- ACTIVE / SELECTED STATE (Glowing Blue) -->
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                            <Setter TargetName="GridCard" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                        <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="NameTextGrid" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                            <Setter TargetName="GridCard" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{DynamicResource FacilityAccentColor}" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="AvatarPlaceholder" Property="Fill" Value="{DynamicResource OnAccentSecondary}"/>
                            <Setter TargetName="EditIconGrid" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- List View Layout (Updated to match MembersView) -->
        <ListBox ItemsSource="{Binding FilteredStaffMembers}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0,0,12,0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 SelectedItem="{Binding SelectedStaff, Mode=TwoWay}"
                 Visibility="{Binding ViewMode, Converter={StaticResource EqualToVisibilityConverter}, ConverterParameter=List}">
            
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,12">
                        <!-- Shadow Border -->
                        <Border CornerRadius="16" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                            </Border.Effect>
                        </Border>

                        <!-- Content Border -->
                        <Border x:Name="RowBorder" 
                                Background="White" 
                                CornerRadius="16" 
                                Padding="16"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                              Command="{Binding DataContext.OpenStaffDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>  <!-- Avatar -->
                                <ColumnDefinition Width="*"/>   <!-- Name/Email -->
                                <ColumnDefinition Width="Auto"/> <!-- Role -->
                                <ColumnDefinition Width="Auto"/> <!-- Status -->
                                <ColumnDefinition Width="Auto"/> <!-- Actions -->
                            </Grid.ColumnDefinitions>

                            <!-- Avatar & Identity -->
                            <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.ColumnSpan="2" Margin="16,0,0,0">
                                <Grid x:Name="AvatarContainer" VerticalAlignment="Center">
                                    <Ellipse Width="40" Height="40" x:Name="AvatarPlaceholder" 
                                             Fill="{Binding FullName, Converter={StaticResource NameToBrushConverter}}"/>
                                    <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialConverter}}" 
                                               x:Name="AvatarInitial"
                                               Foreground="White" 
                                               FontWeight="Bold" 
                                               FontSize="16"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding FullName}" x:Name="NameText" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Email}" x:Name="EmailText" Style="{DynamicResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Role -->
                            <ContentControl Grid.Column="2" 
                                            Content="{Binding Role}"
                                            Style="{StaticResource GlobalRoleBadgeStyle}"
                                            VerticalAlignment="Center"
                                            Margin="24,0"
                                            x:Name="RoleBadge"/>

                            <!-- Status -->
                            <Border Grid.Column="3" x:Name="StatusBorder" Padding="8,4" CornerRadius="12" Background="{DynamicResource StatusSuccessBackground}" VerticalAlignment="Center" Margin="0,0,24,0">
                                <TextBlock Text="{Binding EmploymentStatus}" x:Name="StatusText" Foreground="{DynamicResource StatusSuccessBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>

                            <!-- Actions -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="24,0,16,0">
                                <Button Style="{StaticResource IconButtonStyle}" 
                                        Command="{Binding DataContext.DeleteStaffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}"
                                        Margin="0,0,8,0">
                                    <Path x:Name="DeleteIcon" Data="{StaticResource IconDelete}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource StatusErrorBrush}"/>
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" 
                                        Command="{Binding DataContext.EditStaffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}">
                                    <Path x:Name="EditIcon" Data="{StaticResource IconEdit}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource BrandPrimaryBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                    
                    <DataTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SurfaceBg}"/>
                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.005" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.005" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- ACTIVE / SELECTED STATE (Glowing Blue) -->
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                             <Setter TargetName="RowBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                        <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="RowBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{DynamicResource FacilityAccentColor}" BlurRadius="25" ShadowDepth="0" Opacity="0.5"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="Transparent"/>
                            <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                            <Setter TargetName="EmailText" Property="Foreground" Value="{DynamicResource OnAccentSecondary}"/>
                            <Setter TargetName="StatusBorder" Property="Background" Value="{DynamicResource OnAccentSecondary}"/>
                            <Setter TargetName="StatusText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                            <Setter TargetName="AvatarPlaceholder" Property="Fill" Value="{DynamicResource OnAccentSecondary}"/>
                            <Setter TargetName="DeleteIcon" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                            <Setter TargetName="EditIcon" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>
