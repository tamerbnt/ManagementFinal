<UserControl x:Class="Management.Presentation.Views.Auth.OnboardingOwnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="560"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="{StaticResource SurfaceBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Premium Top Bar Branding -->
        <Border Grid.Row="0" Height="80" Padding="40,20" Background="{StaticResource SurfaceBg}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="32" Height="32" Margin="0,0,16,0">
                    <Ellipse Fill="{DynamicResource FacilityAccentBrush}" Opacity="0.1"/>
                    <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" 
                          Fill="{DynamicResource FacilityAccentBrush}" 
                          Width="18" Height="18" Stretch="Uniform"/>
                </Grid>
                <StackPanel>
                    <TextBlock Text="LUXURYA" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding FacilityName}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="500" Margin="60,40">
                
                <!-- Large Premium Title -->
                <TextBlock Text="{DynamicResource Strings.Auth.AccountSetup}" 
                           FontSize="42" FontWeight="Black" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>
                
                <TextBlock Text="Finalize your workstation account to begin managing your facility." 
                           FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" 
                           TextWrapping="Wrap" LineHeight="24"
                           Margin="0,0,0,48" Opacity="0.8"/>

                <Grid ShowGridLines="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Business Name -->
                    <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,24">
                        <TextBlock Text="{DynamicResource Strings.Auth.BUSINESSNAME}" Style="{StaticResource PremiumInputLabelStyle}"/>
                        <TextBox Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource PremiumTextBoxStyle}"
                                 Tag="e.g. Elite Fitness Center"/>
                    </StackPanel>

                    <!-- Admin Name -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,24">
                        <TextBlock Text="{DynamicResource Strings.Auth.ADMINFULLNAME}" Style="{StaticResource PremiumInputLabelStyle}"/>
                        <TextBox Text="{Binding AdminFullName, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource PremiumTextBoxStyle}"
                                 Tag="e.g. John Doe"/>
                    </StackPanel>

                    <!-- Admin Email -->
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,24">
                        <TextBlock Text="{DynamicResource Strings.Auth.ADMINEMAIL}" Style="{StaticResource PremiumInputLabelStyle}"/>
                        <TextBox Text="{Binding AdminEmail, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource PremiumTextBoxStyle}"
                                 Tag="admin@luxurya.com"/>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,32">
                        <TextBlock Text="{DynamicResource Strings.Auth.SECUREPASSWORD}" Style="{StaticResource PremiumInputLabelStyle}"/>
                        <Grid>
                            <PasswordBox x:Name="OnboardingPasswordBox" 
                                         Style="{StaticResource PremiumPasswordBoxStyle}"
                                         Tag="Enter a secure password"
                                         PasswordChanged="PasswordBox_PasswordChanged"/>
                            
                            <TextBox x:Name="OnboardingPasswordTextBox"
                                     Style="{StaticResource PremiumTextBoxStyle}"
                                     Visibility="Collapsed"
                                     Tag="Enter a secure password"
                                     TextChanged="OnboardingPasswordTextBox_TextChanged"/>

                            <Button Style="{StaticResource IconButtonSmall}"
                                    HorizontalAlignment="Right" Margin="0,0,12,0"
                                    Click="TogglePasswordVisibility_Click">
                                <Grid>
                                    <Path x:Name="OnboardingEyeOpenIcon" 
                                          Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5M12,17.5A5.5,5.5 0 0,1 6.5,12A5.5,5.5 0 0,1 12,6.5A5.5,5.5 0 0,1 17.5,12A5.5,5.5 0 0,1 12,17.5Z"
                                          Fill="{DynamicResource TextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                    <Path x:Name="OnboardingEyeClosedIcon" 
                                          Data="M11.83,9L15,12.17C14.84,12.63 14.63,13.06 14.36,13.46L11.83,10.93M2,4.27L3.27,3L21,20.73L19.73,22L16.46,18.73A11.39,11.39 0 0,1 12,19.5C7,19.5 2.73,16.39 1,12C1.96,9.54 3.61,7.44 5.75,5.92L2,4.27M12,4.5C17,4.5 21.27,7.61 23,12C22.25,13.88 20.91,15.5 19.31,16.7L17.75,15.13C18.66,14.24 19.41,13.18 19.89,12C18.25,8.24 14.45,5.5 10,5.5C9.3,5.5 8.61,5.6 7.96,5.78L6.2,4.03C8.04,3.37 10,3 12,3M12,4.5C17,4.5 21.27,7.61 23,12C21.27,7.61 17,4.5 12,4.5M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z" 
                                          Fill="{DynamicResource TextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed"/>
                                </Grid>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Action Button -->
                <Button Command="{Binding CompleteSetupCommand}"
                        Content="{DynamicResource Strings.Auth.CompleteRegistration}"
                        Height="64" FontSize="18" FontWeight="Bold"
                        Style="{StaticResource PremiumPrimaryButtonStyle}"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer Branding -->
        <Border Grid.Row="2" Padding="40,24" Background="{StaticResource SurfaceBg}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Opacity="0.5">
                <TextBlock Text="POWERED BY" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="FROM SCRATCH" FontSize="10" FontWeight="Black" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
