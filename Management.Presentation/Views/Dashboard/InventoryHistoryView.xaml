<Window x:Class="Management.Presentation.Views.Dashboard.InventoryHistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:Management.Presentation.Converters"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{DynamicResource SurfaceBg}"
        WindowStyle="None"
        Title="Inventory Audit History"
        d:DesignHeight="600" d:DesignWidth="500">
    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="500"
            Margin="32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Highlights -->
                <RowDefinition Height="*"/>    <!-- Transaction List -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Inventory Audit History" 
                           Style="{DynamicResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Detailed tracking of all stock movements." 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 2. Triple Highlights Grid -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <!-- Top Investment -->
                <Border Background="{DynamicResource FacilityAccentDimBrush}" CornerRadius="12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="TOP INVESTMENT" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" Opacity="0.8"/>
                        <TextBlock Text="{Binding TopPurchasedItemName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding TopPurchasedItemCost, StringFormat='{}{0:N0} DA'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- High Velocity -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceSecondaryBrush}" CornerRadius="12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="HIGHEST VELOCITY" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Opacity="0.8"/>
                        <TextBlock Text="{Binding HighestVelocityItemName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding HighestVelocityItemQty, StringFormat='{}{0} units'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Critical Runway (Forecaster) -->
                <Border Grid.Column="4" CornerRadius="12" Padding="12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SurfaceSecondaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCriticalStockAlert}" Value="True">
                                    <Setter Property="Background" Value="#1AFFF1EF"/> <!-- Faint Red -->
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="CRITICAL RUNWAY" FontSize="9" FontWeight="Bold" Opacity="0.8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCriticalStockAlert}" Value="True">
                                            <Setter Property="Foreground" Value="#EF4444"/> <!-- Red -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding CriticalStockItemName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock FontSize="13" FontWeight="Bold" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="Text" Value="{Binding CriticalStockRunwayDays, StringFormat='{}{0} days left'}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CriticalStockRunwayDays}" Value="2147483647">
                                            <Setter Property="Text" Value="Stable (No Sales)"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCriticalStockAlert}" Value="True">
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 3. Transaction Content -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Text="RECENT MOVEMENTS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                
                <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Transactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceSecondaryBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                 <TextBlock Text="{Binding Type}" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                <TextBlock Text=" • " Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}g'}" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Notes}" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" FontStyle="Italic" Visibility="{Binding Notes, Converter={StaticResource StringToVisibilityConverter}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding QuantityChange, StringFormat='{} + {0}'}" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding TotalCost, StringFormat='{}{0:N0} DA'}" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- 4. Footer Actions -->
            <Grid Grid.Row="3" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="{Binding LowStockCount, StringFormat='{}{0} items currently low on stock'}" 
                           Style="{StaticResource Caption}" 
                           Foreground="#EF4444" 
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <Button Grid.Column="1" 
                        Content="Close" 
                        Command="{Binding CloseCommand}"
                        Style="{DynamicResource Button.Ghost}"
                        Margin="12,0,0,0" Width="80" Height="36"/>
            </Grid>
        </Grid>
    </Border>
</Window>
