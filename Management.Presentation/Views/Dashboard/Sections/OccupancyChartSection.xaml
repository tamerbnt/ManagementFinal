<UserControl x:Class="Management.Presentation.Dashboard.Sections.OccupancyChartSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="400"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <!-- FIX 1: Removed invalid 'Inverse' definition. We use the parameter in the Binding instead. -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Header -->
        <TextBlock Grid.Row="0" 
                   Text="24h Occupancy" 
                   Style="{StaticResource Title3}" 
                   Margin="{StaticResource MarginHeaderBottom}"/>

        <!-- 2. Chart Container -->
        <Border Grid.Row="1" 
                Height="{StaticResource SizeChartHeightStandard}"
                Background="{StaticResource ContentBackground}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Margin="{StaticResource MarginSectionBottom}">

            <Grid>
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Data" Command="{Binding CopyChartDataCommand}"/>
                        <MenuItem Header="Save as Image" Command="{Binding SaveChartImageCommand}"/>
                    </ContextMenu>
                </Grid.ContextMenu>

                <!-- A. Background Grid Lines -->
                <Grid Opacity="0.5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"/>
                    <Border Grid.Row="1" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"/>
                    <Border Grid.Row="2" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"/>
                    <Border Grid.Row="3" BorderBrush="{StaticResource SeparatorBrush}" BorderThickness="0,1,0,0"/>
                </Grid>

                <!-- B. X-Axis Labels -->
                <Grid VerticalAlignment="Bottom" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="00:00" Style="{StaticResource Caption}" Foreground="{StaticResource TextTertiary}"/>
                    <TextBlock Grid.Column="1" Text="06:00" Style="{StaticResource Caption}" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="12:00" Style="{StaticResource Caption}" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="18:00" Style="{StaticResource Caption}" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="24:00" Style="{StaticResource Caption}" Foreground="{StaticResource TextTertiary}" HorizontalAlignment="Right"/>
                </Grid>

                <!-- C. Skeleton State -->
                <Grid x:Name="LoadingSkeleton"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                      IsHitTestVisible="False">
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource SkeletonPulseAnimation}"/>
                        </EventTrigger>
                    </Grid.Triggers>
                    <Polyline Points="0,150 50,140 100,160 150,100 200,120 250,80 300,100 350,50"
                              Stroke="#F5F5F5"
                              StrokeThickness="6"
                              Stretch="Fill"
                              VerticalAlignment="Center"
                              Margin="0,20"/>
                </Grid>

                <!-- D. Data Layer -->
                <!-- FIX 2: Added ConverterParameter='Inverse' here -->
                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter='Inverse'}">

                    <Polyline Points="{Binding OccupancyPoints}"
                              Stroke="{StaticResource PrimaryAccentBrush}"
                              StrokeThickness="3"
                              Stretch="Fill"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"/>

                    <ItemsControl ItemsSource="{Binding DataPoints}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- FIX 3: Correct ToolTip Styling -->
                                <Ellipse Width="8" Height="8"
                                         Fill="{StaticResource PrimaryAccentBrush}"
                                         Stroke="{StaticResource ContentBackground}"
                                         StrokeThickness="2"
                                         Margin="-4,-4,0,0">
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{Binding TooltipText}" 
                                                 Style="{StaticResource ChartTooltipStyle}"/>
                                    </ToolTipService.ToolTip>
                                </Ellipse>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- Error State -->
                <!-- FIX 4: Added ConverterParameter='Inverse' here -->
                <TextBlock Text="No data available for this period"
                           Style="{StaticResource BodySecondary}"
                           Foreground="{StaticResource TextTertiary}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter='Inverse'}"/>
            </Grid>
        </Border>

        <!-- 3. Quick Actions Footer -->
        <StackPanel Grid.Row="2">
            <Button Content="View Reports" 
                    Style="{StaticResource SecondaryButton}" 
                    Margin="{StaticResource MarginSmallBottom}"
                    Command="{Binding NavigateToReportsCommand}">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconChart}" 
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Style="{StaticResource IconSmall}"
                                  Margin="{StaticResource MarginIconRight}"/>
                            <TextBlock Text="View Reports"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button Content="Quick Check-in" 
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding QuickCheckInCommand}">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconCheck}" 
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Style="{StaticResource IconSmall}"
                                  Margin="{StaticResource MarginIconRight}"/>
                            <TextBlock Text="Quick Check-in"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>