<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- Identity Layer: SALON FACILITY -->
    
    <!-- Sidebar -->
    <SolidColorBrush x:Key="FacilitySidebarBrush" Color="{StaticResource Color.Midnight.800}"/>
    
    <!-- Accents -->
    <Color x:Key="FacilityAccentColor">#F48FB1</Color> <!-- Linked to Color.Blush.Accent -->
    <Color x:Key="FacilityAccentShadowColor">#F06292</Color>
    <LinearGradientBrush x:Key="FacilityAccentGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#F06292" Offset="0"/>
        <GradientStop Color="#F48FB1" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="FacilityAccentBrush" Color="{StaticResource Color.Blush.Accent}"/>
    <SolidColorBrush x:Key="FacilityAccentDimBrush" Color="{StaticResource Color.Blush.Accent}" Opacity="0.15"/>
    
    <!-- Contrast Tokens (Safety) -->
    <SolidColorBrush x:Key="OnAccentPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OnAccentSecondary" Color="#FCE4EC"/> 

    <!-- Aliases for compatibility -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Color.Blush.Accent}"/>
    <Color x:Key="AccentColor">#F48FB1</Color>
    <SolidColorBrush x:Key="IllustrationBackgroundBrush" Color="{StaticResource Color.Blush.Light}"/>
    <SolidColorBrush x:Key="OverlayBackdropBrush" Color="#80000000"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#0FFFFFFF" Opacity="0.06"/>
    <Color x:Key="AccentLightColor">#FCE4EC</Color>
    <SolidColorBrush x:Key="StatusRoseBackground" Color="{StaticResource Color.Blush.Light}"/>

    <!-- Legacy/Alias Tokens (Fix Startup Crash) -->
    <SolidColorBrush x:Key="Brush.Brand.Primary" Color="{StaticResource Color.Blush.Accent}"/>
    <SolidColorBrush x:Key="Brush.Brand.Primary.Deep" Color="{StaticResource Color.Midnight.800}"/>
    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource Color.Blush.Accent}"/>
    
    <!-- Terminology -->
    <sys:String x:Key="TerminologyLabel">Client</sys:String>
</ResourceDictionary>
