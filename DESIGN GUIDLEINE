    CONSTRAINT UQ_Tables_Number UNIQUE (FacilityID, TableNumber),
    CONSTRAINT CHK_Tables_Capacity CHECK (SeatingCapacity > 0)
);

CREATE INDEX IX_Tables_Facility_Status 
    ON Tables(FacilityID, Status) WHERE IsActive = 1;
