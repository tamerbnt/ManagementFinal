<UserControl x:Class="Management.Presentation.Views.Restaurant.TableDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Restaurant"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="480"
             Background="Transparent">

    <!-- Modal container â€” uses the global modal style like all other modals in the app -->
    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            CornerRadius="{DynamicResource RadiusModal}"
            Padding="32"
            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Status badge + info row -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>     <!-- Order items list -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>  <!-- Bill summary -->
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>  <!-- Actions -->
            </Grid.RowDefinitions>

            <!-- â•â• HEADER â•â• -->
            <Grid Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="{Binding TableNumber, StringFormat='Table {0}'}"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.Text.Primary}"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <!-- Time -->
                        <TextBlock Text="{Binding ElapsedTime, StringFormat='Seated {0} ago'}"
                                   FontSize="13" Foreground="{DynamicResource Brush.Text.Secondary}"
                                   Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        
                        <!-- NEW: Payment Status Badge -->
                        <Border Margin="12,0,0,0" Padding="8,2" CornerRadius="6" VerticalAlignment="Center"
                                Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Surface.Secondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                            <Setter Property="Background" Value="#3322C55E"/> <!-- Success/Green tint -->
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPaid}" Value="False">
                                            <Setter Property="Background" Value="#33EF4444"/> <!-- Error/Red tint -->
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="10" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="UNPAID"/>
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                <Setter Property="Text" Value="PAID"/>
                                                <Setter Property="Foreground" Value="#22C55E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Close button -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="32" Height="32"
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource Button.Ghost}"
                        ToolTip="{DynamicResource Strings.Restaurant.Close}">
                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                          Fill="{DynamicResource Brush.Text.Secondary}" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
            </Grid>

            <!-- â•â• INFO ROW â•â• -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Guests -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceBgSecondary}"
                        CornerRadius="12" Padding="12,10" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Strings.Restaurant.Guests}" FontSize="11" Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding GuestCount}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text.Primary}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Capacity -->
                <Border Grid.Column="1" Background="{DynamicResource SurfaceBgSecondary}"
                        CornerRadius="12" Padding="12,10" Margin="0,0,8,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Strings.Restaurant.Capacity}" FontSize="11" Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Capacity}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.Text.Primary}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Server -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceBgSecondary}"
                        CornerRadius="12" Padding="12,10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Strings.Restaurant.Server}" FontSize="11" Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ServerInitials}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource FacilityAccentBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- â•â• ORDER ITEMS â•â• -->
            <Border Grid.Row="4" Background="{DynamicResource SurfaceBgSecondary}"
                    CornerRadius="16" Padding="16">
                <!-- Single Grid child â€” both states overlap via Visibility toggling -->
                <Grid>
                    <!-- Empty state: shown when OrderService has no data -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasOrders, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Path Data="{StaticResource Icon.Sliders}"
                              Fill="{DynamicResource Brush.Text.Tertiary}"
                              Width="32" Height="32" Stretch="Uniform"
                              HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.4"/>
                        <TextBlock Text="{DynamicResource Strings.Restaurant.Noordersyet}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Strings.Restaurant.Orderswillappearherewhent}"
                                   FontSize="12" Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"
                                   TextAlignment="Center" MaxWidth="280" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Order list: shown when real data is available -->
                    <ItemsControl ItemsSource="{Binding OrderItems}"
                                  Visibility="{Binding HasOrders, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:OrderLineItemViewModel}">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="8"
                                            Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Quantity}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource FacilityAccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14"
                                               Foreground="{DynamicResource Brush.Text.Primary}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding LineTotal, StringFormat='{}{0:N2} DA'}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Text.Primary}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- â•â• BILL SUMMARY â•â• -->
            <Border Grid.Row="6" Background="{DynamicResource SurfaceBg}"
                    CornerRadius="14" Padding="16">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{DynamicResource Strings.Restaurant.Subtotal}" FontSize="13" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                        <TextBlock Text="{Binding Subtotal, StringFormat='{}{0:N2} DA'}"
                                   FontSize="13" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </Grid>
                    <Grid>
                        <TextBlock Text="{DynamicResource Strings.Restaurant.GrandTotal}" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource FacilityAccentBrush}"/>
                        <TextBlock Text="{Binding GrandTotal, StringFormat='{}{0:N2} DA'}"
                                   FontSize="20" FontWeight="ExtraBold" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource FacilityAccentBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ╔═ ACTIONS ═╗ -->
            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Cancel -->
                <Button Grid.Column="0" Command="{Binding CloseCommand}"
                        Style="{StaticResource Button.Ghost}"
                        Content="{DynamicResource Terminology.Global.Cancel}"/>

                <!-- Open Table: available tables → start new order and go to POS -->
                <Button Grid.Column="2"
                        Command="{Binding OpenTableCommand}"
                        Style="{StaticResource Button.Primary}"
                        Content="{DynamicResource Strings.Restaurant.OpenTable}"
                        Visibility="{Binding IsAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Pay Bill: occupied tables → print receipt + complete/pay order -->
                <Button Grid.Column="2"
                        Command="{Binding PayBillCommand}"
                        Style="{StaticResource Button.Primary}"
                        Content="{DynamicResource Terminology.Restaurant.Action.PayBill}"
                        Visibility="{Binding IsOccupied, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
