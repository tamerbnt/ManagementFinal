<UserControl x:Class="Management.Presentation.Views.Shell.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Shell"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="260">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ResourceKeyToIconConverter x:Key="ResourceKeyToIconConverter"/>
        
        <!-- Sidebar Navigation Button Style (COINEST Floating) -->
        <Style x:Key="SidebarNavigationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="{DynamicResource Corner.LG}"> <!-- Tokenized Rounds -->
                            <ContentPresenter x:Name="Presenter" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <ContentPresenter.RenderTransform>
                                    <TranslateTransform X="0" Y="0"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Presenter" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="4" Duration="{StaticResource DurationStandard}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Presenter" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="{StaticResource DurationStandard}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border x:Name="SidebarBorder" 
            Background="{DynamicResource FacilitySidebarBrush}"
            CornerRadius="{DynamicResource Corner.XL}"
            BorderThickness="1,1,0,0"
            BorderBrush="{DynamicResource Brush.Surface.Glass.Standard}"> <!-- Tokenized Highlight -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/> <!-- Breathing Room -->
                <RowDefinition Height="Auto"/> <!-- Logo Area -->
                <RowDefinition Height="*"/> <!-- Navigation Track -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
                <RowDefinition Height="24"/> <!-- Bottom Space -->
            </Grid.RowDefinitions>

            <!-- LOGO AREA (Interactive Engine Brand) -->
            <Button Grid.Row="1" Command="{Binding ToggleSidebarCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavigationButtonStyle}">
                        <Setter Property="Margin" Value="16,0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <Setter Property="Margin" Value="8,0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Grid>
                    <!-- Expanded State -->
                    <StackPanel x:Name="ExpandedLogo" Orientation="Vertical" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Glowing Logo Container -->
                        <Border x:Name="ExpandedLogoBorder" Width="48" Height="48" CornerRadius="{DynamicResource Corner.MD}" HorizontalAlignment="Center"
                                Background="{DynamicResource Brush.Sidebar.Hover}">
                            <Border.Effect>
                                <StaticResource ResourceKey="ShadowGlow"/>
                            </Border.Effect>
                            <Path Stretch="Uniform" Margin="10" Fill="{DynamicResource FacilityAccentBrush}">
                                <Path.Data>
                                    <GeometryGroup FillRule="EvenOdd">
                                        <!-- Head/Star Background -->
                                        <PathGeometry Figures="M 296.5,82.5 C 315.333,80.5111 324.833,88.8444 325,107.5C 319.855,122.323 309.688,127.49 294.5,123C 283.713,116.316 280.213,106.816 284,94.5C 286.744,88.9206 290.911,84.9206 296.5,82.5 Z"/>
                                        <!-- Star cut-out -->
                                        <PathGeometry Figures="M 303.5,90.5 C 306.785,95.7847 311.118,100.118 316.5,103.5C 310.493,106.174 306.159,110.507 303.5,116.5C 300.022,111.188 295.688,106.688 290.5,103C 297.314,101.351 301.648,97.1846 303.5,90.5 Z"/>
                                        <!-- Main Body Leaf -->
                                        <PathGeometry Figures="M 317.5,301.5 C 316.549,300.081 316.216,298.415 316.5,296.5C 316.334,289.825 316.5,283.158 317,276.5C 322.5,264.497 327.167,252.164 331,239.5C 334.576,227.385 334.243,215.385 330,203.5C 323.91,189.94 316.076,177.607 306.5,166.5C 292.925,178.648 283.091,193.315 277,210.5C 273.748,221.816 273.748,233.149 277,244.5C 284.443,274.162 294.276,302.995 306.5,331C 313.987,329.562 320.654,326.228 326.5,321C 386.832,268.318 395.166,208.318 351.5,141C 376.176,158.468 390.009,182.635 393,213.5C 395.351,250.781 384.351,283.448 360,311.5C 345.329,327.053 328.829,340.053 310.5,350.5C 313.219,363.356 314.552,376.356 314.5,389.5C 309.463,389.413 304.463,389.746 299.5,390.5C 297.477,348.539 286.31,309.205 266,272.5C 252.184,242.418 253.518,213.084 270,184.5C 281.638,167.362 293.472,150.362 305.5,133.5C 323.367,153.213 337.2,175.546 347,200.5C 354.111,228.387 349.778,254.387 334,278.5C 328.981,286.549 323.481,294.215 317.5,301.5 Z"/>
                                        <!-- Left Wing Leaf -->
                                        <PathGeometry Figures="M 249.5,140.5 C 250.239,140.369 250.906,140.536 251.5,141C 229.606,171.74 220.773,205.907 225,243.5C 234.521,279.212 253.188,309.212 281,333.5C 283.143,339.727 284.476,346.06 285,352.5C 246.353,327.842 221.686,293.175 211,248.5C 203.357,204.912 216.191,168.912 249.5,140.5 Z"/>
                                    </GeometryGroup>
                                </Path.Data>
                            </Path>
                        </Border>
 
                         <TextBlock Text="LUXURYA" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" FontSize="16"
                                    HorizontalAlignment="Center" Margin="0,8,0,0">
                              <TextBlock.Effect>
                                 <StaticResource ResourceKey="Shadow.Level1"/>
                              </TextBlock.Effect>
                         </TextBlock>
                    </StackPanel>
 
                     <!-- Collapsed State -->
                     <Border x:Name="CollapsedLogo" 
                             Width="44" Height="44" CornerRadius="{DynamicResource Corner.MD}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToVis}}"
                             Background="{DynamicResource Brush.Sidebar.Hover}">
                         <Border.Effect>
                             <StaticResource ResourceKey="ShadowGlow"/>
                         </Border.Effect>
                         <Path Stretch="Uniform" Margin="10" Fill="{DynamicResource FacilityAccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                             <Path.Data>
                                 <GeometryGroup FillRule="EvenOdd">
                                     <!-- Head/Star Background -->
                                     <PathGeometry Figures="M 296.5,82.5 C 315.333,80.5111 324.833,88.8444 325,107.5C 319.855,122.323 309.688,127.49 294.5,123C 283.713,116.316 280.213,106.816 284,94.5C 286.744,88.9206 290.911,84.9206 296.5,82.5 Z"/>
                                     <!-- Star cut-out -->
                                     <PathGeometry Figures="M 303.5,90.5 C 306.785,95.7847 311.118,100.118 316.5,103.5C 310.493,106.174 306.159,110.507 303.5,116.5C 300.022,111.188 295.688,106.688 290.5,103C 297.314,101.351 301.648,97.1846 303.5,90.5 Z"/>
                                     <!-- Main Body Leaf -->
                                     <PathGeometry Figures="M 317.5,301.5 C 316.549,300.081 316.216,298.415 316.5,296.5C 316.334,289.825 316.5,283.158 317,276.5C 322.5,264.497 327.167,252.164 331,239.5C 334.576,227.385 334.243,215.385 330,203.5C 323.91,189.94 316.076,177.607 306.5,166.5C 292.925,178.648 283.091,193.315 277,210.5C 273.748,221.816 273.748,233.149 277,244.5C 284.443,274.162 294.276,302.995 306.5,331C 313.987,329.562 320.654,326.228 326.5,321C 386.832,268.318 395.166,208.318 351.5,141C 376.176,158.468 390.009,182.635 393,213.5C 395.351,250.781 384.351,283.448 360,311.5C 345.329,327.053 328.829,340.053 310.5,350.5C 313.219,363.356 314.552,376.356 314.5,389.5C 309.463,389.413 304.463,389.746 299.5,390.5C 297.477,348.539 286.31,309.205 266,272.5C 252.184,242.418 253.518,213.084 270,184.5C 281.638,167.362 293.472,150.362 305.5,133.5C 323.367,153.213 337.2,175.546 347,200.5C 354.111,228.387 349.778,254.387 334,278.5C 328.981,286.549 323.481,294.215 317.5,301.5 Z"/>
                                     <!-- Left Wing Leaf -->
                                     <PathGeometry Figures="M 249.5,140.5 C 250.239,140.369 250.906,140.536 251.5,141C 229.606,171.74 220.773,205.907 225,243.5C 234.521,279.212 253.188,309.212 281,333.5C 283.143,339.727 284.476,346.06 285,352.5C 246.353,327.842 221.686,293.175 211,248.5C 203.357,204.912 216.191,168.912 249.5,140.5 Z"/>
                                 </GeometryGroup>
                             </Path.Data>
                         </Path>
                     </Border>
                </Grid>
            </Button>

            <!-- NAVIGATION (COINEST Floating Pillars) -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <!-- SELECTION RAIL (Fluid Motion Layer) -->
                <Canvas x:Name="SelectionRail" IsHitTestVisible="False" Margin="0,0">
                    <!-- GLOWING BLUE PILL INDICATOR -->
                    <Border x:Name="FluidIndicator">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="IndicatorTransform" Y="0"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Width" Value="248"/>
                                <Setter Property="Height" Value="64"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="CornerRadius" Value="{DynamicResource Corner.LG}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Width" Value="52"/>
                                        <Setter Property="Margin" Value="10,0"/>
                                        <Setter Property="CornerRadius" Value="{DynamicResource Corner.XL}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="SelectionStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition From="*" To="*" GeneratedDuration="0:0:0.4">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                </VisualStateGroup.Transitions>

                                <VisualState x:Name="State0">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="0" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State1">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="64" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State2">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="128" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State3">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="192" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State4">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="256" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State5">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="320" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State6">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="384" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State7">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="448" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <i:Interaction.Triggers>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="0">
                                <i:GoToStateAction StateName="State0"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="1">
                                <i:GoToStateAction StateName="State1"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="2">
                                <i:GoToStateAction StateName="State2"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="3">
                                <i:GoToStateAction StateName="State3"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="4">
                                <i:GoToStateAction StateName="State4"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="5">
                                <i:GoToStateAction StateName="State5"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="6">
                                <i:GoToStateAction StateName="State6"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="7">
                                <i:GoToStateAction StateName="State7"/>
                            </i:DataTrigger>
                        </i:Interaction.Triggers>
                        
                        <!-- CoachPro Style: Solid Identity Pill -->
                        <Border.Background>
                            <DynamicResource ResourceKey="FacilityAccentGradient"/>
                        </Border.Background>
                        
                        <Border.BorderThickness>0</Border.BorderThickness>

                        <Border.Effect>
                            <StaticResource ResourceKey="ShadowGlow"/>
                        </Border.Effect>
                        
                        <!-- No internal dot for CoachPro style, just solid gradient -->
                    </Border>
                </Canvas>

                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Floating Container -->
                            <Border x:Name="NavItemBorder" Background="Transparent" CornerRadius="{DynamicResource Corner.LG}" Margin="6,0" Height="64">
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavigationButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                    <Setter Property="ToolTip" Value="{Binding DisplayName}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Path x:Name="IconPath" Grid.Column="0"
                                              Data="{Binding IconKey, Converter={StaticResource ResourceKeyToIconConverter}}"
                                              Fill="{DynamicResource Brush.Sidebar.Text.Inactive}"
                                              Width="20" Height="20" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        
                                        <TextBlock x:Name="LabelText" Grid.Column="1" 
                                                   Text="{Binding DisplayName}" 
                                                   VerticalAlignment="Center" Margin="4,0,16,0"
                                                   Foreground="{DynamicResource Brush.Sidebar.Text.Inactive}"
                                                   FontSize="14" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                            <Setter Property="Opacity" Value="0"/>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <!-- REMOVED TextGlow to fix ghosting/blur issues -->
                                        </TextBlock>
                                    </Grid>
                                </Button>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <!-- Using semi-transparent background for hover -->
                                    <Setter TargetName="NavItemBorder" Property="Background" Value="{DynamicResource Brush.Sidebar.Hover}"/> 
                                </Trigger>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Brush.Sidebar.Text.Active}"/>
                                    <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource Brush.Sidebar.Text.Active}"/>
                                    <Setter TargetName="LabelText" Property="FontWeight" Value="SemiBold"/>
                                    <!-- NO TEXT EFFECT -> FIXES GHOSTING -->
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
            
            <!-- SEPARATOR -->
            <Rectangle Grid.Row="2" VerticalAlignment="Bottom" Height="1" Margin="16,12" Opacity="0.2">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="White" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- FOOTER (Premium Branding) -->
            <Grid Grid.Row="3" Margin="4,0,4,8">
                <StackPanel x:Name="BrandingStack" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Powered by" 
                               FontSize="10" 
                               Foreground="{DynamicResource Brush.Sidebar.Text.Inactive}" 
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               FontWeight="Medium"
                               Opacity="0.5"
                               FontFamily="Segoe UI Variable Display, Segoe UI">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="FontSize" Value="7"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="From Scratch" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource FacilityAccentBrush}" 
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"
                               MaxWidth="200"
                               FontFamily="Segoe UI Variable Display, Segoe UI">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="FontSize" Value="9"/>
                                        <Setter Property="MaxWidth" Value="40"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                         <TextBlock.Effect>
                            <StaticResource ResourceKey="Shadow.Level1"/>
                         </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
