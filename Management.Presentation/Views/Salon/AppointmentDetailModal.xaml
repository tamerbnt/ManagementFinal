<Window x:Class="Management.Presentation.Views.Salon.AppointmentDetailModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:converters="clr-namespace:Management.Presentation.Converters"
        mc:Ignorable="d" 
        Title="{DynamicResource Terminology.Salon.AppointmentDetail.Title}"
        Width="460" Height="520"
        FlowDirection="{DynamicResource GlobalFlowDirection}"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:TerminologyConverter x:Key="TerminologyConverter"/>
    </Window.Resources>
    <Grid Margin="24"> <!-- Shadow Padding -->
        <Border Background="{DynamicResource Brush.Surface.Primary}" 
                CornerRadius="24" 
                Padding="32"
                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}"
                Effect="{StaticResource Shadow3}">
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Terminology.Salon.AppointmentDetail.Title}" 
                             Style="{StaticResource Text.Caption}" 
                             Foreground="{DynamicResource Brush.Text.Tertiary}" 
                             FontWeight="Bold" 
                             Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Appointment.ClientName, Converter={StaticResource TerminologyConverter}}" 
                             Style="{StaticResource Title.H2}" 
                             Foreground="{DynamicResource Brush.Text.Primary}"/>
                </StackPanel>
                <Button Command="{Binding CloseCommand}" 
                        Style="{StaticResource IconButtonStyle}" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top">
                    <Path Data="{StaticResource IconClose}" 
                          Style="{StaticResource Style.Icon.Small}" 
                          Stroke="{DynamicResource Brush.Text.Secondary}"/>
                </Button>
            </Grid>

            <!-- Info Cards -->
            <UniformGrid Columns="1">
                <!-- Service Info -->
                <Border Background="{DynamicResource Brush.Surface.Secondary}" 
                        CornerRadius="16" Padding="20" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{DynamicResource Brush.Brand.Primary.Transparent}" 
                                Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0">
                            <Path Data="{StaticResource IconTag}" 
                                  Style="{StaticResource Style.Icon.Small}" 
                                  Stroke="{DynamicResource Brush.Brand.Primary}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Terminology.Salon.AppointmentDetail.Service}" Style="{StaticResource Text.Caption}" Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                            <TextBlock Text="{Binding Appointment.ServiceName}" Style="{StaticResource Body}" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Staff Info -->
                <Border Background="{DynamicResource Brush.Surface.Secondary}" 
                        CornerRadius="16" Padding="20" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{DynamicResource Brush.Accent.Blue.Transparent}" 
                                Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0">
                            <Path Data="{StaticResource IconUsers}" 
                                  Style="{StaticResource Style.Icon.Small}" 
                                  Stroke="{DynamicResource Brush.Accent.Blue}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Terminology.Salon.AppointmentDetail.StaffMember}" Style="{StaticResource Text.Caption}" Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                            <TextBlock Text="{Binding Appointment.StaffName, Converter={StaticResource TerminologyConverter}}" Style="{StaticResource Body}" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Schedule Info -->
                <Border Background="{DynamicResource Brush.Surface.Secondary}" 
                        CornerRadius="16" Padding="20" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <Path Data="{StaticResource IconCalendar}" 
                                  Style="{StaticResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Appointment.StartTime, StringFormat='{}{0:MMM dd}'}" 
                                     Style="{StaticResource Body}" 
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource Brush.Text.Primary}" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                            <Path Data="{StaticResource IconClock}" 
                                  Style="{StaticResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource Brush.Text.Secondary}" 
                                  Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Appointment.StartTime, StringFormat='{}{0:t}'}" 
                                     Style="{StaticResource Body}" 
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource Brush.Text.Primary}" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Status Footer Action -->
            <Button Command="{Binding UpdateStatusCommand}" 
                    Background="{DynamicResource Brush.Brand.Primary}" 
                    BorderThickness="0"
                    Padding="32,16" 
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center" 
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="16" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="{Binding ActionButtonText}" 
                         FontWeight="Bold" 
                         Foreground="White"
                         FontSize="14"/>
            </Button>
        </StackPanel>
    </Border>
    </Grid>
</Window>
