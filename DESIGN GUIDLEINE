**Services Table:**
```sql
CREATE TABLE Services (
    ServiceID INT PRIMARY KEY IDENTITY(1,1),
    FacilityID INT NOT NULL,
    Name NVARCHAR(100) NOT NULL,
    Description NVARCHAR(500),
    Category TINYINT NOT NULL, -- ServiceCategory enum
    BasePrice DECIMAL(10,2) NOT NULL,
    Duration INT NOT NULL, -- Minutes
    IsActive BIT NOT NULL DEFAULT 1,
    RequiresProducts BIT NOT NULL DEFAULT 0,
    CreatedAt DATETIME NOT NULL DEFAULT GETDATE(),
    ModifiedAt DATETIME,
    
    CONSTRAINT FK_Services_Facility FOREIGN KEY (FacilityID) 
        REFERENCES Facilities(FacilityID) ON DELETE CASCADE,
    CONSTRAINT CHK_Services_BasePrice CHECK (BasePrice >= 0),
    CONSTRAINT CHK_Services_Duration CHECK (Duration > 0)
);

CREATE INDEX IX_Services_Facility_Category 
    ON Services(FacilityID, Category, IsActive);

CREATE INDEX IX_Services_Active 
    ON Services(IsActive) WHERE IsActive = 1;
```

**Appointments Table:**
```sql
CREATE TABLE Appointments (
    AppointmentID INT PRIMARY KEY IDENTITY(1,1),
    FacilityID INT NOT NULL,
    ClientID INT NOT NULL, -- FK to Members
    ServiceID INT NOT NULL,
    StaffID INT NULL, -- Nullable, auto-assign later
    ScheduledDate DATE NOT NULL,
    ScheduledTime TIME NOT NULL,
    Duration INT NOT NULL, -- Minutes
    Status TINYINT NOT NULL DEFAULT 1, -- AppointmentStatus enum
    Notes NVARCHAR(500),
    TotalPrice DECIMAL(10,2) NOT NULL,
    CreatedAt DATETIME NOT NULL DEFAULT GETDATE(),
    ModifiedAt DATETIME,
    CreatedBy INT, -- StaffID who created booking
    
    CONSTRAINT FK_Appointments_Facility FOREIGN KEY (FacilityID) 
        REFERENCES Facilities(FacilityID) ON DELETE CASCADE,
    CONSTRAINT FK_Appointments_Client FOREIGN KEY (ClientID) 
        REFERENCES Members(MemberID) ON DELETE CASCADE,
    CONSTRAINT FK_Appointments_Service FOREIGN KEY (ServiceID) 
        REFERENCES Services(ServiceID),
    CONSTRAINT FK_Appointments_Staff FOREIGN KEY (StaffID) 
        REFERENCES Staff(StaffID),
    CONSTRAINT CHK_Appointments_TotalPrice CHECK (TotalPrice >= 0)
);

-- Critical indexes for performance
CREATE INDEX IX_Appointments_Facility_Date 
    ON Appointments(FacilityID, ScheduledDate, ScheduledTime);

CREATE INDEX IX_Appointments_Staff_Date 
    ON Appointments(StaffID, ScheduledDate) WHERE StaffID IS NOT NULL;

CREATE INDEX IX_Appointments_Client 
    ON Appointments(ClientID);

CREATE INDEX IX_Appointments_Status 
    ON Appointments(Status) WHERE Status IN (1,2,3); -- Active statuses
```

**AppointmentProducts Table:**
```sql
CREATE TABLE AppointmentProducts (
    AppointmentProductID INT PRIMARY KEY IDENTITY(1,1),
    AppointmentID INT NOT NULL,
    ProductID INT NOT NULL,
    QuantityUsed DECIMAL(10,2) NOT NULL,
    UnitPrice DECIMAL(10,2) NOT NULL,
    
    CONSTRAINT FK_AppointmentProducts_Appointment FOREIGN KEY (AppointmentID) 
        REFERENCES Appointments(AppointmentID) ON DELETE CASCADE,
    CONSTRAINT FK_AppointmentProducts_Product FOREIGN KEY (ProductID) 
        REFERENCES Products(ProductID),
