<UserControl x:Class="Management.Presentation.Components.UndoBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Width="600" Height="64">
    <Border Background="{DynamicResource SurfaceBg}" 
            CornerRadius="24" 
            BorderThickness="1" 
            BorderBrush="{DynamicResource SeparatorStroke}"
            Effect="{StaticResource Shadow3}">
        <Grid Margin="24,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Action deleted." Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="UNDO" 
                        Command="{Binding UndoCommand}"
                        Style="{StaticResource PrimaryButton}" 
                        Width="80" Height="36"
                        FontSize="12" FontWeight="Bold"/>
            </StackPanel>
            
            <Grid HorizontalAlignment="Right" VerticalAlignment="Center">
                <Ellipse Width="32" Height="32" Stroke="{DynamicResource SeparatorStroke}" StrokeThickness="2"/>
                <Path Data="M 16,0 A 16,16 0 1 1 15.99,0" 
                      Stroke="{DynamicResource FacilityAccentBrush}" 
                      StrokeThickness="2"
                      x:Name="TimerPath"
                      StrokeDashArray="100"
                      StrokeDashOffset="100">
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="TimerPath"
                                                     Storyboard.TargetProperty="StrokeDashOffset"
                                                     From="100" To="0" Duration="0:0:5"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
                <TextBlock Text="5" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
