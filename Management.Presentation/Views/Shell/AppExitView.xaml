<Window x:Class="Management.Presentation.Views.Shell.AppExitView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d" 
        Title="Quit Luxurya"
        Height="400" Width="600"
        WindowStyle="None" 
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Window.Background}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                          GlassFrameThickness="-1"
                          CornerRadius="24"
                          ResizeBorderThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Padding="{DynamicResource PaddingModal}">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <StackPanel VerticalAlignment="Center">
            <!-- 1. Hero Icon -->
            <Grid Margin="{DynamicResource MarginHeaderBottom}">
                <Path Data="{DynamicResource IconWarning}"
                      Fill="{DynamicResource StatusWarningBrush}"
                      Style="{DynamicResource Style.Icon.Hero}"
                      HorizontalAlignment="Center"/>
            </Grid>

            <!-- 2. Title -->
            <TextBlock Text="{DynamicResource Terminology.Shell.Exit.Title}"
                       Style="{DynamicResource Title2}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="{DynamicResource MarginHeaderBottom}"/>

            <!-- 3. Message -->
            <TextBlock Text="{DynamicResource Terminology.Shell.Exit.Message}"
                       Style="{DynamicResource Body}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="{DynamicResource MarginSectionBottom}"/>

            <!-- 4. Action Buttons -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center">

                <!-- Skip & Exit (Ghost) -->
                <Button Content="{DynamicResource Terminology.Shell.Exit.Close}"
                        Command="{Binding ExitCommand}"
                        Style="{DynamicResource GhostButton}"
                        Margin="{DynamicResource Space.MD.Right}"
                        IsEnabled="{Binding IsGeneratingReport, Converter={StaticResource InverseBooleanConverter}}"/>

                <!-- Cancel / Stay (Secondary) -->
                <Button Content="{DynamicResource Terminology.Shell.Exit.Cancel}"
                        Command="{Binding StayCommand}"
                        Style="{DynamicResource Button.Secondary}"
                        Margin="{DynamicResource Space.MD.Right}"
                        IsEnabled="{Binding IsGeneratingReport, Converter={StaticResource InverseBooleanConverter}}"/>

                <!-- Close Day & Exit (Primary) -->
                <Button Content="{DynamicResource Terminology.Shell.Exit.CloseAndReport}"
                        Command="{Binding CloseAndReportCommand}"
                        Style="{DynamicResource PrimaryButton}"
                        MinWidth="200">
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
