<UserControl x:Class="Management.Presentation.Views.Auth.OnboardingOwnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="{DynamicResource WindowBg}">

    <ScrollViewer x:Name="MainScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <!-- MinHeight binding ensures vertical centering within the scrollable area -->
        <Grid MinHeight="{Binding ElementName=MainScroll, Path=ActualHeight}">
            <!-- Premium Setup Card -->
            <Border Width="560" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="24"
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1"
                    Padding="48" 
                    Margin="40,60"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="50" Color="{DynamicResource ShadowColor}" Opacity="0.1" ShadowDepth="4"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Header Icon & Text -->
                    <StackPanel Margin="0,0,0,40">
                        <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Ellipse Width="64" Height="64" Fill="{DynamicResource PatternPolkaDots}" Opacity="0.1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Canvas Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                <Canvas.RenderTransform><ScaleTransform ScaleX="2.5" ScaleY="2.5"/></Canvas.RenderTransform>
                                <Path Style="{DynamicResource IconBase}" Stroke="{DynamicResource TextPrimary}" Data="{DynamicResource IconCelebration}"/>
                            </Canvas>
                        </Grid>

                        <TextBlock Text="Set Up Your Workspace" 
                                   Foreground="{DynamicResource TextPrimary}" 
                                   FontSize="32" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Complete your owner profile to initialize your secure organization." 
                                   Foreground="{DynamicResource TextSecondary}" 
                                   FontSize="15" HorizontalAlignment="Center" 
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <!-- Form Content -->
                    <StackPanel>
                        <!-- Organization Name -->
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock Text="FACILITY NAME" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,12"/>
                            <TextBox Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{DynamicResource UnderlineTextBox}" 
                                     Foreground="{DynamicResource TextPrimary}" FontSize="18"/>
                        </StackPanel>

                        <!-- Owner Email -->
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock Text="OWNER EMAIL" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,12"/>
                            <TextBox Text="{Binding AdminEmail, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{DynamicResource UnderlineTextBox}" 
                                     Foreground="{DynamicResource TextPrimary}" FontSize="18"/>
                        </StackPanel>

                        <!-- Admin Password (Masked) -->
                        <StackPanel Margin="0,0,0,48">
                            <TextBlock Text="ADMIN PASSWORD" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,12"/>
                            <PasswordBox x:Name="PasswordBox" 
                                         Padding="0,8" 
                                         BorderThickness="0,0,0,1" 
                                         BorderBrush="{DynamicResource BorderBrush}" 
                                         Background="Transparent" 
                                         Foreground="{DynamicResource TextPrimary}" 
                                         FontSize="20" 
                                         PasswordChanged="PasswordBox_PasswordChanged"/>
                            <TextBlock Text="This password will be required for owner-level access." 
                                       Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiary}" 
                                       Margin="0,8,0,0" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Primary Action -->
                    <Button Content="Initialize Workspace" 
                            Command="{Binding CompleteOnboardingCommand}" 
                            Height="60" 
                            Style="{DynamicResource PrimaryButton}" 
                            FontSize="18" FontWeight="SemiBold" 
                            Cursor="Hand"/>
                    
                    <TextBlock Text="By clicking initialize, you agree to the workspace terms." 
                               Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiary}" 
                               Margin="0,16,0,0" HorizontalAlignment="Center" Opacity="0.5"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
