<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Style for TextBlocks -->
    <Style x:Key="Text.Base" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Primary}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Hero Text Style -->
    <Style x:Key="Text.Hero" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{StaticResource Text.Size.Hero}" />
        <Setter Property="FontWeight" Value="Light" />
    </Style>

    <!-- Title Level 1 Style -->
    <Style x:Key="Text.Title1" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{StaticResource Text.Size.Title1}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- Title Level 2 Style -->
    <Style x:Key="Text.Title2" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{StaticResource Text.Size.Title2}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- Aliases for common titles -->
    <Style x:Key="Title.H1" TargetType="TextBlock" BasedOn="{StaticResource Text.Title1}" />
    <Style x:Key="Title.H2" TargetType="TextBlock" BasedOn="{StaticResource Text.Title2}" />
    <Style x:Key="Title.H3" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{StaticResource Text.Size.Title3}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Display Text Styles (Large & Punchy) -->
    <Style x:Key="Text.Display1" TargetType="TextBlock" BasedOn="{StaticResource Text.Title1}">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="Text.Display2" TargetType="TextBlock" BasedOn="{StaticResource Text.Title2}">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- Subtitle Styles -->
    <Style x:Key="Text.Subtitle1" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <Style x:Key="Text.Subtitle2" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>

    <!-- Body Text Style -->
    <Style x:Key="Text.Body" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{StaticResource Text.Size.Body}" />
        <Setter Property="FontWeight" Value="Regular" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
    </Style>

    <Style x:Key="Text.Body1" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}" />

    <Style x:Key="Text.Body2" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>

    <Style x:Key="Text.BodySmall" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Regular" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    </Style>

    <Style x:Key="Text.BodyBold" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- Caption Text Style -->
    <Style x:Key="Text.Caption" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{StaticResource Text.Size.Caption}" />
        <Setter Property="FontWeight" Value="Regular" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    </Style>

    <!-- Micro Text Style -->
    <Style x:Key="Text.Micro" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Regular" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
    </Style>

    <!-- Aliases for Short Names -->
    <Style x:Key="Title1" TargetType="TextBlock" BasedOn="{StaticResource Text.Title1}"/>
    <Style x:Key="Title2" TargetType="TextBlock" BasedOn="{StaticResource Text.Title2}"/>
    <Style x:Key="Title3" TargetType="TextBlock" BasedOn="{StaticResource Title.H3}"/>
    <Style x:Key="Body" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}"/>
    <Style x:Key="BodyMedium" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    <Style x:Key="Caption" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}"/>
    <Style x:Key="BodySmall" TargetType="TextBlock" BasedOn="{StaticResource Text.BodySmall}"/>
    <Style x:Key="BodyBold" TargetType="TextBlock" BasedOn="{StaticResource Text.BodyBold}"/>

    <!-- Form Styles -->
    <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>

    <Style x:Key="FormValue" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Aliases for legacy compatibility -->
    <Style x:Key="HeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Text.Title2}"/>
    <Style x:Key="LabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource FormLabel}"/>
    <Style x:Key="CaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}"/>
    <Style x:Key="Micro" TargetType="TextBlock" BasedOn="{StaticResource Text.Micro}"/>
    <Style x:Key="Text.BodyLarge" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <Style x:Key="BodyLarge" TargetType="TextBlock" BasedOn="{StaticResource Text.BodyLarge}"/>
    <Style x:Key="BodyLargeBold" TargetType="TextBlock" BasedOn="{StaticResource BodyLarge}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
</ResourceDictionary>
