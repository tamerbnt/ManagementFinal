<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Window.Background" Color="{StaticResource Palette.Neutral.White}" />
    <SolidColorBrush x:Key="Brush.Sidebar.Background" Color="{StaticResource Palette.Navy.500}" />
    <SolidColorBrush x:Key="Brush.Content.Background" Color="{StaticResource Palette.Neutral.OffWhite}" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Palette.Neutral.Black}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Palette.Neutral.Gray900}" Opacity="0.6" />
    <SolidColorBrush x:Key="Brush.Text.Tertiary" Color="{StaticResource Palette.Neutral.Gray900}" Opacity="0.3" />
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{StaticResource Palette.Blue.400}" />
    <SolidColorBrush x:Key="Brush.Status.Success" Color="{StaticResource Palette.Success}" />
    <SolidColorBrush x:Key="Brush.Error" Color="#E53935" />
    <SolidColorBrush x:Key="Brush.Neutral.White" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Neutral.OffWhite" Color="#F8F9FA" />
    
    <!-- Fix for ComboBox Background -->
    <SolidColorBrush x:Key="Brush.Surface.Primary" Color="{StaticResource Palette.Neutral.White}" />

    <!-- Semantic Aliases for Cross-Component Compatibility -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource Palette.Neutral.Black}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource Palette.Neutral.Gray900}" Opacity="0.6"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{DynamicResource Palette.Neutral.Gray900}" Opacity="0.3"/>

    <!-- Non-Suffix Aliases for Typography.xaml -->
    <StaticResource x:Key="TextPrimary" ResourceKey="TextPrimaryBrush"/>
    <StaticResource x:Key="TextSecondary" ResourceKey="TextSecondaryBrush"/>
    
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF"/> <!-- Global compatibility alias -->
    
    <SolidColorBrush x:Key="SeparatorStroke" Color="{DynamicResource Color.Border.Subtle}"/>
    <StaticResource x:Key="SeparatorBrush" ResourceKey="SeparatorStroke"/>
    <SolidColorBrush x:Key="SurfaceBg" Color="{DynamicResource Color.Gray.50}"/>
    <SolidColorBrush x:Key="SurfaceBgDim" Color="{DynamicResource Color.Background.Static}"/>
    <SolidColorBrush x:Key="Brush.Surface.Subtle" Color="{StaticResource Color.Gray.50}"/>

</ResourceDictionary>
