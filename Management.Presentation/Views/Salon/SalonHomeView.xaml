<UserControl x:Class="Management.Presentation.Views.Salon.SalonHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Salon"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1440">
    
    <UserControl.Resources>
        <Style x:Key="CarouselButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid VerticalAlignment="Stretch">
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- SECTION 0: HEADER -->
            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,32">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <Path Data="{StaticResource IconSalon}" 
                          Style="{StaticResource Style.Icon.Large}" 
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="{Binding Greeting}" FontSize="32" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                        <TextBlock Text="{DynamicResource Terminology.Home.Subtitle}" FontSize="15" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ZONE 1: CORE (Metrics + Activity) -->
            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Hero + Metrics Strip -->
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HERO + METRICS STRIP -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*"/> <!-- Next Appointment Hero -->
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>     <!-- Appointments -->
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>     <!-- Revenue -->
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>     <!-- Utilization -->
                    </Grid.ColumnDefinitions>

                    <!-- HERO: NEXT APPOINTMENT CAROUSEL -->
                    <Border Grid.Column="0" Height="140" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="16" Padding="16,16,16,12" Effect="{StaticResource Shadow2}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- Label row -->
                                <RowDefinition Height="*"/>     <!-- Content row -->
                                <RowDefinition Height="Auto"/>  <!-- Footer: arrows + counter -->
                            </Grid.RowDefinitions>

                            <!-- Header label -->
                            <StackPanel Orientation="Horizontal">
                                <Border Width="24" Height="24" CornerRadius="6" Background="#20FFFFFF" Margin="0,0,10,0">
                                    <Path Data="M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20C3,21.1 3.89,22 5,22H19C20.1,22 21,21.1 21,20V6C21,4.9 20.1,4 19,4M19,20H5V10H19V20M19,8H5V6H19V8Z"
                                          Fill="White" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Terminology.Salon.Home.NextAppointment}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>

                            <!-- CONTENT: appointment info (visible when there is one) -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0"
                                        Visibility="{Binding HasNoUpcoming, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding CurrentUpcoming.ClientName, FallbackValue='â€”'}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding CurrentUpcoming.ServiceName, FallbackValue='â€”'}" FontSize="13" Foreground="{DynamicResource FacilityAccentBrush}"/>
                                <StackPanel Orientation="Horizontal" Opacity="0.8" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding CurrentUpcoming.StartTime, StringFormat=HH:mm}" FontSize="12" Foreground="{DynamicResource Brush.Neutral.White}" FontWeight="Medium"/>
                                    <TextBlock Text=" â€¢ " Foreground="{DynamicResource Brush.Neutral.White}"/>
                                    <TextBlock Text="{Binding CurrentUpcoming.StaffName}" FontSize="12" Foreground="{DynamicResource Brush.Neutral.White}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- EMPTY STATE -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0"
                                        Visibility="{Binding HasNoUpcoming, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{DynamicResource Terminology.Salon.Home.NoUpcoming}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}"/>
                                <TextBlock Text="{DynamicResource Terminology.Sidebar.Dashboard}" FontSize="13" Foreground="{DynamicResource FacilityAccentBrush}"/>
                            </StackPanel>

                            <!-- FOOTER: arrows + counter (only when multiple) -->
                            <Grid Grid.Row="2" Margin="0,4,0,0"
                                  Visibility="{Binding HasMultipleUpcoming, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Prev arrow -->
                                <Button Grid.Column="0" Command="{Binding PreviousUpcomingCommand}"
                                        Style="{StaticResource CarouselButtonStyle}">
                                    <Path Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z"
                                          Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.8"/>
                                </Button>

                                <!-- Counter: "2 / 5" -->
                                <TextBlock Grid.Column="1" Text="{Binding UpcomingPosition}"
                                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>

                            <!-- Next arrow -->
                            <Button Grid.Column="2" Command="{Binding NextUpcomingCommand}"
                                    Style="{StaticResource CarouselButtonStyle}">
                                <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                      Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.8"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                    <!-- APPOINTMENTS COUNT -->
                    <Border Grid.Column="2" Height="140" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="White" BorderThickness="0,1.5,0,0" CornerRadius="16" Padding="24,20" Effect="{StaticResource Shadow2}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Stat.Appointments}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                <TextBlock Text="{Binding AppointmentsTodayCount}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="42" Height="42" CornerRadius="12" Background="{DynamicResource FacilityAccentDimBrush}" VerticalAlignment="Top">
                                <Path Data="{StaticResource IconCalendar}" Fill="{DynamicResource FacilityAccentBrush}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- REVENUE -->
                    <Border Grid.Column="4" Height="140" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="White" BorderThickness="0,1.5,0,0" CornerRadius="16" Padding="24,20" Effect="{StaticResource Shadow2}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Stat.Revenue}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                <TextBlock Text="{Binding TotalRevenueToday}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="42" Height="42" CornerRadius="12" Background="{DynamicResource FacilityAccentDimBrush}" VerticalAlignment="Top">
                                <Path Data="{StaticResource IconFinance}" Fill="{DynamicResource FacilityAccentBrush}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- UTILIZATION -->
                    <Border Grid.Column="6" Height="140" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="White" BorderThickness="0,1.5,0,0" CornerRadius="16" Padding="24,20" Effect="{StaticResource Shadow2}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Terminology.Salon.Home.ChairUtilization}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding ChairUtilization, StringFormat={}{0:P0}}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                    <Border Background="{DynamicResource Brush.Success}" CornerRadius="6" Padding="6,2" Margin="10,0,0,10" VerticalAlignment="Bottom">
                                        <TextBlock Text="{DynamicResource Terminology.Salon.Home.Optimal}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="1" Width="42" Height="42" CornerRadius="12" Background="{DynamicResource FacilityAccentDimBrush}" VerticalAlignment="Top">
                                <Path Data="{StaticResource IconApparatus}" Fill="{DynamicResource FacilityAccentBrush}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- RECENT ACTIVITY -->
                <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="White" BorderThickness="0,1.5,0,0" CornerRadius="24" Padding="20" Effect="{StaticResource Shadow2}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                            <Path Data="{StaticResource IconHistory}" Fill="{DynamicResource FacilityAccentBrush}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource Terminology.Salon.Home.TodayActivity}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                        </StackPanel>
                        
                        <!-- List -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ActivityStream}">
                                <ItemsControl.Resources>
                                    <!-- APPOINTMENT TEMPLATE -->
                                    <DataTemplate DataType="{x:Type vm:AppointmentActivityItem}">
                                        <Border Background="{DynamicResource Brush.Surface.Secondary}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Time -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0" MinWidth="40">
                                                    <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                </StackPanel>
                                                
                                                <!-- Client & Service -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                    <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="{DynamicResource FacilityAccentBrush}"/>
                                                </StackPanel>
                                                
                                                <!-- Status -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <Border Padding="8,4" CornerRadius="8" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,4">
                                                        <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>

                                    <!-- SALE TEMPLATE -->
                                    <DataTemplate DataType="{x:Type vm:SaleActivityItem}">
                                        <Border Background="{DynamicResource Brush.Surface.Secondary}" CornerRadius="12" Padding="16" Margin="0,0,0,12" BorderBrush="#204CAF50" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Time -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0" MinWidth="40">
                                                    <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                </StackPanel>
                                                
                                                <!-- Customer & Items -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <Path Data="M19,3H5C3.89,3 3,3.89,3,5V19C3,20.1 3.89,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.89 20.1,3 19,3M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                                                              Fill="{DynamicResource Brush.Text.Secondary}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7"/>
                                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                                </StackPanel>

                                                <!-- Amount -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding AmountText}" FontSize="16" FontWeight="Bold" Foreground="#4CAF50"/>
                                                    <TextBlock Text="{DynamicResource Terminology.Salon.Sale}" FontSize="11" Foreground="#4CAF50" HorizontalAlignment="Right" Opacity="0.8"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.Resources>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ZONE 2: ACTION SIDEBAR (DUAL CARDS) -->
            <Grid Grid.Row="1" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- Quick Actions (Expanded) -->
                    <RowDefinition Height="16"/>   <!-- Gap -->
                    <RowDefinition Height="Auto"/> <!-- Time/Date (Anchored Bottom) -->
                </Grid.RowDefinitions>

                <!-- QUICK ACTIONS CARD -->
                <Border Grid.Row="0" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="24" Padding="20" Effect="{StaticResource Shadow2}" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Header -->
                            <RowDefinition Height="*"/>     <!-- Buttons (centered) -->
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="{DynamicResource Terminology.Home.QuickActions}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                        
                        <!-- 2x2 Grid using real Commands -->
                        <Grid Grid.Row="1" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/> <!-- Gap -->
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/> <!-- Gap -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- New Retail Sale -->
                            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource Button.Ghost}" Command="{Binding SellItemCommand}" Height="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="14" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,12">
                                        <Path Data="{StaticResource IconFinance}" 
                                              Style="{StaticResource Style.Icon.Standard}"
                                              Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Salon.Home.Action.NewSale}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Add Client -->
                            <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource Button.Ghost}" Command="{Binding RegisterMemberCommand}" Height="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="14" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,12">
                                        <Path Data="{StaticResource IconPlus}" 
                                              Style="{StaticResource Style.Icon.Standard}"
                                              Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Salon.Home.Action.AddClient}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Walk-In -->
                            <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource Button.Ghost}" Command="{Binding ProcessWalkInCommand}" Height="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="14" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,12">
                                        <Path Data="{StaticResource IconMembers}" 
                                              Style="{StaticResource Style.Icon.Standard}"
                                              Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Salon.Home.Action.WalkIn}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Cart -->
                            <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource Button.Ghost}" Command="{Binding OpenMultiSaleCartCommand}" Height="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="14" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,12">
                                        <Path Data="{StaticResource IconCart}" 
                                              Style="{StaticResource Style.Icon.Standard}"
                                              Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Salon.Home.Action.OpenCart}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- TIME/DATE WIDGET (Gym Style) -->
                <Border Grid.Row="2" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="24" Padding="20" Effect="{StaticResource Shadow2}">
                    <StackPanel>
                        <!-- Time Display -->
                        <Path Data="{StaticResource IconClock}" Fill="{DynamicResource FacilityAccentBrush}" Width="28" Height="28" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="{Binding CurrentTime}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        
                        <!-- Date Display -->
                        <TextBlock Text="{Binding CurrentDate}" FontSize="12" Foreground="{DynamicResource Brush.Sidebar.Text.Inactive}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        
                        <!-- System Status -->
                        <Border Background="#10FFFFFF" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Terminology.Home.SystemStatus}" FontSize="9" FontWeight="Black" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.5" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{DynamicResource Terminology.Salon.Home.Status.Scanner}" FontSize="11" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.8"/>
                                    <TextBlock Visibility="{Binding IsScannerOnline, Converter={StaticResource BooleanToVisibilityConverter}}" Text="{DynamicResource Terminology.Global.Online}" FontSize="10" FontWeight="Black" Foreground="LimeGreen" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="{DynamicResource Terminology.Salon.Home.Status.Printer}" FontSize="11" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.8"/>
                                    <TextBlock Visibility="{Binding IsPrinterOnline, Converter={StaticResource BooleanToVisibilityConverter}}" Text="{DynamicResource Terminology.Global.Online}" FontSize="10" FontWeight="Black" Foreground="LimeGreen" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
