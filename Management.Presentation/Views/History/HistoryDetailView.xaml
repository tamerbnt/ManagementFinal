<UserControl x:Class="Management.Presentation.Views.History.HistoryDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.History"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="400"
             Background="White">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Scrollable Content -->
            <RowDefinition Height="Auto"/> <!-- Footer Actions -->
        </Grid.RowDefinitions>

        <!-- 1. Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <!-- Close Button -->
            <Button Style="{DynamicResource IconButtonStyle}" 
                    HorizontalAlignment="Right" 
                    Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=local:HistoryView}}"
                    Margin="0,-8,-8,0">
                <Path Data="{StaticResource IconClose}" 
                      Fill="{DynamicResource TextTertiaryBrush}" 
                      Style="{DynamicResource Style.Icon.Small}"/>
            </Button>

            <!-- Large Event Icon -->
            <Border Width="80" Height="80" 
                    CornerRadius="40" 
                    Background="#F8FAFC"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
                <!-- Generic History Icon - In real app, bind this using a converter based on Event Type -->
                <Path Data="{StaticResource IconHistory}" 
                      Fill="{DynamicResource TextSecondaryBrush}" 
                      Stretch="Uniform" 
                      Width="32" Height="32"
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="{Binding Title}" 
                       Style="{DynamicResource Title2}" 
                       HorizontalAlignment="Center" 
                       TextAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding Timestamp, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Format.Date.Long'}" 
                       Style="{DynamicResource Body}" 
                       Foreground="{DynamicResource TextTertiaryBrush}" 
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 2. Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-8,0" Padding="0,0,8,0">
            <StackPanel>
                <!-- Card: Event Details -->
                <ContentControl Content="{Binding}" Margin="0,0,0,32">
                    <ContentControl.ContentTemplate>
                        <!-- Default Template -->
                        <DataTemplate>
                             <StackPanel>
                                <TextBlock Text="{DynamicResource Terminology.History.Details}" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Details}" Style="{DynamicResource Body}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- Card: Audit Log -->
                <StackPanel>
                    <TextBlock Text="{DynamicResource Terminology.History.AuditLog}" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                    <Border Background="#F8FAFC" 
                            CornerRadius="8" 
                            BorderBrush="#E2E8F0" 
                            BorderThickness="1">
                        <TextBox Text="{Binding DataContext.AuditNote, RelativeSource={RelativeSource AncestorType=local:HistoryView}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{DynamicResource UnderlineTextBox}" 
                                 BorderThickness="0"
                                 Background="Transparent"
                                 MinHeight="120"
                                 Padding="12"
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap"
                                 Tag="{DynamicResource Terminology.History.Placeholder.AuditNote}"/>
                    </Border>
                    <TextBlock Text="{DynamicResource Terminology.History.AuditNoteInfo}" 
                               Style="{DynamicResource Micro}" 
                               Foreground="{DynamicResource TextTertiaryBrush}" 
                               Margin="0,8,0,0"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 3. Footer -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Content="{DynamicResource Terminology.History.Action.SaveNote}" 
                    Style="{DynamicResource SecondaryButton}" 
                    Margin="0,0,8,0"
                    Height="44"
                    Command="{Binding DataContext.SaveAuditNoteCommand, RelativeSource={RelativeSource AncestorType=local:HistoryView}}"/>

            <Button Grid.Column="1" 
                    Content="{DynamicResource Terminology.History.Action.Print}" 
                    Style="{DynamicResource PrimaryButton}" 
                    Height="44"
                    Command="{Binding DataContext.PrintSelectedEventCommand, RelativeSource={RelativeSource AncestorType=local:HistoryView}}"/>
        </Grid>
    </Grid>
</UserControl>
