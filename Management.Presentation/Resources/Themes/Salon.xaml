<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- SALON THEME SEMANTIC MAPPING -->
    
    <SolidColorBrush x:Key="Brush.Window.Background" Color="{StaticResource Color.White}"/>
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Gray.900}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Gray.500}"/>
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Gray.200}"/>
    <SolidColorBrush x:Key="Brush.Surface.Background" Color="{StaticResource Color.White}"/> <!-- White cards as requested -->
    <Color x:Key="Color.Brand.Primary">#F48FB1</Color> <!-- Blush accent -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{StaticResource Color.Brand.Primary}"/>
    
    <LinearGradientBrush x:Key="Brush.Sidebar.Background" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Color.Midnight.800}" Offset="0.0"/>
        <GradientStop Color="{StaticResource Color.Midnight.900}" Offset="1.0"/>
    </LinearGradientBrush>

</ResourceDictionary>
