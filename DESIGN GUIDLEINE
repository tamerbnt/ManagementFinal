```csharp
public async Task LoginAsync(string email, string password)
{
    // 1. Authenticate with Supabase
    var authResponse = await _supabase.Auth.SignInAsync(email, password);
    
    if (!authResponse.IsSuccess)
    {
        ShowError("Invalid email or password");
        return;
    }
    
    // 2. Get user profile
    var profile = await _supabase.From<Profiles>()
        .Select("*, businesses(*), facility_access(*)")
        .Where(p => p.Id == authResponse.User.Id)
        .SingleAsync();
    
    // 3. Get current PC's facility
    var currentFacility = await GetCurrentFacilityAsync();
    
    // 4. Check if user has access to this facility
    if (profile.Role == "Owner")
    {
        // Owner has access to all facilities
        AllowLogin(profile, currentFacility);
    }
    else
    {
        // Staff: Check facility access
        var hasAccess = profile.FacilityAccess
            .Any(fa => fa.FacilityId == currentFacility.Id && fa.IsActive);
        
        if (!hasAccess)
        {
            ShowError($"You don't have access to {currentFacility.Name}. " +
                      $"Please contact your manager.");
            return;
        }
        
        // Check if allowed to login at current time
        if (!IsWithinWorkingHours(profile, currentFacility))
        {
            ShowError("You're not scheduled to work at this time.");
            return;
        }
        
        AllowLogin(profile, currentFacility);
    }
    
    // 5. Load permissions
    var permissions = await LoadPermissionsAsync(profile.Id, currentFacility.Id);
    
    // 6. Store session
    await SessionManager.SaveAsync(new {
        UserId = profile.Id,
        Role = profile.Role,
        FacilityId = currentFacility.Id,
        Permissions = permissions,
        LoginTime = DateTime.UtcNow
    });
    
    // 7. Navigate to dashboard
    NavigateToDashboard();
}

private async Task<Facility> GetCurrentFacilityAsync()
{
    // Get facility associated with current hardware ID
    var hardwareId = HardwareIdService.Generate();
    
    var activation = await _supabase.From<LicenseActivations>()
        .Select("*, facilities(*)")
        .Where(a => a.HardwareId == hardwareId)
        .SingleAsync();
    
    return activation.Facility;
}
```

