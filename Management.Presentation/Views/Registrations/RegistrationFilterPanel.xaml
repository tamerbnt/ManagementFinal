<UserControl x:Class="Management.Presentation.Views.Registrations.RegistrationFilterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <!-- Search -->
            <ColumnDefinition Width="*"/>
            <!-- Spacer -->
            <ColumnDefinition Width="Auto"/>
            <!-- Filter Pills -->
        </Grid.ColumnDefinitions>

        <!-- 1. Search Box -->
        <!-- Fluid width up to max, rounded container -->
        <Border Grid.Column="0"
                MinWidth="{StaticResource SizeInputMinWidth}"
                MaxWidth="{StaticResource SizeSearchBarWidth}"
                Height="{StaticResource SizeInputHeight}"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="{StaticResource RadiusSearchBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search Icon -->
                <Path Grid.Column="0"
                      Data="{StaticResource IconSearch}"
                      Fill="{StaticResource TextTertiaryBrush}"
                      Style="{StaticResource IconStandard}"
                      Margin="{StaticResource MarginInputIcon}"/>

                <!-- Input Field -->
                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource UnderlineTextBox}"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         Tag="Search registrations..."/>
            </Grid>
        </Border>

        <!-- 2. Filter Pills -->
        <!-- Uses Global TogglePillStyle for consistent look/feel -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

            <RadioButton Content="All" 
                         IsChecked="{Binding FilterAll}" 
                         Style="{StaticResource TogglePillStyle}"/>

            <RadioButton Content="New (&lt;24h)" 
                         IsChecked="{Binding FilterNew}" 
                         Style="{StaticResource TogglePillStyle}"/>

            <RadioButton Content="Priority" 
                         IsChecked="{Binding FilterPriority}" 
                         Style="{StaticResource TogglePillStyle}"/>

        </StackPanel>
    </Grid>
</UserControl>