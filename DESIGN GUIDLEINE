## 📱 PHASE 7: OFFLINE MODE & SYNC

### Offline Capabilities

```csharp
public class OfflineService
{
    public async Task<bool> IsOnlineAsync()
    {
        try
        {
            var ping = await _supabase.HealthCheckAsync();
            return ping.IsSuccess;
        }
        catch
        {
            return false;
        }
    }
    
    public async Task SyncWhenOnlineAsync()
    {
        if (!await IsOnlineAsync()) return;
        
        // 1. Upload pending changes
        var pendingChanges = await _localDb.GetPendingChangesAsync();
        foreach (var change in pendingChanges)
        {
            await _supabase.SyncAsync(change);
            await _localDb.MarkAsSyncedAsync(change.Id);
        }
        
        // 2. Download updates
        var lastSyncTime = await _localDb.GetLastSyncTimeAsync();
        var updates = await _supabase.GetUpdatesSinceAsync(lastSyncTime);
        
        foreach (var update in updates)
        {
            await _localDb.ApplyUpdateAsync(update);
        }
        
        await _localDb.SetLastSyncTimeAsync(DateTime.UtcNow);
    }
}
