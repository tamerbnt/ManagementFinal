<UserControl x:Class="Management.Presentation.Views.Shop.AddProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             xmlns:shopvm="clr-namespace:Management.Presentation.ViewModels.Shop"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="400"
             d:DataContext="{d:DesignInstance shopvm:AddProductViewModel}">

    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}"
            Padding="{DynamicResource PaddingModal}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Form -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="{DynamicResource MarginHeaderBottom}">
                <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.Title}" 
                           Style="{DynamicResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.Subtitle}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="{DynamicResource MarginTextTop}"/>
            </StackPanel>

            <!-- 2. Form Content -->
            <StackPanel Grid.Row="1">
                <!-- Product Name -->
                <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.Name}" Style="{DynamicResource FormLabel}"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{DynamicResource UnderlineTextBox}"
                         Margin="{DynamicResource MarginSmallBottom}"
                         Tag="{DynamicResource Terminology.Shop.AddProduct.NameHint}"/>

                <!-- SKU & Category -->
                <Grid Margin="{DynamicResource MarginSectionTop}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.Sku}" Style="{DynamicResource FormLabel}"/>
                        <TextBox Text="{Binding Sku, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{DynamicResource UnderlineTextBox}"
                                 Tag="{DynamicResource Terminology.Shop.AddProduct.SkuHint}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.Category}" Style="{DynamicResource FormLabel}"/>
                        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{DynamicResource UnderlineTextBox}"
                                 Tag="{DynamicResource Terminology.Shop.AddProduct.CategoryHint}"/>
                    </StackPanel>
                </Grid>

                <!-- Prices -->
                <Grid Margin="{DynamicResource MarginSectionTop}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.SalePrice}" Style="{DynamicResource FormLabel}"/>
                        <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                 Style="{DynamicResource UnderlineTextBox}"
                                 Tag="0.00"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.UnitCost}" Style="{DynamicResource FormLabel}"/>
                        <TextBox Text="{Binding Cost, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                 Style="{DynamicResource UnderlineTextBox}"
                                 Tag="0.00"/>
                    </StackPanel>
                </Grid>

                <!-- Stock -->
                <Grid Margin="{DynamicResource MarginSectionTop}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.InitialStock}" Style="{DynamicResource FormLabel}"/>
                        <TextBox Text="{Binding StockQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{DynamicResource UnderlineTextBox}"
                                 Tag="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource Terminology.Shop.AddProduct.LowStockAlert}" Style="{DynamicResource FormLabel}"/>
                        <TextBox Text="{Binding ReorderLevel, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{DynamicResource UnderlineTextBox}"
                                 Tag="10"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- 3. Footer Actions -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="{DynamicResource MarginSectionTop}">
                
                <Button Content="{DynamicResource Terminology.Global.Cancel}" 
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource SecondaryButton}"
                        Margin="{DynamicResource MarginSmallRight}"/>

                <Button Content="{DynamicResource Terminology.Shop.AddProduct.Action.Save}" 
                        Command="{Binding SaveCommand}"
                        Style="{DynamicResource PrimaryButton}"
                        MinWidth="{DynamicResource SizeButtonMinWidth}"/>
            </StackPanel>

            <!-- Loading Overlay -->
            <Grid Grid.RowSpan="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <Border Background="White" Opacity="0.6" CornerRadius="{DynamicResource RadiusModal}"/>
                <ProgressBar IsIndeterminate="True" VerticalAlignment="Center" Width="100"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
