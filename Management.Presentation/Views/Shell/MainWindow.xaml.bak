&lt;controls:ModernWindow x:Class="Management.Presentation.Views.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Management.Presentation.Views.Shell"
        xmlns:controls="clr-namespace:Management.Presentation.Resources.Controls"
        xmlns:components="clr-namespace:Management.Presentation.Components.Layout"
        xmlns:settings="clr-namespace:Management.Presentation.Views.Settings"
        mc:Ignorable="d"
        Title="Gym OS" Height="900" Width="1440"
        WindowStartupLocation="CenterScreen"&gt;

    &lt;Window.InputBindings&gt;
        &lt;KeyBinding Key="K" Modifiers="Ctrl" Command="{Binding ToggleCommandPaletteCommand}"/&gt;
    &lt;/Window.InputBindings&gt;

    &lt;WindowChrome.WindowChrome&gt;
        &lt;WindowChrome CaptionHeight="80"
                      GlassFrameThickness="-1"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/&gt;
    &lt;/WindowChrome.WindowChrome&gt;

    &lt;Grid x:Name="RootGrid" Background="{DynamicResource Brush.Background.Static}"&gt;
        &lt;Grid.ColumnDefinitions&gt;
            &lt;ColumnDefinition x:Name="SidebarColumn" Width="280"/&gt;
            &lt;ColumnDefinition Width="*"/&gt;
        &lt;/Grid.ColumnDefinitions&gt;

        &lt;!-- Col 0: Sidebar (Fixed Left) --&gt;
        &lt;!-- ZIndex 100 to ensure it stays above content if needed, though independent column --&gt;
        &lt;local:SidebarView Grid.Column="0" Panel.ZIndex="100"/&gt;

        &lt;!-- Col 1: Main Content Area --&gt;
        &lt;Grid Grid.Column="1"&gt;
            &lt;Grid.RowDefinitions&gt;
                &lt;RowDefinition Height="80"/&gt; &lt;!-- Fixed TopBar Height --&gt;
                &lt;RowDefinition Height="*"/&gt;  &lt;!-- Remaining space for Content --&gt;
            &lt;/Grid.RowDefinitions&gt;

            &lt;!-- Row 0: TopBar --&gt;
            &lt;local:TopBarView Grid.Row="0"
                              DataContext="{Binding TopBar}"
                              Panel.ZIndex="50" /&gt;

            &lt;!-- Row 1: Content (Scrolls Internally) --&gt;
            &lt;ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"
                            Focusable="False"/&gt;
        &lt;/Grid&gt;

        &lt;!-- OVERLAYS (Spanning entire window) --&gt;
        &lt;components:CommandPaletteView
            Grid.ColumnSpan="2"
            DataContext="{Binding CommandPalette}"
            Panel.ZIndex="999"/&gt;

        &lt;settings:SettingsModalView
            Grid.ColumnSpan="2"
            DataContext="{Binding Settings}"
            Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
            Panel.ZIndex="1000"/&gt;
    &lt;/Grid&gt;
&lt;/controls:ModernWindow&gt;

