<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    
    <!-- Restaurant Specific Terminology -->
    <sys:String x:Key="Terminology.Restaurant.Order.EmptyList">No active orders for any table.</sys:String>
    <sys:String x:Key="Terminology.Restaurant.Order.SelectBillToPay">Select a bill to process payment</sys:String>
    <sys:String x:Key="Terminology.Restaurant.Order.Toast.Paid">Order for {0} paid successfully.</sys:String>

    <!-- Sidebar Navigation -->
    <sys:String x:Key="Terminology.Sidebar.FloorPlan">Floor Plan</sys:String>
    <sys:String x:Key="Terminology.Settings.Menu">Menu Management</sys:String>

    <!-- Floor Plan Screen -->
    <sys:String x:Key="Terminology.FloorPlan.Subtitle">Live overview of your dining area and table status.</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Section.MainHall">Main Hall</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Section.Patio">Patio</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Section.Bar">Bar Seating</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Legend.Title">Table Status Legend</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Status.Available">Available</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Status.Seated">Seated</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Status.Ordered">Ordered</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Status.BillReady">Bill Ready</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Status.Reserved">Reserved</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Stats.Total">Total Tables</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Stats.Occupied">Occupied</sys:String>
    <sys:String x:Key="Terminology.FloorPlan.Stats.Available">Available Now</sys:String>
    
</ResourceDictionary>
