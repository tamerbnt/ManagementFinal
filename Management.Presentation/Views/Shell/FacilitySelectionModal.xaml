<UserControl x:Class="Management.Presentation.Views.Shell.FacilitySelectionModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Shell"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:ChangeFacilityViewModel}"
             Background="Transparent">

    <UserControl.Resources>
        <converters:ResourceKeyToIconConverter x:Key="ResourceKeyToIconConverter"/>
    </UserControl.Resources>

    <Border Style="{DynamicResource GlobalModalContainerStyle}" 
            CornerRadius="{DynamicResource RadiusModal}"
            Padding="32"
            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
            <!-- Header -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                <Border Width="72" Height="72" CornerRadius="36" Margin="0,0,0,24" Background="{DynamicResource FacilityAccentBrush}" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Path Data="{StaticResource Icon.Storefront}" 
                          Fill="White" 
                          Width="32" Height="32" 
                          Stretch="Uniform" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource Strings.Auth.SELECTFACILITY}" Style="{DynamicResource Title1}" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Strings.Shell.Choosethemanagementcontex}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Facility Selection List -->
            <ListBox ItemsSource="{Binding Facilities}" 
                      SelectedItem="{Binding SelectedFacility}"
                      BorderThickness="0"
                      Background="Transparent"
                      Margin="0,0,0,32">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" 
                                            CornerRadius="16" 
                                            BorderThickness="1.5" 
                                            BorderBrush="{DynamicResource SeparatorStroke}"
                                            Background="{DynamicResource SurfaceBg}"
                                            Padding="16,20"
                                            Margin="0,0,0,12"
                                            Cursor="Hand">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Icon -->
                                            <Border x:Name="IconContainer" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource SurfaceBg}" Margin="0,0,16,0">
                                                <Path x:Name="IconPath" 
                                                      Data="{Binding IconKey, Converter={StaticResource ResourceKeyToIconConverter}}" 
                                                      Fill="{DynamicResource TextSecondaryBrush}"
                                                      Width="20" Height="20" 
                                                      Stretch="Uniform" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Content -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="NameText" Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="DescText" Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Check Indicator -->
                                            <Ellipse x:Name="CheckMark" 
                                                     Grid.Column="2"
                                                     Width="12" Height="12" 
                                                     Fill="White"
                                                     Visibility="Collapsed"
                                                     VerticalAlignment="Center"
                                                     Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="Transparent"/>
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#40FFFFFF"/>
                                            <Setter TargetName="IconContainer" Property="Background" Value="#33FFFFFF"/>
                                            <Setter TargetName="IconPath" Property="Fill" Value="White"/>
                                            <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                                            <Setter TargetName="DescText" Property="Foreground" Value="#E0F2FE"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource StatusInfoBackground}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" 
                        Command="{Binding CancelCommand}" 
                        Style="{DynamicResource GhostButton}" 
                        Content="{DynamicResource Strings.Global.Cancel}"/>
                        
                <Button Grid.Column="2" 
                        Command="{Binding ContinueCommand}" 
                        Style="{DynamicResource PrimaryButton}" 
                        Content="{DynamicResource Strings.Onboarding.Continue}"
                        Padding="16,8"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
