<UserControl x:Class="Management.Presentation.Views.Dashboard.Sections.RecentRegistrationsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <converters:IntToVisibilityConverter x:Key="ZeroIsVisibleConverter" />
        <converters:RegistrationAgeToBrushConverter x:Key="RegistrationAgeToBrushConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- List / Empty State -->
        </Grid.RowDefinitions>

        <!-- 1. Section Header -->
        <TextBlock Grid.Row="0" 
                   Text="Recent Registrations" 
                   Style="{StaticResource Title3}" 
                   Margin="{StaticResource MarginHeaderBottom}"/>

        <!-- 2. Virtualized List -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Registrations}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 AutomationProperties.LiveSetting="Polite">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRingStyle}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Margin" Value="{StaticResource MarginCardGap}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <!-- Accessibility Name -->
                    <Setter Property="AutomationProperties.Name">
                        <Setter.Value>
                            <MultiBinding StringFormat="{}{0}, {1}, {2}">
                                <Binding Path="FullName"/>
                                <Binding Path="Source"/>
                                <Binding Path="CreatedAt" Converter="{StaticResource RelativeTimeConverter}"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Card Root -->
                    <Border x:Name="CardBorder"
                            Style="{StaticResource ElevatedCardStyleInteractive}"
                            Height="{StaticResource SizeRegistrationItemHeight}"
                            Padding="{StaticResource PaddingCardCompact}">

                        <!-- 
                            GLOBAL BEHAVIOR: Hover Reveal 
                            Replaces local Storyboards/Triggers.
                            TargetName="ActionPanel" will be faded In/Out on MouseOver of CardBorder.
                        -->
                        <i:Interaction.Behaviors>
                            <behaviors:HoverRevealBehavior TargetName="ActionPanel" 
                                                           Duration="{StaticResource DurationStandard}"/>
                        </i:Interaction.Behaviors>

                        <!-- Card Click Command -->
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding ViewDetailsCommand}"/>
                        </Border.InputBindings>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Avatar -->
                                <ColumnDefinition Width="*"/>
                                <!-- Info -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Timestamp / Actions -->
                            </Grid.ColumnDefinitions>

                            <!-- Avatar -->
                            <Ellipse Grid.Column="0" 
                                     Width="{StaticResource SizeAvatarStandard}" 
                                     Height="{StaticResource SizeAvatarStandard}"
                                     Margin="{StaticResource MarginAvatarRight}">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{StaticResource AccentLight}"/>
                                </Ellipse.Fill>
                            </Ellipse>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FullName}" 
                                           Style="{StaticResource BodyMedium}" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginTextTop}">
                                    <TextBlock Text="{Binding Source}" 
                                               Style="{StaticResource Caption}" 
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock Text=" &#x2022; " 
                                               Style="{StaticResource Caption}" 
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock Text="{Binding PhoneNumber}" 
                                               Style="{StaticResource Caption}" 
                                               Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right Side -->
                            <Grid Grid.Column="2" VerticalAlignment="Center">

                                <!-- Timestamp -->
                                <TextBlock Text="{Binding CreatedAt, Converter={StaticResource RelativeTimeConverter}}"
                                           Style="{StaticResource Caption}"
                                           Foreground="{Binding CreatedAt, Converter={StaticResource RegistrationAgeToBrushConverter}}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"/>

                                <!-- 
                                    Action Buttons Panel 
                                    Controlled by HoverRevealBehavior (Opacity 0->1)
                                -->
                                <StackPanel x:Name="ActionPanel" 
                                            Orientation="Horizontal" 
                                            Opacity="0"
                                            IsHitTestVisible="False">

                                    <!-- Approve (Green, Compact 40px) -->
                                    <Button Style="{StaticResource ButtonCompactSuccess}"
                                            Margin="{StaticResource MarginSmallRight}"
                                            Command="{Binding ApproveCommand}"
                                            ToolTip="Approve Registration">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconCheck}" 
                                                  Fill="{DynamicResource OnAccentPrimary}"
                                                  Style="{StaticResource IconSmall}"
                                                  Margin="{StaticResource MarginIconRight}"/>
                                            <TextBlock Text="Approve"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Decline (Red, Compact 40px) -->
                                    <Button Style="{StaticResource ButtonCompactError}"
                                            Command="{Binding DeclineCommand}"
                                            ToolTip="Decline Registration">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconClose}" 
                                                  Fill="{DynamicResource OnAccentPrimary}"
                                                  Style="{StaticResource IconSmall}"
                                                  Margin="{StaticResource MarginIconRight}"/>
                                            <TextBlock Text="Decline"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 3. Empty State -->
        <Grid Grid.Row="1" 
              Visibility="{Binding Registrations.Count, Converter={StaticResource ZeroIsVisibleConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Data="{StaticResource IconCelebration}"
                      Fill="{DynamicResource FacilityAccentBrush}"
                      Width="64" Height="64"
                      Stretch="Uniform"
                      Margin="{StaticResource MarginSectionBottom}"
                      HorizontalAlignment="Center"/>

                <TextBlock Text="All caught up!" 
                           Style="{StaticResource Title2}" 
                           Foreground="{StaticResource TextSecondary}" 
                           HorizontalAlignment="Center"
                           Margin="{StaticResource MarginTextBottom}"/>

                <TextBlock Text="No pending registrations" 
                           Style="{StaticResource Body}" 
                           Foreground="{StaticResource TextTertiary}" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>