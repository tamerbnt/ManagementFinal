<UserControl x:Class="Management.Presentation.Views.AccessControl.RealTimeFeedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

	<UserControl.Resources>
         <converters:BoolToSuccessErrorBrushConverter x:Key="BoolToSuccessErrorBrushConverter"/> 
         <converters:IntToVisibilityConverter x:Key="ZeroIsVisibleConverter" /> 
        <!-- RelativeTimeConverter assumed global -->
	</UserControl.Resources>

	<Grid>
		<!-- 
            1. Access Event List 
            Strict Virtualization Enabled for performance with high-frequency logs.
        -->
		<ListBox ItemsSource="{Binding ActivityFeed}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 AutomationProperties.LiveSetting="Assertive">

			<ListBox.ItemContainerStyle>
				<Style TargetType="ListBoxItem">
					<Setter Property="Padding" Value="0"/>
					<Setter Property="Background" Value="Transparent"/>
					<Setter Property="FocusVisualStyle" Value="{StaticResource FocusRingStyle}"/>
					<!-- Add gap between items via Margin on the container -->
					<Setter Property="Margin" Value="{StaticResource MarginCardGap}"/>
					<Setter Property="Template">
						<Setter.Value>
							<ControlTemplate TargetType="ListBoxItem">
								<ContentPresenter />
							</ControlTemplate>
						</Setter.Value>
					</Setter>

					<!-- Accessibility Name -->
					<Setter Property="AutomationProperties.Name">
						<Setter.Value>
							<MultiBinding StringFormat="{}{0} access {1} at {2}">
								<Binding Path="MemberName"/>
								<Binding Path="AccessStatus"/>
								<Binding Path="FacilityName"/>
							</MultiBinding>
						</Setter.Value>
					</Setter>
				</Style>
			</ListBox.ItemContainerStyle>

			<ListBox.ItemTemplate>
				<DataTemplate>
					<!-- 
                        Card Layout
                        Height: 88px (SizeAccessItemHeight)
                    -->
					<Border Style="{StaticResource ElevatedCardStyle}"
                            Height="{StaticResource SizeAccessItemHeight}"
                            Padding="0">
						<!-- Padding 0 to allow Status Strip to touch edge -->

						<!-- 
                            GLOBAL BEHAVIOR: List Item Entrance 
                            Handles GPU TranslateY Slide + Opacity Fade + Flash Overlay trigger.
                            Strictly defined in Behaviors.xaml logic.
                        -->
						<i:Interaction.Behaviors>
							<behaviors:ListItemEntranceBehavior FlashOverlayName="FlashOverlay" 
                                                                Duration="{StaticResource DurationFast}"/>
						</i:Interaction.Behaviors>

						<!-- Transform Group required for behavior manipulation -->
						<Border.RenderTransform>
							<TranslateTransform Y="0"/>
						</Border.RenderTransform>

						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="6"/>
								<!-- Status Strip -->
								<ColumnDefinition Width="Auto"/>
								<!-- Avatar -->
								<ColumnDefinition Width="*"/>
								<!-- Name/ID -->
								<ColumnDefinition Width="Auto"/>
								<!-- Facility/Time -->
							</Grid.ColumnDefinitions>

							<!-- Status Strip (Left Edge) - 4px Width mandated -->
							<Rectangle Grid.Column="0"
                                       Fill="{Binding IsAccessGranted, Converter={StaticResource BoolToSuccessErrorBrushConverter}}"
                                       RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left"
                                       Width="4"/>

							<!-- Avatar -->
							<Ellipse Grid.Column="1"
                                     Width="{StaticResource SizeAvatarMedium}"
                                     Height="{StaticResource SizeAvatarMedium}"
                                     Margin="16,0,16,0">
								<Ellipse.Fill>
									<SolidColorBrush Color="{DynamicResource AccentColor}"/>
								</Ellipse.Fill>
								<!-- Image Binding would go here -->
							</Ellipse>

							<!-- Name & Card ID -->
							<StackPanel Grid.Column="2" VerticalAlignment="Center">
								<TextBlock Text="{Binding MemberName}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
								<TextBlock Text="{Binding CardId}"
                                           Style="{StaticResource Caption}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="{StaticResource MarginTextTop}"/>
							</StackPanel>

							<!-- Facility & Timestamp -->
							<StackPanel Grid.Column="3"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Margin="{StaticResource MarginCardRight}">
								<TextBlock Text="{Binding FacilityName}"
                                           Style="{StaticResource Body}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right"/>
								<TextBlock Text="{Binding Timestamp, Converter={StaticResource RelativeTimeConverter}}"
                                           Style="{StaticResource Caption}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           HorizontalAlignment="Right"
                                           Margin="{StaticResource MarginTextTop}"/>
							</StackPanel>

							<!-- 
                                Flash Overlay (For New Item Highlight) 
                                Controlled by ListItemEntranceBehavior.
                                Uses Semantic Brush (NewItemFlashBrush).
                            -->
							<Rectangle x:Name="FlashOverlay"
                                       Fill="{DynamicResource NewItemFlashBrush}"
                                       Opacity="0"
                                       IsHitTestVisible="False"
                                       RadiusX="{StaticResource RadiusCardStandardDouble}"
                                       RadiusY="{StaticResource RadiusCardStandardDouble}"/>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

		<!-- 
            2. Empty State Overlay 
            Visible when Count == 0
        -->
        <Grid Visibility="{Binding ActivityFeed.Count, Converter={StaticResource ZeroIsVisibleConverter}, ConverterParameter='ZeroIsVisible'}"
              IsHitTestVisible="False">
			<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
				<!-- Door Icon (256px) -->
				<Path Data="{StaticResource IconDoor}"
                      Fill="{StaticResource IllustrationBackgroundBrush}"
                      Width="256" Height="256"
                      Stretch="Uniform"
                      Margin="{StaticResource MarginSectionBottom}"
                      HorizontalAlignment="Center"/>

				<TextBlock Text="{DynamicResource TerminologyNoActivityYetLabel}"
                           Style="{StaticResource Title2}"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="{StaticResource MarginTextBottom}"/>

				<TextBlock Text="{DynamicResource TerminologyAccessEventsWillAppearLabel}"
                           Style="{StaticResource Body}"
                           Foreground="{StaticResource TextTertiary}"
                           HorizontalAlignment="Center"/>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>