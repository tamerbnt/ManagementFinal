<UserControl x:Class="Management.Presentation.Views.Dashboard.Sections.MetricsOverviewSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <!-- Responsive Grid Logic Converter -->
        <converters:WindowWidthToColumnsConverter x:Key="WindowWidthToColumnsConverter"/>
    </UserControl.Resources>

    <!-- 
        Main Layout: Responsive UniformGrid 
        Columns: 4 (>=1440px) or 2 (<1440px)
        Rows: Auto-calculated based on item count
    -->
    <UniformGrid VerticalAlignment="Top">
        <UniformGrid.Columns>
            <Binding Path="ActualWidth" 
                     RelativeSource="{RelativeSource AncestorType=Window}" 
                     Converter="{StaticResource WindowWidthToColumnsConverter}">
                <Binding.ConverterParameter>
                    <sys:Double>1440</sys:Double>
                </Binding.ConverterParameter>
            </Binding>
        </UniformGrid.Columns>

        <!-- 1. People Inside (Blue) -->
        <Border Style="{StaticResource ElevatedCardStyle}"
                Height="{StaticResource SizeStatTileHeight}"
                Padding="{StaticResource PaddingCard}"
                Margin="{StaticResource MarginCardGap}"
                AutomationProperties.Name="People Inside">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Icon -->
                <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse Width="{StaticResource SizeIconCircleLarge}" 
                             Height="{StaticResource SizeIconCircleLarge}" 
                             Fill="{StaticResource PrimaryAccentBrush}" 
                             Opacity="0.3"/>
                    <Path Data="{StaticResource IconRunner}" 
                          Fill="{StaticResource PrimaryAccentBrush}" 
                          Style="{StaticResource IconLarge}"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Grid>

                <!-- Value & Label -->
                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding ActivePeopleCount, FallbackValue='0'}" 
                               Style="{StaticResource Hero}" 
                               Foreground="{StaticResource TextPrimary}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock Text="Currently Active" 
                               Style="{StaticResource BodySecondary}" 
                               Foreground="{StaticResource TextSecondary}" 
                               Margin="{StaticResource MarginTextTop}"/>
                </StackPanel>
            </Grid>
            <Border.ToolTip>
                <ToolTip Content="Total people currently checked into the facility"/>
            </Border.ToolTip>
        </Border>

        <!-- 2. Active Members (Green) -->
        <Border Style="{StaticResource ElevatedCardStyle}"
                Height="{StaticResource SizeStatTileHeight}"
                Padding="{StaticResource PaddingCard}"
                Margin="{StaticResource MarginCardGap}"
                AutomationProperties.Name="Total Active Members">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse Width="{StaticResource SizeIconCircleLarge}" 
                             Height="{StaticResource SizeIconCircleLarge}" 
                             Fill="{StaticResource StatusSuccessBrush}" 
                             Opacity="0.3"/>
                    <Path Data="{StaticResource IconCheck}" 
                          Fill="{StaticResource StatusSuccessBrush}" 
                          Style="{StaticResource IconLarge}"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding TotalActiveMembers, FallbackValue='0'}" 
                               Style="{StaticResource Hero}" 
                               Foreground="{StaticResource TextPrimary}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock Text="Total Active" 
                               Style="{StaticResource BodySecondary}" 
                               Foreground="{StaticResource TextSecondary}" 
                               Margin="{StaticResource MarginTextTop}"/>
                </StackPanel>
            </Grid>
            <Border.ToolTip>
                <ToolTip Content="Members with an active, paid membership"/>
            </Border.ToolTip>
        </Border>

        <!-- 3. Expiring Soon (Yellow) -->
        <Border Style="{StaticResource ElevatedCardStyle}"
                Height="{StaticResource SizeStatTileHeight}"
                Padding="{StaticResource PaddingCard}"
                Margin="{StaticResource MarginCardGap}"
                AutomationProperties.Name="Members Expiring Soon">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse Width="{StaticResource SizeIconCircleLarge}" 
                             Height="{StaticResource SizeIconCircleLarge}" 
                             Fill="{StaticResource StatusWarningBrush}" 
                             Opacity="0.3"/>
                    <Path Data="{StaticResource IconClock}" 
                          Fill="{StaticResource StatusWarningBrush}" 
                          Style="{StaticResource IconLarge}"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding ExpiringSoonCount, FallbackValue='0'}" 
                               Style="{StaticResource Hero}" 
                               Foreground="{StaticResource TextPrimary}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock Text="Next 7 Days" 
                               Style="{StaticResource BodySecondary}" 
                               Foreground="{StaticResource TextSecondary}" 
                               Margin="{StaticResource MarginTextTop}"/>
                </StackPanel>
            </Grid>
            <Border.ToolTip>
                <ToolTip Content="Memberships expiring within the next 7 days"/>
            </Border.ToolTip>
        </Border>

        <!-- 4. Pending Registrations (Red) - INTERACTIVE -->
        <Border Style="{StaticResource ElevatedCardStyleInteractive}"
                Height="{StaticResource SizeStatTileHeight}"
                Padding="{StaticResource PaddingCard}"
                Margin="{StaticResource MarginCardGap}"
                AutomationProperties.Name="Pending Registrations"
                FocusVisualStyle="{StaticResource FocusRingStyle}">

            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" 
                              Command="{Binding NavigateToRegistrationsCommand}"/>
            </Border.InputBindings>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse Width="{StaticResource SizeIconCircleLarge}" 
                             Height="{StaticResource SizeIconCircleLarge}" 
                             Fill="{StaticResource StatusErrorBrush}" 
                             Opacity="0.3"/>
                    <Path Data="{StaticResource IconFileText}" 
                          Fill="{StaticResource StatusErrorBrush}" 
                          Style="{StaticResource IconLarge}"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding PendingRegistrationsCount, FallbackValue='0'}" 
                               Style="{StaticResource Hero}" 
                               Foreground="{StaticResource TextPrimary}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock Text="Awaiting Review" 
                               Style="{StaticResource BodySecondary}" 
                               Foreground="{StaticResource TextSecondary}" 
                               Margin="{StaticResource MarginTextTop}"/>
                </StackPanel>
            </Grid>
            <Border.ToolTip>
                <ToolTip Content="Click to view pending registrations"/>
            </Border.ToolTip>
        </Border>

    </UniformGrid>
</UserControl>