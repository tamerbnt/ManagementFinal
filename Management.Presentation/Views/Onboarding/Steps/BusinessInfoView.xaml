<UserControl x:Class="Management.Presentation.Views.Onboarding.Steps.BusinessInfoView"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              mc:Ignorable="d" 
              d:DesignHeight="550" d:DesignWidth="400">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,0,20">
                <!-- Header -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Path Data="{StaticResource Icon.Storefront}" 
                          Fill="{DynamicResource Brush.Brand.Primary}" 
                          Width="64" Height="64" Stretch="Uniform" />
                    <TextBlock Text="{DynamicResource Strings.Onboarding\Steps.BusinessProfile}" 
                               FontSize="24" FontWeight="SemiBold" 
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               Margin="0,16,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Error Message -->
                <Border Background="{DynamicResource Brush.Danger.Dim}" 
                        CornerRadius="{DynamicResource Corner.MD}" 
                        Padding="12"
                        Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="{DynamicResource Brush.Danger}" 
                               FontSize="14"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Inputs -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="{DynamicResource Strings.Auth.BUSINESSNAME}" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input.Apple}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="{DynamicResource Strings.FinanceAndStaff.PhoneNumber}" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input.Apple}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="{DynamicResource Strings.Onboarding\Steps.Currency}" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding Currencies}" 
                              SelectedItem="{Binding SelectedCurrency}"
                              Style="{StaticResource Input.ComboBox}"
                              IsEditable="False"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="{DynamicResource Strings.Onboarding\Steps.Address}" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource Input.Apple}" 
                             Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Padding="12"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
