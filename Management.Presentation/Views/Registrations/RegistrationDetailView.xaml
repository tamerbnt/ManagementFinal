<UserControl x:Class="Management.Presentation.Views.Registrations.RegistrationDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Registrations"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="400"
             Background="{DynamicResource SurfaceBg}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NameToBrushConverter x:Key="NameToBrushConverter"/>
        <converters:NameToInitialConverter x:Key="NameToInitialConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Scrollable Content -->
            <RowDefinition Height="Auto"/> <!-- Footer Actions -->
        </Grid.RowDefinitions>

        <!-- 1. Profile Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <!-- Close Button -->
            <Button Style="{StaticResource IconButtonStyle}" 
                    HorizontalAlignment="Right" 
                    Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}}"
                    Margin="0,-12,-12,0">
                <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextTertiaryBrush}" Style="{StaticResource Style.Icon.Small}"/>
            </Button>

            <!-- Avatar -->
            <Grid HorizontalAlignment="Center" Margin="0,12,0,16">
                <Ellipse Width="96" Height="96" 
                         Fill="{Binding FullName, Converter={StaticResource NameToBrushConverter}}"/>
                <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialConverter}}" 
                           Style="{StaticResource Title1}" Foreground="White" 
                           FontSize="32" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Name -->
            <StackPanel Margin="0,0,0,8" HorizontalAlignment="Center">
                <TextBlock Text="{Binding FullName}" Style="{StaticResource Title2}" HorizontalAlignment="Center"
                           Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                <TextBox Text="{Binding FullName, Mode=TwoWay}" Style="{StaticResource Input.Field}" Width="250" HorizontalAlignment="Center"
                         Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>

            <!-- Status Badge -->
            <Border Background="{DynamicResource SurfaceBg}" Padding="12,4" CornerRadius="12" HorizontalAlignment="Center" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <TextBlock Text="{Binding Status}" Style="{StaticResource Caption}" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>
        </StackPanel>

        <!-- 2. Content Sections -->
        <ScrollViewer Grid.Row="1" Margin="0,0,-8,0" Padding="0,0,8,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Quick Stats Grid -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Terminology.Registrations.Detail.Source}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Source}" Style="{StaticResource BodyMedium}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Terminology.Registrations.Detail.PlanChoice}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding PlanName}" Style="{StaticResource BodyMedium}" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource BrandPrimaryBrush}"/>
                    </StackPanel>
                </Grid>

                <Separator Background="{DynamicResource SeparatorStroke}" Margin="0,0,0,24" BorderThickness="0" Height="1"/>

                <!-- Contact Info -->
                <TextBlock Text="{DynamicResource Terminology.Registrations.Detail.ContactInfo}" Style="{StaticResource Title3}" Margin="0,0,0,20"/>
                
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="{DynamicResource Terminology.Registrations.Detail.Email}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Email}" Style="{StaticResource Body}" FontWeight="Medium"
                               Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    <TextBox Text="{Binding Email, Mode=TwoWay}" Style="{StaticResource Input.Field}"
                             Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="{DynamicResource Terminology.Registrations.Detail.Phone}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding PhoneNumber}" Style="{StaticResource Body}" FontWeight="Medium"
                               Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    <TextBox Text="{Binding PhoneNumber, Mode=TwoWay}" Style="{StaticResource Input.Field}"
                             Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Message Section -->
                <TextBlock Text="{DynamicResource Terminology.Registrations.Detail.Message}" Style="{StaticResource Title3}" Margin="0,0,0,12"/>
                <Border Background="{DynamicResource SurfaceBg}" Padding="16" CornerRadius="12" BorderBrush="{DynamicResource SeparatorStroke}" BorderThickness="1">
                    <TextBlock Text="{Binding Message}" Style="{StaticResource Body}" TextWrapping="Wrap" FontStyle="Italic" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="20"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 3. Actions Footer -->
        <Border Grid.Row="2" VerticalAlignment="Bottom" Padding="0,24,0,0">
            <Grid>
                <!-- Normal Mode Actions -->
                <Grid Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="{DynamicResource Terminology.Registrations.Detail.Decline}" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding DeclineCommand}" Height="48"/>
                    
                    <Button Grid.Column="2" Content="{DynamicResource Terminology.Registrations.Detail.Approve}" Style="{StaticResource PrimaryButton}" 
                            Command="{Binding ApproveCommand}" Height="48"/>
                </Grid>

                <!-- Edit Mode Actions -->
                <Grid Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{DynamicResource Terminology.Global.Cancel}" Style="{StaticResource SecondaryButton}" Height="48"
                            Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}}"/>
                    <Button Grid.Column="2" Content="{DynamicResource Terminology.Global.Update}" Style="{StaticResource PrimaryButton}" Height="48"
                            Command="{Binding DataContext.SaveRegistrationCommand, RelativeSource={RelativeSource AncestorType=local:RegistrationsView}}"/>
                </Grid>
                

            </Grid>
        </Border>
    </Grid>
</UserControl>
