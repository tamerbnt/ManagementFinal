<UserControl x:Class="Management.Presentation.Views.AccessControl.AccessControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             
             xmlns:access="clr-namespace:Management.Presentation.Views.AccessControl"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">


<UserControl.Resources>
	<!-- Removed redundant WindowWidthToMarginConverter -->
</UserControl.Resources>

<!-- Global Screen Entrance Animation -->
<UserControl.Triggers>
	<EventTrigger RoutedEvent="Loaded">
		<BeginStoryboard>
			<Storyboard>
				<DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0" To="1"
                                 Duration="{StaticResource DurationScreenTransition}">
					<DoubleAnimation.EasingFunction>
						<CubicEase EasingMode="EaseOut"/>
					</DoubleAnimation.EasingFunction>
				</DoubleAnimation>
			</Storyboard>
		</BeginStoryboard>
	</EventTrigger>
</UserControl.Triggers>

<Grid>
	<!-- 1. Main Content Layout (Fixed 48px Padding) -->
	<Grid Margin="48,0">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Header -->
			<RowDefinition Height="Auto"/>
			<!-- Hero Card -->
			<RowDefinition Height="Auto"/>
			<!-- Hardware Panel -->
			<RowDefinition Height="*"/>
			<!-- Live Feed -->
		</Grid.RowDefinitions>

		<!-- Header -->
		<TextBlock Grid.Row="0"
                   Text="{DynamicResource TerminologyAccessControlLabel}"
                   Style="{StaticResource Title1}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="{StaticResource MarginSectionBottom}"/>

		<!-- 
            Hero Counter Card 
            Uses global style 'HeroLiveCounterCardStyle' which encapsulates:
            - Width 400px
            - Shadow Level 3 (Glow)
            - Corner Radius 24px
            - Padding 48px
        -->
		<Border Grid.Row="1"
                Style="{StaticResource HeroLiveCounterCardStyle}"
                HorizontalAlignment="Center">

			<StackPanel HorizontalAlignment="Center">
				<!-- Label -->
				<TextBlock Text="{DynamicResource TerminologyPeopleInsideLabel}"
                           Style="{StaticResource Micro}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"
                           FontWeight="Medium"/>

				<!-- Count (Uses global 'HeroLive' style for 96pt sizing + Tabular Alignment) -->
				<TextBlock Text="{Binding PeopleInsideCount}"
                           Style="{StaticResource HeroLive}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Typography.NumeralAlignment="Tabular"
                           HorizontalAlignment="Center"
                           Margin="{StaticResource MarginTextVertical}"/>

				<!-- Live Indicator Container -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<!-- 
                        Live Dot 
                        Uses global 'LiveIndicatorStyle' which encapsulates:
                        - Green Brush
                        - Infinite Pulse Animation
                    -->
					<Ellipse Style="{StaticResource LiveIndicatorStyle}"
                             Margin="{StaticResource MarginSmallRight}"/>

					<TextBlock Text="{DynamicResource TerminologyLiveLabel}"
                               Style="{StaticResource Caption}"
                               Foreground="{DynamicResource StatusSuccessBrush}"
                               VerticalAlignment="Center"/>
				</StackPanel>
			</StackPanel>
		</Border>

		<!-- Hardware Section (Turnstiles) -->
            <access:TurnstileStatusPanel Grid.Row="2"
                                    Margin="{StaticResource MarginSectionTop}"
                                    HorizontalAlignment="Center"/>

		<!-- Feed Section -->
		<Grid Grid.Row="3" Margin="{StaticResource MarginSectionTop}">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0"
                       Text="Real-Time Feed"
                       Style="{StaticResource Title3}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="{StaticResource MarginHeaderBottom}"/>

			<!-- Injected Feed Component -->
                <access:RealTimeFeedView Grid.Row="1"/>
		</Grid>
	</Grid>

	<!-- 
        2. Floating Action Button (FAB) 
        Uses global 'FloatingActionButtonStyle' which encapsulates:
        - Position (Bottom/Right)
        - Size (200x80)
        - Shadow Level 3
        - Z-Index behavior
    -->
	<Button Style="{StaticResource FloatingActionButtonStyle}"
            Command="{Binding SimulateScanCommand}">
		<StackPanel Orientation="Horizontal">
			<Path Data="{StaticResource IconBolt}"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  Style="{StaticResource IconSmall}"
                  Margin="{StaticResource MarginSmallRight}"/>
			<TextBlock Text="{DynamicResource TerminologySimulateScanLabel}"
                       FontSize="15"
                       FontWeight="Medium"/>
		</StackPanel>
	</Button>
</Grid>


</UserControl>