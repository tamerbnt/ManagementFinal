<UserControl x:Class="Management.Presentation.Components.Layout.ModalHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Visibility="Collapsed">
    <Grid>
        <!-- Modal Backdrop (TitanBlur Simulation) -->
        <Border x:Name="Backdrop" Background="#CC0F172A" MouseDown="Backdrop_MouseDown" Opacity="0">
            <Border.Effect>
                <BlurEffect x:Name="BackdropBlur" Radius="0"/>
            </Border.Effect>
        </Border>

        <!-- Centered Modal Content Container -->
        <Border x:Name="ModalContainer"
                Background="{DynamicResource Brush.Window.Background}"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                MinWidth="400"
                MinHeight="200"
                MaxHeight="800"
                MaxWidth="1000"
                CornerRadius="16"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1"
                Padding="32"
                Opacity="0">
            <Border.RenderTransform>
                <ScaleTransform x:Name="ModalScale" CenterX="200" CenterY="100" ScaleX="0.9" ScaleY="0.9"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.2" Color="Black"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Close Button -->
                <Button HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Width="32" Height="32"
                        Style="{StaticResource Button.Ghost}"
                        Click="Close_Click"
                        Content="âœ•"
                        Margin="0,-16,-16,0"/>

                <ContentPresenter Grid.Row="1" Content="{Binding ModalContent, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
