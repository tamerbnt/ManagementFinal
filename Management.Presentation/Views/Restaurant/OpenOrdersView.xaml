<UserControl x:Class="Management.Presentation.Views.Restaurant.OpenOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Restaurant"
             xmlns:dto="clr-namespace:Management.Application.Interfaces;assembly=Management.Application"
             mc:Ignorable="d" 
             d:DesignHeight="620" d:DesignWidth="520">

    <Border Background="{DynamicResource CardBackgroundBrush}" 
            CornerRadius="24" 
            Padding="32" 
            Width="500"
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            Effect="{DynamicResource Shadow3}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="{DynamicResource Terminology.Restaurant.Order.PayBill}" 
                           FontSize="26" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}" VerticalAlignment="Center"/>
                
                <!-- CLOSE BUTTON â€” uses Stroke path, always visible -->
                <Button Grid.Column="1" Command="{Binding CancelCommand}" 
                        Width="40" Height="40"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Close">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" 
                                    Background="{DynamicResource Brush.Surface.Secondary}" 
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource Brush.Surface.Hover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <!-- Use X path with Stroke, not Fill -->
                    <Path Data="M14 6L6 14M6 6L14 14"
                          Stroke="{DynamicResource Brush.Text.Primary}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Width="16" Height="16" Stretch="Uniform"/>
                </Button>
            </Grid>
            
            <!-- LIST -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="420">
                <StackPanel>
                    <!-- EMPTY STATE -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0"
                                Visibility="{Binding OpenOrders.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=Inverse}">
                        <Path Data="{StaticResource IconCheckCircle}" 
                              Stroke="{DynamicResource Brush.Text.Secondary}" 
                              StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="40" Height="40" Stretch="Uniform" 
                              HorizontalAlignment="Center" Opacity="0.4" Margin="0,0,0,12"/>
                        <TextBlock Text="{DynamicResource Terminology.Restaurant.Order.EmptyList}" 
                                   FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- OPEN ORDERS REPEATER -->
                    <ItemsControl ItemsSource="{Binding OpenOrders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type dto:RestaurantOrderDto}">
                                <Border Background="{DynamicResource Brush.Surface.Secondary}" 
                                        CornerRadius="16" Padding="20,16" Margin="0,0,0,12" 
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        MinHeight="80">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- ORDER INFO -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <!-- Table number -->
                                            <TextBlock FontSize="17" FontWeight="Bold" 
                                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                                       Text="{Binding TableNumber, StringFormat='Table {0}'}"/>
                                            <!-- Section badge + time -->
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <!-- Section pill -->
                                                <Border Background="{DynamicResource FacilityAccentDimBrush}" 
                                                        CornerRadius="6" Padding="8,3" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Section}" 
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource FacilityAccentBrush}"/>
                                                </Border>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat=HH:mm}" 
                                                           FontSize="13" Foreground="{DynamicResource Brush.Text.Secondary}" 
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Total, StringFormat={}{0:C2}}" 
                                                           FontSize="14" FontWeight="Bold" 
                                                           Foreground="{DynamicResource FacilityAccentBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- PAY BUTTON â€” larger and more prominent -->
                                        <Button Grid.Column="2" 
                                                Style="{StaticResource Button.Primary}" 
                                                Command="{Binding DataContext.PayOrderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="28,0"
                                                Height="60"
                                                MinWidth="120"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                <Path Data="{StaticResource IconCheckCircle}" 
                                                      Fill="{DynamicResource Brush.Neutral.White}" 
                                                      Width="20" Height="20" Stretch="Uniform" 
                                                      HorizontalAlignment="Center"
                                                      Margin="0,0,0,4"/>
                                                <TextBlock Text="{DynamicResource Terminology.Restaurant.Action.PayBill}" 
                                                           Foreground="{DynamicResource Brush.Neutral.White}" 
                                                           FontWeight="Bold" FontSize="14"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            
            <!-- FOOTER INFO -->
            <TextBlock Grid.Row="4" Text="{DynamicResource Terminology.Restaurant.Order.SelectBillToPay}" 
                       FontSize="13" Foreground="{DynamicResource Brush.Text.Secondary}" 
                       HorizontalAlignment="Center" Margin="0"/>
        </Grid>
    </Border>
</UserControl>
