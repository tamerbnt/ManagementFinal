<Window x:Class="Management.Presentation.Views.Onboarding.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Management.Presentation.Views.Onboarding"
        xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Onboarding"
        xmlns:steps="clr-namespace:Management.Presentation.ViewModels.Onboarding.Steps"
        xmlns:stepViews="clr-namespace:Management.Presentation.Views.Onboarding.Steps"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{DynamicResource Strings.Onboarding.Onboarding}" Height="680" Width="980"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Window.Background}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                          GlassFrameThickness="-1"
                          CornerRadius="24"
                          ResizeBorderThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <!-- Wizard Visibility Switch Style -->
        <Style x:Key="WizardStageGrid" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <!-- Main Spatial Card -->
        <Border x:Name="MainSlab" 
                CornerRadius="24" 
                Background="#FFFFFF"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border Grid.Column="0" CornerRadius="24,0,0,24" ClipToBounds="True"
                        Background="{DynamicResource Brush.Sidebar.Background}">
                    <Grid>
                        <Ellipse Width="400" Height="400" Margin="-150,-100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.1" Fill="{DynamicResource Brush.Accent.Primary}"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path Data="M12,1L3,5v6c0,5.55,3.84,10.74,9,12c5.16-1.26,9-6.45,9-12V5L12,1L12,1z" Fill="White" Width="48" Height="48" Stretch="Uniform" Opacity="0.9" Margin="0,0,0,16"/>
                            <TextBlock Text="{DynamicResource Strings.Onboarding.GYM}" FontFamily="Segoe UI Variable Display" FontSize="24" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Opacity="0.95"/>
                            <TextBlock Text="{DynamicResource Strings.Onboarding.OS}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT CONTENT AREA -->
                <Grid Grid.Column="1" Margin="48">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header Space -->
                        <RowDefinition Height="*"/>    <!-- Content Space -->
                    </Grid.RowDefinitions>

                    <!-- Close Button Hardened -->
                    <Button x:Name="CloseButton" Click="CloseButton_Click" 
                            HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Background="Transparent" BorderThickness="0" 
                            Margin="0" Padding="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" Padding="8" Margin="0">
                                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41z" Fill="#9CA3AF" Width="12" Height="12" Stretch="Uniform"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Content Wizard -->
                    <Grid Grid.Row="1">
                        
                        <!-- STAGE A: LICENSE ACTIVATION -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource WizardStageGrid}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.LicenseActivation}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Strings.Onboarding.SystemActivation}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}" Margin="0,0,0,8"/>
                                <TextBlock Text="{DynamicResource Strings.Onboarding.Enteryourorganizationslic}" FontSize="16" Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap" Margin="0,0,0,40"/>

                                <TextBlock Text="{DynamicResource Strings.Onboarding.LICENSEKEY}" FontSize="11" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,0,0,4"/>
                                <TextBox Style="{DynamicResource Input.Field}" Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12" Margin="0,4,0,32" TextWrapping="Wrap"
                                           Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <TextBlock Text="{DynamicResource Strings.Onboarding.HARDWAREIDENTIFIER}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,4"/>
                                <Border Background="{DynamicResource Brush.Surface.Background}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,40">
                                    <Grid>
                                        <TextBlock Text="{Binding HardwareId}" FontFamily="Consolas" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Grid>
                                    <Button Content="{DynamicResource Strings.Onboarding.VerifyampContinue}" Command="{Binding VerifyLicenseCommand}" Height="54" FontSize="16" FontWeight="SemiBold" Foreground="White" Background="{DynamicResource Brush.Accent.Primary}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="12">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                 <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="BtnBorder" Property="Background" Value="#4A75A0"/></Trigger>
                                                                 <Trigger Property="IsEnabled" Value="False"><Setter TargetName="BtnBorder" Property="Opacity" Value="0.5"/></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <!-- Loading Spinner Overlay -->
                                    <ProgressBar IsIndeterminate="True" Height="4" VerticalAlignment="Bottom" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Background="Transparent" Foreground="White" BorderThickness="0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- STAGE B: OWNER REGISTRATION -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource WizardStageGrid}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.OwnerRegistration}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <!-- Use AdminRegistrationView UserControl -->
                            <ContentControl Content="{Binding AdminRegistrationViewModel}" 
                                          VerticalAlignment="Stretch"
                                          HorizontalAlignment="Stretch">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type steps:AdminRegistrationViewModel}">
                                        <stepViews:AdminRegistrationView />
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                        </Grid>
                        
                        <!-- STAGE C: BUSINESS PROFILE -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource WizardStageGrid}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.BusinessProfile}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <!-- Use BusinessInfoView -->
                             <ContentControl VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Content="{Binding BusinessInfoViewModel}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type steps:BusinessInfoViewModel}">
                                        <stepViews:BusinessInfoView />
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                            
                            <!-- Next Button for Business Step -->
                            <Button Content="{DynamicResource Strings.Onboarding.Continue}" Command="{Binding DataContext.NavigateToNextStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,0" Style="{StaticResource Button.Primary}" Width="150"/>
                        </Grid>

                        <!-- STAGE D: FACILITY CONFIG -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource WizardStageGrid}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.FacilityConfig}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <!-- Use FacilityConfigView -->
                             <ContentControl VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Content="{Binding FacilityConfigViewModel}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type steps:FacilityConfigViewModel}">
                                        <stepViews:FacilityConfigView />
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>

                             <!-- Next Button for Facility Step -->
                            <Button Content="{DynamicResource Strings.Onboarding.ReviewampFinish}" Command="{Binding DataContext.NavigateToNextStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,0" Style="{StaticResource Button.Primary}" Width="150"/>
                        </Grid>

                        <!-- STAGE E: FINISH -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource WizardStageGrid}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="{x:Static vm:OnboardingStep.Complete}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <ContentControl Content="{Binding FinishViewModel}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type steps:FinishViewModel}">
                                        <stepViews:FinishView />
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                        </Grid>
                        
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
