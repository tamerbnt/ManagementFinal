<UserControl x:Class="Management.Presentation.Views.Auth.SplashOnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:conv="clr-namespace:Management.Presentation.Converters"
             xmlns:auth="clr-namespace:Management.Presentation.ViewModels.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="980">

    <UserControl.Resources>
        <!-- The Floating Card Shadow -->
        <DropShadowEffect x:Key="HeavyFloatShadow" BlurRadius="60" Opacity="0.15" ShadowDepth="20" Direction="270" Color="Black"/>
    </UserControl.Resources>

    <!-- Master Clipping Grid to preserve rounded corners -->
    <Grid>
        <Grid.Clip>
            <RectangleGeometry RadiusX="24" RadiusY="24" Rect="0,0,980,720"/>
        </Grid.Clip>

        <!-- 1. BACKGROUND CROSSFADER LAYER (Liquid fast 0.35s snap morph) -->
        <ItemsControl ItemsSource="{Binding Slides}" IsHitTestVisible="False">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><Grid/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Panel.ZIndex" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Panel.ZIndex" Value="1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="BgSlide" Background="{Binding BackgroundColor}" Opacity="0" CornerRadius="24"/>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard><Storyboard Timeline.DesiredFrameRate="60">
                                    <DoubleAnimation Storyboard.TargetName="BgSlide" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6" FillBehavior="HoldEnd">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard></BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard><Storyboard Timeline.DesiredFrameRate="60">
                                    <DoubleAnimation Storyboard.TargetName="BgSlide" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:1.0" FillBehavior="HoldEnd">
                                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard></BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 2. FOREGROUND LAYOUT (40/60 Split) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Floating Action Card -->
            <Border Grid.Column="0" Width="380" VerticalAlignment="Center" HorizontalAlignment="Left"
                    Background="White" CornerRadius="24" Padding="32" Margin="60,0,0,0" Effect="{StaticResource HeavyFloatShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Select Discovery" FontSize="26" FontWeight="Black" Foreground="#0F172A" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="Choose your facility context." FontSize="14" Foreground="#64748B" Margin="0,0,0,24"/>

                    <!-- Facility Picker -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden" MaxHeight="240">
                        <ItemsControl ItemsSource="{Binding AvailableFacilities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectFacilityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,0,10" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RootItem" Background="#F8FAFC" CornerRadius="12" Padding="12" BorderThickness="1.5" BorderBrush="Transparent">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                                                            <Path Data="{Binding IconKey}" Fill="#64748B" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#64748B" Margin="0,1,0,0"/>
                                                        </StackPanel>

                                                        <Border x:Name="CheckCircle" Grid.Column="2" Width="20" Height="20" CornerRadius="10" BorderThickness="1.5" BorderBrush="#CBD5E1" Background="Transparent" VerticalAlignment="Center">
                                                            <Path x:Name="CheckIcon" Data="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41L9,16.17z" 
                                                                  Fill="White" Width="12" Height="12" Stretch="Uniform" Visibility="Collapsed"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="RootItem" Property="Background" Value="#F0F9FF"/>
                                                        <Setter TargetName="RootItem" Property="BorderBrush" Value="#0EA5E9"/>
                                                        <Setter TargetName="CheckCircle" Property="Background" Value="#0EA5E9"/>
                                                        <Setter TargetName="CheckCircle" Property="BorderBrush" Value="#0EA5E9"/>
                                                        <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                            <Condition Binding="{Binding IsSelected}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="RootItem" Property="BorderBrush" Value="#E2E8F0"/>
                                                    </MultiDataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="3" Command="{Binding EnterWorkspaceCommand}" Height="52" BorderThickness="0" Cursor="Hand" Margin="0,16,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="EnterBtn" Background="#0F172A" CornerRadius="16">
                                    <TextBlock Text="Enter Workspace" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False"><Setter TargetName="EnterBtn" Property="Opacity" Value="0.4"/></Trigger>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="EnterBtn" Property="Background" Value="#1E293B"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- RIGHT: Typography, Illustration, and Navigation -->
            <Grid Grid.Column="2" Margin="0,60,60,60">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: High-End Cinematic Typography Reveal -->
                <!-- Reduced to 48px, Switched to Staggered BlurEffect Entry -->
                <ItemsControl Grid.Row="0" ItemsSource="{Binding Slides}" Background="Transparent" BorderThickness="0" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Grid/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="MasterTextGrid" Opacity="0" Visibility="Hidden" HorizontalAlignment="Right" VerticalAlignment="Top" CacheMode="BitmapCache">
                                <StackPanel>
                                    <!-- Elevated Font to Georgia Italic Light -->
                                    <TextBlock x:Name="HeadlineText" Text="{Binding EmotionalHeadline}" Foreground="{Binding TitleColor}" FontFamily="Georgia, Playfair Display, Serif" FontStyle="Italic" FontWeight="Light" FontSize="48" LineHeight="52" TextWrapping="Wrap" Margin="0,0,0,12" HorizontalAlignment="Right" TextAlignment="Right" Opacity="0">
                                        <TextBlock.Effect><BlurEffect Radius="25" RenderingBias="Performance"/></TextBlock.Effect>
                                        <TextBlock.RenderTransform><TranslateTransform Y="40"/></TextBlock.RenderTransform>
                                    </TextBlock>
                                    <TextBlock x:Name="SubtitleText" Text="{Binding TechnicalSubtitle}" Foreground="{Binding SubtitleColor}" FontSize="16" FontWeight="Medium" LineHeight="24" MaxWidth="420" TextWrapping="Wrap" HorizontalAlignment="Right" TextAlignment="Right" Opacity="0">
                                        <TextBlock.Effect><BlurEffect Radius="25" RenderingBias="Performance"/></TextBlock.Effect>
                                        <TextBlock.RenderTransform><TranslateTransform Y="20"/></TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="MasterTextGrid" Property="Visibility" Value="Visible"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard><Storyboard Timeline.DesiredFrameRate="60">
                                            <!-- Sub-Second Tension: Fade Grid in -->
                                            <DoubleAnimation Storyboard.TargetName="MasterTextGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                                            
                                            <!-- Staggered Headline (Starts at 80ms) + Fluid QuarticEase -->
                                            <DoubleAnimation Storyboard.TargetName="HeadlineText" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="HeadlineText" Storyboard.TargetProperty="(UIElement.Effect).(BlurEffect.Radius)" From="25" To="0" Duration="0:0:0.4" BeginTime="0:0:0.08">
                                                <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="HeadlineText" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="40" To="0" Duration="0:0:0.4" BeginTime="0:0:0.08">
                                                <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Staggered Subtitle (Starts at 150ms) -->
                                            <DoubleAnimation Storyboard.TargetName="SubtitleText" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="SubtitleText" Storyboard.TargetProperty="(UIElement.Effect).(BlurEffect.Radius)" From="25" To="0" Duration="0:0:0.4" BeginTime="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="SubtitleText" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.4" BeginTime="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard></BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ROW 1: Centered Illustration with Masking & Fluid Gravity -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Slides}" Background="Transparent" BorderThickness="0" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Grid/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="ImgRoot" Opacity="0" Visibility="Hidden" CacheMode="BitmapCache">
                                <Grid.RenderTransform><TranslateTransform/></Grid.RenderTransform>
                                
                                <Image Source="{Binding ImagePath}" Stretch="Uniform" MaxWidth="380" MaxHeight="380" HorizontalAlignment="Right" VerticalAlignment="Center" x:Name="FloatingImage">
                                    <Image.RenderTransform><TranslateTransform/></Image.RenderTransform>
                                    
                                    <!-- Radial Mask absolutely neutralizes the hard colored box edge -->
                                    <Image.OpacityMask>
                                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                            <GradientStop Color="#FFFFFFFF" Offset="0.6"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                                        </RadialGradientBrush>
                                    </Image.OpacityMask>
                                </Image>
                            </Grid>
                            
                            <DataTemplate.Triggers>
                                <!-- 2026 Tensile Swipe Entry Snap -->
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="ImgRoot" Property="Visibility" Value="Visible"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard><Storyboard Timeline.DesiredFrameRate="60">
                                            <DoubleAnimation Storyboard.TargetName="ImgRoot" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                            <!-- Extreme fluid entry sliding tension -->
                                            <DoubleAnimation Storyboard.TargetName="ImgRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="60" To="0" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard></BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ROW 2: The Adaptive Bi-Directional Swipe Interactive Cue -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    
                    <!-- PREVIOUS Slide Button -->
                    <Button Command="{Binding PrevSlideCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,16,0" ToolTip="Previous Slide">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="Transparent" Padding="8">
                                    <Path x:Name="ChevLeft" Data="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" Fill="{Binding CurrentActionColor}" Width="16" Height="16" Stretch="Uniform" Opacity="0.5">
                                        <Path.RenderTransform><TranslateTransform/></Path.RenderTransform>
                                    </Path>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChevLeft" Property="Opacity" Value="1"/>
                                    </Trigger>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="ChevLeft" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="0" To="-4" Duration="0:0:0.8" AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- DYNAMIC Navigation Dots -->
                    <ItemsControl ItemsSource="{Binding Slides}" VerticalAlignment="Center" Margin="0,0,16,0">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="Dot" Width="6" Height="6" CornerRadius="3" Background="#94A3B8" Margin="0,0,12,0" CacheMode="BitmapCache"/>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="Dot" Property="Background" Value="{Binding TitleColor}"/> <!-- Active color logic retains absolute high contrast -->
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard><Storyboard Timeline.DesiredFrameRate="60"><DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="Width" To="24" Duration="0:0:0.3"/></Storyboard></BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- NEXT Slide Button -->
                    <Button Command="{Binding NextSlideCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Next Slide">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="Transparent" Padding="8">
                                    <Path x:Name="ChevRight" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="{Binding CurrentActionColor}" Width="16" Height="16" Stretch="Uniform" Opacity="0.5">
                                        <Path.RenderTransform><TranslateTransform/></Path.RenderTransform>
                                    </Path>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ChevRight" Property="Opacity" Value="1"/>
                                    </Trigger>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="ChevRight" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="0" To="4" Duration="0:0:0.8" AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
