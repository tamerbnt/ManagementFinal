<controls:ModernWindow x:Class="Management.Presentation.Views.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Management.Presentation.Views.Shell"
        xmlns:controls="clr-namespace:Management.Presentation.Resources.Controls"
        xmlns:components="clr-namespace:Management.Presentation.Components.Layout"
        xmlns:settings="clr-namespace:Management.Presentation.Views.Settings"
        xmlns:shared="clr-namespace:Management.Presentation.Views.Shared"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{DynamicResource Strings.Shell.GymOS}"
        MinWidth="1280" MinHeight="720"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FlowDirection="{DynamicResource GlobalFlowDirection}"
        Background="{DynamicResource Brush.Window.Background}">

    <Window.InputBindings>
        <KeyBinding Key="K" Modifiers="Ctrl" Command="{Binding ToggleCommandPaletteCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Sidebar Panel Animation Style -->
        <Style x:Key="SidebarPanelStyle" TargetType="Border">
            <Setter Property="Width" Value="260"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width" 
                                                  To="72" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width" 
                                                  To="260" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>


    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="80"
                          GlassFrameThickness="-1"
                          CornerRadius="16"
                          ResizeBorderThickness="6"
                          UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- Root: Gradient background to ground the atmospheric nebula -->
    <Grid x:Name="RootGrid" Background="{DynamicResource WindowBg}" Focusable="True">
        <Grid x:Name="MainLayoutGrid">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="32"/>
                    <Style.Triggers>
                        <!-- When maximized, we increase margin to 40px to offset the ~8px OS overflow -->
                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                            <Setter Property="Margin" Value="40"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="24"/> 
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border x:Name="SidebarPanel" Grid.Column="0" 
                    Style="{StaticResource SidebarPanelStyle}"
                    CornerRadius="16"
                    Background="{DynamicResource FacilitySidebarBrush}"
                    ClipToBounds="True"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Border.Effect>
                    <StaticResource ResourceKey="Shadow3"/>
                </Border.Effect>
                <local:SidebarView DataContext="{Binding}"/>
            </Border>
            
            <!-- RIGHT COLUMN: TopBar + Content -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/> <!-- Consistent Gap -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- TOPBAR PANEL (Elite Glass Style) -->
                <Border Grid.Row="0" CornerRadius="16" Background="{DynamicResource SurfaceBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0.8,0,0" ClipToBounds="False" MinHeight="80" VerticalAlignment="Stretch">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="8" Opacity="0.04" Color="Black"/>
                    </Border.Effect>
                    <local:TopBarView DataContext="{Binding TopBar}" VerticalAlignment="Stretch" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Border>
                
                <!-- CONTENT PANEL (Transparent Canvas) -->
                <Border Grid.Row="2" Background="Transparent">
                    <ContentControl Content="{Binding CurrentView}" Focusable="False"/>
                </Border>
            </Grid>
        </Grid>

        <!-- OVERLAYS (Spanning entire window inside RootGrid) -->


        <!-- Connectivity Banner (Global Offline Indicator) -->
        <shared:ConnectivityBanner 
            DataContext="{Binding Connectivity}"
            Panel.ZIndex="1050"/> 

        <ContentControl Content="{Binding Settings}"
                        Panel.ZIndex="1000" 
                        Focusable="False">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <!-- GLOBAL MODAL HOST (Titan Overlay System) -->
        <Grid Panel.ZIndex="1100">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModalOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Backdrop with Blur -->
            <Border Background="#4D0F172A">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>

            <!-- Modal Content Host -->
            <ContentControl Content="{Binding CurrentModalViewModel}" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"/>
        </Grid>

        <!-- Toast Notifications Overlay (Bottom-Right) -->
        <ItemsControl ItemsSource="{Binding ActiveToasts}"
                      VerticalAlignment="Bottom" 
                      HorizontalAlignment="Right"
                      Margin="0,0,24,24"
                      Panel.ZIndex="2000">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel VerticalAlignment="Bottom"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,12,0,0" 
                            MinWidth="300" 
                            Padding="20" 
                            CornerRadius="12"
                            Background="{DynamicResource Brush.Surface.Glass}"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CircleEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.RenderTransform>
                            <TranslateTransform Y="20"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.05" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Icon / Indicator -->
                            <Ellipse Width="8" Height="8" Margin="0,4,16,0" VerticalAlignment="Top">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource Brush.Accent.Primary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Success">
                                                <Setter Property="Fill" Value="#10B981"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Error">
                                                <Setter Property="Fill" Value="#EF4444"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Warning">
                                                <Setter Property="Fill" Value="#F59E0B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                <TextBlock Text="{Binding Message}" Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap" Foreground="{DynamicResource Brush.Text.Primary}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</controls:ModernWindow>
