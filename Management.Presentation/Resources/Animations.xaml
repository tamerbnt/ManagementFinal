<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- 1. PRIMARY EASING (Section 5.1)                               -->
    <!-- Apple's signature deceleration curve (Cubic EaseOut)          -->
    <!-- ============================================================= -->
    <CubicEase x:Key="EaseOutPrimary" EasingMode="EaseOut"/>

    <!-- ============================================================= -->
    <!-- 2. CORE DURATION TOKENS (Section 5.2)                         -->
    <!-- Defined exactly per Design System Spec                        -->
    <!-- ============================================================= -->

    <!-- Micro-interactions (Button press) -->
    <Duration x:Key="DurationMicro">0:0:0.120</Duration>

    <!-- Small transitions (Hover lift, Icons) -->
    <Duration x:Key="DurationSmall">0:0:0.180</Duration>

    <!-- Standard UI movement (Cards, Focus rings) -->
    <Duration x:Key="DurationStandard">0:0:0.220</Duration>

    <!-- Medium transitions (Slide-ins, Dropdowns) -->
    <Duration x:Key="DurationMedium">0:0:0.300</Duration>

    <!-- Screen/Page Transitions -->
    <Duration x:Key="DurationScreen">0:0:0.350</Duration>

    <!-- Modal/Dialog Entrances -->
    <Duration x:Key="DurationModal">0:0:0.400</Duration>

    <!-- Live Indicator Pulse -->
    <Duration x:Key="DurationPulse">0:0:0.600</Duration>

    <!-- Loading Spinner / Long Loops (Exempt from Reduced Motion) -->
    <Duration x:Key="DurationSpinner">0:0:1.200</Duration>

    <!-- ============================================================= -->
    <!-- 3. COMPATIBILITY BRIDGE (Aliases for View Compatibility)      -->
    <!-- These keys are referenced by specific generated Views.        -->
    <!-- ============================================================= -->

    <!-- Mapped to DurationSmall (Used by RealTimeFeedView for List Items) -->
    <Duration x:Key="DurationFast">0:0:0.180</Duration>

    <!-- Mapped to DurationScreen (Used by MainWindow/Shell) -->
    <Duration x:Key="DurationScreenTransition">0:0:0.350</Duration>

    <!-- ============================================================= -->
    <!-- 4. GLOBAL STORYBOARDS (Shared Logic)                          -->
    <!-- ============================================================= -->

    <!-- 
        Skeleton Loading Pulse 
        Used by: OccupancyChartSection.xaml
        Behavior: Infinite oscillation of Opacity for "Shimmer" effect
    -->
    <Storyboard x:Key="SkeletonPulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0.4" To="0.8" 
                         Duration="0:0:1"/>
    </Storyboard>

</ResourceDictionary>