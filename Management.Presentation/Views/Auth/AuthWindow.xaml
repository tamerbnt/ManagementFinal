<Window x:Class="Management.Presentation.Views.Auth.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:auth="clr-namespace:Management.Presentation.Views.Auth"
        xmlns:viewmodels="clr-namespace:Management.Presentation.ViewModels"
        xmlns:sharedVm="clr-namespace:Management.Presentation.ViewModels.Shared"
        xmlns:sharedView="clr-namespace:Management.Presentation.Views.Shared"
        xmlns:reg="clr-namespace:Management.Presentation.Views.Registrations"
        mc:Ignorable="d"
        Title="{DynamicResource Strings.Auth.LuxuryaActivation}"
        Height="720" Width="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="OnMouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- View routing DataTemplates -->
            <DataTemplate DataType="{x:Type viewmodels:LicenseEntryViewModel}">
                <auth:LicenseEntryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:OnboardingOwnerViewModel}">
                <auth:OnboardingOwnerView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
                <auth:LoginView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:FacilityOnboardingViewModel}">
                <auth:FacilityOnboardingView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:EmailConfirmationViewModel}">
                <auth:EmailConfirmationView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type sharedVm:ConfirmationModalViewModel}">
                <sharedView:ConfirmationModal/>
            </DataTemplate>


            <Style x:Key="GlobalModalContainerStyle" TargetType="Border">
                <Setter Property="Background" Value="#F0FFFFFF"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="24"/>
                <Setter Property="Padding" Value="32"/>
                <Setter Property="Effect">
                    <Setter.Value><StaticResource ResourceKey="Shadow4"/></Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="Title2" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
            </Style>
            <Style x:Key="Body" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
            </Style>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            GlassFrameThickness="-1"
                            CornerRadius="24"
                            ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <!-- ROOT BORDER: clips everything into rounded corners.
         #CCE3F0 is the specific light blue color from the illustration background. -->
    <Border CornerRadius="24" ClipToBounds="True" Background="#CCE3F0">

        <Grid MouseDown="OnMouseLeftButtonDown">

            <!-- ══════════════════════════════════════════════════════
                 LAYER 1 — ILLUSTRATION BACKGROUND
                 OpacityMask creates a "feathered" edge effect so the 
                 image blends seamlessly into the blue background.
                 ══════════════════════════════════════════════════════ -->
            <Image Source="pack://application:,,,/Luxurya.Client;component/Resources/Images/login_illustration.png"
                   Stretch="Uniform"
                   Height="520"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,30,30,0"
                   IsHitTestVisible="False">
                <Image.OpacityMask>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.45" RadiusY="0.45">
                        <GradientStop Color="#FF000000" Offset="0.5"/>
                        <GradientStop Color="#00000000" Offset="1.0"/>
                    </RadialGradientBrush>
                </Image.OpacityMask>
            </Image>

            <!-- ══════════════════════════════════════════════════════
                 LAYER 2 — FLOATING INFO CARDS (right side)
                 ══════════════════════════════════════════════════════ -->

            <!-- Ahmed S. / Active (Moved further left to clear head, and made smaller) -->
            <Border x:Name="CardAhmed"
                    Background="White" CornerRadius="12" Padding="10,8"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,175,300,0"
                    Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="12"/></Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.10" Direction="270" Color="#000000"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard BeginTime="0:0:0.3">
                                <DoubleAnimation Storyboard.TargetName="CardAhmed" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CardAhmed" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="12" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <StackPanel Orientation="Horizontal">
                    <Border Width="30" Height="30" CornerRadius="6" Background="#0EA5E9" Margin="0,0,8,0">
                        <TextBlock Text="AS" FontSize="11" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Ahmed S." FontSize="12" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,1"/>
                        <TextBlock Text="Active" FontSize="10" FontWeight="Medium" Foreground="#10B981"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Revenue Today (Smaller) -->
            <Border x:Name="CardRevenue"
                    Background="White" CornerRadius="12" Padding="12,10"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,40,75,0"
                    Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="12"/></Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.10" Direction="270" Color="#000000"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard BeginTime="0:0:0.5">
                                <DoubleAnimation Storyboard.TargetName="CardRevenue" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CardRevenue" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="12" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <StackPanel>
                    <TextBlock Text="Revenue Today" FontSize="10" Foreground="#9CA3AF" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="4,820 DA" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                        <Path Data="M7,14L12,9L17,14H7Z" Fill="#10B981"
                              Width="10" Height="10" Stretch="Uniform"
                              Margin="6,0,0,1" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Karim M. / Checked In (Smaller) -->
            <Border x:Name="CardKarim"
                    Background="White" CornerRadius="12" Padding="10,8"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,320,120"
                    Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="12"/></Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.10" Direction="270" Color="#000000"/>
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard BeginTime="0:0:0.7">
                                <DoubleAnimation Storyboard.TargetName="CardKarim" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CardKarim" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="12" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <StackPanel Orientation="Horizontal">
                    <Border Width="30" Height="30" CornerRadius="6" Background="#6366F1" Margin="0,0,8,0">
                        <TextBlock Text="KM" FontSize="11" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Karim M." FontSize="12" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,1"/>
                        <TextBlock Text="Checked In" FontSize="10" FontWeight="Medium" Foreground="#0EA5E9"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 LAYER 3 — FLOATING WHITE FORM CARD (LEFT)
                 ══════════════════════════════════════════════════════ -->
            <Border x:Name="CardBorder"
                    Width="450"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Background="{StaticResource SurfaceBg}"
                    CornerRadius="20"
                    Margin="50,50,0,50">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="60" ShadowDepth="10" Opacity="0.13"
                                      Direction="270" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <!-- Fallback skeleton: visible ONLY when CurrentView is null -->
                    <auth:LoginSkeletonView Visibility="{Binding CurrentView, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    
                    <!-- Main content: fades in/out as views change -->
                    <ContentControl Content="{Binding CurrentView}"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 LAYER 4 — MODAL OVERLAY
                 ══════════════════════════════════════════════════════ -->
            <Grid Visibility="{Binding IsModalOpen, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                  Panel.ZIndex="1000">
                <Border Background="#66000000" MouseDown="OnMouseLeftButtonDown"/>
                <ContentControl Content="{Binding CurrentModal}"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ContentControl.Resources>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentModal}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 LAYER 5 — MINIMIZE + CLOSE BUTTONS (top-right)
                 ══════════════════════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,16,20,0"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Panel.ZIndex="2000">

                <Button Click="MinimizeButton_Click" Margin="0,0,8,0"
                        Width="30" Height="30"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="15">
                                <Path x:Name="icon" Data="M19,13H5V11H19V13Z" Fill="#374151"
                                      Stretch="Uniform" Width="12" Height="2"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#18000000"/>
                                    <Setter TargetName="icon" Property="Fill" Value="#111827"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Click="CloseButton_Click"
                        Width="30" Height="30"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="15">
                                <Path x:Name="icon"
                                      Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                      Fill="#374151" Stretch="Uniform" Width="12" Height="12"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#18EF4444"/>
                                    <Setter TargetName="icon" Property="Fill" Value="#EF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>

            <!-- Toast notifications -->
            <StackPanel x:Name="ToastContainer" VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="0,24,24,0" Panel.ZIndex="3000"/>

        </Grid>
    </Border>

</Window>
