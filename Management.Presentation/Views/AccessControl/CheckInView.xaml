<UserControl x:Class="Management.Presentation.Views.AccessControl.CheckInView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:CheckInViewModel}"
             Width="400">
    
    <Border Background="{DynamicResource Neutral50Brush}" 
            CornerRadius="12" 
            Padding="24"
            BorderBrush="{DynamicResource Neutral200Brush}"
            BorderThickness="1">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="{DynamicResource TerminologyQuickCheckInLabel}" 
                       Style="{DynamicResource HeadlineSmallStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            
            <TextBlock Text="{DynamicResource TerminologyScanOrEnterIdLabel}"
                       Style="{DynamicResource BodyMediumStyle}"
                       Foreground="{DynamicResource Neutral600Brush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Input Area -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{DynamicResource TerminologyCardIdLabel}" Style="{DynamicResource LabelMediumStyle}" Margin="0,0,0,8"/>
                <TextBox Text="{Binding CardId, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource ModernTextBoxStyle}"
                         Padding="12"
                         FontSize="18"
                         HorizontalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding CheckInCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
            </StackPanel>

            <!-- Status Indicator -->
            <Border Height="60" 
                    CornerRadius="8"
                    Padding="12"
                    Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"
                    Margin="0,0,0,20">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource Neutral100Brush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource StatusSuccessBgBrush}"/> <!-- Success Green Surface -->
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                <Setter Property="Background" Value="{DynamicResource StatusErrorBgBrush}"/> <!-- Error Red Surface -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           FontWeight="Medium">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyMediumStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource StatusSuccessBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource StatusErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- Actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Content="{DynamicResource TerminologyCancelLabel}" 
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource GhostButtonStyle}"
                        Margin="0,0,8,0"/>
                
                <Button Grid.Column="1" 
                        Content="{DynamicResource TerminologyCheckInLabel}" 
                        Command="{Binding CheckInCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
