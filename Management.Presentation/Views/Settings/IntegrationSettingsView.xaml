<UserControl x:Class="Management.Presentation.Views.Settings.IntegrationSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToConnectionTextConverter x:Key="BoolToConnectionTextConverter"/>
        <!-- Assumed Global: BoolToStatusBrushConverter (True=Success, False=Separator/Gray) -->
        <converters:BoolToStatusBrushConverter x:Key="BoolToStatusBrushConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="{StaticResource PaddingCard}">

            <!-- Header Description -->
            <TextBlock Text="{DynamicResource TerminologyManageIntegrationsLabel}" 
                       Style="{StaticResource BodySecondary}" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="{StaticResource MarginSectionBottom}"/>

            <!-- Integration List -->
            <ItemsControl ItemsSource="{Binding Integrations}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Integration Card -->
                        <Border Height="{StaticResource SizeIntegrationCardHeight}"
                                Background="{DynamicResource SurfaceBg}"
                                BorderBrush="{DynamicResource SeparatorBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusCardStandard}"
                                Padding="{StaticResource PaddingCardList}"
                                Margin="{StaticResource MarginCardGap}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Logo -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- Info -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Status & Action -->
                                </Grid.ColumnDefinitions>

                                <!-- 1. Logo Area -->
                                <Border Grid.Column="0"
                                        Width="{StaticResource SizeIconContainer}"
                                        Height="{StaticResource SizeIconContainer}"
                                        CornerRadius="{StaticResource RadiusSmall}"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        Margin="{StaticResource MarginCardRight}">
                                    <ContentPresenter Content="{Binding IconKey, Converter={StaticResource ResourceKeyToIconConverter}}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Width="{StaticResource SizeIconStandard}" 
                                                      Height="{StaticResource SizeIconStandard}"/>
                                </Border>

                                <!-- 2. Text Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" 
                                               Style="{StaticResource BodyMedium}" 
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                    <TextBlock Text="{Binding Description}" 
                                               Style="{StaticResource Caption}" 
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- 3. Status & Action -->
                                <StackPanel Grid.Column="2" 
                                            Orientation="Horizontal" 
                                            VerticalAlignment="Center">

                                    <!-- Status Badge -->
                                    <!-- Background logic delegated to Converter for cleaner XAML -->
                                    <Border Style="{StaticResource StatusBadgeStyle}"
                                            Background="{Binding IsConnected, Converter={StaticResource BoolToStatusBrushConverter}}"
                                            Margin="{StaticResource MarginMediumRight}">

                                        <StackPanel Orientation="Horizontal">
                                            <!-- Checkmark -->
                                            <Path Data="{StaticResource IconCheck}" 
                                                  Fill="#FFFFFF" 
                                                  Style="{StaticResource IconMicro}"
                                                  Margin="{StaticResource MarginSmallRight}"
                                                  Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                            <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToConnectionTextConverter}}"
                                                       Style="{StaticResource Micro}" 
                                                       Foreground="{DynamicResource TextOnDarkBrush}" 
                                                       FontWeight="Bold"/>
                                                       
                                        </StackPanel>
                                    </Border>

                                    <!-- Configure Button -->
                                    <Button Content="{DynamicResource TerminologyConfigureLabel}"
                                            Command="{Binding ConfigureCommand}"
                                            Style="{StaticResource ButtonCompactSecondary}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>