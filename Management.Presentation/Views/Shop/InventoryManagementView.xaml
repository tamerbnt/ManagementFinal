<UserControl x:Class="Management.Presentation.Views.Shop.InventoryManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StockToBrushConverter x:Key="StockToBrushConverter"/>
        <converters:IntToVisibilityConverter x:Key="ZeroIsVisibleConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Low Stock Alert -->
            <RowDefinition Height="Auto"/>
            <!-- Table Header -->
            <RowDefinition Height="*"/>
            <!-- Table Content -->
        </Grid.RowDefinitions>

        <!-- 1. LOW STOCK ALERT BANNER (Section 30.4) -->
        <!-- Visible only if HasLowStock is true -->
        <Grid Grid.Row="0" 
              Visibility="{Binding HasLowStock, Converter={StaticResource BoolToVisibilityConverter}}"
              Margin="{StaticResource MarginSectionBottom}">

            <!-- Background Layer (10% Opacity Warning) -->
            <Border Background="{DynamicResource StatusWarningBrush}" 
                    CornerRadius="{StaticResource RadiusCardStandard}" 
                    Opacity="0.1"
                    Height="{StaticResource SizeSidebarItemHeight}"/>

            <!-- Content Layer -->
            <StackPanel Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        Margin="{StaticResource PaddingCard}">
                <Path Data="{StaticResource IconAlert}" 
                      Fill="{DynamicResource StatusWarningBrush}" 
                      Style="{StaticResource IconStandard}"
                      Margin="{StaticResource MarginIconRight}"/>

                <TextBlock Text="{Binding LowStockCount, StringFormat={DynamicResource TerminologyLowStockCountFormat}}" 
                           Style="{StaticResource BodyMedium}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>

                <!-- Action Link -->
                <Button Content="{DynamicResource TerminologyViewDetailsLabel}" 
                        Command="{Binding FilterLowStockCommand}"
                        Style="{StaticResource SecondaryButton}"
                        BorderThickness="0"
                        Foreground="{DynamicResource StatusWarningBrush}"
                        Margin="{StaticResource MarginMediumLeft}"
                        Height="Auto" Padding="0"/>
            </StackPanel>
        </Grid>

        <!-- 2. TABLE HEADER (Section 20.1) -->
        <Border Grid.Row="1" 
                Height="{StaticResource SizeTableHeaderHeight}"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,1,0,1">
            <Grid Margin="{StaticResource PaddingCardList}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Product -->
                    <ColumnDefinition Width="120"/>
                    <!-- SKU -->
                    <ColumnDefinition Width="100"/>
                    <!-- Stock -->
                    <ColumnDefinition Width="100"/>
                    <!-- Reorder -->
                    <ColumnDefinition Width="140"/>
                    <!-- Updated -->
                    <ColumnDefinition Width="100"/>
                    <!-- Actions -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource TerminologyTableHeaderProduct}" Style="{StaticResource Caption}" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="{DynamicResource TerminologyTableHeaderSKU}" Style="{StaticResource Caption}" FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="{DynamicResource TerminologyTableHeaderStock}" Style="{StaticResource Caption}" FontWeight="Bold"/>
                <TextBlock Grid.Column="3" Text="{DynamicResource TerminologyTableHeaderReorder}" Style="{StaticResource Caption}" FontWeight="Bold"/>
                <TextBlock Grid.Column="4" Text="{DynamicResource TerminologyTableHeaderUpdated}" Style="{StaticResource Caption}" FontWeight="Bold"/>
                <TextBlock Grid.Column="5" Text="{DynamicResource TerminologyTableHeaderActions}" Style="{StaticResource Caption}" FontWeight="Bold" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- 3. INVENTORY LIST (Virtualization Enabled) -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding InventoryItems}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRingStyle}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{StaticResource SeparatorBrush}"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                        <!-- Note: Subtle hover tint defined in SidebarHoverBrush usually suffices for rows -->
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Height="{StaticResource SizeTableRowHeight}" Margin="{StaticResource PaddingCardList}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <!-- Product -->
                            <ColumnDefinition Width="120"/>
                            <!-- SKU -->
                            <ColumnDefinition Width="100"/>
                            <!-- Stock -->
                            <ColumnDefinition Width="100"/>
                            <!-- Reorder -->
                            <ColumnDefinition Width="140"/>
                            <!-- Updated -->
                            <ColumnDefinition Width="100"/>
                            <!-- Actions -->
                        </Grid.ColumnDefinitions>

                        <!-- Product: Image + Name -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="{StaticResource SizeAvatarSmall}" 
                                     Height="{StaticResource SizeAvatarSmall}"
                                     Margin="{StaticResource MarginCardRight}">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{DynamicResource AccentLightColor}"/>
                                </Ellipse.Fill>
                                <!-- Image Binding: <ImageBrush ImageSource="{Binding ImageUrl}"/> -->
                            </Ellipse>
                            <TextBlock Text="{Binding Name}" 
                                       Style="{StaticResource BodyMedium}" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- SKU -->
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding SKU}" 
                                   Style="{StaticResource Caption}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <!-- Stock Level (Semantic Color) -->
                        <TextBlock Grid.Column="2" 
                                   Text="{Binding StockCount}" 
                                   Style="{StaticResource BodyMedium}" 
                                   Foreground="{Binding StockLevel, Converter={StaticResource StockToBrushConverter}}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <!-- Reorder Level -->
                        <TextBlock Grid.Column="3" 
                                   Text="{Binding ReorderLevel}" 
                                   Style="{StaticResource Body}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Padding="16,0,0,0"/>

                        <!-- Last Updated -->
                        <TextBlock Grid.Column="4" 
                                   Text="{Binding LastUpdated, Converter={StaticResource RelativeTimeConverter}}" 
                                   Style="{StaticResource Caption}" 
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>

                        <!-- Actions -->
                        <Button Grid.Column="5"
                                Content="{DynamicResource TerminologyEditLabel}"
                                Command="{Binding EditCommand}"
                                Style="{StaticResource ButtonCompactSecondary}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 4. EMPTY STATE -->
        <Grid Grid.Row="2" 
              Visibility="{Binding InventoryItems.Count, Converter={StaticResource ZeroIsVisibleConverter}}"
              IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,64">
                <Path Data="{StaticResource IconBox}"
                      Fill="{StaticResource IllustrationBackgroundBrush}"
                      Width="256" Height="256"
                      Stretch="Uniform"
                      Margin="{StaticResource MarginSectionBottom}"
                      HorizontalAlignment="Center"/>

                <TextBlock Text="{DynamicResource TerminologyInventoryEmptyTitle}" 
                           Style="{StaticResource Title2}" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center"
                           Margin="{StaticResource MarginTextBottom}"/>

                <TextBlock Text="{DynamicResource TerminologyInventoryEmptySubtitle}" 
                           Style="{StaticResource Body}" 
                           Foreground="{DynamicResource TextTertiaryBrush}" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>