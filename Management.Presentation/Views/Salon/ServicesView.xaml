<UserControl x:Class="Management.Presentation.Views.Salon.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <x:Array x:Key="ShimmerItems" Type="sys:Int32">
            <sys:Int32>1</sys:Int32><sys:Int32>2</sys:Int32><sys:Int32>3</sys:Int32>
            <sys:Int32>4</sys:Int32><sys:Int32>5</sys:Int32><sys:Int32>6</sys:Int32>
        </x:Array>

        <Style x:Key="ShimmerRow" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="0.7" Duration="0:0:1" AutoReverse="True"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,24">
            <Path Data="{StaticResource IconSliders}" 
                  Style="{StaticResource Style.Icon.Large}" 
                  Stroke="{DynamicResource TextPrimaryBrush}"
                  Margin="0,0,12,0"/>
            <TextBlock Text="{DynamicResource Terminology.Salon.Services.Title}" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Services}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  RowHeight="72"
                  Style="{StaticResource PremiumDataGrid}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{DynamicResource Terminology.Salon.Services.Service}" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" Margin="16,0">
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Category}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="{DynamicResource Terminology.Salon.Services.Price}" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center">
                                <TextBox Text="{Binding BasePrice, StringFormat=C, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource InlineTextBox}"/>
                                <!-- Live Saved Heartbeat -->
                                <TextBlock Text="{DynamicResource Terminology.Salon.Services.Saved}" Foreground="{DynamicResource StatusSuccessBrush}" FontSize="10" 
                                           HorizontalAlignment="Right" VerticalAlignment="Top"
                                           Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}"
                                           Margin="0,-12,12,0">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="{DynamicResource Terminology.Salon.Services.Duration}" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource InlineTextBox}" Width="60"/>
                                <TextBlock Text="{DynamicResource Terminology.Salon.Services.Minutes}" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="HoverOverlay" Background="{DynamicResource OverlayBackdrop}" Opacity="0" CornerRadius="8" Margin="4">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Command="{Binding EditCommand}" Style="{StaticResource GhostButton}" Padding="8,4">
                                        <Path Data="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z" Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2" Width="16" Height="16"/>
                                    </Button>
                                    <Button Command="{Binding DeleteCommand}" Style="{StaticResource GhostButton}" Padding="8,4" Margin="4,0,0,0">
                                        <Path Data="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M10 11v6M14 11v6" Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="2" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                    <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Loading Overlay -->
        <Grid Grid.Row="1" Background="{DynamicResource WindowBg}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{StaticResource ShimmerItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ShimmerRow}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
