<UserControl x:Class="Management.Presentation.Views.Shell.FacilityAuthModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Shell"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:FacilityAuthViewModel}"
             Background="Transparent">

    <Border Style="{DynamicResource GlobalModalContainerStyle}" 
            CornerRadius="{DynamicResource RadiusModal}"
            Padding="32"
            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
            <!-- Header -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                <Border Width="72" Height="72" CornerRadius="36" Margin="0,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#3B82F6" BlurRadius="40" ShadowDepth="0" Opacity="0.25"/>
                    </Border.Effect>
                    <Path Data="{StaticResource Icon.Shield}" 
                          Fill="White" 
                          Width="32" Height="32" 
                          Stretch="Uniform" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource Strings.Shell.AuthorizeAccess}" Style="{DynamicResource Title1}" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Strings.Shell.Elevatedpermissionsrequir}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="{DynamicResource Strings.Auth.EMAILADDRESS}" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{DynamicResource Input.Apple}" 
                         Tag="{DynamicResource Strings.Shell.stafftitancom}"
                         Margin="0,0,0,24"/>

                <TextBlock Text="{DynamicResource Strings.Auth.PASSWORD}" Style="{DynamicResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                <PasswordBox x:Name="PassBox" 
                            Style="{DynamicResource Input.Apple.Password}" 
                            Margin="0,0,0,8">
                </PasswordBox>
                
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#EF4444" 
                           FontSize="12" 
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" 
                        Command="{Binding CancelCommand}" 
                        Style="{DynamicResource GhostButton}" 
                        Content="{DynamicResource Strings.Shell.Back}"
                        Height="48"/>
                        
                <Button Grid.Column="2" 
                        Command="{Binding SubmitCommand}" 
                        Style="{DynamicResource PrimaryButton}" 
                        Content="{DynamicResource Strings.Shell.ConfirmSwitch}"
                        IsDefault="True"
                        Height="48"
                        FontWeight="Bold">
                    <Button.Effect>
                        <DropShadowEffect Color="#3B82F6" BlurRadius="20" ShadowDepth="2" Opacity="0.2"/>
                    </Button.Effect>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
