<UserControl x:Class="Management.Presentation.Views.Scheduler.BookAppointmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <UserControl.Resources>
    </UserControl.Resources>

    <!-- Glass Background -->
    <Border Background="{DynamicResource Brush.Surface.Glass}" 
            CornerRadius="16" 
            Padding="40"
            MaxWidth="600"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="20" Direction="270" Opacity="0.2" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                <TextBlock Text="{DynamicResource Terminology.Scheduler.BookAppointment}" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource Brush.Text.Primary}"/>
                <TextBlock Text="{DynamicResource Terminology.Scheduler.Subtitle}" 
                           FontSize="14" 
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Service Selection Cards -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Terminology.Scheduler.Section.SelectService}" 
                               FontWeight="SemiBold" 
                               FontSize="16"
                               Margin="0,0,0,16"/>
                    
                    <ListBox ItemsSource="{Binding AvailableServices}" 
                             SelectedItem="{Binding SelectedService}"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource Card.Selectable}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" 
                                        Padding="20" 
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Grid.Column="0" 
                                                Width="48" 
                                                Height="48" 
                                                Background="{DynamicResource Brush.Brand.Primary}"
                                                CornerRadius="24"
                                                Margin="0,0,16,0">
                                            <TextBlock Text="âœ‚" 
                                                       FontSize="24" 
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Service Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="16"/>
                                            <TextBlock Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       Margin="0,4,0,0">
                                                <Run Text="{Binding DurationMinutes}"/>
                                                <Run Text=" "/>
                                                <Run Text="{DynamicResource Terminology.Scheduler.Duration.Suffix}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Price -->
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding BasePrice, StringFormat='{}{0:N2} DA'}" 
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource Brush.Brand.Primary}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Time Slot Selection (Shown after service selection) -->
                    <StackPanel Visibility="{Binding SelectedService, Converter={StaticResource NullToVisibilityConverter}}"
                                Margin="0,30,0,0">
                        <TextBlock Text="{DynamicResource Terminology.Scheduler.Section.AvailableSlots}" 
                                   FontWeight="SemiBold" 
                                   FontSize="16"
                                   Margin="0,0,0,16"/>
                        
                        <ItemsControl ItemsSource="{Binding FilteredTimeSlots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding StringFormat='{}{0:HH:mm}'}" 
                                            Command="{Binding DataContext.SelectTimeSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource Button.Primary}"
                                            Width="100"
                                            Margin="4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Actions -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,30,0,0">
                <Button Content="{DynamicResource Terminology.Global.Cancel}" 
                        Command="{Binding CancelCommand}"
                        Width="120"
                        Height="48"
                        Margin="0,0,12,0"
                        Background="Transparent"
                        Foreground="{DynamicResource Brush.Text.Primary}"/>
                <Button Content="{DynamicResource Terminology.Scheduler.BookAppointment}" 
                        Command="{Binding ConfirmCommand}"
                        Style="{StaticResource Button.Primary}"
                        Width="180"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
