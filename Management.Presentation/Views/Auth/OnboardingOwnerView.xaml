<UserControl x:Class="Management.Presentation.Views.Auth.OnboardingOwnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="460"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <Style x:Key="OnboardingInputBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Height" Value="48"/>
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="{DynamicResource FacilityAccentColor}" 
                                                  BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel VerticalAlignment="Top" Margin="40,32,40,40">

            <!-- ROW 1 — TITAN BRAND -->
            <Grid Margin="0,8,0,8">
                <Image Source="/Assets/luxurya_header_logo.png"
                       Height="64"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Stretch="Uniform"
                       ToolTip="Luxurya Management System"/>
            </Grid>

            <!-- ROW 2 — "Account Setup" H1 TITLE -->
            <TextBlock Text="{DynamicResource Strings.Auth.AccountSetup}"
                       FontSize="32" FontWeight="ExtraBold"
                       Foreground="#0F172A"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap"
                       FontFamily="Segoe UI Variable Display, Segoe UI"/>

            <!-- ROW 3 — SUBTITLE -->
            <TextBlock Text="Finalize your workstation account to begin managing your facility."
                       FontSize="13" Foreground="#6B7280"
                       TextWrapping="Wrap" LineHeight="20"
                       Margin="0,0,0,32"
                       FontFamily="Segoe UI Variable Display, Segoe UI"/>

            <!-- FIELD 1: Business Name -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Strings.Auth.BUSINESSNAME}"
                           FontSize="12" FontWeight="Medium"
                           Foreground="#374151" Margin="0,0,0,4"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>
                <Border Style="{StaticResource OnboardingInputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Briefcase Icon -->
                        <Path Grid.Column="0"
                              Data="M16 6V4H8V6M7 6H5C3.89 6 3 6.89 3 8V19C3 20.11 3.89 21 5 21H19C20.11 21 21 20.11 21 19V8C21 6.89 20.11 6 19 6H17M10 4C10 3.45 10.45 3 11 3H13C13.55 3 14 3.45 14 4V6H10V4Z"
                              Fill="#D1D5DB" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- Text Input -->
                        <TextBox Grid.Column="1" Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#111827" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,12,0" CaretBrush="#0EA5E9" FontFamily="Segoe UI Variable Display, Segoe UI" Tag="e.g. Elite Fitness Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- FIELD 2: Admin Full Name -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Strings.Auth.ADMINFULLNAME}"
                           FontSize="12" FontWeight="Medium"
                           Foreground="#374151" Margin="0,0,0,4"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>
                <Border Style="{StaticResource OnboardingInputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Person Icon -->
                        <Path Grid.Column="0"
                              Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                              Fill="#D1D5DB" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding AdminFullName, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#111827" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,12,0" CaretBrush="#0EA5E9" FontFamily="Segoe UI Variable Display, Segoe UI" Tag="e.g. John Doe"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- FIELD 3: Admin Email -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Strings.Auth.ADMINEMAIL}"
                           FontSize="12" FontWeight="Medium"
                           Foreground="#374151" Margin="0,0,0,4"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>
                <Border Style="{StaticResource OnboardingInputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Envelope Icon -->
                        <Path Grid.Column="0"
                              Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"
                              Fill="#D1D5DB" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding AdminEmail, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#111827" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,12,0" CaretBrush="#0EA5E9" FontFamily="Segoe UI Variable Display, Segoe UI" Tag="admin@luxurya.com"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- FIELD 4: Secure Password -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="{DynamicResource Strings.Auth.SECUREPASSWORD}"
                           FontSize="12" FontWeight="Medium"
                           Foreground="#374151" Margin="0,0,0,4"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>
                <Border Style="{StaticResource OnboardingInputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <!-- Lock Icon -->
                        <Path Grid.Column="0"
                              Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.11,13 12,13A2,2 0 0,0 10,15C10,16.11 10.89,17 12,17M18,8H17V6A5,5 0 0,0 12,1A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M9,6A3,3 0 0,1 12,3A3,3 0 0,1 15,6V8H9V6Z"
                              Fill="#D1D5DB" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Grid Grid.Column="1">
                            <PasswordBox x:Name="OnboardingPasswordBox"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#111827" FontSize="14" VerticalContentAlignment="Center"
                                         CaretBrush="#0EA5E9" FontFamily="Segoe UI Variable Display, Segoe UI"
                                         Tag="Enter a secure password" PasswordChanged="PasswordBox_PasswordChanged"/>
                            <TextBox x:Name="OnboardingPasswordTextBox"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#111827" FontSize="14" VerticalContentAlignment="Center"
                                     CaretBrush="#0EA5E9" FontFamily="Segoe UI Variable Display, Segoe UI"
                                     Tag="Enter a secure password" Visibility="Collapsed" TextChanged="OnboardingPasswordTextBox_TextChanged"/>
                        </Grid>

                        <!-- Eye Toggle Button -->
                        <Button Grid.Column="2" Click="TogglePasswordVisibility_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center" Width="32" Height="32" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid Width="18" Height="18">
                                <Path x:Name="OnboardingEyeOpenIcon" Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Fill="#D1D5DB" Stretch="Uniform"/>
                                <Path x:Name="OnboardingEyeClosedIcon" Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.22 16.38,18.7L16.81,19.13L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.76 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z" Fill="#D1D5DB" Stretch="Uniform" Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ACTION BUTTON + "POWERED BY" -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding CompleteOnboardingCommand}" Width="162" Height="46" IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="#E5E7EB" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform><ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="btnText" Text="{DynamicResource Strings.Auth.CompleteRegistration}" FontSize="14" FontWeight="SemiBold" Foreground="#9CA3AF" FontFamily="Segoe UI Variable Display, Segoe UI"/>
                                    <Path x:Name="btnChevron" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="#9CA3AF" Width="10" Height="10" Stretch="Uniform" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="busyBar" IsIndeterminate="True" Width="50" Height="3" Background="Transparent" Foreground="White" BorderThickness="0" Visibility="Collapsed" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                    <Setter TargetName="btnText" Property="Foreground" Value="White"/>
                                    <Setter TargetName="btnChevron" Property="Fill" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                    <Setter TargetName="btnText" Property="Foreground" Value="#9CA3AF"/>
                                    <Setter TargetName="btnChevron" Property="Fill" Value="#9CA3AF"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.05"/>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleY" To="0.97" Duration="0:0:0.05"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter TargetName="btnText" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="btnChevron" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="busyBar" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,0,0">
                    <TextBlock Text="Powered by" FontSize="10" Foreground="#6B7280" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    <Border Width="110" Height="80" Background="#111827" HorizontalAlignment="Center" Margin="0,4,0,0" ToolTip="Powered by From Scratch">
                        <Border.OpacityMask>
                            <ImageBrush ImageSource="/Assets/from_scratch_logo.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border.OpacityMask>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
</UserControl>
