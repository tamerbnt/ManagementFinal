<UserControl x:Class="Management.Presentation.Views.Shop.QuickSaleViewNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Shop"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:QuickSaleViewModel, IsDesignTimeCreatable=True}"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StockToBrushConverter x:Key="StockToBrushConverter"/>
    </UserControl.Resources>

    <!-- Overlay Background -->
    <!-- Overlay Background with pronounced rounded corners -->
    <Border Style="{DynamicResource GlobalModalContainerStyle}" 
            CornerRadius="{DynamicResource RadiusModal}"
            Padding="0"
            Margin="32" MaxWidth="640" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Search -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header Section -->
            <Grid Grid.Row="0" Margin="40,40,40,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Terminology.Shop.QuickSale.Title}" 
                               Style="{DynamicResource Title2}" 
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                    
                    <TextBlock Text="{DynamicResource Terminology.Shop.QuickSale.Subtitle}" 
                               Style="{DynamicResource Body}" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 2. Premium Search Bar -->
            <Border Grid.Row="1" 
                    Background="{DynamicResource SurfaceBgSecondary}" 
                    CornerRadius="{DynamicResource RadiusSearchBar}" 
                    Height="52" 
                    Margin="40,8,40,24"
                    Padding="16,0" 
                    BorderBrush="{DynamicResource SeparatorStroke}" 
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Path Data="{StaticResource IconSearch}" 
                          Stroke="{DynamicResource TextTertiaryBrush}" 
                          StrokeThickness="1.5"
                          Width="18" Height="18" 
                          Stretch="Uniform" 
                          Margin="0,0,12,0"/>
                    <Grid Grid.Column="1">
                        <TextBlock Text="{DynamicResource Terminology.Shop.QuickSale.SearchPlaceholder}" 
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Body}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource Input.Field}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 VerticalContentAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 3. Product Grid -->
            <ScrollViewer Grid.Row="2" Margin="24,0,24,24" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <ListBox ItemsSource="{Binding Products}"
                             SelectedItem="{Binding SelectedProduct}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/> 
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="8"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="OuterBorder" 
                                                    Width="240" MinHeight="100" 
                                                    CornerRadius="20" 
                                                    BorderBrush="{DynamicResource SeparatorStroke}" 
                                                    BorderThickness="1"
                                                    Background="{DynamicResource SurfaceBg}"
                                                    Padding="16"
                                                    Margin="4">
                                                <Grid>
                                                    <!-- Selection Accent -->
                                                    <Border x:Name="SelectionBar" 
                                                            Width="4" HorizontalAlignment="Left" 
                                                            Background="{DynamicResource Brush.Accent.Primary}" 
                                                            CornerRadius="2"
                                                            Margin="-16,0,0,0"
                                                            Visibility="Collapsed"/>
                                                    
                                                    <Grid Margin="4,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel VerticalAlignment="Center" Margin="12,0">
                                                        <TextBlock x:Name="NameText" 
                                                                   Text="{Binding Name}" 
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock x:Name="CategoryText" 
                                                                   Text="{Binding Category}" 
                                                                   FontSize="12" 
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </StackPanel>

                                                    <TextBlock x:Name="PriceText" 
                                                               Grid.Column="1" 
                                                               Text="{Binding Price, StringFormat='{}{0:N2} DA'}" 
                                                               FontWeight="Bold" 
                                                               FontSize="17"
                                                               Foreground="{DynamicResource Brush.Accent.Primary}"
                                                               VerticalAlignment="Center"
                                                               Margin="12,0,0,0"/>
                                                </Grid>
                                                </Grid>
                                             </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource FacilityAccentDimBrush}"/>
                                                    <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource SurfaceBgSecondary}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="OuterBorder" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                                <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                                                <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="OuterBorder" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="{DynamicResource FacilityAccentColor}" BlurRadius="20" ShadowDepth="4" Opacity="0.4"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="OuterBorder" Property="BorderBrush" Value="Transparent"/>
                                                    <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                                                    <Setter TargetName="CategoryText" Property="Foreground" Value="{DynamicResource OnAccentSecondary}"/>
                                                    <Setter TargetName="PriceText" Property="Foreground" Value="White"/>
                                                    <Setter TargetName="SelectionBar" Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Loading Overlay -->
                    <Border Background="{DynamicResource SurfaceBg}" 
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                            Opacity="0.8"
                            CornerRadius="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,0,12"/>
                            <TextBlock Text="{DynamicResource Terminology.Shop.QuickSale.Loading}" Style="{StaticResource Caption}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- 4. Explicit Footer -->
            <Border Grid.Row="3" 
                    Background="{DynamicResource SurfaceBgSecondary}" 
                    BorderBrush="{DynamicResource SeparatorStroke}" 
                    BorderThickness="0,1,0,0" 
                    Padding="40,32"
                    CornerRadius="0,0,24,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                            Command="{Binding CancelCommand}" 
                            IsCancel="True"
                            Style="{StaticResource GhostButton}" 
                            Content="{DynamicResource Terminology.Global.Cancel}" 
                            HorizontalAlignment="Left"
                            Padding="24,0"
                            MinWidth="120"
                            Width="Auto"/>

                    <Button Grid.Column="1" 
                            Command="{Binding ProcessSaleCommand}" 
                            Style="{StaticResource PrimaryButton}" 
                            IsDefault="True"
                            MinWidth="220"
                            Width="Auto">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconCheck}" 
                                      Stroke="White" 
                                      StrokeThickness="2"
                                      Width="14" Height="14" 
                                      Stretch="Uniform" 
                                      Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Terminology.Shop.QuickSale.Action.Confirm}"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
