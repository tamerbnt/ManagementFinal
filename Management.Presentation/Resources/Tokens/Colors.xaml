<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Neutrals -->
    <Color x:Key="Color.White">#FFFFFF</Color>
    <Color x:Key="Color.Gray.50">#F8FAFC</Color>
    <Color x:Key="Color.Gray.200">#E5E7EB</Color>
    <Color x:Key="Color.Gray.500">#6B7280</Color>
    <Color x:Key="Color.Gray.900">#1A1A1A</Color>

    <!-- Brand: Gym (Navy) -->
    <Color x:Key="Color.Navy.900">#02122B</Color>
    <Color x:Key="Color.Navy.700">#052659</Color>
    <Color x:Key="Color.Blue.Accent">#5B8AB8</Color>

    <!-- Brand: Salon (Plum - Legacy / Transitioning to Rose) -->
    <Color x:Key="Color.Plum.900">#2E0228</Color>
    <Color x:Key="Color.Plum.700">#5A189A</Color>
    <Color x:Key="Color.Lavender.Accent">#D8A7D8</Color>

    <!-- Brand: Salon (Rose - Legacy / Transitioning to Blush & Midnight) -->
    <Color x:Key="Color.Rose.900">#880E4F</Color>
    <Color x:Key="Color.Rose.800">#AD1457</Color>
    <Color x:Key="Color.Rose.700">#C2185B</Color>
    <Color x:Key="Color.Rose.Accent">#E91E63</Color>
    <Color x:Key="Color.Rose.Light">#F8BBD0</Color>

    <!-- Brand: Salon (Blush & Midnight - New Direction) -->
    <Color x:Key="Color.Midnight.900">#12121D</Color> <!-- Deepest Midnight -->
    <Color x:Key="Color.Midnight.800">#1E1E2D</Color> <!-- Premium Sidebar -->
    <Color x:Key="Color.Midnight.700">#2D2D3F</Color>
    
    <Color x:Key="Color.Blush.Accent">#F48FB1</Color> <!-- Soft Pink Accent -->
    <Color x:Key="Color.Blush.Light">#FCE4EC</Color>  <!-- Blush Hover/Tint -->
    <Color x:Key="Color.Blush.Deep">#F06292</Color>   <!-- Pressed State -->

    <!-- Brand: Restaurant (Burgundy) -->
    <Color x:Key="Color.Burgundy.900">#2A0A0A</Color>
    <Color x:Key="Color.Burgundy.700">#7C2D12</Color>
    <Color x:Key="Color.Burgundy.500">#991B1B</Color> <!-- Default for Palette.Burgundy.500 -->
    <Color x:Key="Color.Orange.Accent">#F97316</Color>
    <Color x:Key="Color.Red.400">#F87171</Color>

    <!-- Global Brand Slots (Dynamically Overridden by Themes) -->
    <Color x:Key="Color.Brand.Primary">#0078D4</Color>
    <Color x:Key="Color.Brand.Primary.Deep">#005A9E</Color>
    <Color x:Key="Color.Background.Static">#F1F5F9</Color>
    <Color x:Key="Color.Surface.Glass">#FFFFFF</Color>
    <Color x:Key="Color.Text.Primary">#1A1A1A</Color>
    <Color x:Key="Color.Text.Secondary">#6B7280</Color>
    <Color x:Key="Color.Border.Subtle">#E5E7EB</Color>
    <Color x:Key="Color.Success">#10B981</Color>
    <Color x:Key="Color.Danger">#EF4444</Color>
    <Color x:Key="Color.Shadow.Depth">#1A000000</Color>

    <!-- Legacy/Missing Palettes Mapping -->
    <Color x:Key="Palette.Burgundy.500">#991B1B</Color> <!-- Legacy -->
    <Color x:Key="Palette.Navy.500">#0F172A</Color> <!-- Fix: Added missing resource (matches Sidebar Bg) -->
    <Color x:Key="Palette.Red.400">#F87171</Color>
    <Color x:Key="Palette.Neutral.White">#FFFFFF</Color>
    <Color x:Key="Palette.Neutral.OffWhite">#F9FAFB</Color>
    <Color x:Key="Palette.Neutral.Black">#111827</Color>
    <Color x:Key="Palette.Neutral.Gray900">#1A1A1A</Color>
    <Color x:Key="Palette.Blue.400">#3B82F6</Color>
    <Color x:Key="Palette.Success">#10B981</Color>

    <!-- Sidebar Specific Colors -->
    <Color x:Key="Color.Sidebar.Background">#0F172A</Color>
    <Color x:Key="Color.Sidebar.Text.Inactive">#94A3B8</Color>
    <Color x:Key="Color.Sidebar.Text.Active">#FFFFFF</Color>
    <Color x:Key="Color.Sidebar.Accent.Blue">#3B82F6</Color>
    <Color x:Key="Color.Sidebar.Accent.Cyan">#0EA5E9</Color>
    <Color x:Key="Color.Sidebar.Accent.Teal">#06B6D4</Color>
    <Color x:Key="Color.Sidebar.Separator">#334155</Color>
    <Color x:Key="Color.Sidebar.Hover">#0FFFFFFF</Color>

    <SolidColorBrush x:Key="Brush.Neutral.White" Color="#FFFFFF" />
</ResourceDictionary>
