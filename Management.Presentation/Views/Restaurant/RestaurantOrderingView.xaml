<UserControl x:Class="Management.Presentation.Views.Restaurant.RestaurantOrderingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:local="clr-namespace:Management.Presentation.Views.Restaurant"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Restaurant"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1440"
             Background="{DynamicResource AppBackgroundBrush}">

    <UserControl.Resources>
        <ResourceDictionary>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:EqualToVisibilityConverter x:Key="EqualToVisibilityConverter"/>
            <converters:EqualToVisibilityConverter x:Key="NotEqualToOneVisibilityConverter" Inverted="True"/>
            <converters:WindowWidthToColumnsConverter x:Key="WindowWidthToColumnsConverter"/>
            <converters:EqualityConverter x:Key="EqualityConverter"/>

        <!-- Premium Tab Style -->
        <Style x:Key="OrderTabStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabBorder" 
                                Background="{DynamicResource SurfaceBgSecondary}" 
                                CornerRadius="12" 
                                Padding="16,8"
                                MinWidth="140"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="{Binding DisplayName}" 
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           x:Name="HeaderText"/>

                                <Button Grid.Column="1" 
                                        Command="{Binding DataContext.CloseSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CompactIconButtonStyle}"
                                        Margin="8,0,0,0"
                                        Padding="4">
                                    <Path Data="{DynamicResource IconClose}" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Width="8" Height="8"/>
                                </Button>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                <Setter TargetName="HeaderText" Property="Foreground" Value="White"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0"/>
                                <Setter TargetName="TabBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="{DynamicResource FacilityAccentColor}" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceBgTertiary}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="{StaticResource MarginPageContent}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Controls & Tabs -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- 1. Header (MATCH SHOPVIEW) -->
        <Grid Grid.Row="0" Margin="{StaticResource MarginSectionBottom}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Path Data="{StaticResource Icon.Storefront}" 
                      Style="{StaticResource Style.Icon.Large}" 
                      Stroke="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Terminology.Restaurant.Order.Takeout}" 
                               Style="{StaticResource Title1}" 
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{DynamicResource Terminology.Restaurant.Order.Subtitle}"
                               Style="{StaticResource BodySmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- Add Session Button -->
                <Button Command="{Binding AddSessionCommand}" 
                        Style="{StaticResource PrimaryButton}"
                        Visibility="{Binding CanAddSession, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconPlus}" 
                              Stroke="White" 
                              Style="{StaticResource Style.Icon.Small}" 
                              Margin="{StaticResource MarginIconRight}"/>
                        <TextBlock Text="{DynamicResource Terminology.Restaurant.Order.Action.AddSession}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 2. Controls Area (Filters & Tabs) -->
        <Grid Grid.Row="1" Margin="{StaticResource MarginSectionBottom}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Filters -->
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>    <!-- Tabs -->
            </Grid.ColumnDefinitions>

            <!-- Filter Bar (MATCH SHOPVIEW) -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBg}" CornerRadius="12" Padding="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding}"
                                         GroupName="Categories"
                                         Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         CommandParameter="{Binding}"
                                         Margin="2,0">
                                <RadioButton.IsChecked>
                                    <MultiBinding Converter="{StaticResource EqualityConverter}" Mode="OneWay">
                                        <Binding />
                                        <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </RadioButton.IsChecked>
                                <RadioButton.Style>
                                    <Style TargetType="RadioButton" BasedOn="{StaticResource TogglePillStyle}"/>
                                </RadioButton.Style>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Session Tabs (Sub-Header Style) -->
            <ListBox Grid.Column="2" 
                     ItemsSource="{Binding OpenSessions}"
                     SelectedItem="{Binding CurrentSession}"
                     Style="{DynamicResource CleanListBoxStyle}"
                     ItemContainerStyle="{StaticResource OrderTabStyle}"
                     Background="Transparent"
                     BorderThickness="0"
                     VerticalAlignment="Center">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>

        <!-- 3. MAIN AREA WRAPPER -->
        <Grid Grid.Row="2">
            
            <!-- EMPTY STATE OVERLAY -->
            <Grid Visibility="{Binding IsEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,100">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="120" Height="120" Background="{DynamicResource SurfaceBgSecondary}" CornerRadius="60" Margin="0,0,0,24" HorizontalAlignment="Center">
                        <Path Data="{StaticResource IconShop}" Fill="{DynamicResource TextTertiaryBrush}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="No Active Takeout Orders" Style="{StaticResource Title2}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Start a new order to begin adding items for a customer." Style="{StaticResource BodyMedium}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,32"/>
                    <Button Content="Start New Order" 
                            Command="{Binding AddSessionCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="48" Width="200" HorizontalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="24"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ACTUAL CONTENT AREA (Hidden when empty) -->
            <Grid Visibility="{Binding IsEmptyState, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/> <!-- Summary Panel -->
                </Grid.ColumnDefinitions>

                <!-- Left: Menu Grid (MATCH SHOPVIEW) -->
                <Grid Margin="0,0,24,0">
                    <!-- Redundant Search Bar Removed -->

                <ListBox ItemsSource="{Binding FilteredItems}" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <!-- Using a Button wrapper for most reliable interaction handling -->
                                        <Button Command="{Binding DataContext.AddToOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="0" Margin="0" BorderThickness="0" Background="Transparent"
                                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Button.Template>
                                            
                                            <Border x:Name="CardBorder"
                                                    Height="320"
                                                    Width="240"
                                                    Padding="20"
                                                    CornerRadius="16"
                                                    Margin="0,0,20,20"
                                                    Background="{DynamicResource CardBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="140"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Image / Icon Area -->
                                                    <Grid Grid.Row="0">
                                                        <Border x:Name="IconWell" Background="{DynamicResource SurfaceBgTertiary}" CornerRadius="12">
                                                            <Path x:Name="CardIcon" Data="{StaticResource IconShop}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Fill="{DynamicResource TextTertiaryBrush}"
                                                                  Opacity="0.3"
                                                                  Style="{StaticResource Style.Icon.Hero}"/>
                                                        </Border>

                                                        <!-- SELECTED Badge -->
                                                        <Border x:Name="SelectedBadge" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                                                                Background="White" CornerRadius="10" Padding="8,4"
                                                                Visibility="Collapsed">
                                                            <TextBlock Text="{DynamicResource Strings.Restaurant.SELECTED}" Style="{StaticResource Micro}"
                                                                       Foreground="{DynamicResource FacilityAccentBrush}" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Info Area -->
                                                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                                        <TextBlock x:Name="CategoryText" Text="{Binding Category}" FontWeight="Bold" Margin="0,0,0,4"
                                                                   Style="{StaticResource Micro}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock x:Name="NameText" Text="{Binding Name}" FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" MaxHeight="44"
                                                                   Style="{StaticResource BodyMedium}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock x:Name="PriceText" Text="{Binding Price, StringFormat='{}{0:N2} DA'}"
                                                                   Margin="0,4,0,0"
                                                                   Style="{StaticResource Title3}" Foreground="{DynamicResource FacilityAccentBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                        <ControlTemplate.Triggers>
                                            <!-- HOVER STATE (Routed through the ListBoxItem) -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                                            </Trigger>

                                            <!-- SELECTION STATE (IsInCurrentOrder) -->
                                            <DataTrigger Binding="{Binding IsInCurrentOrder}" Value="True">
                                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="0"/>
                                                <Setter TargetName="CardBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="{DynamicResource FacilityAccentColor}" Opacity="0.4"/>
                                                    </Setter.Value>
                                                </Setter>
                                                
                                                <Setter TargetName="IconWell" Property="Background" Value="Transparent"/>
                                                <Setter TargetName="CardIcon" Property="Fill" Value="White"/>
                                                <Setter TargetName="CardIcon" Property="Opacity" Value="0.6"/>
                                                <Setter TargetName="SelectedBadge" Property="Visibility" Value="Visible"/>
                                                
                                                <Setter TargetName="CategoryText" Property="Foreground" Value="White"/>
                                                <Setter TargetName="CategoryText" Property="Opacity" Value="0.8"/>
                                                <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                                                <Setter TargetName="PriceText" Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>




            <!-- Right: Order Summary Panel -->
            <Border Grid.Column="1" 
                    Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="24" 
                    Effect="{StaticResource Shadow2}"
                    Padding="24"
                    DataContext="{Binding CurrentSession}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Items -->
                        <RowDefinition Height="Auto"/> <!-- Notes -->
                        <RowDefinition Height="Auto"/> <!-- Totals -->
                        <RowDefinition Height="Auto"/> <!-- Footer -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding OrderTypeLabel}" Style="{StaticResource Title3}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        
                        <Button Grid.Column="1"
                                Command="{Binding DataContext.PrintOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Style="{StaticResource CompactIconButtonStyle}"
                                ToolTip="Print Receipt (Staff/Client)">
                             <Path Data="{StaticResource IconPrinter}" 
                                   Style="{StaticResource Style.Icon.Small}"
                                   Stroke="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Item List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CurrentOrder.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Background="{DynamicResource SurfaceBgSecondary}" Padding="12" CornerRadius="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} DA'}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource ButtonCompactSecondary}" 
                                                        Content="-" 
                                                        Width="24" Height="24"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <TextBlock Text="{Binding Quantity}" Margin="12,0" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <Button Style="{StaticResource ButtonCompactSecondary}" 
                                                        Content="+" 
                                                        Width="24" Height="24"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Notes Area -->
                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <TextBlock Text="{DynamicResource Terminology.Restaurant.Order.Notes}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource GhostTextBox}"
                                 Tag="Add instructions (e.g., no onions)..."
                                 AcceptsReturn="True"
                                 MinHeight="60"
                                 Padding="8"
                                 Background="{DynamicResource SurfaceBgSecondary}"/>
                    </StackPanel>

                    <!-- Totals -->
                    <StackPanel Grid.Row="3" Margin="0,24,0,24">
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                            <Grid>
                                <TextBlock Text="{DynamicResource Terminology.Restaurant.Order.Total}" Style="{StaticResource BodyBold}" FontSize="24" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Total, StringFormat='{}{0:N2} DA'}" HorizontalAlignment="Right" Style="{StaticResource BodyBold}" FontSize="24" Foreground="{DynamicResource FacilityAccentBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="{DynamicResource Terminology.Restaurant.Order.Action.Cancel}" 
                                Command="{Binding DataContext.CancelOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Style="{StaticResource SecondaryButton}" 
                                Margin="0,0,8,0"
                                Padding="16,0"/>
                        <Button Grid.Column="1" 
                                IsEnabled="{Binding CurrentOrder.Items.Count, Converter={StaticResource NotEqualToOneVisibilityConverter}, ConverterParameter=0}"
                                Content="{DynamicResource Terminology.Restaurant.Order.Action.ToKitchen}" 
                                Command="{Binding DataContext.SendToKitchenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Style="{StaticResource SecondaryButton}" 
                                Height="48"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="2" 
                                IsEnabled="{Binding CurrentOrder.Items.Count, Converter={StaticResource NotEqualToOneVisibilityConverter}, ConverterParameter=0}"
                                Content="{DynamicResource Terminology.Restaurant.Order.Action.PayComplete}" 
                                Command="{Binding DataContext.PayAndCompleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Style="{StaticResource PrimaryButton}"
                                Height="48"/>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

