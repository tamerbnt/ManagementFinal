<Window x:Class="Management.Presentation.Views.Dashboard.OccupancyHistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{DynamicResource SurfaceBg}"
        WindowStyle="None"
        Title="Occupancy History Analysis"
        d:DesignHeight="600" d:DesignWidth="500">
    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="500"
            Margin="32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Summary -->
                <RowDefinition Height="*"/>    <!-- Hourly Chart -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Occupancy History Analysis" 
                           Style="{DynamicResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding AnalyzedPeriodLabel}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

                <ComboBox ItemsSource="{Binding AvailablePeriods}"
                          SelectedItem="{Binding SelectedPeriod}"
                          Width="150" Height="34"
                          Margin="0,16,0,0"
                          HorizontalAlignment="Center"
                          Style="{StaticResource Input.ComboBox}"/>
            </StackPanel>

            <!-- 2. Peak Hour Highlight -->
            <Border Grid.Row="1" Margin="0,0,0,24" Background="{DynamicResource FacilityAccentDimBrush}" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="PEAK OPERATION HOUR" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" Opacity="0.8"/>
                        <TextBlock Text="{Binding Data.PeakHourFormatted}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="BEST INTERVALS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Right"/>
                        <ItemsControl ItemsSource="{Binding Data.BestIntervals}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Hourly Bar Chart (Simulated) -->
            <ScrollViewer Grid.Row="2" MaxHeight="400" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="AVERAGE HOURLY OCCUPANCY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding Data.HourlyAverages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Hour, StringFormat='{}{0:D2}:00'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Height="14" CornerRadius="4" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Width" Value="{Binding AverageOccupancy, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=15}"/>
                                                <Setter Property="Background" Value="#3B82F6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AverageOccupancy, Converter={StaticResource IsGreaterThanConverter}, ConverterParameter=5}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding AverageOccupancy}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Analysis Summary -->
                    <Border Background="{DynamicResource SurfaceSecondaryBrush}" CornerRadius="12" Padding="16" Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="PERIOD SUMMARY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Data.AnalysisPeriod}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding Data.TotalDaysAnalyzed, StringFormat='{}Data collected over {0} days'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 4. Footer Actions -->
            <Grid Grid.Row="3" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Content="Report to PDF" 
                        Command="{Binding ExportPdfCommand}"
                        Style="{DynamicResource Button.Primary}"
                        Padding="16,0" Height="36"/>

                <Button Grid.Column="2" 
                        Content="Close" 
                        Command="{Binding CloseCommand}"
                        Style="{DynamicResource Button.Ghost}"
                        Margin="12,0,0,0" Width="80" Height="36"/>
            </Grid>
        </Grid>
    </Border>
</Window>
