<UserControl x:Class="Management.Presentation.Views.Auth.FacilityOnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Auth"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="600"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Icon Geometries -->
        <StreamGeometry x:Key="Icon.Gym">M21,16.5C19.8,17.2 18.2,16.8 17.5,15.6L16,13L15,13.5L16.5,16.1C17.2,17.3 16.8,18.8 15.6,19.5L13,21L11,17.5L12.5,16.6C13.7,15.9 14.1,14.3 13.4,13.1L11.9,10.5L9,12.2V16H7V10.2L10.2,8.4L13.7,14.4L14.7,13.8L11.2,7.8C10.5,6.6 8.9,6.2 7.7,6.9L4.2,8.9L3,6.8L5.1,5.6C7.3,4.3 10.2,5 11.5,7.2L12.5,8.9L15.3,7.2C16.5,6.5 18.1,6.9 18.8,8.1L22.3,14.1L21,16.5M7,2C5.9,2 5,2.9 5,4C5,5.1 5.9,6 7,6C8.1,6 9,5.1 9,4C9,2.9 8.1,2 7,2Z</StreamGeometry>
        <StreamGeometry x:Key="Icon.Salon">M11,13.5V20H13V13.5C13,10.1 14.9,7.3 17.6,5.3C18.1,5 18.1,4.3 17.6,3.9C15.8,2.7 13.7,2 11.5,2C6.3,2 2,6.3 2,11.5C2,13.7 2.7,15.8 3.9,17.6C4.3,18.1 5,18.1 5.3,17.6C7.3,14.9 10.1,13 13.5,13M10,13.5C6.6,13.5 3.8,11.6 1.8,8.9C1.4,8.4 1.4,7.7 1.9,7.3C3.7,6.1 5.8,5.4 8,5.4C13.2,5.4 17.5,9.7 17.5,14.9C17.5,17.1 16.8,19.2 15.6,21C15.2,21.5 14.5,21.5 14.1,21C12.1,18.3 10,14.9 10,13.5M10.5,10.5A1.5,1.5 0 0,0 9,9A1.5,1.5 0 0,0 7.5,10.5A1.5,1.5 0 0,0 9,12A1.5,1.5 0 0,0 10.5,10.5Z</StreamGeometry>
        <StreamGeometry x:Key="Icon.Restaurant">M11,9H9V2H7V9H5V2H3V9C3,11.12 4.66,12.84 6.75,12.97V22H9.25V12.97C11.34,12.84 13,11.12 13,9V2H11V9M16,6V14H18.5V22H21V2C18.24,2 16,4.24 16,6Z</StreamGeometry>
    </UserControl.Resources>

    <Grid>
        <!-- Background Ambient Glow Layer 1 (Outer) -->
        <Ellipse Width="900" Height="900" Opacity="0.08" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#8B5CF6" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.1"/>
                    <GradientStop Color="#008B5CF6" Offset="0.5"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.06" To="0.12" Duration="0:0:6" AutoReverse="True" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>

        <!-- Background Ambient Glow Layer 2 (Inner) -->
        <Ellipse Width="500" Height="500" Opacity="0.12" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#8B5CF6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.08" To="0.15" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever"/>
                            <DoubleAnimation Storyboard.TargetProperty="Width" From="480" To="520" Duration="0:0:6" AutoReverse="True" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>

        <Border VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480"
                Background="#0DFFFFFF" CornerRadius="32" BorderThickness="1.5" Padding="40,48">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#668B5CF6" Offset="0"/>
                    <GradientStop Color="#338B5CF6" Offset="0.5"/>
                    <GradientStop Color="#668B5CF6" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="80" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>

        <StackPanel>
            <!-- Animated Building Icon -->
            <Grid Width="120" Height="120" Margin="0,0,0,32">
                <!-- Outer Rotating Ring -->
                <Ellipse Width="100" Height="100" Stroke="#508B5CF6" StrokeThickness="2" StrokeDashArray="4 2">
                    <Ellipse.RenderTransform>
                        <RotateTransform CenterX="50" CenterY="50"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                   From="0" To="360" Duration="0:0:20" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <!-- Inner Core Glow -->
                <Ellipse Width="80" Height="80" Fill="#8B5CF6" Opacity="0.3">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="0.45" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <!-- Building Icon -->
                <Path Data="M12,3L1,9L12,15L21,10.09V17H23V9M5,13.18V17.18L12,21L19,17.18V13.18L12,17L5,13.18Z" 
                      Fill="#8B5CF6" Width="32" Height="32" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path.Effect>
                        <DropShadowEffect BlurRadius="25" Color="#8B5CF6" Opacity="0.8" ShadowDepth="0"/>
                    </Path.Effect>
                </Path>
            </Grid>

            <!-- Title -->
            <TextBlock Text="{DynamicResource Strings.Auth.FacilitySelection}" FontSize="32" FontWeight="ExtraBold" Foreground="White" 
                       Margin="0,0,0,12" HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.3" ShadowDepth="2"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="{DynamicResource Strings.Auth.Selecttheindustrythatbest}" 
                       TextWrapping="Wrap" TextAlignment="Center" FontSize="14" Foreground="#94A3B8" MaxWidth="360" Margin="0,0,0,40" LineHeight="20"/>

            <!-- Industry Cards -->
            <ItemsControl ItemsSource="{Binding Options}" Margin="0,0,0,32">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,0,16"
                                Command="{Binding DataContext.ContinueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="16" BorderThickness="1.5" Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" Padding="20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon Container -->
                                            <Border Width="56" Height="56" CornerRadius="14" Margin="0,0,20,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{Binding GradientStart}" Offset="0"/>
                                                        <GradientStop Color="{Binding GradientEnd}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Path Data="{Binding IconKey, Converter={StaticResource ResourceKeyToIconConverter}, FallbackValue={StaticResource Icon.Gym}}" 
                                                      Fill="White" Width="28" Height="28" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Content -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <!-- Arrow -->
                                            <Path Grid.Column="2" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" 
                                                  Fill="#33FFFFFF" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#508B5CF6"/>
                                            <Setter TargetName="border" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="20" Color="#8B5CF6" Opacity="0.3" ShadowDepth="0"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="#8B5CF6"/>
                                            <Setter TargetName="border" Property="Background" Value="#1A8B5CF6"/>
                                            <Setter TargetName="border" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="20" Color="#8B5CF6" Opacity="0.5" ShadowDepth="0"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Help -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource Strings.Auth.Needtochangedetails}" Foreground="#475569" FontSize="12.5" Margin="0,0,6,0"/>
                <TextBlock Foreground="#8B5CF6" FontSize="12.5">
                    <Hyperlink Command="{Binding NavigateBackCommand}" Foreground="#8B5CF6" FontWeight="SemiBold" TextDecorations="{x:Null}">
                        Back to Account Setup
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>
        </Border>
    </Grid>
</UserControl>
