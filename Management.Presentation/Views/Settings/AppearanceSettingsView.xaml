<UserControl x:Class="Management.Presentation.Views.Settings.AppearanceSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="{StaticResource PaddingCard}" 
                    MaxWidth="{StaticResource MaxWidthForm}" 
                    HorizontalAlignment="Left">

            <!-- 1. THEME & BRANDING -->
            <TextBlock Text="{DynamicResource TerminologyThemeAndBrandingLabel}" 
                       Style="{StaticResource Title3}" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="{StaticResource MarginHeaderBottom}"/>

            <!-- Accent Color -->
            <TextBlock Text="{DynamicResource TerminologyAccentColorLabel}" 
                       Style="{StaticResource FormLabel}" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="{StaticResource MarginLabelBottom}"/>

            <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginSectionBottom}">
                <!-- Blue (Locked/Active) -->
                <RadioButton Background="{DynamicResource FacilityAccentBrush}" 
                             Style="{StaticResource GlobalColorSwatchStyle}" 
                             IsChecked="True"/>

                <!-- Others (Disabled per spec) -->
                <RadioButton Background="{StaticResource StatusSuccessBrush}" 
                             Style="{StaticResource GlobalColorSwatchStyle}" 
                             IsEnabled="False" ToolTip="Coming Soon"/>
                <RadioButton Background="{StaticResource StatusWarningBrush}" 
                             Style="{StaticResource GlobalColorSwatchStyle}" 
                             IsEnabled="False" ToolTip="Coming Soon"/>
                <RadioButton Background="{StaticResource StatusErrorBrush}" 
                             Style="{StaticResource GlobalColorSwatchStyle}" 
                             IsEnabled="False" ToolTip="Coming Soon"/>
            </StackPanel>

            <!-- Mode -->
            <TextBlock Text="{DynamicResource TerminologyAppearanceModeLabel}" 
                       Style="{StaticResource FormLabel}" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="{StaticResource MarginLabelBottom}"/>

            <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginSectionBottom}">
                <RadioButton Content="{DynamicResource TerminologyLightLabel}" 
                             IsChecked="{Binding IsLightMode}" 
                             Margin="{StaticResource MarginMediumRight}"/>

                <!-- Dark Mode (Disabled + Global Badge) -->
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="{DynamicResource TerminologyDarkLabel}" 
                                 IsEnabled="False"
                                 Margin="{StaticResource MarginSmallRight}"/>

                    <!-- Uses Global Coming Soon Badge Style -->
                    <Border Style="{StaticResource GlobalComingSoonBadgeStyle}">
                        <TextBlock Text="Coming Soon"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- 2. REGIONAL SETTINGS -->
            <TextBlock Text="{DynamicResource TerminologyRegionalLabel}" 
                       Style="{StaticResource Title3}" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="{StaticResource MarginSectionVertical}"/>

            <Grid Margin="{StaticResource MarginSectionBottom}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="{StaticResource MarginMedium}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Language" Style="{StaticResource FormLabel}"/>
                    <ComboBox SelectedItem="{Binding SelectedLanguage}" 
                              Style="{StaticResource GlobalComboBoxStyle}">
                        <sys:String>English (US)</sys:String>
                        <sys:String>English (UK)</sys:String>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Date Format" Style="{StaticResource FormLabel}"/>
                    <ComboBox SelectedItem="{Binding DateFormat}" 
                              Style="{StaticResource GlobalComboBoxStyle}">
                        <sys:String>MM/DD/YYYY</sys:String>
                        <sys:String>DD/MM/YYYY</sys:String>
                        <sys:String>YYYY-MM-DD</sys:String>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- 3. ACCESSIBILITY -->
            <TextBlock Text="Accessibility" 
                       Style="{StaticResource Title3}" 
                       Margin="{StaticResource MarginSectionVertical}"/>

            <!-- High Contrast -->
            <Grid Margin="{StaticResource MarginSmallBottom}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="High Contrast Mode" Style="{StaticResource BodyMedium}"/>
                    <TextBlock Text="Increase contrast for better readability" 
                               Style="{StaticResource Caption}" 
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Uses Global Toggle Switch Style -->
                <CheckBox IsChecked="{Binding HighContrastEnabled}" 
                          Style="{StaticResource GlobalToggleSwitchStyle}"
                          HorizontalAlignment="Right"/>
            </Grid>

            <Border Height="1" Background="{StaticResource SeparatorBrush}" Margin="{StaticResource MarginListVertical}"/>

            <!-- Reduced Motion -->
            <Grid Margin="{StaticResource MarginSmallBottom}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Reduced Motion" Style="{StaticResource BodyMedium}"/>
                    <TextBlock Text="Minimize animations across the app" 
                               Style="{StaticResource Caption}" 
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <CheckBox IsChecked="{Binding ReducedMotionEnabled}" 
                          Style="{StaticResource GlobalToggleSwitchStyle}"
                          HorizontalAlignment="Right"/>
            </Grid>

            <Border Height="1" Background="{StaticResource SeparatorBrush}" Margin="{StaticResource MarginListVertical}"/>

            <!-- Text Size -->
            <Grid Margin="{StaticResource MarginSectionBottom}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Text Scaling" Style="{StaticResource BodyMedium}"/>
                    <TextBlock Text="Adjust the global font size" 
                               Style="{StaticResource Caption}" 
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <ComboBox SelectedItem="{Binding TextScale}" 
                          Style="{StaticResource GlobalComboBoxStyle}"
                          Width="120"
                          HorizontalAlignment="Right">
                    <sys:String>100%</sys:String>
                    <sys:String>110%</sys:String>
                    <sys:String>125%</sys:String>
                </ComboBox>
            </Grid>

            <!-- 4. ACTION FOOTER -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="{StaticResource MarginSectionVertical}">
                <Button Content="{DynamicResource TerminologySaveChangesLabel}" 
                        Command="{Binding SaveAppearanceCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="{StaticResource SizeButtonMinWidth}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>