<Window x:Class="Management.Presentation.Views.Dashboard.RevenueHistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{DynamicResource SurfaceBg}"
        WindowStyle="None"
        Title="Revenue History Analysis"
        d:DesignHeight="600" d:DesignWidth="500">
    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="500"
            Margin="32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Best of Month -->
                <RowDefinition Height="*"/>    <!-- Stats -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Revenue History Analysis" 
                           Style="{DynamicResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding AnalyzedPeriodLabel}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

                <ComboBox ItemsSource="{Binding AvailablePeriods}"
                          SelectedItem="{Binding SelectedPeriod}"
                          Width="150" Height="34"
                          Margin="0,16,0,0"
                          HorizontalAlignment="Center"
                          Style="{StaticResource Input.ComboBox}"/>
            </StackPanel>

            <!-- 2. Dual Highlights Grid -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Best Plan -->
                <Border Background="{DynamicResource FacilityAccentDimBrush}" CornerRadius="12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="TOP PLAN (MONTH)" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" Opacity="0.8"/>
                        <TextBlock Text="{Binding Data.BestPlanOfMonth.PlanName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Data.BestPlanOfMonth.Revenue, StringFormat='{}{0:N0} DA'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Best Product -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceSecondaryBrush}" CornerRadius="12" Padding="12">
                    <StackPanel>
                        <TextBlock Text="TOP PRODUCT (MONTH)" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Opacity="0.8"/>
                        <TextBlock Text="{Binding Data.BestProductOfMonth.ItemName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Data.BestProductOfMonth.Revenue, StringFormat='{}{0:N0} DA'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 3. Stats Content -->
            <ScrollViewer Grid.Row="2" MaxHeight="400" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Gender Split -->
                    <Border Background="{DynamicResource SurfaceSecondaryBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="GENDER REVENUE SPLIT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,12"/>
                            <Grid Height="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding Data.GenderSplit.MalePercentage, Converter={StaticResource GridStarConverter}}"/>
                                    <ColumnDefinition Width="{Binding Data.GenderSplit.FemalePercentage, Converter={StaticResource GridStarConverter}}"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#3B82F6" CornerRadius="6,0,0,6"/>
                                <Border Grid.Column="1" Background="#EC4899" CornerRadius="0,6,6,0"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Male Members (" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Data.GenderSplit.MaleCount}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text=")" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Female Members (" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Data.GenderSplit.FemaleCount}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text=")" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Top Plans -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="TOP MEMBERSHIP PLANS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Data.TopPlans}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding PlanName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Revenue, StringFormat='{}{0:N2} DA'}" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Top Products -->
                    <StackPanel>
                        <TextBlock Text="TOP RETAIL PRODUCTS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Data.TopProducts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Revenue, StringFormat='{}{0:N2} DA'}" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Analysis Summary -->
                    <Border Background="{DynamicResource SurfaceSecondaryBrush}" CornerRadius="12" Padding="16" Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="PERIOD SUMMARY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Data.AnalysisPeriod}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding Data.TotalDaysAnalyzed, StringFormat='{}Data collected over {0} days'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 4. Footer Actions -->
            <Grid Grid.Row="3" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Content="Report to PDF" 
                        Command="{Binding ExportPdfCommand}"
                        Style="{DynamicResource Button.Primary}"
                        Padding="16,0" Height="36"/>

                <Button Grid.Column="2" 
                        Content="Close" 
                        Command="{Binding CloseCommand}"
                        Style="{DynamicResource Button.Ghost}"
                        Margin="12,0,0,0" Width="80" Height="36"/>
            </Grid>
        </Grid>
    </Border>
</Window>
