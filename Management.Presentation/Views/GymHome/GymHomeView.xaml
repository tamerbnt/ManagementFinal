<UserControl x:Class="Management.Presentation.Views.GymHome.GymHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.GymHome"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1440">
    
    <UserControl.Resources>
        <!-- Use Global Standardized Shadows and Brushes -->

        <StaticResource x:Key="Shadow.Hover" ResourceKey="Shadow3"/>
        
        <!-- Laser Accents (Dynamic based on Facility) -->
        <DropShadowEffect x:Key="Glow.Blue" BlurRadius="25" ShadowDepth="0" Opacity="0.4" Color="{DynamicResource FacilityAccentColor}"/>
        <DropShadowEffect x:Key="Glow.Green" BlurRadius="20" ShadowDepth="0" Opacity="0.6" Color="{DynamicResource Color.Success}"/>
        
        <DropShadowEffect x:Key="Shadow.TextContrast" BlurRadius="4" ShadowDepth="1" Opacity="0.3" Color="Black"/>

        <!-- Animations (Standardized Durations) -->
        <Storyboard x:Key="PulseBreathing" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="0.8" Duration="0:0:2.5"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.95" To="1.05" Duration="0:0:3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.95" To="1.05" Duration="0:0:3"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid VerticalAlignment="Stretch">
        <Grid Margin="0">
        <i:Interaction.Triggers>
                <i:EventTrigger EventName="Loaded">
                    <i:InvokeCommandAction Command="{Binding OnLoadedCommand}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/> <!-- Lateral Gap -->
                <ColumnDefinition Width="280"/> <!-- Sidebar Column -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Row 0: Header (Greeting) -->
                <RowDefinition Height="*"/>    <!-- Row 1: Multi-Zone Content -->
            </Grid.RowDefinitions>

            <!-- ====================================================================== -->
            <!-- SECTION 0: DASHBOARD HEADER (Greeting + Primary Action) -->
            <!-- ====================================================================== -->
            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,32">
                <!-- Time-based Greeting -->
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <Path Data="{StaticResource IconGym}" 
                          Style="{StaticResource Style.Icon.Large}" 
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          Margin="0,0,16,0"
                          VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding GreetingText}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}" FontFamily="Segoe UI Variable Display"/>
                        <TextBlock Text="{DynamicResource Terminology.Home.Subtitle}" FontSize="15" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ====================================================================== -->
            <!-- ZONE 1: LEFT CONTENT AREA (Metrics + Core) -->
            <!-- ====================================================================== -->
            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Metrics Strip -->
                    <RowDefinition Height="32"/>   <!-- Spacer -->
                    <RowDefinition Height="*"/>    <!-- Operational Core -->
                </Grid.RowDefinitions>

                <!-- SECTION 1: METRICS STRIP (Hero + Support Cards - Fluid Grid) -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*"/> <!-- Hero: People Inside -->
                        <ColumnDefinition Width="20"/>   <!-- Gap -->
                        <ColumnDefinition Width="1*"/>   <!-- Active Members -->
                        <ColumnDefinition Width="20"/>   <!-- Gap -->
                        <ColumnDefinition Width="1*"/>   <!-- Expiring Soon -->
                        <ColumnDefinition Width="20"/>   <!-- Gap -->
                        <ColumnDefinition Width="1*"/>   <!-- Revenue Today -->
                    </Grid.ColumnDefinitions>

                    <!-- HERO: ACTIVE MEMBERS CAROUSEL (Salon Style) -->
                    <Border Grid.Column="0" Height="140" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="16" Padding="16,16,16,12" Effect="{StaticResource Shadow2}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- Label row -->
                                <RowDefinition Height="*"/>     <!-- Content row -->
                                <RowDefinition Height="Auto"/>  <!-- Footer: arrows + counter -->
                            </Grid.RowDefinitions>

                            <!-- Header label -->
                            <StackPanel Orientation="Horizontal">
                                <Border Width="24" Height="24" CornerRadius="6" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,10,0">
                                    <Path Data="{StaticResource IconMembers}"
                                          Fill="{DynamicResource FacilityAccentBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Terminology.Home.PeopleInside}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>

                            <!-- CONTENT: Occupancy -->
                            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock Text="{Binding OccupancyCount}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                            Visibility="{Binding HasOccupancyTrend, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding OccupancyTrendText}" FontSize="11" FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Success}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTrendPositive}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ACTIVE MEMBERS TOTAL -->
                    <Border Grid.Column="2" Height="140" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="White" BorderThickness="0,1.5,0,0" CornerRadius="16" Padding="24,20" Effect="{StaticResource Shadow2}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- HEADER -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                                <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource FacilityAccentDimBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Path Data="{StaticResource IconMembers}" Fill="{DynamicResource FacilityAccentBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Terminology.Home.ActiveMembers}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- CONTENT -->
                            <TextBlock Grid.Row="1" Text="{Binding ActiveMembersTotal}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- EXPIRING SOON -->
                    <Border Grid.Column="4" Height="140" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="White" BorderThickness="0,1.5,0,0" CornerRadius="16" Padding="24,20" Effect="{StaticResource Shadow2}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- HEADER -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                                <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource FacilityAccentDimBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Path Data="{StaticResource IconClock}" Fill="{DynamicResource FacilityAccentBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Terminology.Home.ExpiringSoon}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- CONTENT -->
                            <TextBlock Grid.Row="1" Text="{Binding ExpiringSoonCount}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- REVENUE TODAY -->
                    <Border Grid.Column="6" Height="140" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="White" BorderThickness="0,1.5,0,0" CornerRadius="16" Padding="24,20" Effect="{StaticResource Shadow2}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- HEADER -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                                <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource FacilityAccentDimBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Path Data="{StaticResource IconFinance}" Fill="{DynamicResource FacilityAccentBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Terminology.Home.RevenueToday}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- CONTENT -->
                            <TextBlock Grid.Row="1" Text="{Binding RevenueToday, StringFormat={}{0:C0}}" FontSize="40" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- SECTION 2: OPERATIONAL CORE (Activity + Hub) -->
                <Grid Grid.Row="2" VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/> <!-- Expanded: Recent Activity fills space -->
                    </Grid.ColumnDefinitions>
                    <!-- Recent Activity Section -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="White" BorderThickness="0,1.5,0,0" CornerRadius="24" Padding="20" Effect="{StaticResource Shadow2}" VerticalAlignment="Stretch">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconHistory}" Fill="{DynamicResource FacilityAccentBrush}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="{DynamicResource Terminology.Home.RecentActivity}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                </StackPanel>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ActivityStream}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource Brush.Surface.Secondary}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,16,0">
                                                        <TextBlock Text="{Binding AvatarInitials}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                        <TextBlock Text="{Binding Status}" FontSize="14" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Timestamp}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding RelativeTime, StringFormat='({0})'}" FontSize="13" Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Button Grid.Row="2" Style="{StaticResource Button.Ghost}" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <TextBlock Text="{DynamicResource Terminology.Home.SeeAll}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}"/>
                            </Button>
                            <!-- Background Scan Listener (TextBox) - Moved inside to ensure focus behavior works -->
                            <TextBox Width="1" Height="1" Opacity="0" Text="{Binding ScanInput, UpdateSourceTrigger=PropertyChanged}" behaviors:FocusBehavior.FocusOnVisible="True">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ScanCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <!-- ====================================================================== -->
            <!-- ZONE 2: RIGHT SIDEBAR (Quick Actions + Time) -->
            <!-- ====================================================================== -->
            <Grid Grid.Row="1" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- Quick Actions (Expanded) -->
                    <RowDefinition Height="16"/>   <!-- Gap -->
                    <RowDefinition Height="Auto"/> <!-- Time/Date (Anchored Bottom) -->
                </Grid.RowDefinitions>
                
                <!-- QUICK ACTIONS CARD (Full Vertical Stretch) -->
                <Border Grid.Row="0" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="24" Padding="20" Effect="{StaticResource Shadow2}" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Header -->
                            <RowDefinition Height="*"/>     <!-- Buttons (centered) -->
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="{DynamicResource Terminology.Home.QuickActions}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" Margin="0,0,0,16"/>
                        
                        <!-- 2x2 Grid of Buttons -->
                        <Grid Grid.Row="1" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/> <!-- Gap -->
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/> <!-- Gap -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Row 0, Col 0: Quick Sale -->
                            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource Button.Ghost}" Command="{Binding SellItemCommand}" Height="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="14" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,12">
                                        <Path Data="{StaticResource IconFinance}" 
                                              Style="{StaticResource Style.Icon.Standard}"
                                              Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Home.Action.QuickSale}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Row 0, Col 2: Create Member -->
                            <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource Button.Ghost}" Command="{Binding RegisterMemberCommand}" Height="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="14" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,12">
                                        <Path Data="{StaticResource IconPlus}" 
                                              Style="{StaticResource Style.Icon.Standard}"
                                              Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Home.Action.CreateMember}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Row 2, Col 0: Walk-In Check-In -->
                            <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource Button.Ghost}" Command="{Binding ProcessWalkInCommand}" Height="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="14" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,12">
                                        <Path Data="{StaticResource IconMembers}" 
                                              Style="{StaticResource Style.Icon.Standard}"
                                              Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Home.Action.WalkIn}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Row 2, Col 2: Multi-Sale Cart -->
                            <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource Button.Ghost}" Command="{Binding OpenMultiSaleCartCommand}" Height="110">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="50" Height="50" CornerRadius="14" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,0,12">
                                        <Path Data="{StaticResource IconCart}" 
                                              Style="{StaticResource Style.Icon.Standard}"
                                              Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="2.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Home.Action.MultiSale}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Neutral.White}" Opacity="0.9" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- TIME/DATE WIDGET -->
                <Border Grid.Row="2" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="24" Padding="20" Effect="{StaticResource Shadow2}">
                    <StackPanel>
                        <!-- Time Display -->
                        <Path Data="{StaticResource IconClock}" Fill="{DynamicResource FacilityAccentBrush}" Width="28" Height="28" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="{Binding CurrentTime}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        
                        <!-- Date Display -->
                        <TextBlock Text="{Binding CurrentDate}" FontSize="12" Foreground="{DynamicResource Brush.Sidebar.Text.Inactive}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        
                        <!-- System Status -->
                        <Border Background="{DynamicResource Brush.Sidebar.Separator}" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Terminology.Home.SystemStatus}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{DynamicResource Terminology.Home.Scanner}" FontSize="11" Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                                    <TextBlock Text="{DynamicResource Terminology.Global.Online}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Brush.Success}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="{DynamicResource Terminology.Home.Printer}" FontSize="11" Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                                    <TextBlock Text="{DynamicResource Terminology.Global.Online}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Brush.Success}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
