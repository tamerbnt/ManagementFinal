<UserControl x:Class="Management.Presentation.Views.AccessControl.TurnstileStatusPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <!-- Status Converters -->
        <converters:TurnstileStatusToBrushConverter x:Key="TurnstileStatusToBrushConverter"/>
        <converters:TurnstileStatusToTextConverter x:Key="TurnstileStatusToTextConverter"/>
    </UserControl.Resources>

    <!-- Turnstile Collection Grid -->
    <ItemsControl ItemsSource="{Binding Turnstiles}"
                  Background="Transparent"
                  BorderThickness="0">

        <!-- Layout: Responsive WrapPanel -->
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <!-- 
                    Hardware Card 
                    Fixed dimensions per spec: 200x120px.
                    Uses ElevatedCardStyle for Shadow L2 and Hover Lift.
                -->
                <Border Style="{StaticResource ElevatedCardStyle}"
                        Width="200"
                        Height="120"
                        Padding="{StaticResource PaddingCardCompact}"
                        Margin="{StaticResource MarginCardGap}">

                    <!-- Hardware Actions (Right Click) -->
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Force Open" Command="{Binding ForceOpenCommand}">
                                <MenuItem.Icon>
                                    <Path Data="{StaticResource IconUnlock}" 
                                          Fill="{StaticResource TextPrimary}" 
                                          Style="{StaticResource IconSmall}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Lock Down" Command="{Binding LockDownCommand}">
                                <MenuItem.Icon>
                                    <Path Data="{StaticResource IconLock}" 
                                          Fill="{StaticResource TextPrimary}" 
                                          Style="{StaticResource IconSmall}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Reset Error" Command="{Binding ResetErrorCommand}">
                                <MenuItem.Icon>
                                    <Path Data="{StaticResource IconRefresh}" 
                                          Fill="{StaticResource TextPrimary}" 
                                          Style="{StaticResource IconSmall}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </Border.ContextMenu>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Name & Icon -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Name -->
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding Name}" 
                                       Style="{StaticResource BodyMedium}" 
                                       Foreground="{StaticResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- Hardware Icon (Faded visual flair) -->
                            <Path Grid.Column="1"
                                  Data="{StaticResource IconGate}" 
                                  Fill="{StaticResource TextTertiary}"
                                  Opacity="0.3"
                                  Width="24" Height="24"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"/>
                        </Grid>

                        <!-- Row 1: Status Indicator -->
                        <StackPanel Grid.Row="1" 
                                    Orientation="Horizontal" 
                                    VerticalAlignment="Bottom">

                            <!-- Status Dot -->
                            <Ellipse Width="12" Height="12"
                                     Fill="{Binding Status, Converter={StaticResource TurnstileStatusToBrushConverter}}"
                                     Margin="{StaticResource MarginSmallRight}"/>

                            <!-- Status Text -->
                            <TextBlock Text="{Binding Status, Converter={StaticResource TurnstileStatusToTextConverter}}"
                                       Style="{StaticResource Caption}"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Accessibility Info -->
                    <AutomationProperties.Name>
                        <MultiBinding StringFormat="Turnstile {0}, Status {1}">
                            <Binding Path="Name"/>
                            <Binding Path="Status"/>
                        </MultiBinding>
                    </AutomationProperties.Name>

                    <!-- Technical Tooltip -->
                    <Border.ToolTip>
                        <ToolTip>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding HardwareId, StringFormat='ID: {0}'}"/>
                                <TextBlock Text="{Binding LastHeartbeat, StringFormat='Ping: {0:ss}s ago'}"/>
                            </StackPanel>
                        </ToolTip>
                    </Border.ToolTip>

                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>