public async Task CreateStaffAccountAsync(StaffData data)
{
    // 1. Create invitation record
    var invitationToken = Guid.NewGuid().ToString();
    
    var invitation = await _supabase.From<StaffInvitations>().InsertAsync(new {
        Email = data.Email,
        FullName = data.FullName,
        Role = data.Role,
        InvitedBy = CurrentUser.Id,
        Token = invitationToken,
        ExpiresAt = DateTime.UtcNow.AddDays(7),
        Status = "Pending"
    });
    
    // 2. Create facility access records (pre-approved)
    foreach (var facilityId in data.FacilityIds)
    {
        await _supabase.From<FacilityAccess>().InsertAsync(new {
            InvitationId = invitation.Id,
            FacilityId = facilityId,
            WorkingHours = data.WorkingHours,
            IsActive = false // Activate when they accept
        });
    }
    
    // 3. Create permission records
    foreach (var permission in data.Permissions)
    {
        await _supabase.From<UserPermissions>().InsertAsync(new {
            InvitationId = invitation.Id,
            Permission = permission,
            IsGranted = true
        });
    }
    
    // 4. Send invitation email
    await _emailService.SendInvitationAsync(new {
        To = data.Email,
        Subject = $"You're invited to join {CurrentBusiness.Name}",
        Body = $@"
            Hi {data.FullName},
            
            You've been invited to join {CurrentBusiness.Name} as a {data.Role}.
            
            Facility Access: {string.Join(", ", data.FacilityNames)}
            
            Click here to accept and create your account:
            https://app.yourcompany.com/accept-invitation?token={invitationToken}
            
            This invitation expires in 7 days.
        "
    });
    
    // 5. Show success message
    ShowToast($"Invitation sent to {data.Email}");
}
