<Window x:Class="Management.Presentation.Views.FinanceAndStaff.PayrollView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{DynamicResource SurfaceBg}"
        WindowStyle="None"
        mc:Ignorable="d" 
        d:DesignHeight="600" d:DesignWidth="500">

    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="{DynamicResource SizeModalWidth}"
            Margin="32">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Form (Scrollable) -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="{DynamicResource MarginHeaderBottom}">
                <TextBlock Text="{DynamicResource Terminology.Payroll.Title}" 
                           Style="{DynamicResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Terminology.Payroll.Subtitle}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="{DynamicResource MarginTextTop}"/>
            </StackPanel>

            <!-- 2. Form Content -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          MaxHeight="500"
                          Margin="0,0,0,12">
                <StackPanel>
                    <!-- Staff Selection -->
                    <TextBlock Text="{DynamicResource Terminology.Payroll.SelectStaff}" Style="{DynamicResource FormLabel}"/>
                    <ComboBox ItemsSource="{Binding StaffList}"
                              SelectedItem="{Binding SelectedStaff}"
                              Style="{StaticResource Input.ComboBox}"
                              IsEditable="False"
                              Margin="{DynamicResource MarginSmallBottom}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Payroll Details (Visible when staff selected) -->
                    <StackPanel Visibility="{Binding SelectedStaff, Converter={StaticResource NullToVisibilityConverter}}" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Monthly Salary -->
                            <Border Background="{DynamicResource SurfaceSecondaryBrush}" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Terminology.Payroll.MonthlySalary}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SelectedStaff.BaseSalary, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Format.Currency'}" Style="{DynamicResource ValueMedium}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Absence Tracking -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="{DynamicResource Terminology.Payroll.AbsentDays}" Style="{DynamicResource FormLabel}"/>
                                <TextBox Text="{Binding AbsenceDays, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource UnderlineTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="{DynamicResource Terminology.Payroll.DeductionPerDay}" Style="{DynamicResource FormLabel}"/>
                                <TextBox Text="{Binding DeductionPerDay, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource UnderlineTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Padding="16" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Terminology.Payroll.RemainingBalance}" FontSize="10" Foreground="#AAFFFFFF" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding AmountToPay, StringFormat='{}{0:N2} DA'}" Style="{DynamicResource Title2}" Foreground="White" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Amount to Pay Now -->
                        <TextBlock Text="{DynamicResource Terminology.Payroll.AmountToPay}" Style="{DynamicResource FormLabel}" Margin="0,24,0,0"/>
                        <TextBox Text="{Binding AmountToPay, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{DynamicResource UnderlineTextBox}"
                                 FontSize="18" FontWeight="Bold"
                                 Margin="{DynamicResource MarginSmallBottom}"
                                 Tag="{DynamicResource Strings.FinanceAndStaff.eg5000}"/>

                        <!-- Payment Method -->
                        <TextBlock Text="{DynamicResource Terminology.Payroll.PaymentMethod}" Style="{DynamicResource FormLabel}" Margin="0,12,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <RadioButton Content="{DynamicResource Terminology.Payroll.Cash}" IsChecked="True" Style="{DynamicResource TitanRadioButtonStyle}" Margin="0,0,16,0"/>
                            <RadioButton Content="{DynamicResource Terminology.Payroll.BankTransfer}" Style="{DynamicResource TitanRadioButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 3. Footer Actions -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="24">
                
                <Button Content="{DynamicResource Terminology.Global.Cancel}" 
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource SecondaryButton}"
                        Width="120" Margin="0,0,12,0"/>

                <Button Content="{DynamicResource Terminology.Payroll.ProcessPayment}" 
                        Command="{Binding PayCommand}"
                        Style="{DynamicResource PrimaryButton}"
                        Width="220"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
