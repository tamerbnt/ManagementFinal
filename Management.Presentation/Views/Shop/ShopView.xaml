<UserControl x:Class="Management.Presentation.Views.Shop.ShopView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:local="clr-namespace:Management.Presentation.Views.Shop"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:WindowWidthToColumnsConverter x:Key="WindowWidthToColumnsConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Main Shop Floor -->
            <ColumnDefinition Width="Auto"/>
            <!-- Cart Sidebar (Collapses when hidden) -->
        </Grid.ColumnDefinitions>

        <!-- 1. MAIN CONTENT AREA -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Tabs Content -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" 
                       Text="{DynamicResource TerminologyShopTitle}" 
                       Style="{StaticResource Title1}" 
                       Margin="{StaticResource MarginSectionBottom}"/>

            <!-- Top-Level Navigation Tabs -->
            <!-- Uses GlobalDetailTabStyle for consistent look -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        SelectedIndex="{Binding SelectedTabIndex}">

                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="HorizontalAlignment" Value="Left"/>
                        <Setter Property="Margin" Value="0,0,0,32"/>
                    </Style>
                </TabControl.Resources>

                <!-- TAB 1: PRODUCTS (POS Mode) -->
                <TabItem Header="{DynamicResource TerminologyProductsTab}" Style="{StaticResource GlobalDetailTabStyle}">
                    <Grid Margin="{StaticResource MarginSectionTop}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Filter Bar -->
                            <RowDefinition Height="*"/>
                            <!-- Product Grid -->
                        </Grid.RowDefinitions>

                        <!-- Filter Bar -->
                        <Grid Grid.Row="0" Margin="{StaticResource MarginSectionBottom}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Search -->
                                <ColumnDefinition Width="*"/>
                                <!-- Spacer -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Category Pills -->
                            </Grid.ColumnDefinitions>

                            <!-- Search Box -->
                            <Border Grid.Column="0"
                                    MinWidth="{StaticResource SizeInputMinWidth}"
                                    MaxWidth="{StaticResource SizeSearchBarWidth}"
                                    Height="{StaticResource SizeInputHeight}"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    CornerRadius="{StaticResource RadiusSearchBar}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Path Grid.Column="0"
                                          Data="{StaticResource IconSearch}"
                                          Fill="{DynamicResource TextTertiaryBrush}"
                                          Style="{StaticResource IconStandard}"
                                          Margin="{StaticResource MarginInputIcon}"/>

                                    <TextBox Grid.Column="1"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource UnderlineTextBox}"
                                             BorderThickness="0"
                                             VerticalAlignment="Center"
                                             Tag="{DynamicResource TerminologySearchProductsPlaceholder}"/>
                                </Grid>
                            </Border>

                            <!-- Category Pills -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <RadioButton Content="{DynamicResource TerminologyFilterAllLabel}" 
                                             IsChecked="{Binding FilterAll}" 
                                             Style="{StaticResource TogglePillStyle}"/>

                                <RadioButton Content="{DynamicResource TerminologyFilterSupplementsLabel}" 
                                             IsChecked="{Binding FilterSupplements}" 
                                             Style="{StaticResource TogglePillStyle}"/>

                                <RadioButton Content="{DynamicResource TerminologyFilterApparelLabel}" 
                                             IsChecked="{Binding FilterApparel}" 
                                             Style="{StaticResource TogglePillStyle}"/>

                                <RadioButton Content="{DynamicResource TerminologyFilterEquipmentLabel}" 
                                             IsChecked="{Binding FilterEquipment}" 
                                             Style="{StaticResource TogglePillStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Product Grid -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Products}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.CanContentScroll="True">

                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid VerticalAlignment="Top">
                                        <UniformGrid.Columns>
                                            <!-- Responsive Columns: 4 (>=1440px), 3 (<1440px) -->
                                            <Binding Path="ActualWidth" 
                                                     RelativeSource="{RelativeSource AncestorType=Window}" 
                                                     Converter="{StaticResource WindowWidthToColumnsConverter}">
                                                <Binding.ConverterParameter>
                                                    <sys:Double>1440</sys:Double>
                                                </Binding.ConverterParameter>
                                            </Binding>
                                        </UniformGrid.Columns>
                                    </UniformGrid>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRingStyle}"/>
                                    <!-- Grid Gutter -->
                                    <Setter Property="Margin" Value="{StaticResource MarginCardGridGutter}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- Injected Product Card -->
                                    <local:ProductListItem />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <!-- TAB 2: INVENTORY (Management Mode) -->
                <TabItem Header="{DynamicResource TerminologyInventoryTab}" Style="{StaticResource GlobalDetailTabStyle}">
                    <!-- Injected Inventory Table -->
                    <local:InventoryManagementView Margin="{StaticResource MarginSectionTop}"/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- 2. SHOPPING CART SIDEBAR (Right Column) -->
        <!-- 
             Visibility bound to 'IsCartVisible' in ViewModel.
             If collapsed, the Main Content expands to fill the space.
             Fixed width 400px defined in resources.
        -->
        <local:CartView Grid.Column="1"
                        Width="{StaticResource SizeSidePanelWidth}"
                        Visibility="{Binding IsCartVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</UserControl>