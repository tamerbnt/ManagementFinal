<UserControl x:Class="Management.Presentation.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Management.Presentation.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
             d:DesignHeight="720" d:DesignWidth="560"
             Background="{StaticResource SurfaceBg}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="420" Margin="40,32">

            <!-- Expansion Header (Titan Alert) — logic unchanged -->
            <Border Background="{DynamicResource FacilityAccentDimBrush}"
                    BorderBrush="{DynamicResource FacilityAccentBrush}"
                    BorderThickness="1" CornerRadius="{DynamicResource Corner.MD}"
                    Padding="16,12" Margin="0,0,0,20"
                    Visibility="{Binding IsExpansionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z" 
                          Fill="{DynamicResource FacilityAccentBrush}" Width="16" Height="16"
                          Margin="0,0,12,0" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ExpansionMessage}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Animated Lock Icon -->
            <Grid Width="72" Height="72" Margin="0,0,0,16" HorizontalAlignment="Center">
                <!-- Outer Rotating Ring -->
                <Ellipse Width="64" Height="64" StrokeThickness="1.5" StrokeDashArray="4 2">
                    <Ellipse.Stroke>
                        <SolidColorBrush Color="{DynamicResource FacilityAccentColor}" Opacity="0.35"/>
                    </Ellipse.Stroke>
                    <Ellipse.RenderTransform>
                        <RotateTransform CenterX="32" CenterY="32"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     From="0" To="360" Duration="0:0:20" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <!-- Inner Core Glow -->
                <Ellipse Width="48" Height="48" Opacity="0.15">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{DynamicResource FacilityAccentColor}"/>
                    </Ellipse.Fill>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.1" To="0.25" Duration="0:0:2"
                                                     AutoReverse="True" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <!-- Lock Icon -->
                <Path Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z" 
                      Fill="{DynamicResource FacilityAccentBrush}"
                      Width="22" Height="22" Stretch="Uniform"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Title -->
            <TextBlock Text="{DynamicResource Strings.Auth.Login}"
                       FontSize="26" FontWeight="ExtraBold"
                       Foreground="{DynamicResource Brush.Text.Primary}"
                       Margin="0,0,0,4" HorizontalAlignment="Center"/>
            <TextBlock Text="{DynamicResource Strings.Auth.SecuresignintoyourTitanWo}"
                       TextAlignment="Center" FontSize="13"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       Margin="0,0,0,24" LineHeight="18"/>

            <!-- Email Input -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Strings.Auth.ADMINEMAIL}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                           Margin="0,0,0,8"/>
                <Border Background="{StaticResource SurfaceBg}"
                        CornerRadius="{DynamicResource Corner.MD}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="1.5" Padding="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" 
                              Fill="{DynamicResource Brush.Text.Tertiary}"
                              Width="16" Height="16" Stretch="Uniform"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource Brush.Text.Primary}" 
                                 FontSize="14" Height="40" VerticalContentAlignment="Center"
                                 Margin="0,0,12,0"
                                 CaretBrush="{DynamicResource Brush.Accent.Primary}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Password Input -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Strings.Auth.PASSWORD}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                           Margin="0,0,0,8"/>
                <Border Background="{StaticResource SurfaceBg}"
                        CornerRadius="{DynamicResource Corner.MD}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="1.5" Padding="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <!-- Lock icon -->
                        <Path Grid.Column="0"
                              Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.11,13 12,13A2,2 0 0,0 10,15C10,16.11 10.89,17 12,17M18,8H17V6A5,5 0 0,0 12,1A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M9,6A3,3 0 0,1 12,3A3,3 0 0,1 15,6V8H9V6Z"
                              Fill="{DynamicResource Brush.Text.Tertiary}"
                              Width="16" Height="16" Stretch="Uniform"/>

                        <!-- Password input area: PasswordBox (hidden) overlaid by TextBox (visible) -->
                        <Grid Grid.Column="1">
                            <PasswordBox x:Name="PasswordInput"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource Brush.Text.Primary}"
                                         FontSize="14" Height="40" VerticalContentAlignment="Center"
                                         CaretBrush="{DynamicResource Brush.Accent.Primary}"/>
                            <TextBox x:Name="PasswordTextBox"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource Brush.Text.Primary}"
                                     FontSize="14" Height="40" VerticalContentAlignment="Center"
                                     CaretBrush="{DynamicResource Brush.Accent.Primary}"
                                     Visibility="Collapsed"/>
                        </Grid>

                        <!-- Eye toggle button -->
                        <Button Grid.Column="2"
                                Click="TogglePasswordVisibility_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="Show/Hide password"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Width="32" Height="32" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid Width="18" Height="18">
                                <!-- Eye open — shown when password is hidden -->
                                <Path x:Name="EyeOpenIcon"
                                      Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                      Fill="{DynamicResource Brush.Text.Tertiary}"
                                      Stretch="Uniform"/>
                                <!-- Eye closed — shown when password is visible -->
                                <Path x:Name="EyeClosedIcon"
                                      Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.22 16.38,18.7L16.81,19.13L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.76 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z"
                                      Fill="{DynamicResource Brush.Text.Tertiary}"
                                      Stretch="Uniform" Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                    </Grid>
                </Border>
            </StackPanel>

            <!-- Facility Selector -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{DynamicResource Strings.Auth.SELECTFACILITY}"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                           Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding AvailableFacilities}" 
                         SelectedItem="{Binding SelectedFacility}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="3"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border"
                                                Background="{StaticResource SurfaceBgSecondary}"
                                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                BorderThickness="1.5" CornerRadius="12"
                                                Margin="4" Padding="0" Height="48"
                                                ToolTip="{Binding Name}">
                                            <Grid>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource FacilityAccentDimBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Surface.Hover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                               <Path x:Name="Icon" Fill="{DynamicResource Brush.Text.Tertiary}"
                                     Width="16" Height="16" Stretch="Uniform" Margin="0,0,0,2"/>
                               <TextBlock x:Name="Text" Text="{Binding Name}"
                                          FontSize="9" FontWeight="SemiBold"
                                          Foreground="{DynamicResource Brush.Text.Secondary}"
                                          HorizontalAlignment="Center"/>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                 <DataTrigger Binding="{Binding IconKey}" Value="Icon.Dumbbell">
                                     <Setter TargetName="Icon" Property="Data" Value="M20.57,14.86L22,13.43L20.57,12L17,15.57L8.43,7L12,3.43L10.57,2L9.14,3.43L7.71,2L5.57,4.14L4.14,2.71L2.71,4.14L4.14,5.57L2,7.71L3.43,9.14L2,10.57L3.43,12L7,8.43L15.57,17L12,20.57L13.43,22L14.86,20.57L16.29,22L18.43,19.86L19.86,21.29L21.29,19.86L19.86,18.43L22,16.29L20.57,14.86Z"/>
                                 </DataTrigger>
                                 <DataTrigger Binding="{Binding IconKey}" Value="Icon.Scissors">
                                     <Setter TargetName="Icon" Property="Data" Value="M6,2C6,2 6,3 7,3C7,3 10,6 10,6L13,3C13,3 13,2 14,2C15.5,2 16,3 16,3C16,3 13,6.5 13,6.5L18,11.5L20.5,9C20.5,9 21.5,10 21.5,11.5C21.5,12 21,12 21,12L16,17C16,17 14,19 14,20.5C14,22 13,23 11.5,23C10,23 9,21.5 9,20.5C9,19 11,17 11,17L12,16L7,11C7,11 6,13 6,13C6,13 2,13 2,11.5C2,10 3,9 3,9L5.5,6.5L2,3C2,3 2.5,2 4,2C5,2 6,2 6,2M10,8.5L8.5,10L10,11.5L11.5,10L10,8.5Z"/>
                                 </DataTrigger>
                                 <DataTrigger Binding="{Binding IconKey}" Value="Icon.Utensils">
                                     <Setter TargetName="Icon" Property="Data" Value="M11,9H9V2H7V9H5V2H3V9C3,11.12 4.66,12.84 6.75,12.97V22H9.25V12.97C11.34,12.84 13,11.12 13,9V2H11V9M16,6V14H18.5V22H21V2C18.24,2 16,4.24 16,6Z"/>
                                 </DataTrigger>
                                 <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                     <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource FacilityAccentBrush}"/>
                                     <Setter TargetName="Text" Property="Foreground" Value="{DynamicResource FacilityAccentBrush}"/>
                                 </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Actions Row (Remember Me + Forgot Password) -->
            <Grid Margin="0,0,0,16">
                <CheckBox Content="{DynamicResource Strings.Auth.Rememberdevice}"
                          IsChecked="{Binding RememberMe}"
                          Foreground="{DynamicResource Brush.Text.Secondary}"
                          FontSize="12" VerticalContentAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" FontSize="12">
                    <Hyperlink Command="{Binding ForgotPasswordCommand}"
                               Foreground="{DynamicResource Brush.Accent.Primary}"
                               FontWeight="SemiBold" TextDecorations="{x:Null}">
                        Forgot Password?
                    </Hyperlink>
                </TextBlock>
            </Grid>

            <!-- Error State -->
            <StackPanel Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,0,0,16">
                <Border Background="{StaticResource StatusErrorBackground}"
                        BorderBrush="{DynamicResource Brush.Danger}"
                        BorderThickness="1" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Data="M13,13H11V7H13M13,17H11V15H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" 
                              Fill="{DynamicResource Brush.Danger}"
                              Width="14" Height="14" Stretch="Uniform"
                              VerticalAlignment="Top" Margin="0,2,0,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource Brush.Danger}"
                                   FontSize="12" TextWrapping="Wrap" Margin="10,0,0,0"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Initialization State -->
            <StackPanel Visibility="{Binding IsInitializingApp, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,0,0,16">
                <TextBlock Text="{Binding AppInitializationStatus}"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <ProgressBar IsIndeterminate="True" Height="3"
                             Foreground="{DynamicResource Brush.Accent.Primary}"
                             Background="{DynamicResource Brush.Border.Subtle}"
                             BorderThickness="0"/>
            </StackPanel>

            <!-- Sign In Button -->
            <Button Command="{Binding LoginCommand}"
                    CommandParameter="{Binding ElementName=PasswordInput}"
                    Height="50" IsDefault="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="border" CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                        <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <StaticResource ResourceKey="ShadowGlow"/>
                                </Border.Effect>
                                <Grid>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ContentPresenter.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{DynamicResource Strings.Auth.LaunchDashboard}"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource Brush.Neutral.White}"
                                                           FontSize="14"/>
                                                <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                                      Fill="{DynamicResource Brush.Neutral.White}"
                                                      Width="12" Height="12" Stretch="Uniform" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </ContentPresenter.Content>
                                    </ContentPresenter>
                                </Grid>
                            </Border>
                            <Border x:Name="busyBorder" CornerRadius="12"
                                    Background="{DynamicResource Brush.Surface.Glass.Eco}"
                                    Opacity="0.95" Visibility="Collapsed">
                                <TextBlock Text="{DynamicResource Strings.Auth.Authenticating}"
                                           Foreground="{DynamicResource Brush.Neutral.White}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="13"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter TargetName="busyBorder" Property="Visibility" Value="Visible"/>
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Border.Subtle}"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
