<UserControl x:Class="Management.Presentation.Views.Registrations.ConfirmDeclineModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <!-- 
        Modal Container
        - Style: 'GlobalModalContainerStyle' (Encapsulates Shadow L3, Radius 24px, ContentBackground)
        - Behavior: 'ModalEntranceBehavior' (Handles Zoom/Fade entrance safely)
        - Width: Fixed 480px per Section 19.3
    -->
    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="{DynamicResource SizeModalWidth}"
            Padding="{DynamicResource PaddingModal}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            
            AutomationProperties.Name="Decline Registration Confirmation"
            AutomationProperties.HelpText="Confirms permanent decline of registration">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <StackPanel>
            <!-- 1. Status Icon -->
            <Grid Margin="{DynamicResource MarginHeaderBottom}">
                <!-- Success Icon -->
                <Path Data="{DynamicResource IconCheck}"
                      Fill="{DynamicResource StatusSuccessBrush}"
                      Style="{DynamicResource Style.Icon.Hero}"
                      Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                
                <!-- Warning Icon -->
                <Path Data="{DynamicResource IconWarning}"
                      Fill="{DynamicResource StatusWarningBrush}"
                      Style="{DynamicResource Style.Icon.Hero}"
                      Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse, FallbackValue=Visible}"/>
            </Grid>

            <!-- 2. Title -->
            <TextBlock Text="{Binding Title, FallbackValue='Confirmation'}"
                       Style="{DynamicResource Title2}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="{DynamicResource MarginHeaderBottom}"/>

            <!-- 3. Message (Scrollable for overflow protection) -->
            <ScrollViewer MaxHeight="240" 
                          VerticalScrollBarVisibility="Auto"
                          Margin="{DynamicResource MarginSectionBottom}">
                <TextBlock Text="{Binding Message}"
                           Style="{DynamicResource Body}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </ScrollViewer>

            <!-- 4. Action Buttons -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center">

                <!-- Cancel (Secondary) - Hidden if Alert -->
                <Button Content="{Binding CancelText, FallbackValue='Cancel'}"
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource SecondaryButton}"
                        MinWidth="{DynamicResource SizeButtonMinWidth}"
                        Margin="{DynamicResource MarginSmallRight}"
                        Visibility="{Binding IsAlert, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                <!-- Confirm (Destructive or Primary) -->
                <Button Content="{Binding ConfirmText, FallbackValue='OK'}"
                        Command="{Binding ConfirmCommand}"
                        MinWidth="{DynamicResource SizeButtonMinWidth}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDestructive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource StatusErrorBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource StatusErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
