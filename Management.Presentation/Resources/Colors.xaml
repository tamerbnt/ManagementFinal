	<SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
	<SolidColorBrush x:Key="TextTertiaryBrush" Color="#757575"/>
	<SolidColorBrush x:Key="TextOnDarkBrush" Color="#FFFFFF"/>
	<SolidColorBrush x:Key="TextDimOnDarkBrush" Color="#B0BEC5"/>
	<SolidColorBrush x:Key="StatusSuccessBrush" Color="#00E676"/>
	<SolidColorBrush x:Key="StatusWarningBrush" Color="#FFB300"/>
	<SolidColorBrush x:Key="StatusErrorBrush" Color="#FF5252"/>
	<SolidColorBrush x:Key="CardBackgroundBrush" Color="#FAFBFD"/>
	<SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FFFFFF"/>
	<SolidColorBrush x:Key="SidebarHoverBrush" Color="#0F3D92"/>
	<SolidColorBrush x:Key="FocusRingBrush" Color="#5B8AB8"/>
	<SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#A8D8F0" Opacity="0.2"/>
	<SolidColorBrush x:Key="ActiveNavigationBorderBrush" Color="#5B8AB8"/>
	<SolidColorBrush x:Key="HoverLightBgBrush" Color="#F5F7FA"/>
	<SolidColorBrush x:Key="IllustrationBackgroundBrush" Color="#F0F4F8"/>
</ResourceDictionary>