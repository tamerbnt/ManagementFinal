<Window x:Class="Management.Presentation.Views.FinanceAndStaff.PayrollHistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{DynamicResource SurfaceBg}"
        WindowStyle="None"
        Title="{DynamicResource Terminology.Payroll.History.Title}"
        d:DesignHeight="640" d:DesignWidth="720">
    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="500"
            Margin="32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Alerts -->
                <RowDefinition Height="*"/>    <!-- History -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header (Centered, matching Run Payroll) -->
            <StackPanel Grid.Row="0" Margin="{DynamicResource MarginHeaderBottom}">
                <TextBlock Text="{DynamicResource Terminology.Payroll.History.Title}" 
                           Style="{DynamicResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Terminology.Payroll.History.Subtitle}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="{DynamicResource MarginTextTop}"/>
            </StackPanel>

            <!-- 2. Alerts Banner (Pending Payments) -->
            <Border Grid.Row="1" Margin="0,0,0,24" Background="{DynamicResource FacilityAccentBrush}" CornerRadius="12" Padding="16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TodayAlerts.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding TodayAlerts.Count, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Terminology.Payroll.History.PaymentDueToday}" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text=" âš " FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <ItemsControl ItemsSource="{Binding TodayAlerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" 
                                            Content="{DynamicResource Terminology.Payroll.History.PayNow}" 
                                            Command="{Binding DataContext.PayCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding StaffId}"
                                            Style="{DynamicResource SecondaryButton}"
                                            Height="28" Padding="12,0" FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 3. History List -->
            <ScrollViewer Grid.Row="2" 
                          VerticalScrollBarVisibility="Auto" 
                          MaxHeight="400"
                          Margin="0,0,0,12">
                <Grid>
                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,40">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding History.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="ðŸ“‹" FontSize="32" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="{DynamicResource Terminology.Payroll.History.NoHistory}" 
                                   Style="{DynamicResource Body}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" 
                                   Margin="0,8,0,0" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- List -->
                    <ItemsControl ItemsSource="{Binding History}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceSecondaryBrush}" CornerRadius="12" Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Staff & Date -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StaffName}" Style="{DynamicResource Body}" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="{DynamicResource Terminology.Payroll.History.PaidOn}"/><Run Text=" "/><Run Text="{Binding Date, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Format.Date.Short'}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Amount -->
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="16,0">
                                            <TextBlock Text="{Binding PaidAmount, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Format.Currency'}" 
                                                       Style="{DynamicResource ValueSmall}" 
                                                       HorizontalAlignment="Right"/>
                                            
                                            <!-- Partial Warning -->
                                            <TextBlock FontSize="10" Foreground="{DynamicResource StatusWarningBrush}" HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPartial}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{DynamicResource Terminology.Payroll.History.Of}"/>
                                                <Run Text="{Binding TotalAmount, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Format.Currency'}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Badge/Action -->
                                        <Grid Grid.Column="2" VerticalAlignment="Center">
                                            <!-- Paid Badge -->
                                            <Border CornerRadius="6" Background="{DynamicResource StatusSuccessBackground}" Padding="8,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{DynamicResource Terminology.Payroll.History.Paid}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource StatusSuccessBrush}"/>
                                            </Border>

                                            <!-- Pay Button (if pending/partial) -->
                                            <Button Command="{Binding DataContext.PayCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding StaffId}"
                                                    ToolTip="{DynamicResource Terminology.Payroll.History.Tooltip.CompletePayment}"
                                                    Height="32" Padding="12,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paid">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{DynamicResource Terminology.Payroll.History.Pay}" FontSize="11" FontWeight="Bold"/>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- 4. Footer -->
            <StackPanel Grid.Row="3" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="{DynamicResource Terminology.Global.Close}" 
                        Command="{Binding CloseCommand}"
                        Style="{DynamicResource SecondaryButton}"
                        Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
