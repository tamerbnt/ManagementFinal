#### **Logic Flow**

```csharp
// Pseudo-code for activation
public async Task ActivateLicenseAsync(string licenseKey, FacilityType facility)
{
    // 1. Generate hardware ID
    var hardwareId = HardwareIdService.Generate();
    
    // 2. Validate license key format
    if (!LicenseValidator.IsValidFormat(licenseKey))
    {
        ShowError("Invalid license key format");
        return;
    }
    
    // 3. Check with Supabase
    var response = await _licenseApi.ValidateAndActivateAsync(new {
        LicenseKey = licenseKey,
        HardwareId = hardwareId,
        FacilityType = facility,
        DeviceName = Environment.MachineName,
        ActivatedAt = DateTime.UtcNow
    });
    
    // 4. Handle response
    if (response.IsSuccess)
    {
        if (response.IsFirstActivation)
        {
            // First PC → Go to Owner Onboarding
            NavigateToOnboarding();
        }
        else
        {
            // 2nd or 3rd PC → Go to Login
            NavigateToLogin();
        }
        
        // Store license locally (encrypted)
        await SecureStorage.SaveAsync("license", new {
            LicenseKey = licenseKey,
            HardwareId = hardwareId,
            Facility = facility,
            ActivatedAt = response.ActivatedAt
        });
    }
    else
    {
        ShowError(response.ErrorMessage);
        // e.g., "License already activated on 3 devices"
    }
}
```

#### **Database Schema (Supabase)**

```sql
-- licenses table
CREATE TABLE licenses (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    license_key VARCHAR(50) UNIQUE NOT NULL,
    owner_email VARCHAR(255),
    business_name VARCHAR(255),
    max_activations INT DEFAULT 3,
    created_at TIMESTAMP DEFAULT NOW(),
    expires_at TIMESTAMP,
    is_active BOOLEAN DEFAULT TRUE
);

-- license_activations table
CREATE TABLE license_activations (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    license_id UUID REFERENCES licenses(id),
    hardware_id VARCHAR(100) UNIQUE NOT NULL,
    facility_type VARCHAR(20), -- 'Gym', 'Salon', 'Restaurant'
    device_name VARCHAR(100),
    activated_at TIMESTAMP DEFAULT NOW(),
    last_seen_at TIMESTAMP DEFAULT NOW(),
    is_active BOOLEAN DEFAULT TRUE,
    
    UNIQUE(license_id, hardware_id)
);

-- Check constraint: max 3 activations per license
CREATE OR REPLACE FUNCTION check_activation_limit()
RETURNS TRIGGER AS $$
BEGIN
    IF (SELECT COUNT(*) FROM license_activations 
        WHERE license_id = NEW.license_id AND is_active = TRUE) >= 3 THEN
        RAISE EXCEPTION 'License activation limit reached (3/3)';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER enforce_activation_limit
    BEFORE INSERT ON license_activations
    FOR EACH ROW EXECUTE FUNCTION check_activation_limit();
```

#### **Enhancements**

1. **Offline Activation**: Allow license file upload for air-gapped systems
2. **Hardware Change Detection**: Alert if hardware ID changes (reinstall/upgrade)
3. **Grace Period**: 7-day offline operation before revalidation required
4. **Transfer License**: Allow owner to deactivate one device and activate another

