<UserControl x:Class="Management.Presentation.Views.Shell.DashboardView"
             x:Name="DashboardRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:data="clr-namespace:Management.Presentation.Components.Data"
             xmlns:controls="clr-namespace:Management.Presentation.Resources.Controls"
             xmlns:shell="clr-namespace:Management.Presentation.ViewModels.Shell"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:dashcomps="clr-namespace:Management.Presentation.Components.Dashboard"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="Transparent">
    <UserControl.Resources>
        <controls:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <converters:TerminologyConverter x:Key="TerminologyConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter"/>
        <converters:EqualToVisibilityConverter x:Key="EqualToVisibilityConverter"/>

        <!-- Mini Mode Toggle for Detail/Summary switching in Cards -->
        <Style x:Key="Style.MiniModeToggle" TargetType="ToggleButton">
            <Setter Property="Height" Value="28" />
            <Setter Property="Width" Value="80" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Background="#F1F5F9" CornerRadius="14" BorderBrush="#CBD5E1" BorderThickness="1">
                            <Grid>
                                <!-- Icons -->
                                <Grid Margin="8,0">
                                    <Path x:Name="GraphIcon" Data="M19,3H5C3.89,3 3,3.9 3,5V19C3,20.1 3.89,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.9 20.1,3 19,3M9,17H7V10H9V17M13,17H11V7H13V17M17,17H15V12H17V17Z" 
                                          Fill="#94A3B8" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Left" />
                                    <Path x:Name="ListIcon" Data="M3,4H21V6H3V4M3,9H21V11H3V9M3,14H21V16H3V14M3,19H21V21H3V19Z" 
                                          Fill="#94A3B8" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Right" />
                                </Grid>
                                <!-- Thumb -->
                                <Border x:Name="Thumb" Background="White" Width="36" Height="22" CornerRadius="11" HorizontalAlignment="Left" Margin="2">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1" Color="#000000"/>
                                    </Border.Effect>
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTransform" X="0" />
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="38" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Premium Dashboard Mode Toggle Style -->
        <Style x:Key="Style.DashboardModeToggle" TargetType="ToggleButton">
            <Setter Property="Height" Value="44" />
            <Setter Property="Width" Value="250" /> <!-- Slightly wider to accommodate track arrows -->
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <!-- Outer Track (Grey/Dark Pill) -->
                            <Border x:Name="Track" 
                                    Background="#F1F5F9" 
                                    CornerRadius="22" 
                                    BorderBrush="#CBD5E1" 
                                    BorderThickness="1.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                                                <Setter Property="Background" Value="#1E293B"/>
                                                <Setter Property="BorderBrush" Value="#475569"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!-- Stationary Arrows (In the Track Area) -->
                            <Grid Margin="16,0">
                                <!-- Back Arrow (Visible on the left when thumb is on the right) -->
                                <Path x:Name="BackArrow" 
                                      Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                                      Fill="White" 
                                      Width="14" Height="14" Stretch="Uniform" 
                                      HorizontalAlignment="Left" VerticalAlignment="Center"
                                      Opacity="0" Visibility="Visible"/>
                                      
                                <!-- Forward Arrow (Visible on the right when thumb is on the left) -->
                                <Path x:Name="ForwardArrow" 
                                      Data="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" 
                                      Fill="{DynamicResource FacilityAccentBrush}" 
                                      Width="14" Height="14" Stretch="Uniform" 
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Opacity="1" Visibility="Visible"/>
                            </Grid>

                            <!-- Animated Thumb (The Moving Pill) -->
                            <Border x:Name="Thumb" 
                                    Background="White" 
                                    CornerRadius="19" 
                                    Margin="3" 
                                    HorizontalAlignment="Left"
                                    Width="184"
                                    Effect="{StaticResource Shadow.Level2}">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Border.RenderTransform>
                                <TextBlock x:Name="ThumbText" 
                                           Text="{DynamicResource Terminology.Dashboard.View.SwitchToBusiness}" 
                                           FontWeight="Bold" 
                                           FontSize="11" 
                                           Foreground="#1E293B" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                 <Setter TargetName="ThumbText" Property="Text" Value="{DynamicResource Terminology.Dashboard.View.SwitchToOperations}" />
                                 <Setter TargetName="ThumbText" Property="Foreground" Value="White" />
                                 <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource FacilityAccentBrush}" />
                                 <Trigger.EnterActions>
                                     <BeginStoryboard>
                                         <Storyboard>
                                             <DoubleAnimation Storyboard.TargetName="ThumbTransform" 
                                                              Storyboard.TargetProperty="X" 
                                                              To="60" Duration="0:0:0.35">
                                                 <DoubleAnimation.EasingFunction>
                                                     <QuarticEase EasingMode="EaseInOut" />
                                                 </DoubleAnimation.EasingFunction>
                                             </DoubleAnimation>
                                             <DoubleAnimation Storyboard.TargetName="ForwardArrow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                                             <DoubleAnimation Storyboard.TargetName="BackArrow" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.2" Duration="0:0:0.15" />
                                         </Storyboard>
                                     </BeginStoryboard>
                                 </Trigger.EnterActions>
                                 <Trigger.ExitActions>
                                     <BeginStoryboard>
                                         <Storyboard>
                                             <DoubleAnimation Storyboard.TargetName="ThumbTransform" 
                                                              Storyboard.TargetProperty="X" 
                                                              To="0" Duration="0:0:0.35">
                                                 <DoubleAnimation.EasingFunction>
                                                     <QuarticEase EasingMode="EaseInOut" />
                                                 </DoubleAnimation.EasingFunction>
                                             </DoubleAnimation>
                                             <DoubleAnimation Storyboard.TargetName="BackArrow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                                             <DoubleAnimation Storyboard.TargetName="ForwardArrow" Storyboard.TargetProperty="Opacity" To="1" BeginTime="0:0:0.2" Duration="0:0:0.15" />
                                         </Storyboard>
                                     </BeginStoryboard>
                                 </Trigger.ExitActions>
                            </Trigger>
                            
                            <Trigger Property="IsMouseOver" Value="True">
                                 <Setter TargetName="Thumb" Property="Effect" Value="{StaticResource Shadow.Level3}" />
                            </Trigger>

                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Row 0: Header -->
            <RowDefinition Height="Auto" /> <!-- Row 1: Bento Stats -->
            <RowDefinition Height="*" />    <!-- Row 2: Content (Chart + Activity) -->
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Grid Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Path Data="{StaticResource IconDashboard}" 
                      Style="{StaticResource Style.Icon.Large}" 
                      Stroke="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,12,0"
                      VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Terminology.Dashboard.Title}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{DynamicResource Terminology.Dashboard.Subtitle}" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            
            <!-- Context Action & Toggle -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- Unified Header Actions -->
                <StackPanel Orientation="Horizontal">
                    
                    <!-- Switch View Button -->
                    <!-- Premium View Switcher Toggle -->
                    <ToggleButton IsChecked="{Binding IsBusinessMode}"
                                  Style="{StaticResource Style.DashboardModeToggle}"
                                  Margin="0,0,12,0"/>


                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ========================== -->
        <!-- OPERATIONS VIEW (Original) -->
        <!-- ========================== -->
        <Grid Grid.Row="1" Grid.RowSpan="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Row 1: Bento Grid Stats -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" /> <!-- Hero -->
                    <ColumnDefinition Width="1*" />   <!-- Standard -->
                    <ColumnDefinition Width="1*" />   <!-- Split Column -->
                    <ColumnDefinition Width="1*" />   <!-- Actions/Extra -->
                </Grid.ColumnDefinitions>

                <!-- 1. Hero Card: People Inside (Gym) / Today's Appointments (Salon) -->
                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <!-- Gym: People Inside -->
                    <Border CornerRadius="16" Background="{DynamicResource FacilitySidebarBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect><StaticResource ResourceKey="Shadow.Level3"/></Border.Effect>
                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- HEADER: Icon + Label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                                <Border Width="24" Height="24" CornerRadius="8" Background="White" Opacity="0.1" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconGym}" Stroke="White" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Foreground="White" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.PeopleInside}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.LiveTableStatus}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="{Binding PeopleInside}" Foreground="White" FontSize="48" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Grid.Row="2" CornerRadius="12" HorizontalAlignment="Left" Padding="8,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasPeopleInsideTrend}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding PeopleInsideTrendText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            
                            <!-- Restaurant: Table Seating Percent -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Visibility="{Binding IsRestaurantMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Background="{DynamicResource FacilityAccentBrush}" CornerRadius="10" Padding="8,3" Margin="0,0,8,0">
                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                        <Run Text="{Binding ActiveTablesCount}"/><Run Text="/"/><Run Text="{Binding TotalTablesCount}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.TablesOccupied}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Salon: Today's Appointments -->
                    <Border CornerRadius="16" Background="{DynamicResource FacilitySidebarBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect><StaticResource ResourceKey="Shadow.Level3"/></Border.Effect>
                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- HEADER: Icon + Label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                                <Border Width="24" Height="24" CornerRadius="8" Background="White" Opacity="0.15" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconClock}" Stroke="White" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Stat.TodaysAppointments}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="{Binding TodayAppointmentsTotal}" Foreground="White" FontSize="48" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <Border Background="{DynamicResource StatusSuccessBrush}" CornerRadius="10" Padding="8,3" Margin="0,0,8,0">
                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                        <Run Text="&#x2713; "/><Run Text="{Binding TodayAppointmentsCompleted}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.Stat.Done}"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="#30FFFFFF" CornerRadius="10" Padding="8,3">
                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                        <Run Text="&#x23F3; "/><Run Text="{Binding TodayAppointmentsPending}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.Stat.Upcoming}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2. Active Members (Gym) / Today's Covers (Restaurant) -->
                <data:StatTile Grid.Column="1" Margin="0,0,16,0" 
                               Value="{Binding TotalActiveMembers}" 
                               IconData="{StaticResource IconMembers}" 
                               IconBrush="{DynamicResource StatusSuccessBrush}" 
                               IsLoading="{Binding IsLoading}">
                    <data:StatTile.Style>
                        <Style TargetType="data:StatTile">
                            <Setter Property="Label" Value="{DynamicResource Terminology.Dashboard.Stat.ActiveMembers}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                    <Setter Property="Label" Value="{DynamicResource Terminology.Dashboard.Stat.CoversToday}"/>
                                    <Setter Property="Value" Value="{Binding TodayCovers}"/>
                                    <Setter Property="IconData" Value="{StaticResource IconMembers}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                    <Setter Property="Label" Value="{DynamicResource Terminology.Dashboard.Stat.ActiveClients}"/>
                                    <Setter Property="Value" Value="{Binding TotalActiveMembers}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </data:StatTile.Style>
                </data:StatTile>

                <!-- 3. Split Column (Expiring / Pending) -->
                <Grid Grid.Column="2" Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" /> <!-- Spacer -->
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Expiring -->
                    <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16">
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level1"/>
                        </Border.Effect>
                        <Grid Margin="16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- HEADER: Icon + Label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,12">
                                <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource StatusWarningBackground}" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconClock}" Stroke="{DynamicResource StatusWarningBrush}" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.ExpiringSoon}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.AverageOrderValue}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Row="1" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding ExpiringSoonCount}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                <Setter Property="Text" Value="{Binding AverageOrderValue, StringFormat='{}{0:N1} DA'}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Pending -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16">
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level1"/>
                        </Border.Effect>
                        <Grid Margin="16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- HEADER: Icon + Label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,12">
                                <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource StatusErrorBackground}" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconRegistrations}" Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.PendingRegs}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.PendingOrders}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Row="1" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding PendingRegistrationsCount}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                <Setter Property="Text" Value="{Binding PendingOrdersCount}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 4. Revenue Snapshot (Replaces Quick Actions) -->
                 <Border Grid.Column="3" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="16">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2"/>
                    </Border.Effect>
                    <Grid Margin="20">
                         <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                            <Border Background="#20FFFFFF" Width="24" Height="24" CornerRadius="8" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconFinance}" Stroke="White" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/> 
                            </Border>
                            <TextBlock Text="{DynamicResource Terminology.Home.RevenueToday}" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                             <TextBlock Text="{Binding FinancialSummary.Revenue, StringFormat='{}{0:N2} DA'}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                             <ProgressBar Value="{Binding RevenueProgress}" Maximum="1" Height="4" Background="#20FFFFFF" Foreground="{DynamicResource FacilityAccentBrush}" BorderThickness="0" Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding RevenueProgress, StringFormat={}{0:P0}}" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" FontSize="12"/>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Stat.DailyTarget}" Foreground="White" Opacity="0.7" FontSize="12" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 2: Content Grid (Chart Left, Member Dev Right) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*" /> <!-- Occupancy Chart -->
                    <ColumnDefinition Width="1.2*" /> <!-- Member Development -->
                </Grid.ColumnDefinitions>

                <!-- Chart Section -->
            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,24,0">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2"/>
                    </Border.Effect>
                    <Grid Margin="32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- HEADER: Icon + Label + Filter -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource StatusSuccessBackground}" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconDashboard}" Fill="{DynamicResource StatusSuccessBrush}" Stroke="{DynamicResource StatusSuccessBrush}" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Terminology.Dashboard.Chart.Occupancy.Title}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{DynamicResource Terminology.Dashboard.Chart.Occupancy.Subtitle}" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- DAY FILTERS -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FormattedOccupancyDate}" VerticalAlignment="Center" Margin="0,0,12,0" 
                                           Foreground="{DynamicResource FacilityAccentBrush}" FontWeight="SemiBold" FontSize="12"/>
                                
                                <Border Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="12" Padding="4">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Today Button -->
                                        <Button Command="{Binding SetOccupancyFilterCommand}" CommandParameter="Today"
                                                Padding="12,4" Margin="2,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedOccupancyDate}" Value="{x:Static System:DateTime.Today}">
                                                            <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Range.Today}"/>
                                        </Button>
                                        
                                        <!-- Yesterday Button -->
                                        <Button Command="{Binding SetOccupancyFilterCommand}" CommandParameter="Yesterday"
                                                Padding="12,4" Margin="2,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <!-- Need a property for yesterday or just use a helper -->
                                                        <DataTrigger Binding="{Binding FormattedOccupancyDate}" Value="YESTERDAY">
                                                            <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Range.Yesterday}"/>
                                        </Button>
                                        
                                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,2"/>
                                        
                                        <!-- Calendar Select -->
                                        <Grid Margin="2,0">
                                            <DatePicker SelectedDate="{Binding SelectedOccupancyDate, Mode=TwoWay}"
                                                       Width="32" Height="28" Opacity="0" 
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <Button Style="{StaticResource Button.Ghost}" Padding="8,4" IsHitTestVisible="False"
                                                    ToolTip="{DynamicResource Terminology.Dashboard.Action.SelectDate}">
                                                <Path Data="{StaticResource IconCalendar}" Stroke="White" StrokeThickness="1.5" Width="14" Height="12" Stretch="Uniform"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                
                                <!-- Loading Spinner (Granular) -->
                                <Border Width="16" Height="16" Margin="12,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsOccupancyLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Path Data="M12,4V2A10,10 0 0,0 2,12H4A8,8 0 0,1 12,4Z" Fill="{DynamicResource FacilityAccentBrush}" RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="Rotator" Angle="0"/>
                                        </Path.RenderTransform>
                                        <Path.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="Rotator" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Path.Triggers>
                                    </Path>
                                </Border>
                            </StackPanel>
                        </Grid>
                        
                        <lvc:CartesianChart Grid.Row="1" Margin="0,24,0,0"
                                            Series="{Binding OccupancySeries}" 
                                            XAxes="{Binding OccupancyXAxes}"
                                            YAxes="{Binding OccupancyYAxes}" 
                                            TooltipPosition="Top">
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <!-- Right Panel: Member Development Trend (High Fidelity) -->
                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,0">
                    <dashcomps:RevenueByPlanCard VerticalAlignment="Stretch" Margin="0,0,0,0">
                        <dashcomps:RevenueByPlanCard.Style>
                            <Style TargetType="dashcomps:RevenueByPlanCard">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </dashcomps:RevenueByPlanCard.Style>
                    </dashcomps:RevenueByPlanCard>

                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGymMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level2" />
                        </Border.Effect>
                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header Row: Icon + Title (left) | Month Navigator (right) -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                                    <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource StatusSuccessBackground}" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource IconMembers}" Fill="{DynamicResource StatusSuccessBrush}" Stroke="{DynamicResource StatusSuccessBrush}" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Data" Value="{StaticResource IconMembers}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                            <Setter Property="Data" Value="{StaticResource IconMembers}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Strings.Shell.MemberDevelopment}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{DynamicResource Strings.Shell.Totalactivememberstrend}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right: Month Navigation -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Command="{Binding PreviousMonthCommand}" Cursor="Hand" Style="{StaticResource IconButtonStyle}" Padding="6,4">
                                        <Path Data="{StaticResource IconChevronLeft}" Fill="{DynamicResource TextSecondaryBrush}" Width="8" Height="12" Stretch="Uniform"/>
                                    </Button>
                                    <TextBlock Text="{Binding FormattedSelectedMonth}" FontWeight="SemiBold" FontSize="12" Margin="8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Button Command="{Binding NextMonthCommand}" Cursor="Hand" Style="{StaticResource IconButtonStyle}" Padding="6,4">
                                        <Path Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextSecondaryBrush}" Width="8" Height="12" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <lvc:CartesianChart Grid.Row="1" 
                                              Series="{Binding MemberSeries}" 
                                              XAxes="{Binding MemberXAxes}"
                                              YAxes="{Binding MemberYAxes}"
                                              TooltipPosition="Top"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ========================== -->
        <!-- BUSINESS VIEW (New)        -->
        <!-- ========================== -->
        <ScrollViewer Grid.Row="1" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            
            <!-- Row 1: Financial Cards -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" /> <!-- Hero -->
                    <ColumnDefinition Width="1*" />   <!-- Revenue -->
                    <ColumnDefinition Width="1*" />   <!-- Expenses -->
                </Grid.ColumnDefinitions>

                <!-- 1. Master Financial Card -->
                <Border Grid.Column="0" Margin="0,0,16,0" CornerRadius="16" Height="170" Background="{DynamicResource FacilitySidebarBrush}">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Modal" />
                    </Border.Effect>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- HEADER: Icon + Label -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                            <Border Width="24" Height="24" CornerRadius="8" Background="White" Opacity="0.1" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconFinance}" Stroke="White" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Business.NetProfitToday}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Strings.Shell.DA}" Foreground="White" FontSize="32" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="0,0,4,6"/>
                            <TextBlock Text="{Binding FinancialSummary.NetProfit, StringFormat=N0}" Foreground="White" FontSize="48" FontWeight="Bold" VerticalAlignment="Bottom"/>
                        </StackPanel>
                        
                        <Border Grid.Row="2" Background="{Binding FinancialSummary.NetProfitPercentChange, Converter={StaticResource TrendToBrushConverter}, ConverterParameter='NetProfit_Background'}" CornerRadius="12" HorizontalAlignment="Left" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{Binding FinancialSummary.NetProfitPercentChange, Converter={StaticResource TrendToIconConverter}, ConverterParameter='NetProfit_Icon'}" Stroke="White" StrokeThickness="2" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding FinancialSummary.NetProfitPercentChange, StringFormat='{}{0:F1}% '}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.VsYesterday}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 2. Revenue Card -->
                <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,16,0" Height="170">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2" />
                    </Border.Effect>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- HEADER: Icon + Label -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                            <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource BackgroundBrush}" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconFinance}" Stroke="{DynamicResource BrandPrimaryBrush}" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Business.Revenue}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="{Binding FinancialSummary.Revenue, StringFormat='{}{0:N2} DA'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="32" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding FinancialSummary.RevenuePercentChange, StringFormat='{}{0:F1}%'}" Foreground="{Binding FinancialSummary.RevenuePercentChange, Converter={StaticResource TrendToTextBrushConverter}, ConverterParameter='Revenue'}" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.VsYesterday}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 3. Expenses Card -->
                <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Height="170">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2" />
                    </Border.Effect>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- HEADER: Icon + Label -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                            <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource StatusErrorBackground}" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconFinance}" Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Business.Expenses}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="{Binding FinancialSummary.Expenses, StringFormat='{}{0:N2} DA'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="32" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                         <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding FinancialSummary.ExpensesPercentChange, StringFormat='{}{0:F1}%'}" Foreground="{Binding FinancialSummary.ExpensesPercentChange, Converter={StaticResource TrendToTextBrushConverter}, ConverterParameter='Expenses'}" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.VsYesterday}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 2: Charts & Lists -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" /> <!-- Allocated space for charts to prevent collapse -->
                    <RowDefinition Height="1*" /> <!-- Lists -->
                </Grid.RowDefinitions>

                <!-- NEW: High-Fidelity Revenue Trend Chart -->
                <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,0,24" MinHeight="360">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level1"/>
                    </Border.Effect>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- HEADER: Title & Month Navigation -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Stat.RevenueTrend}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                <TextBlock Text="{Binding FormattedRevenueTrendMonth}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Command="{Binding PreviousRevenueTrendMonthCommand}" 
                                        Style="{StaticResource Button.Ghost}" Width="32" Height="32" Padding="0" Margin="0,0,8,0"
                                        ToolTip="{DynamicResource Terminology.Dashboard.Action.PreviousMonth}">
                                    <Path Data="{StaticResource IconChevronLeft}" Fill="{DynamicResource TextSecondaryBrush}" Width="8" Height="12" Stretch="Uniform"/>
                                </Button>
                                <Button Command="{Binding NextRevenueTrendMonthCommand}" 
                                        Style="{StaticResource Button.Ghost}" Width="32" Height="32" Padding="0"
                                        ToolTip="{DynamicResource Terminology.Dashboard.Action.NextMonth}">
                                    <Path Data="{StaticResource IconChevronRight}" Fill="{DynamicResource TextSecondaryBrush}" Width="8" Height="12" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- CHART CONTENT -->
                        <Grid Grid.Row="1" Margin="0,0,0,16" MinHeight="220">
                            <lvc:CartesianChart Series="{Binding RevenueSeries}" 
                                                XAxes="{Binding RevenueXAxes}" 
                                                YAxes="{Binding RevenueYAxes}" 
                                                TooltipPosition="Top"
                                                ZoomMode="X"
                                                AnimationsSpeed="00:00:00.500"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"/>
                        </Grid>

                        <!-- BOTTOM CONTROL BAR -->
                        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{DynamicResource FacilityAccentDimBrush}" CornerRadius="8" Padding="12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconFinance}" Fill="{DynamicResource FacilityAccentBrush}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Chart.DailyView}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource FacilityAccentBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Button Grid.Column="1" Command="{Binding ExportReportCommand}" Style="{StaticResource Button.Secondary}" Height="32" Padding="16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" 
                                              Fill="{DynamicResource TextSecondaryBrush}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Terminology.Dashboard.Action.Export}" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Loading State -->
                        <Grid Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource CardBackgroundBrush}" Opacity="0.7"
                              Visibility="{Binding IsRevenueTrendLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ProgressBar IsIndeterminate="True" Width="100" Height="2" VerticalAlignment="Center" Foreground="{DynamicResource BrandPrimaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>


                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Retention Guardian Card (Replaces Recent Transactions) -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,16,0">
                         <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level1"/>
                        </Border.Effect>
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- HEADER: Icon + Label + Toggle -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource StatusErrorBackground}" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource IconMembers}" Fill="{DynamicResource StatusErrorBrush}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Dashboard.Stat.RetentionGuardian}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Opacity="0.8"/>
                                </StackPanel>
                                
                                <ToggleButton Grid.Column="1" Style="{StaticResource Style.MiniModeToggle}" IsChecked="{Binding IsRetentionDetailVisible, Mode=TwoWay}"/>
                            </Grid>

                            <!-- Subtitle Info -->
                            <TextBlock Grid.Row="1" Text="{Binding RetentionSummaryText}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,16"/>
                            
                            <!-- CONTENT: Hybrid Graph/List -->
                            <Grid Grid.Row="2">
                                <!-- GRAPH VIEW (Risk Level Distribution) -->
                                <Grid Visibility="{Binding IsRetentionDetailVisible, Converter={StaticResource BoolToVisibilityInverseConverter}}">
                                    <lvc:PieChart Series="{Binding RetentionSeries}" LegendPosition="Right" VisualElements="{Binding RetentionVisualElements}" Height="180"/>
                                </Grid>

                                <!-- LIST VIEW (Top Churn Risks) -->
                                <ScrollViewer Height="180" Visibility="{Binding IsRetentionDetailVisible, Converter={StaticResource BoolToVisibilityConverter}}" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ChurnRisks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Margin="0,0,0,8" Padding="12,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding MemberName}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                <Border Background="{DynamicResource StatusErrorBrush}" CornerRadius="4" Padding="4,1" Margin="8,0,0,0" 
                                                                        Visibility="{Binding RiskLevel, Converter={StaticResource EqualToVisibilityConverter}, ConverterParameter='High'}">
                                                                    <TextBlock Text="{DynamicResource Terminology.Dashboard.Status.HighRisk}" FontSize="8" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        
                                                        <Button Grid.Column="1" Command="{Binding Data.ReEngageMemberCommand, Source={StaticResource Proxy}}" CommandParameter="{Binding}"
                                                                Style="{StaticResource IconButtonStyle}" ToolTip="Send Re-engagement Email">
                                                            <Path Data="M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4M20,18H4V8L12,13L20,8V18M20,6L12,11L4,6V6H20V6Z" 
                                                                  Fill="{DynamicResource FacilityAccentBrush}" Width="16" Height="16" Stretch="Uniform"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Top Staff / Performance List -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,16,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                             <Border.Effect>
                                <StaticResource ResourceKey="Shadow1"/>
                            </Border.Effect>
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,16">
                                    <Border Width="24" Height="24" CornerRadius="8" Background="{DynamicResource FacilityAccentDimBrush}" Margin="0,0,12,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource IconRunner}" Fill="{DynamicResource FacilityAccentBrush}" Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource Terminology.Dashboard.TopPerformingStaff}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="{DynamicResource Terminology.Dashboard.Range.Today}" Command="{Binding SetStaffFilterCommand}" CommandParameter="Today" Margin="0,0,6,0" Height="24" Padding="10,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStaffFilter}" Value="Today">
                                                        <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="{DynamicResource Terminology.Dashboard.Range.ThisWeek}" Command="{Binding SetStaffFilterCommand}" CommandParameter="This Week" Margin="0,0,6,0" Height="24" Padding="10,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStaffFilter}" Value="This Week">
                                                        <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="{DynamicResource Terminology.Dashboard.Range.ThisMonth}" Command="{Binding SetStaffFilterCommand}" CommandParameter="This Month" Height="24" Padding="10,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStaffFilter}" Value="This Month">
                                                        <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <ScrollViewer Grid.Row="2" Margin="0,8,0,0" MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding StaffPerformance}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="{DynamicResource BackgroundBrush}" Width="32" Height="32" CornerRadius="16">
                                                         <Path Data="{DynamicResource IconRunner}" Fill="{DynamicResource FacilityAccentBrush}" Width="12" Height="12" Stretch="Uniform"/>
                                                    </Border>
                                                     <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                        <TextBlock Text="{Binding StaffName, Converter={StaticResource TerminologyConverter}}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}">
                                                            <Run Text="{Binding AppointmentCount}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.Stat.Appointments}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding TotalSales, StringFormat='{}{0:N2} DA'}" FontWeight="Bold" Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                 </ScrollViewer>
                            </Grid>
                        </Border>

                    <!-- Revenue by Plan (Business Slot) -->
                    <dashcomps:RevenueByPlanCard Grid.Column="1" Margin="0,0,16,0">
                        <dashcomps:RevenueByPlanCard.Style>
                            <Style TargetType="dashcomps:RevenueByPlanCard">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </dashcomps:RevenueByPlanCard.Style>
                    </dashcomps:RevenueByPlanCard>

                    <!-- Quick Actions -->
                     <Border Grid.Column="2" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="16" VerticalAlignment="Stretch">
                         <Border.Effect>
                            <StaticResource ResourceKey="Shadow1"/>
                         </Border.Effect>
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- HEADER: Icon + Label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,12">
                                <Border Width="24" Height="24" CornerRadius="8" Background="#20FFFFFF" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource IconDashboard}" Stroke="White" StrokeThickness="1.5" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Business.QuickActions}" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Grid Grid.Row="1" Margin="0,2,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Content="{DynamicResource Terminology.Dashboard.Action.RunPayroll}" 
                                        Command="{Binding RunPayrollCommand}"
                                        Style="{DynamicResource Button.Primary}" 
                                        Height="36" FontSize="11" FontWeight="SemiBold"/>
                                
                                <Button Grid.Row="2" Content="{DynamicResource Terminology.Dashboard.Action.RevenueHistory}" 
                                        Command="{Binding OpenRevenueHistoryCommand}"
                                        Style="{DynamicResource Button.Ghost}" Height="36" FontSize="11" FontWeight="SemiBold" Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent"/>
                                
                                <Button Grid.Row="4" Content="{DynamicResource Terminology.Dashboard.Action.OccupancyHistory}" 
                                        Command="{Binding OpenOccupancyHistoryCommand}"
                                        Style="{DynamicResource Button.Ghost}" Height="36" FontSize="11" FontWeight="SemiBold" Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent"/>

                                <Button Grid.Row="6" Content="{DynamicResource Terminology.Dashboard.Action.InventoryHistory}" 
                                        Command="{Binding OpenInventoryHistoryCommand}"
                                        Style="{DynamicResource Button.Ghost}" Height="36" FontSize="11" FontWeight="SemiBold" Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent"/>
                                
                                <Button Grid.Row="8" Content="{DynamicResource Terminology.Dashboard.QuickActions.PayrollHistory}" 
                                        Command="{Binding OpenPayrollHistoryCommand}"
                                        Style="{DynamicResource Button.Ghost}" Height="36" FontSize="11" FontWeight="SemiBold" Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent"/>
                                
                                <Button Grid.Row="10" Content="{DynamicResource Terminology.Dashboard.Action.ExportReport}" 
                                        Command="{Binding ExportReportCommand}"
                                        Style="{DynamicResource Button.Ghost}" Height="36" FontSize="11" FontWeight="SemiBold" Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
        
        <!-- Loading Overlay -->
        <controls:SkeletonLoader Grid.RowSpan="3" 
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 VerticalAlignment="Top" Height="200" Margin="0,100,0,0"/>

    </Grid>
</UserControl>
