<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Static Primitives (Do not change with Theme) -->
    <Color x:Key="ColorSuccess">#34C759</Color>
    <Color x:Key="ColorWarning">#FF9F0A</Color>
    <Color x:Key="ColorError">#FF3B30</Color>
    <Color x:Key="ColorSurfaceDim">#F9FAFB</Color>

    <SolidColorBrush x:Key="StatusSuccessBrush" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource ColorError}"/>
    
    <Color x:Key="ColorInfo">#007AFF</Color>
    <SolidColorBrush x:Key="StatusInfoBrush" Color="{StaticResource ColorInfo}"/>
    
    <!-- Diagnositc Specific -->
    <SolidColorBrush x:Key="SequoiaGray800" Color="#1F2937"/>
</ResourceDictionary>
