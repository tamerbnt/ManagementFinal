<UserControl x:Class="Management.Presentation.Views.Members.MemberDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Members"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="400"
             Background="{DynamicResource SurfaceBg}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Stats -->
            <RowDefinition Height="*"/>    <!-- Content/Tabs -->
        </Grid.RowDefinitions>

        <!-- 1. Profile Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <Grid x:Name="DetailAvatar">
                <Ellipse Width="80" Height="80" HorizontalAlignment="Center"
                         Fill="{Binding FullName, Converter={StaticResource NameToBrushConverter}}"/>
                <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialConverter}}" 
                           Style="{StaticResource Title1}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           Foreground="White"/>
            </Grid>
            <StackPanel x:Name="NameContainer" Margin="0,12,0,4" HorizontalAlignment="Center">
                <TextBlock Text="{Binding FullName}" Style="{StaticResource Title2}"
                           Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:MembersView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                <TextBox Text="{Binding FullName, Mode=TwoWay}" Style="{StaticResource Input.Field}" Width="250"
                         Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:MembersView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
            <TextBlock Text="{Binding CardId, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Members.Id'}" Style="{StaticResource Caption}" HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiaryBrush}"/>
        </StackPanel>

        <!-- 2. Stats Grid -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource Terminology.Members.Detail.Visits}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding VisitCount}" Style="{StaticResource Title3}" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource Terminology.Members.Balance}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Balance, StringFormat={}{0:N2} DA}" Style="{StaticResource Title3}" HorizontalAlignment="Center"/>
            </StackPanel>
        </UniformGrid>

        <!-- 3. Tabs -->
        <TabControl Grid.Row="2" Style="{StaticResource PremiumTabControl}">
            <TabItem Header="{DynamicResource Terminology.Members.Detail.Overview}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="{DynamicResource Terminology.Members.Detail.MembershipInfo}" Style="{StaticResource Title3}" Margin="0,0,0,12"/>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Members.Detail.Plan}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding MembershipPlanName}" Style="{StaticResource Body}" FontWeight="SemiBold" Foreground="{DynamicResource BrandPrimaryBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Members.Detail.ExpirationDate}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding ExpirationDate, StringFormat={}{0:M/d/yyyy}}" Style="{StaticResource Body}"/>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Terminology.Members.Detail.ContactInfo}" Style="{StaticResource Title3}" Margin="0,8,0,12"/>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Members.Detail.Email}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding Email}" Style="{StaticResource Body}"
                                       Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:MembersView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                            <TextBox Text="{Binding Email, Mode=TwoWay}" Style="{StaticResource Input.Field}"
                                     Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:MembersView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Members.Detail.Phone}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding PhoneNumber}" Style="{StaticResource Body}"
                                       Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:MembersView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                            <TextBox Text="{Binding PhoneNumber, Mode=TwoWay}" Style="{StaticResource Input.Field}"
                                     Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:MembersView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                        
                        <TextBlock Text="{DynamicResource Terminology.Members.Detail.EmergencyContact}" Style="{StaticResource Title3}" Margin="0,8,0,12"/>
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Members.Detail.Name}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding EmergencyContactName}" Style="{StaticResource Body}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock Text="{DynamicResource Terminology.Members.Detail.Phone}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding EmergencyContactPhone}" Style="{StaticResource Body}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{DynamicResource Terminology.Members.Detail.Activity}">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{DynamicResource Terminology.Members.Detail.History.Entries}" Style="{StaticResource Title3}" Margin="0,0,0,12"/>
                    
                    <ListBox Grid.Row="1" ItemsSource="{Binding AccessEvents}" 
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Surface.Secondary}" CornerRadius="12" Padding="12" Margin="0,0,0,8" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border.Subtle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource StatusErrorBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAccessGranted}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource StatusSuccessBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:MMM dd, yyyy HH:mm}}" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding FailureReason}" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2" Text="{DynamicResource Terminology.Members.Detail.History.Entrance}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandPrimaryBrush}" VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>
        
        <Button Width="32" Height="32" 
                Style="{StaticResource IconButtonStyle}" 
                Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=local:MembersView}}"
                HorizontalAlignment="Right" VerticalAlignment="Top" Grid.Row="0">
            <Path Data="{StaticResource IconClose}" Stroke="{DynamicResource TextTertiaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
        </Button>

        <!-- Edit Actions Bar -->
        <Border Grid.Row="2" VerticalAlignment="Bottom" Background="White" CornerRadius="16" Padding="16,12" Margin="0,0,0,12"
                Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:MembersView}, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{DynamicResource Terminology.Global.Cancel}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                        Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=local:MembersView}}"/>
                <Button Grid.Column="1" Content="{DynamicResource Terminology.Members.Action.SaveChanges}" Style="{StaticResource PrimaryButton}"
                        Command="{Binding DataContext.SaveMemberCommand, RelativeSource={RelativeSource AncestorType=local:MembersView}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
