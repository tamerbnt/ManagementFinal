<UserControl x:Class="Management.Presentation.Views.PointOfSale.PointOfSaleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.PointOfSale"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:enums="clr-namespace:Management.Domain.Enums;assembly=Management.Domain"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024"
             Background="{DynamicResource Brush.Surface.Background}">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="ProductCategoryEnum" 
                            MethodName="GetValues" 
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:ProductCategory"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <d:UserControl.DataContext>
        <vm:PosViewModel/>
    </d:UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" /> 
            <ColumnDefinition Width="400" /> 
        </Grid.ColumnDefinitions>

        <!-- Product Selection Area -->
        <Grid Grid.Column="0" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconBox}" 
                          Style="{StaticResource Style.Icon.Large}" 
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          Margin="0,0,12,0"/>
                    <TextBlock Text="{DynamicResource Strings.PointOfSale.Products}"
                               FontSize="{DynamicResource Text.Size.Title1}"
                               FontFamily="{DynamicResource Font.Primary}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Search & Filters -->
                <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="{DynamicResource Brush.Surface.Background}"
                            CornerRadius="8"
                            Padding="8,0"
                            Width="250"
                            Margin="0,0,12,0"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconSearch}" 
                                  Width="14" Height="14" 
                                  Fill="{DynamicResource Brush.Text.Secondary}" 
                                  VerticalAlignment="Center" 
                                  Margin="4,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     FontSize="{DynamicResource Text.Size.Body}"
                                     Tag="Search products..."/>
                        </Grid>
                    </Border>

                    <ComboBox Width="150"
                              ItemsSource="{Binding Source={StaticResource ProductCategoryEnum}}"
                              SelectedItem="{Binding SelectedCategory}"
                              VerticalContentAlignment="Center"
                              Height="40">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Virtualized Product Grid -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FilteredProducts}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- Touch-Optimized Product Card (Min 180x180) -->
                        <Border Background="{DynamicResource Brush.Window.Background}"
                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Margin="8"
                                Padding="16"
                                MinHeight="180"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" 
                                              Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="100"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Product Image -->
                                <Border Grid.Row="0" 
                                        Background="{DynamicResource Brush.Surface.Background}" 
                                        CornerRadius="8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="80" Height="80"/>
                                
                                <!-- Product Name -->
                                <TextBlock Grid.Row="1" 
                                           Text="{Binding Name}" 
                                           FontFamily="{DynamicResource Font.Primary}"
                                           FontSize="{DynamicResource Text.Size.Body}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,4"/>
                                
                                <!-- Price -->
                                <TextBlock Grid.Row="2" 
                                           Text="{Binding Price, StringFormat=C}" 
                                           FontFamily="{DynamicResource Font.Primary}"
                                           FontSize="{DynamicResource Text.Size.Title3}"
                                           FontWeight="Bold" 
                                           Foreground="{DynamicResource Brush.Accent.Primary}"
                                           TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Cart Sidebar -->
        <Border Grid.Column="1" 
                Background="{DynamicResource Brush.Window.Background}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1,0,0,0">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,24">
                    <Path Data="{StaticResource Icon.Storefront}" 
                          Style="{StaticResource Style.Icon.Large}" 
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          Margin="0,0,12,0"/>
                    <TextBlock Text="{DynamicResource Strings.PointOfSale.CurrentOrder}"
                               FontSize="{DynamicResource Text.Size.Title2}"
                               FontFamily="{DynamicResource Font.Primary}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Cart Items -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CartItems}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Margin" Value="0,0,0,12"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,12"
                                    Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Product Info -->
                                    <Grid Grid.Row="0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Product.Name}"
                                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                                       FontFamily="{DynamicResource Font.Primary}"
                                                       FontSize="{DynamicResource Text.Size.Body}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Price, StringFormat=C}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       FontFamily="{DynamicResource Font.Primary}"
                                                       FontSize="{DynamicResource Text.Size.Caption}"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Total, StringFormat=C}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   FontWeight="Bold"
                                                   FontSize="{DynamicResource Text.Size.Title3}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Touch-Optimized Quantity Controls (48x48) -->
                                    <Grid Grid.Row="1" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <!-- Decrease Button -->
                                            <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="âˆ’"
                                                    Width="48" Height="48"
                                                    FontSize="24"
                                                    FontWeight="Bold"
                                                    Background="{DynamicResource Brush.Surface.Background}"
                                                    Foreground="{DynamicResource Brush.Text.Primary}"
                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                    BorderThickness="1">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <!-- Quantity Display -->
                                            <Border Background="{DynamicResource Brush.Window.Background}"
                                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Width="60" Height="48"
                                                    Margin="8,0">
                                                <TextBlock Text="{Binding Quantity}" 
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Increase Button -->
                                            <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="+"
                                                    Width="48" Height="48"
                                                    FontSize="24"
                                                    FontWeight="Bold"
                                                    Background="{DynamicResource Brush.Accent.Primary}"
                                                    Foreground="White"
                                                    BorderThickness="0">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>

                                        <!-- Remove Button -->
                                        <Button Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="ðŸ—‘"
                                                HorizontalAlignment="Right"
                                                Width="48" Height="48"
                                                FontSize="20"
                                                Background="Transparent"
                                                Foreground="{DynamicResource Brush.Danger}"
                                                BorderThickness="0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Totals & Pay -->
                <StackPanel Grid.Row="2" Margin="0,24,0,0">
                    <Border BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,1,0,0" Margin="0,0,0,16"/>
                    
                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="{DynamicResource Strings.FinanceAndStaff.Total}" 
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="{DynamicResource Text.Size.Title2}"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat=C}" 
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource Brush.Accent.Primary}"
                                   FontSize="{DynamicResource Text.Size.Title1}"
                                   FontWeight="Bold"/>
                    </Grid>

                    <!-- DOMINANT PAY BUTTON (80px height, largest element) -->
                    <Button Command="{Binding OpenPaymentModalCommand}"
                            Height="80"
                            Background="{DynamicResource Brush.Brand.Primary}"
                            BorderThickness="0">
                        <Button.Content>
                            <TextBlock Text="{DynamicResource Strings.PointOfSale.PAYNOW}" 
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </Button.Content>
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Payment Modal -->
        <Grid Grid.ColumnSpan="2" 
              Background="{DynamicResource Brush.Surface.Glass}"
              Visibility="{Binding ShowPaymentModal, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource Brush.Window.Background}"
                    Width="500"
                    VerticalAlignment="Center"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    Padding="32">
                 <Grid DataContext="{Binding PaymentVm}">
                     <Grid.RowDefinitions>
                         <RowDefinition Height="Auto"/>
                         <RowDefinition Height="Auto"/>
                         <RowDefinition Height="Auto"/>
                         <RowDefinition Height="Auto"/>
                         <RowDefinition Height="Auto"/>
                     </Grid.RowDefinitions>
                     
                     <TextBlock Text="{DynamicResource Strings.PointOfSale.Payment}" 
                                FontSize="{DynamicResource Text.Size.Title1}" 
                                Foreground="{DynamicResource Brush.Text.Primary}"
                                Margin="0,0,0,24"/>
                     
                     <Grid Grid.Row="1" Margin="0,0,0,24">
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                         </Grid.ColumnDefinitions>
                         <TextBlock Text="{DynamicResource Strings.PointOfSale.TotalToPay}" FontSize="{DynamicResource Text.Size.Title2}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                         <TextBlock Text="{Binding TotalAmount, StringFormat=C}" Grid.Column="1" FontSize="{DynamicResource Text.Size.Title1}" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                     </Grid>
                     
                     <!-- Inputs -->
                     <Grid Grid.Row="2" Margin="0,0,0,24">
                         <Grid.RowDefinitions>
                             <RowDefinition Height="Auto"/>
                             <RowDefinition Height="Auto"/>
                         </Grid.RowDefinitions>
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="16"/>
                             <ColumnDefinition Width="*"/>
                         </Grid.ColumnDefinitions>
                         
                         <StackPanel Grid.Column="0">
                             <TextBlock Text="{DynamicResource Strings.PointOfSale.Cash}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                             <TextBox Text="{Binding CashAmount, UpdateSourceTrigger=PropertyChanged}" 
                                      Height="40" 
                                      FontSize="{DynamicResource Text.Size.Body}"
                                      Padding="8"/> 
                         </StackPanel>
                         
                         <StackPanel Grid.Column="2">
                             <TextBlock Text="{DynamicResource Strings.PointOfSale.Card}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                             <TextBox Text="{Binding CardAmount, UpdateSourceTrigger=PropertyChanged}" 
                                      Height="40"
                                      FontSize="{DynamicResource Text.Size.Body}"
                                      Padding="8"/>
                         </StackPanel>
                     </Grid>
                     
                     <StackPanel Grid.Row="3" Margin="0,0,0,32">
                         <TextBlock Text="{DynamicResource Strings.PointOfSale.Remaining}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                         <TextBlock Text="{Binding RemainingAmount, StringFormat=C}" Foreground="{DynamicResource Brush.Danger}" FontWeight="Bold" FontSize="{DynamicResource Text.Size.Title2}"/>
                     </StackPanel>
                     
                     <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                         <Button Command="{Binding DataContext.ClosePaymentModalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Content="{DynamicResource Strings.Global.Cancel}"
                                 Width="100" Height="40"
                                 Background="Transparent"
                                 Foreground="{DynamicResource Brush.Text.Secondary}"
                                 Margin="0,0,16,0"/>
                                 
                         <Button Command="{Binding FinalizePaymentCommand}"
                                 Content="{DynamicResource Strings.PointOfSale.Complete}"
                                 Width="120" Height="40"
                                 Background="{DynamicResource Brush.Brand.Primary}"
                                 Foreground="{DynamicResource Brush.Text.Primary}"/>
                     </StackPanel>
                 </Grid>
            </Border>
        </Grid>
        
        <!-- Success Overlay -->
        <Grid Grid.ColumnSpan="2" 
              Background="{DynamicResource Brush.Surface.Glass}"
              Visibility="{Binding ShowSuccessOverlay, Converter={StaticResource BooleanToVisibilityConverter}}">
             <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                 <Border Background="{DynamicResource Brush.Success}" 
                         Width="80" Height="80" 
                         CornerRadius="40"
                         Margin="0,0,0,16">
                     <TextBlock Text="âœ“" 
                                FontSize="48" 
                                Foreground="White" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                 </Border>
                 <TextBlock Text="{DynamicResource Strings.PointOfSale.PaymentSuccessful}"
                            HorizontalAlignment="Center"
                            FontSize="{DynamicResource Text.Size.Title1}"
                            Foreground="{DynamicResource Brush.Text.Primary}"/>
             </StackPanel>
        </Grid>
    </Grid>
</UserControl>
