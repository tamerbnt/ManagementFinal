<UserControl x:Class="Management.Presentation.Views.Auth.EmailConfirmationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="600"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="Transparent">

    <Grid>
        <!-- Background Ambient Glow Layer 1 -->
        <Ellipse Width="800" Height="800" Opacity="0.08" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#3B82F6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="0.7"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.06" To="0.12" Duration="0:0:6" AutoReverse="True" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>

        <!-- Glass Card -->
        <Border VerticalAlignment="Center" HorizontalAlignment="Center" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}"
                Background="{DynamicResource Brush.Surface.Glass.Standard}" CornerRadius="{DynamicResource Corner.XL}" BorderThickness="1.5" Padding="40">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#663B82F6" Offset="0"/>
                    <GradientStop Color="#333B82F6" Offset="0.5"/>
                    <GradientStop Color="#663B82F6" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <StackPanel>
                <!-- Animated Mail Icon -->
                <Grid Width="70" Height="70" Margin="0,0,0,24">
                    <!-- Rotating Ring -->
                    <Ellipse Width="64" Height="64" Stroke="#503B82F6" StrokeThickness="1.5" StrokeDashArray="4 2">
                        <Ellipse.RenderTransform>
                            <RotateTransform CenterX="32" CenterY="32"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                       From="0" To="360" Duration="0:0:25" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>

                    <!-- Mail Icon -->
                    <Path Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z" 
                          Fill="#3B82F6" Width="30" Height="30" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.7" To="1.0" Duration="0:0:1.5" AutoReverse="True" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                    </Path>
                </Grid>

                <TextBlock Text="{DynamicResource Strings.Auth.VerifyYourEmail}" FontSize="24" FontWeight="Bold" Foreground="White" 
                           Margin="0,0,0,16" HorizontalAlignment="Center"/>

                <TextBlock Text="{DynamicResource Strings.Auth.Wevesentaconfirmationlink}" Foreground="#94A3B8" FontSize="14" 
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                
                <TextBlock Text="{Binding Email}" Foreground="#3B82F6" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="{DynamicResource Strings.Auth.Pleasecheckyourinboxandcl}" 
                           Foreground="#64748B" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" 
                           LineHeight="20" Margin="0,0,0,32"/>

                <!-- Action Button -->
                <Button Command="{Binding GoToLoginCommand}" Height="54">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="{DynamicResource Corner.XL}" BorderThickness="1.5" Padding="20,12" BorderBrush="{DynamicResource FacilityAccentBrush}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#2563EB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="{DynamicResource Strings.Auth.IveVerified}" FontWeight="Bold" Foreground="White" 
                                           FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#66FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Resend Option -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <TextBlock Text="{DynamicResource Strings.Auth.Didntreceiveit}" Foreground="#475569" FontSize="12.5" Margin="0,0,6,0"/>
                    <TextBlock Foreground="#3B82F6" FontSize="12.5">
                        <Hyperlink Command="{Binding ResendEmailCommand}" Foreground="#3B82F6" FontWeight="SemiBold" TextDecorations="{x:Null}">
                            Resend email
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
