<UserControl x:Class="Management.Presentation.Views.Settings.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">
    
        <!-- Root Layout Fixed Padding -->
        <StackPanel Margin="{StaticResource MarginPageContent}">

            <!-- 1. FACILITY IDENTITY SECTION -->
            <TextBlock Text="{DynamicResource TerminologyFacilityIdentityLabel}" 
                       Style="{StaticResource Title3}" 
                       Foreground="{DynamicResource TextPrimaryBrush}" 
                       Margin="{StaticResource MarginHeaderBottom}"/>

            <!-- Logo Upload (Global Component Reuse) -->
            <TextBlock Text="{DynamicResource TerminologyBrandLogoLabel}" Style="{StaticResource FormLabel}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

            <Border Style="{StaticResource GlobalDragDropUploadZoneStyle}"
                    Height="{StaticResource SizeUploadZoneHeight}"
                    AllowDrop="True"
                    Margin="{StaticResource MarginSectionBottom}">
                <Grid>
                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Visibility="{Binding LogoImage, Converter={StaticResource InverseNullToVisibilityConverter}}">
                        <Path Data="{StaticResource IconUpload}"
                              Fill="{DynamicResource TextTertiaryBrush}"
                              Style="{StaticResource IconHero}" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,16"/>
                        <TextBlock Text="{DynamicResource TerminologyUploadLogoLabel}" 
                                   Style="{StaticResource BodySecondary}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TerminologyPngOrSvgLabel}" 
                                   Style="{StaticResource Caption}" 
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="{StaticResource MarginSmallTop}"/>
                    </StackPanel>

                    <!-- Filled State -->
                    <Grid Visibility="{Binding LogoImage, Converter={StaticResource NullToVisibilityConverter}}">
                        <!-- Padding prevents logo from touching borders in preview -->
                        <Image Source="{Binding LogoImage}" 
                               Stretch="Uniform"
                               Margin="24"/>

                        <!-- Remove Button -->
                        <Button Style="{StaticResource IconButtonStyle}"
                                Command="{Binding RemoveLogoCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="{StaticResource MarginSmall}"
                                Background="{DynamicResource SurfaceBg}"
                                Opacity="0.9">
                            <Path Data="{StaticResource IconClose}" 
                                  Fill="{DynamicResource TextPrimaryBrush}" 
                                  Style="{StaticResource IconSmall}"/>
                        </Button>
                    </Grid>

                    <!-- Click Trigger -->
                    <Button Command="{Binding BrowseLogoCommand}"
                            Style="{StaticResource InvisibleClickableButtonStyle}"
                            Visibility="{Binding LogoImage, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- Facility Name -->
            <TextBlock Text="{DynamicResource TerminologyFacilityNameLabel}" Style="{StaticResource FormLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBox Text="{Binding GymName, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource UnderlineTextBox}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     Margin="{StaticResource MarginSectionBottom}"/>

            <!-- 2. CONTACT DETAILS SECTION -->
            <TextBlock Text="{DynamicResource TerminologyContactDetailsLabel}" 
                       Style="{StaticResource Title3}" 
                       Foreground="{DynamicResource TextPrimaryBrush}" 
                       Margin="{StaticResource MarginSectionVertical}"/>

            <Grid Margin="{StaticResource MarginSectionBottom}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="{StaticResource MarginMedium}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource SizeFormRowGap}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Email -->
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="{DynamicResource TerminologyOfficialEmailLabel}" Style="{StaticResource FormLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox Text="{Binding Email}" Style="{StaticResource UnderlineTextBox}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Phone -->
                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="Phone Number *" Style="{StaticResource FormLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox Text="{Binding PhoneNumber}" Style="{StaticResource UnderlineTextBox}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Website -->
                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="Website" Style="{StaticResource FormLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox Text="{Binding Website}" Style="{StaticResource UnderlineTextBox}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Tax/License ID -->
                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Text="Tax / License ID" Style="{StaticResource FormLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox Text="{Binding TaxId}" Style="{StaticResource UnderlineTextBox}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- 3. LOCATION SECTION -->
            <TextBlock Text="{DynamicResource TerminologyLocationLabel}" 
                       Style="{StaticResource Title3}" 
                       Foreground="{DynamicResource TextPrimaryBrush}" 
                       Margin="{StaticResource MarginSectionVertical}"/>

            <TextBlock Text="{DynamicResource TerminologyPhysicalAddressLabel}" Style="{StaticResource FormLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
            <TextBox Text="{Binding Address}" 
                     Style="{StaticResource UnderlineTextBox}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="80"
                     VerticalContentAlignment="Top"
                     Margin="{StaticResource MarginSectionBottom}"/>

            <!-- 4. ACTION FOOTER -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource MarginSectionVertical}">
                <!-- IsEnabled bound to IsSaving to prevent double clicks -->
                <Button Content="{DynamicResource TerminologySaveChangesLabel}" 
                        Command="{Binding SaveGeneralSettingsCommand}"
                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="{StaticResource SizeButtonMinWidth}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>