<UserControl x:Class="Management.Presentation.Views.Restaurant.OrderDetailModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="450">
    <Grid Background="{DynamicResource SurfaceBg}">
        <Border BorderBrush="{DynamicResource SeparatorStroke}" BorderThickness="1" CornerRadius="16" Margin="24">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Info -->
                    <RowDefinition Height="*"/>    <!-- Items -->
                    <RowDefinition Height="Auto"/> <!-- Total -->
                    <RowDefinition Height="Auto"/> <!-- Actions -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Text="{Binding TableNumber, StringFormat='{}Table {0}'}" 
                           Style="{StaticResource Title2}" Foreground="{DynamicResource TextPrimaryBrush}"/>

                <!-- Info -->
                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock Text="{Binding DisplayStatus}" Foreground="{DynamicResource FacilityAccentBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding OrderStartTime, StringFormat='{}Started: {0:t}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                </StackPanel>

                <!-- Items List -->
                <ListBox Grid.Row="2" ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0" Margin="0,24,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Quantity, StringFormat='{}{0}x'}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat={}{0:C}}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Total -->
                <Border Grid.Row="3" BorderBrush="{DynamicResource SeparatorStroke}" BorderThickness="0,1,0,0" Margin="0,24,0,0" Padding="0,16">
                    <Grid>
                        <TextBlock Text="Total Amount" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C}}" HorizontalAlignment="Right" 
                                   Style="{StaticResource Title3}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Actions -->
                <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,16,0,0">
                    <Button Style="{StaticResource SecondaryButton}" 
                            HorizontalAlignment="Stretch" Margin="0,0,0,8" Height="45"
                            Command="{Binding PrintReceiptCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="PRINT RECEIPT" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Content="SETTLE &amp; CLEAR TABLE" Style="{StaticResource PrimaryButton}" 
                            HorizontalAlignment="Stretch" Height="45"
                            Command="{Binding SettleOrderCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
