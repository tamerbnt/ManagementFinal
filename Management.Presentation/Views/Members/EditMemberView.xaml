<UserControl x:Class="Management.Presentation.Views.Members.EditMemberView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="{DynamicResource WindowBg}">

    <UserControl.Resources>
        <!-- FIX 5: Removed invalid ConverterParameter property from resource definition -->
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. HEADER -->
        <Border Grid.Row="0" 
                Padding="{StaticResource PaddingCard}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Style="{StaticResource Title2}" Foreground="{DynamicResource TextPrimaryBrush}">
                <Run Text="{DynamicResource TerminologyEditLabel}"/>
                <Run Text=" "/>
                <Run Text="{DynamicResource TerminologyLabel}"/>
            </TextBlock>
        </Border>

        <!-- 2. SCROLLABLE FORM CONTENT -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">

            <!-- FIX 1: Replaced MaxWidthForm with hardcoded 800 -->
            <StackPanel Margin="{StaticResource PaddingCard}" 
                        MaxWidth="800" 
                        HorizontalAlignment="Stretch">

                <!-- A. PHOTO UPLOAD ZONE -->
                <TextBlock Text="{DynamicResource TerminologyProfilePhotoLabel}" Style="{StaticResource FormLabel}" Margin="0,0,0,8"/>

                <Border Style="{StaticResource GlobalDragDropUploadZoneStyle}"
                        Height="{StaticResource SizeUploadZoneHeight}"
                        AllowDrop="True">
                    <Grid>
                        <!-- Empty State -->
                        <!-- FIX 5: Passed ConverterParameter here -->
                        <StackPanel VerticalAlignment="Center" 
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding ProfileImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                            <Path Data="{StaticResource IconUpload}"
                                  Fill="{DynamicResource TextTertiaryBrush}"
                                  Style="{StaticResource Style.Icon.Hero}" 
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,16"/>
                            <TextBlock Text="{DynamicResource TerminologyDragDropToReplaceLabel}" 
                                       Style="{StaticResource BodySecondary}" 
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Strings.Members.JPGPNGorWebPMax5MB}" 
                                       Style="{StaticResource Caption}" 
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="{StaticResource MarginSmallTop}"/>
                        </StackPanel>

                        <!-- Filled State -->
                        <Grid Visibility="{Binding ProfileImage, Converter={StaticResource NullToVisibilityConverter}}">
                            <!-- FIX 2: Hardcoded RadiusX/Y to 20 -->
                            <Image Source="{Binding ProfileImage, Converter={StaticResource ImagePathConverter}, ConverterParameter=200}" 
                                   Stretch="UniformToFill">
                                <Image.Clip>
                                    <RectangleGeometry Rect="0,0,200,200" 
                                                       RadiusX="20" 
                                                       RadiusY="20"/>
                                </Image.Clip>
                            </Image>

                            <Button Style="{StaticResource IconButtonStyle}"
                                    Command="{Binding RemovePhotoCommand}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="{StaticResource MarginSmall}"
                                    Background="{DynamicResource SurfaceBg}"
                                    Opacity="0.9">
                                <Path Data="{StaticResource IconClose}" 
                                      Fill="{DynamicResource TextPrimaryBrush}" 
                                      Style="{StaticResource Style.Icon.Small}"/>
                            </Button>
                        </Grid>

                        <Button Command="{Binding BrowsePhotoCommand}"
                                Style="{StaticResource InvisibleClickableButtonStyle}"
                                Visibility="{Binding ProfileImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </Grid>
                </Border>

                <!-- B. PERSONAL INFORMATION -->
                <TextBlock Text="{DynamicResource TerminologyPersonalInformationLabel}" 
                           Style="{StaticResource Title3}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="{StaticResource MarginSectionVertical}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- FIX 3: Replaced SizeFormRowGap with 24 -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Full Name -->
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/> <!-- Email/Phone -->
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/> <!-- Card ID -->
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/> <!-- Gender/DOB -->
                    </Grid.RowDefinitions>

                    <!-- Full Name -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="{DynamicResource TerminologyFullNameLabel}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource UnderlineTextBox}"/>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="{DynamicResource TerminologyEmailLabel}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource UnderlineTextBox}"/>
                    </StackPanel>

                    <!-- Phone -->
                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="{DynamicResource TerminologyPhoneLabel}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource UnderlineTextBox}"/>
                    </StackPanel>

                    <!-- Card ID -->
                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Text="{DynamicResource TerminologyCardIdLabel}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding CardId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                 Style="{StaticResource UnderlineTextBox}"/>
                    </StackPanel>

                    <!-- Gender -->
                    <StackPanel Grid.Row="6" Grid.Column="0">
                        <TextBlock Text="{DynamicResource Strings.Members.Gender}" Style="{StaticResource FormLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <RadioButton Content="{DynamicResource Strings.Members.Male}" 
                                         IsChecked="{Binding Gender, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Male}"
                                         Style="{StaticResource RadioButton.Apple}"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="{DynamicResource Strings.Members.Female}" 
                                         IsChecked="{Binding Gender, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Female}"
                                         Style="{StaticResource RadioButton.Apple}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Date of Birth -->
                    <StackPanel Grid.Row="6" Grid.Column="2">
                        <TextBlock Text="{DynamicResource TerminologyDateOfBirthLabel}" Style="{StaticResource FormLabel}"/>
                        <DatePicker SelectedDate="{Binding DateOfBirth}"
                                    Style="{StaticResource GlobalDatePickerStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- C. MEMBERSHIP DETAILS -->
                <TextBlock Style="{StaticResource Title3}" 
                           Margin="{StaticResource MarginSectionVertical}">
                    <Run Text="{DynamicResource TerminologyLabel}"/>
                    <Run Text=" "/>
                    <Run Text="{DynamicResource Terminology.Members.Details}"/>
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource TerminologyMembershipPlanLabel}" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding AvailablePlans}"
                                  SelectedItem="{Binding SelectedPlan}"
                                  Style="{StaticResource Input.ComboBox}"
                                  IsEditable="False">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                        <TextBlock Text="{Binding Price, StringFormat=' ({0:N2} DA)'}" Foreground="{DynamicResource Brush.Text.Secondary}" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource TerminologyStartDateLabel}" Style="{StaticResource FormLabel}"/>
                        <DatePicker SelectedDate="{Binding StartDate}"
                                    Style="{StaticResource GlobalDatePickerStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- D. EMERGENCY CONTACT -->
                <TextBlock Text="{DynamicResource Strings.Members.EmergencyContact}" 
                           Style="{StaticResource Title3}" 
                           Margin="{StaticResource MarginSectionVertical}"/>

                <Grid Margin="0,0,0,48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource TerminologyContactNameLabel}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EmergencyName}" Style="{StaticResource UnderlineTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource TerminologyContactPhoneLabel}" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding EmergencyPhone}" Style="{StaticResource UnderlineTextBox}"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- 3. STICKY FOOTER -->
        <Border Grid.Row="2" 
                Padding="{StaticResource PaddingCard}"
                Background="{DynamicResource SurfaceBg}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource TerminologyCancelLabel}"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="{StaticResource MarginSmallRight}"/>

                <Button Content="{DynamicResource TerminologySaveChangesLabel}"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="{StaticResource SizeButtonMinWidth}"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
