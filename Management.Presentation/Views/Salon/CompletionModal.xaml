<Window x:Class="Management.Presentation.Views.Salon.CompletionModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Terminology.Salon.Completion.Title}" Height="700" Width="880"
        FlowDirection="{DynamicResource GlobalFlowDirection}"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None" 
        AllowsTransparency="False"
        Background="{DynamicResource Brush.Window.Background}"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                          GlassFrameThickness="-1"
                          CornerRadius="24"
                          ResizeBorderThickness="0"/>
    </shell:WindowChrome.WindowChrome>
    <Border Background="{DynamicResource SurfaceBg}" CornerRadius="24" BorderBrush="{DynamicResource SeparatorStroke}" BorderThickness="1">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="{DynamicResource TerminologyCheckoutLabel}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding ClientName}" Foreground="{DynamicResource FacilityAccentBrush}" FontSize="18" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding ServiceName}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"/>
            </StackPanel>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- Product Selection -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource TerminologySelectProductsLabel}" Style="{StaticResource InputLabel}" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableProducts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.AddProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource GhostButton}"
                                            HorizontalContentAlignment="Stretch"
                                            Margin="0,0,0,8">
                                        <Border Padding="12">
                                            <Grid>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SKU}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="10"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Price.Amount, StringFormat=C}" Foreground="{DynamicResource FacilityAccentBrush}" 
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Usage Summary -->
                <Border Grid.Column="2" Background="{DynamicResource SurfaceBg}" CornerRadius="16" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{DynamicResource TerminologyOrderSummaryLabel}" Style="{StaticResource InputLabel}" Margin="0,0,0,16"/>

                        <ScrollViewer Grid.Row="1" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource Terminology.Salon.Completion.ServiceFee}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding BasePrice, StringFormat=C}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                
                                <Separator Background="{DynamicResource SeparatorStroke}" Margin="0,4,0,12"/>
                                
                                <ItemsControl ItemsSource="{Binding UsedProducts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{DynamicResource Terminology.Salon.Completion.Qty}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11"/>
                                                        <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Width="30"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Total, StringFormat=C}" Foreground="{DynamicResource TextPrimaryBrush}" 
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource Terminology.Salon.Completion.Total}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding TotalAmount, StringFormat=C}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Command="{Binding CancelCommand}" Style="{StaticResource GhostButton}" Margin="0,0,12,0" Content="{DynamicResource Terminology.Global.Cancel}"/>
                <Button Command="{Binding CompleteCommand}" Style="{StaticResource PrimaryButton}" Background="{DynamicResource FacilityAccentBrush}" Width="200">
                     <StackPanel Orientation="Horizontal">
                        <Path Data="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z" Stroke="{DynamicResource TextOnAccentBrush}" StrokeThickness="2" Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource TerminologyProcessPrintLabel}" Foreground="{DynamicResource TextOnAccentBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
