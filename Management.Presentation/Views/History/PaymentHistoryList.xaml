<UserControl x:Class="Management.Presentation.Views.History.PaymentHistoryList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <!-- 
        Row Item Structure (Section 28.5)
        - Height: 80px ({StaticResource SizeHistoryItemHeight})
        - Padding: 16,0 via PaddingCardList
        - Style: TimelineCardStyle (Global) - Handles Shadow L1 on Hover
    -->
    <Border Style="{StaticResource TimelineCardStyle}"
            Height="{StaticResource SizeHistoryItemHeight}"
            Padding="{StaticResource PaddingCardList}"
            AutomationProperties.Name="{Binding Title, StringFormat={DynamicResource TerminologyPaymentHistoryName}}">

        <!-- Context Menu -->
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource TerminologyCopyReceiptLabel}" 
                          Command="{Binding CopyReceiptCommand}">
                    <MenuItem.Icon>
                        <Path Data="{StaticResource IconCopy}" 
                              Fill="{StaticResource TextPrimaryBrush}" 
                              Style="{StaticResource IconSmall}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Border.ContextMenu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Icon -->
                <ColumnDefinition Width="*"/>
                <!-- Info -->
                <ColumnDefinition Width="Auto"/>
                <!-- Timestamp -->
            </Grid.ColumnDefinitions>

            <!-- 
                1. Payment Icon (Global Component)
                - Style: GlobalPaymentIconStyle
                - Handles: 40px Circle, Green/Red switching based on Status binding
                - Icon: Dollar sign or Alert
            -->
            <Border Grid.Column="0"
                    Style="{StaticResource GlobalPaymentIconStyle}"
                    Width="{StaticResource SizeIconContainer}"
                    Height="{StaticResource SizeIconContainer}"
                    Margin="{StaticResource MarginIconRight}"/>

            <!-- 2. Transaction Details -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <!-- Title: Transaction Type (e.g. Membership Renewal) -->
                <TextBlock Text="{Binding Title}" 
                           Style="{StaticResource BodyMedium}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <!-- Subtitle: Amount + Method -->
                <!-- Example: "$50.00 &#x2022; Visa ****" -->
                <TextBlock Style="{StaticResource Caption}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="{StaticResource MarginSmallTop}">
                    <Run Text="{Binding Amount, StringFormat={}{0:C}}" 
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Run Text=" &#x2022; "/>
                    <Run Text="{Binding PaymentMethod}"/>
                </TextBlock>
            </StackPanel>

            <!-- 3. Timestamp -->
            <TextBlock Grid.Column="2" 
                       Text="{Binding Timestamp, StringFormat='{}{0:h:mm tt}'}" 
                       Style="{StaticResource Caption}" 
                       Foreground="{StaticResource TextTertiaryBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</UserControl>