<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Management.Presentation.Controls">

    <Style TargetType="{x:Type local:TransitioningContentControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TransitioningContentControl}">
                    <Grid>
                        <!-- Paint Area for Old Content (Optional for advanced crossfade, kept simple here) -->
                        <ContentPresenter x:Name="PART_PaintArea" Content="{TemplateBinding Content}" Opacity="0" IsHitTestVisible="False"/>
                        
                        <!-- Main Content -->
                        <ContentPresenter x:Name="PART_MainPresenter" Content="{TemplateBinding Content}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
