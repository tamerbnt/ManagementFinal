<UserControl x:Class="Management.Presentation.Views.Restaurant.InventoryDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Restaurant"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Restaurant"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="400"
             Background="{DynamicResource CardBackgroundBrush}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- 1. Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <Button Style="{StaticResource IconButtonStyle}" 
                    HorizontalAlignment="Right" 
                    Command="{Binding DataContext.CloseDrawerCommand, RelativeSource={RelativeSource AncestorType=local:InventoryView}}"
                    Margin="0,-8,-8,0">
                <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextTertiaryBrush}" Style="{StaticResource Style.Icon.Small}"/>
            </Button>

            <!-- Icon -->
            <Border Width="80" Height="80" 
                    CornerRadius="40" 
                    Background="{DynamicResource SurfaceBg}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
                <Path Data="{StaticResource IconBox}" 
                      Fill="{DynamicResource TextSecondaryBrush}" 
                      Stretch="Uniform" 
                      Width="32" Height="32"
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Name (Title) -->
            <TextBlock Text="{Binding Name}" 
                       Style="{StaticResource Title.H2}" 
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- 2. Content -->
        <!-- Note: A ScrollViewer isn't used here for the root to allow ListView to manage its own scrolling, but can be added if needed. -->
        <Grid Grid.Row="1" Margin="0,0,-8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Quick Stats Grid -->
            <Grid Grid.Row="0" Margin="0,0,8,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource Strings.Restaurant.CATEGORY}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Category}" Style="{StaticResource Title3}" HorizontalAlignment="Center" Foreground="{DynamicResource FacilityAccentBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource Strings.Restaurant.INSTOCK}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalDisplay}" Style="{StaticResource Title3}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Separator Grid.Row="1" Background="{DynamicResource SeparatorStroke}" Margin="0,0,8,24"/>

            <!-- History Section -->
            <Grid Grid.Row="2" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{DynamicResource Strings.Restaurant.PURCHASEHISTORY}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,16"/>
                
                <!-- History Items (Binding to the parent's PurchaseHistory filtered by ResourceId) -->
                <!-- Since the main ViewModel holds all history, we use an ItemsControl bound to a filtered view or we bind to the parent VM -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                     <ItemsControl ItemsSource="{Binding DataContext.PurchaseHistory, RelativeSource={RelativeSource AncestorType=local:InventoryView}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:InventoryPurchaseViewModel}">
                                <Border BorderBrush="{DynamicResource SeparatorStroke}" BorderThickness="0,0,0,1" Padding="0,12">
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource StringMatchMultiToVisibilityConverter}">
                                            <Binding Path="ResourceName"/>
                                            <Binding Path="DataContext.Name" RelativeSource="{RelativeSource AncestorType=local:InventoryDetailsView}"/>
                                        </MultiBinding>
                                    </Border.Visibility>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DateDisplay}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="+ {Binding QuantityDisplay}" Style="{StaticResource BodyMedium}" Foreground="{DynamicResource FacilityAccentBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Note}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}" FontStyle="Italic" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                     </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- 3. Actions Footer -->
        <Border Grid.Row="2" Padding="0,24,0,0" Background="{DynamicResource CardBackgroundBrush}">
            <Button Content="{DynamicResource Strings.Restaurant.LogPurchase}" 
                    Style="{StaticResource PrimaryButton}" 
                    Height="44"
                    Command="{Binding LogPurchaseCommand}"/>
        </Border>
    </Grid>
</UserControl>
