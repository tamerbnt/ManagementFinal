<UserControl x:Class="Management.Presentation.Views.Shell.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Shell"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="288">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Sidebar Toggle Animation -->
        <Storyboard x:Key="ExpandSidebar">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder" 
                             Storyboard.TargetProperty="Width"
                             To="288" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="NavLabelsContainer" 
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="CollapseSidebar">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder" 
                             Storyboard.TargetProperty="Width"
                             To="72" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="NavLabelsContainer" 
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.1"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="SidebarBorder" Width="288" 
            Background="{DynamicResource SurfaceBg}"
            BorderThickness="0,0,1,0" BorderBrush="{DynamicResource SeparatorStroke}"
            CacheMode="BitmapCache">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/> <!-- Toggle / Top Margin -->
                <RowDefinition Height="Auto"/> <!-- Logo -->
                <RowDefinition Height="*"/> <!-- Nav -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Toggle Button -->
            <Button x:Name="ToggleBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,16,0" Width="40" Height="40"
                    Style="{DynamicResource IconButtonStyle}"
                    Click="ToggleBtn_Click">
                <!-- Lucide Menu Icon -->
                <Path Data="{DynamicResource IconMenu}" Fill="{DynamicResource TextPrimaryBrush}" Width="20" Height="20" Stretch="Uniform" />
            </Button>

            <!-- Logo Area -->
            <Border Grid.Row="1" Margin="24,0,24,24">
                <Grid>
                    <!-- Small Icon for Collapsed -->
                    <Ellipse Width="32" Height="32" Fill="{DynamicResource SurfaceBg}" 
                             HorizontalAlignment="Center" 
                             Visibility="{Binding IsCollapsed, Converter={StaticResource BoolToVis}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <!-- Large Logo for Expanded -->
                    <TextBlock x:Name="LogoText" Text="{DynamicResource TerminologyManagementLabel}" 
                               FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" 
                               FontSize="18" HorizontalAlignment="Center"
                               Opacity="{Binding ElementName=NavLabelsContainer, Path=Opacity}"/>
                </Grid>
            </Border>

            <!-- Navigation -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding NavigationItems}" Margin="0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="NavItemRoot" ToolTip="{Binding DisplayName}">
                            <Button Command="{Binding NavigateCommand}"
                                    Style="{DynamicResource SidebarNavigationButtonStyle}"
                                    Height="48" Margin="12,4">
                                <Grid x:Name="InnerGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Active Line -->
                                    <Border x:Name="ActiveLine" Grid.Column="0" 
                                            HorizontalAlignment="Left" Width="4" 
                                            Height="24" CornerRadius="2"
                                            Background="{DynamicResource AccentBrush}"
                                            Visibility="Collapsed"/>
                                    
                                    <!-- Icon -->
                                    <ContentPresenter Grid.Column="0" 
                                                      Content="{Binding IconKey, Converter={StaticResource ResourceKeyToIconConverter}}"
                                                      Width="20" Height="20" HorizontalAlignment="Center"/>
                                    
                                    <!-- Label -->
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" 
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Opacity="{Binding ElementName=NavLabelsContainer, Path=Opacity}"/>
                                </Grid>
                            </Button>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="ActiveLine" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- Hidden Proxy for Opacity binding -->
            <Grid x:Name="NavLabelsContainer" Visibility="Collapsed"/>

            <!-- Footer -->
            <TextBlock Grid.Row="3" Text="{DynamicResource TerminologyVersionLabel}" 
                       Foreground="{DynamicResource TextTertiaryBrush}" FontSize="10" 
                       Margin="0,24" HorizontalAlignment="Center"
                       Opacity="{Binding ElementName=NavLabelsContainer, Path=Opacity}"/>
        </Grid>
    </Border>
</UserControl>
