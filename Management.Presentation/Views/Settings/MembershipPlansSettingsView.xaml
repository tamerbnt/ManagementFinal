<UserControl x:Class="Management.Presentation.Views.Settings.MembershipPlansSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <converters:WindowWidthToColumnsConverter x:Key="WindowWidthToColumnsConverter"/>
        <converters:IntToVisibilityConverter x:Key="ZeroIsVisibleConverter" />
        <!-- Converter for Active (Green) vs Archived (Gray) -->
        <converters:PlanStatusToBrushConverter x:Key="PlanStatusToBrushConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header Actions -->
            <RowDefinition Height="*"/>
            <!-- Plan Grid -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER ACTION BAR -->
        <Grid Grid.Row="0" Margin="{StaticResource MarginSectionBottom}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Section Title -->
            <TextBlock Text="{DynamicResource TerminologyPricingTiersLabel}" 
                       Style="{StaticResource Title3}" 
                       VerticalAlignment="Center"/>

            <!-- Create Button -->
            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CreatePlanCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconAdd}" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Style="{StaticResource IconSmall}"
                          Margin="{StaticResource MarginIconRight}"/>
                    <TextBlock Text="{DynamicResource TerminologyCreateNewPlanLabel}"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 2. PLAN GRID -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Plans}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.CanContentScroll="True">

            <!-- Responsive Layout (2 Cols < 1280, 3 Cols > 1280) -->
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid VerticalAlignment="Top">
                        <UniformGrid.Columns>
                            <Binding Path="ActualWidth" 
                                     RelativeSource="{RelativeSource AncestorType=Window}" 
                                     Converter="{StaticResource WindowWidthToColumnsConverter}">
                                <Binding.ConverterParameter>
                                    <sys:Double>1280</sys:Double>
                                </Binding.ConverterParameter>
                            </Binding>
                        </UniformGrid.Columns>
                    </UniformGrid>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRingStyle}"/>
                    <!-- Gutter -->
                    <Setter Property="Margin" Value="{StaticResource MarginCardGridGutter}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- 
                        Plan Card 
                        FIX: Replaced hardcoded '160' with '{StaticResource SizePricingCardHeight}'
                        Style: Interactive (Lift on Hover)
                    -->
                    <Border Style="{StaticResource ElevatedCardStyleInteractive}"
                            Height="{StaticResource SizePricingCardHeight}"
                            Padding="{StaticResource PaddingCardCompact}"
                            AutomationProperties.Name="{Binding Name, StringFormat='Plan: {0}'}">

                        <!-- Click to Edit -->
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding EditPlanCommand}"/>
                        </Border.InputBindings>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Name + Status -->
                                <RowDefinition Height="*"/>
                                <!-- Price -->
                                <RowDefinition Height="Auto"/>
                                <!-- Duration -->
                            </Grid.RowDefinitions>

                            <!-- Top Row -->
                            <Grid Grid.Row="0">
                                <TextBlock Text="{Binding Name}" 
                                           Style="{StaticResource BodyMedium}" 
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>

                                <!-- Status Badge -->
                                <Border Style="{StaticResource StatusBadgeStyle}"
                                        Background="{Binding Status, Converter={StaticResource PlanStatusToBrushConverter}}"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Status}" 
                                               Style="{StaticResource Micro}" 
                                               Foreground="{DynamicResource TextOnAccentBrush}" 
                                               FontWeight="Bold"/>
                                               
                                </Border>
                            </Grid>

                            <!-- Middle Row: Price -->
                            <StackPanel Grid.Row="1" 
                                        Orientation="Horizontal" 
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Price, StringFormat='{}{0:C}'}" 
                                           Style="{StaticResource Title1}" 
                                           Foreground="{DynamicResource FacilityAccentBrush}"/>
                                <TextBlock Text="{DynamicResource TerminologyPerMonthLabel}" 
                                           Style="{StaticResource BodySecondary}" 
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           VerticalAlignment="Bottom"
                                           Margin="4,0,0,6"/>
                            </StackPanel>

                            <!-- Bottom Row: Details -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <Path Data="{StaticResource IconClock}" 
                                      Fill="{DynamicResource TextSecondaryBrush}" 
                                      Style="{StaticResource IconSmall}"
                                      Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding DurationDescription}" 
                                           Style="{StaticResource Caption}" 
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 3. EMPTY STATE OVERLAY -->
        <Grid Grid.Row="1" 
              Visibility="{Binding Plans.Count, Converter={StaticResource ZeroIsVisibleConverter}}"
              IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,32">
                <!-- Tag/Price Icon -->
                <Path Data="{StaticResource IconTag}"
                      Fill="{DynamicResource IllustrationBackgroundBrush}"
                      Width="{StaticResource SizeIconHero}" 
                      Height="{StaticResource SizeIconHero}"
                      Stretch="Uniform"
                      Margin="{StaticResource MarginSectionBottom}"
                      HorizontalAlignment="Center"/>

                <TextBlock Text="{DynamicResource TerminologyNoMembershipPlansLabel}" 
                           Style="{StaticResource Title2}" 
                           Foreground="{DynamicResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center"
                           Margin="{StaticResource MarginTextBottom}"/>

                <TextBlock Text="{DynamicResource TerminologyCreatePlansPromptLabel}" 
                           Style="{StaticResource Body}" 
                           Foreground="{DynamicResource TextTertiaryBrush}" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>