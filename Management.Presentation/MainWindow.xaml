<Window x:Class="Management.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Management.Presentation.Converters"
        xmlns:viewmodels="clr-namespace:Management.Presentation.ViewModels"
        xmlns:shell="clr-namespace:Management.Presentation.Views.Shell"
        xmlns:components="clr-namespace:Management.Presentation.Components"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="K" Command="{Binding OpenCommandPaletteCommand}"/>
        <KeyBinding Modifiers="Control+Shift" Key="D" Command="{Binding ToggleDiagnosticCommand}"/>
        <KeyBinding Modifiers="Control" Key="Z" Command="{Binding UndoCommand}"/>
</Window.InputBindings>

    <Grid Background="{DynamicResource WindowBg}">
        <!-- Strictly isolated layers -->
        <TextBlock Text="DEBUG: ROOT" Foreground="{DynamicResource TextTertiaryBrush}" Opacity="0.1" VerticalAlignment="Top" HorizontalAlignment="Left" IsHitTestVisible="False"/>

        <!-- 1. OPERATIONAL SHELL LAYER -->
        <Grid Visibility="{Binding IsOperational, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Automatically sized Sidebar -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource FacilitySidebarBrush}">
                <shell:SidebarView DataContext="{Binding}"/>
            </Border>

            <!-- Workspace -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/> <!-- Strictly 80px TopBar -->
                    <RowDefinition Height="*"/>  <!-- Main Content -->
                </Grid.RowDefinitions>

                <!-- TopBar -->
                <Border Grid.Row="0" Background="{DynamicResource WindowBg}" BorderBrush="{DynamicResource SeparatorStroke}" BorderThickness="0,0,0,1">
                    <Grid Margin="48,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Search Bar -->
                        <Border HorizontalAlignment="Left" Width="480" Height="40"
                                Background="{DynamicResource SurfaceBg}" CornerRadius="18" Margin="0,0,24,0"
                                BorderBrush="{DynamicResource SeparatorStroke}" BorderThickness="1">
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.01,15.14C11.87,16.11 10.39,16.7 8.78,16.7C4.81,16.7 1.6,13.49 1.6,9.52C1.6,5.55 4.81,2.34 8.78,2.34C10.39,2.34 11.87,2.93 13.01,3.9L9.5,3M9.5,5A4.5,4.5 0 0,0 5,9.5A4.5,4.5 0 0,0 9.5,14A4.5,4.5 0 0,0 14,9.5A4.5,4.5 0 0,0 9.5,5Z" 
                                      Fill="{DynamicResource TextSecondaryBrush}" Stretch="Uniform" Width="16" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}"
                                         VerticalAlignment="Center" Margin="12,0" FontSize="14" CaretBrush="{DynamicResource AccentBrush}"/>
                            </Grid>
                        </Border>

                        <!-- Right: Actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{DynamicResource PrimaryButton}" 
                                    Content="{Binding AddButtonText}"
                                    Command="{Binding AddCommand}"
                                    Height="40" Padding="16,0"/>
                            <Ellipse Width="48" Height="48" Fill="{DynamicResource SurfaceBg}" Stroke="{DynamicResource SeparatorStroke}" StrokeThickness="1" Margin="16,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Workspace Content -->
                <Grid Grid.Row="1" Margin="48,0,48,32">
                    <ContentControl Content="{Binding CurrentViewModel, NotifyOnTargetUpdated=True}">
                        <ContentControl.Triggers>
                            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                <BeginStoryboard Storyboard="{DynamicResource ViewEntranceAnimation}"/>
                            </EventTrigger>
                        </ContentControl.Triggers>
                        <ContentControl.RenderTransform>
                            <TranslateTransform/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                </Grid>
            </Grid>
        </Grid>

        <!-- 2. ONBOARDING / LOGIN LAYER (Full Screen) -->
        <Grid Background="{DynamicResource WindowBg}" Visibility="{Binding IsOperational, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
            <ContentControl Content="{Binding CurrentViewModel}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
        </Grid>

        <!-- Overlays (Explicitly Collapsed Default) -->
        <Grid Panel.ZIndex="5000" Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Grid Background="#7F000000" IsHitTestVisible="True" Focusable="True"/>
            <ContentControl Content="{Binding CurrentModalViewModel}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <shell:CommandPaletteView Panel.ZIndex="3000" 
                                  Visibility="{Binding CommandPalette.IsVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
                                  DataContext="{Binding CommandPalette}"
                                  IsEnabled="{Binding IsOperational}"/>

        <shell:NotificationOverlay HorizontalAlignment="Center" VerticalAlignment="Top" Panel.ZIndex="2000"
                                   DataContext="{Binding NotificationService}"
                                   Visibility="{Binding NotificationService.HasNotifications, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
    </Grid>
</Window>
