<UserControl x:Class="Management.Presentation.Views.Restaurant.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Restaurant"
             xmlns:local="clr-namespace:Management.Presentation.Views.Restaurant"
             xmlns:settings="clr-namespace:Management.Presentation.Views.Settings"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F1F5F9">

    <UserControl.Resources>
    </UserControl.Resources>

    <!-- Root layout: content + optional slide-in drawer -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/> <!-- Drawer -->
        </Grid.ColumnDefinitions>

        <!-- Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â MAIN CONTENT Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â -->
        <Grid Grid.Column="0" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                    <Path Data="{StaticResource IconBox}" 
                          Style="{StaticResource Style.Icon.Large}" 
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          Margin="0,0,12,0"/>
                    <TextBlock Text="{DynamicResource Strings.Restaurant.Inventory}" Style="{StaticResource Title.H2}"/>
                </StackPanel>

                <!-- Ã°Å¸â€â€ž View Toggle Button (Dashboard Style) -->
                <Button Grid.Column="1"
                        Command="{Binding RelativeSource={RelativeSource AncestorType=settings:MenuManagementView}, Path=DataContext.ToggleViewCommand}"
                        Width="160" Height="44" Margin="0,0,12,0" 
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <Path Fill="{DynamicResource Brush.Text.Primary}" 
                              Data="{Binding RelativeSource={RelativeSource AncestorType=settings:MenuManagementView}, Path=DataContext.ToggleViewIcon, Converter={StaticResource ResourceLookupConverter}}"
                              Width="16" Height="16" Margin="0,0,10,0" Stretch="Uniform"/>
                        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=settings:MenuManagementView}, Path=DataContext.ToggleViewText}" 
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                       
                <!-- Add Button -->
                <Button Grid.Column="2" 
                        Command="{Binding AddResourceCommand}" 
                        Content="{DynamicResource Strings.Restaurant.AddResource}"
                        Background="{DynamicResource FacilityAccentBrush}"
                        Style="{DynamicResource Button.Primary}" 
                        Height="44" Padding="20,0"/>
            </Grid>

            <!-- 2. Filters (Premium Pills Layout) -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Border Background="{DynamicResource SurfaceBg}" 
                        CornerRadius="12" 
                        Padding="4" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        HorizontalAlignment="Left">
                    
                    <ListBox ItemsSource="{Binding Categories}" 
                             SelectedItem="{Binding SelectedCategoryFilter}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                <Setter Property="Height" Value="36"/>
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="Margin" Value="0,0,4,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="PillBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="18"
                                                    Padding="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource FacilityAccentDimBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource FacilityAccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource FacilityAccentDimBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Grid>

            <!-- 3. Grid of Cards (ListBox for Selection Management) -->
            <ListBox Grid.Row="2" 
                     ItemsSource="{Binding FilteredResources}" 
                     SelectedItem="{Binding SelectedItem}"
                     Background="Transparent" 
                     BorderThickness="0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <local:InventoryResourceListItem/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Loading Overlay -->
            <Border Grid.RowSpan="3" Background="{DynamicResource OverlayBrush}" 
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="16">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Style="{StaticResource CircularProgressBar}" IsIndeterminate="True"/>
                </StackPanel>
            </Border>
            </Grid>

            <!-- Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â DRAWER (Side Panel) Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â -->
            <Border x:Name="Drawer" 
                    Grid.Column="1"
                    HorizontalAlignment="Right" 
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}" 
                    Background="{DynamicResource CardBackgroundBrush}" 
                    BorderBrush="{DynamicResource SeparatorStroke}" 
                    BorderThickness="1,0,0,0"
                    CornerRadius="32,0,0,32"
                    Effect="{StaticResource Shadow3}">
                <Border.RenderTransform>
                        <TranslateTransform X="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=local:InventoryView}, Path=ActualWidth}"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0" Duration="{StaticResource DurationNormal}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="1200" Duration="{StaticResource DurationNormal}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <ContentControl Content="{Binding CurrentDrawerContent}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:LogPurchaseViewModel}">
                            <local:LogPurchaseView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:InventoryResourceCardViewModel}">
                            <local:InventoryDetailsView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Border>
        </Grid>
</UserControl>
