<UserControl x:Class="Management.Presentation.Views.History.ReservationHistoryList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <!-- 
        Row Item Structure (Section 28.5)
        - Height: 80px ({StaticResource SizeHistoryItemHeight})
        - Style: TimelineCardStyle (Global) - Handles Shadow L1 on Hover
    -->
    <Border Style="{StaticResource TimelineCardStyle}"
            Height="{StaticResource SizeHistoryItemHeight}"
            Padding="{StaticResource PaddingCardList}"
            AutomationProperties.Name="{Binding Title, StringFormat={DynamicResource TerminologyReservationHistoryName}}">

        <!-- Context Menu (Booking Specific Actions) -->
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource TerminologyViewDetailsLabel}" 
                          Command="{Binding ViewDetailsCommand}">
                    <MenuItem.Icon>
                        <Path Data="{StaticResource IconEye}" 
                              Fill="{DynamicResource TextPrimaryBrush}" 
                              Style="{StaticResource IconSmall}"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource TerminologyCancelBookingLabel}" 
                          Command="{Binding CancelBookingCommand}">
                    <MenuItem.Icon>
                        <Path Data="{StaticResource IconClose}" 
                              Fill="{DynamicResource StatusErrorBrush}" 
                              Style="{StaticResource IconSmall}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Border.ContextMenu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Icon -->
                <ColumnDefinition Width="*"/>
                <!-- Info -->
                <ColumnDefinition Width="Auto"/>
                <!-- Timestamp -->
            </Grid.ColumnDefinitions>

            <!-- 
                1. Reservation Icon (Global Component)
                - Style: GlobalReservationIconStyle
                - Theme: Yellow/Warning Background + Calendar Icon
                - Dimensions: 40x40px
            -->
            <Border Grid.Column="0"
                    Style="{StaticResource GlobalReservationIconStyle}"
                    Width="{StaticResource SizeIconContainer}"
                    Height="{StaticResource SizeIconContainer}"
                    Margin="{StaticResource MarginIconRight}"/>

            <!-- 2. Booking Details -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <!-- Title: Activity Name (e.g. Personal Training) -->
                <TextBlock Text="{Binding Title}" 
                           Style="{StaticResource BodyMedium}" 
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Subtitle: Instructor + Location -->
                <!-- Example: "with Sarah &#x2022; Zone A" -->
                <TextBlock Style="{StaticResource Caption}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="{StaticResource MarginSmallTop}">
                    <Run Text="{DynamicResource TerminologyWithLabel}"/>
                    <Run Text="{Binding InstructorName}" 
                         FontWeight="Medium"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Run Text=" &#x2022; "/>
                    <Run Text="{Binding Location}"/>
                </TextBlock>
            </StackPanel>

            <!-- 3. Timestamp -->
            <TextBlock Grid.Column="2" 
                       Text="{Binding Timestamp, StringFormat='{}{0:h:mm tt}'}" 
                       Style="{StaticResource Caption}" 
                       Foreground="{StaticResource TextTertiaryBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</UserControl>