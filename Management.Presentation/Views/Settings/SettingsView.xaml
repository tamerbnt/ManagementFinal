<UserControl x:Class="Management.Presentation.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Settings"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Scrollable Accordion -->
        </Grid.RowDefinitions>

        <!-- 1. Header -->
        <TextBlock Grid.Row="0" 
                   Text="{DynamicResource TerminologySettingsLabel}"  
                   Style="{StaticResource Title1}" 
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="{StaticResource MarginPageHeader}"/>

        <!-- 2. Accordion Container -->
        <!-- FIX: Removed Style property from ScrollViewer -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- FIX: Added Style to Resources to target internal ScrollBars -->
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource GlobalScrollBarStyle}"/>
            </ScrollViewer.Resources>

            <StackPanel Margin="{StaticResource MarginPageContent}">

                <!-- Section 1: General -->
                <Expander Header="{DynamicResource TerminologyGeneralLabel}" 
                          Style="{StaticResource GlobalSettingsAccordionStyle}"
                          IsExpanded="{Binding IsGeneralExpanded}">
                    <local:GeneralSettingsView />
                </Expander>

                <!-- Section 2: Membership Plans -->
                <Expander Header="{DynamicResource TerminologyMembershipPlansLabel}" 
                          Style="{StaticResource GlobalSettingsAccordionStyle}"
                          IsExpanded="{Binding IsPlansExpanded}">
                    <local:MembershipPlansSettingsView />
                </Expander>

                <!-- Section 3: Facility -->
                <Expander Header="{DynamicResource TerminologyFacilityAccessLabel}" 
                          Style="{StaticResource GlobalSettingsAccordionStyle}"
                          IsExpanded="{Binding IsFacilityExpanded}">
                    <local:FacilitySettingsView />
                </Expander>

                <!-- Section 4: Appearance -->
                <Expander Header="{DynamicResource TerminologyAppearanceLabel}" 
                          Style="{StaticResource GlobalSettingsAccordionStyle}"
                          IsExpanded="{Binding IsAppearanceExpanded}">
                    <local:AppearanceSettingsView />
                </Expander>

                <!-- Section 5: Integrations -->
                <Expander Header="{DynamicResource TerminologyIntegrationsLabel}" 
                          Style="{StaticResource GlobalSettingsAccordionStyle}"
                          IsExpanded="{Binding IsIntegrationsExpanded}">
                    <local:IntegrationSettingsView />
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>