<UserControl x:Class="Management.Presentation.Views.Shell.DashboardView"
             x:Name="DashboardRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:data="clr-namespace:Management.Presentation.Components.Data"
             xmlns:controls="clr-namespace:Management.Presentation.Resources.Controls"
             xmlns:shell="clr-namespace:Management.Presentation.ViewModels.Shell"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="Transparent">
    <UserControl.Resources>
        <controls:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <converters:TerminologyConverter x:Key="TerminologyConverter"/>
    </UserControl.Resources>

    <Grid Margin="0" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Row 0: Header -->
            <RowDefinition Height="Auto" /> <!-- Row 1: Bento Stats -->
            <RowDefinition Height="*" />    <!-- Row 2: Content (Chart + Activity) -->
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Grid Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Path Data="{StaticResource IconDashboard}" 
                      Style="{StaticResource Style.Icon.Large}" 
                      Stroke="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,12,0"
                      VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Terminology.Dashboard.Title}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{DynamicResource Terminology.Dashboard.Subtitle}" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            
            <!-- Context Action & Toggle -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- Unified Header Actions -->
                <StackPanel Orientation="Horizontal">
                    
                    <!-- Switch View Button -->
                    <Button Command="{Binding ToggleDashboardModeCommand}" Width="160" Height="44" Margin="0,0,12,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                                    CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                    <Setter Property="Effect" Value="{StaticResource Shadow.Level2}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path x:Name="ActionIcon" Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14" Margin="0,0,10,0" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{DynamicResource IconFinance}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                                                <Setter Property="Data" Value="{DynamicResource IconRunner}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Action.BusinessView}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Action.OperationsView}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>


                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ========================== -->
        <!-- OPERATIONS VIEW (Original) -->
        <!-- ========================== -->
        <Grid Grid.Row="1" Grid.RowSpan="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Row 1: Bento Grid Stats -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" /> <!-- Hero -->
                    <ColumnDefinition Width="1*" />   <!-- Standard -->
                    <ColumnDefinition Width="1*" />   <!-- Split Column -->
                    <ColumnDefinition Width="1*" />   <!-- Actions/Extra -->
                </Grid.ColumnDefinitions>

                <!-- 1. Hero Card: People Inside (Gym) / Today's Appointments (Salon) -->
                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <!-- Gym: People Inside -->
                    <Border CornerRadius="16" Height="170" Background="{DynamicResource FacilitySidebarBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect><StaticResource ResourceKey="Shadow.Level3"/></Border.Effect>
                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="White" CornerRadius="8" Padding="6" Opacity="0.1">
                                    <Path Data="{StaticResource IconGym}" Stroke="White" Width="14" Height="14" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Foreground="White" Opacity="0.8" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Medium">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.PeopleInside}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.LiveTableStatus}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="{Binding PeopleInside}" Foreground="White" FontSize="48" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Grid.Row="2" CornerRadius="12" HorizontalAlignment="Left" Padding="8,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasPeopleInsideTrend}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding PeopleInsideTrendText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            
                            <!-- Restaurant: Table Seating Percent -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Visibility="{Binding IsRestaurantMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Background="{DynamicResource FacilityAccentBrush}" CornerRadius="10" Padding="8,3" Margin="0,0,8,0">
                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                        <Run Text="{Binding ActiveTablesCount}"/><Run Text="/"/><Run Text="{Binding TotalTablesCount}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.TablesOccupied}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Salon: Today's Appointments -->
                    <Border CornerRadius="16" Height="170" Background="{DynamicResource FacilitySidebarBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect><StaticResource ResourceKey="Shadow.Level3"/></Border.Effect>
                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="White" CornerRadius="8" Padding="6" Opacity="0.15">
                                    <Path Data="{StaticResource IconClock}" Stroke="White" Width="14" Height="14" Stretch="Uniform"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Stat.TodaysAppointments}" Foreground="White" Opacity="0.85" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="{Binding TodayAppointmentsTotal}" Foreground="White" FontSize="48" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <Border Background="{DynamicResource StatusSuccessBrush}" CornerRadius="10" Padding="8,3" Margin="0,0,8,0">
                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                        <Run Text="&#x2713; "/><Run Text="{Binding TodayAppointmentsCompleted}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.Stat.Done}"/>
                                    </TextBlock>
                                </Border>
                                <Border Background="#30FFFFFF" CornerRadius="10" Padding="8,3">
                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                        <Run Text="&#x23F3; "/><Run Text="{Binding TodayAppointmentsPending}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.Stat.Upcoming}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2. Active Members (Gym) / Today's Covers (Restaurant) -->
                <data:StatTile Grid.Column="1" Margin="0,0,16,0" 
                               Value="{Binding TotalActiveMembers}" 
                               IconData="{StaticResource IconMembers}" 
                               IconBrush="{DynamicResource StatusSuccessBrush}" 
                               IsLoading="{Binding IsLoading}" Height="170">
                    <data:StatTile.Style>
                        <Style TargetType="data:StatTile">
                            <Setter Property="Label" Value="{DynamicResource Terminology.Dashboard.Stat.ActiveMembers}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                    <Setter Property="Label" Value="{DynamicResource Terminology.Dashboard.Stat.CoversToday}"/>
                                    <Setter Property="Value" Value="{Binding TodayCovers}"/>
                                    <Setter Property="IconData" Value="{StaticResource IconMembers}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                    <Setter Property="Label" Value="{DynamicResource Terminology.Dashboard.Stat.ActiveClients}"/>
                                    <Setter Property="Value" Value="{Binding TotalActiveMembers}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </data:StatTile.Style>
                </data:StatTile>

                <!-- 3. Split Column (Expiring / Pending) -->
                <Grid Grid.Column="2" Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" /> <!-- Spacer -->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <!-- Expiring -->
                    <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16">
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level1"/>
                        </Border.Effect>
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource StatusWarningBackground}" Width="40" Height="40" CornerRadius="10">
                                <Path Data="{StaticResource IconClock}" Stroke="{DynamicResource StatusWarningBrush}" Width="16" Height="16" Stretch="Uniform"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="{Binding ExpiringSoon}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding ExpiringSoonCount}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Text" Value="{Binding AverageOrderValue, StringFormat='{}{0:N1} DA'}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.ExpiringSoon}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.AverageOrderValue}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Pending -->
                    <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16">
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level1"/>
                        </Border.Effect>
                        <Grid Margin="16,12">
                             <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource StatusErrorBackground}" Width="40" Height="40" CornerRadius="10">
                                <Path Data="{StaticResource IconRegistrations}" Stroke="{DynamicResource StatusErrorBrush}" Width="16" Height="16" Stretch="Uniform"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding PendingRegistrationsCount}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Text" Value="{Binding PendingOrdersCount}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.PendingRegs}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Stat.PendingOrders}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 4. Revenue Snapshot (Replaces Quick Actions) -->
                 <Border Grid.Column="3" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="16" Height="170">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2"/>
                    </Border.Effect>
                    <Grid Margin="20">
                         <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#20FFFFFF" Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                <Path Data="{StaticResource IconFinance}" Stroke="White" Width="14" Height="14" Stretch="Uniform"/> 
                            </Border>
                            <TextBlock Text="{DynamicResource Terminology.Home.RevenueToday}" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                             <TextBlock Text="{Binding FinancialSummary.Revenue, StringFormat='{}{0:N2} DA'}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                             <ProgressBar Value="{Binding RevenueProgress}" Maximum="1" Height="4" Background="#20FFFFFF" Foreground="{DynamicResource FacilityAccentBrush}" BorderThickness="0" Margin="0,8,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding RevenueProgress, StringFormat={}{0:P0}}" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" FontSize="12"/>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Stat.DailyTarget}" Foreground="White" Opacity="0.7" FontSize="12" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 2: Content Grid (Chart Left, Retention Right) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" /> <!-- Chart (Wider for Strategy) -->
                    <ColumnDefinition Width="1*" /> <!-- Retention List -->
                </Grid.ColumnDefinitions>

                <!-- Chart Section -->
            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,24,0">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2"/>
                    </Border.Effect>
                    <Grid Margin="32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Border Width="4" Height="24" Background="{DynamicResource StatusSuccessBrush}" CornerRadius="2" Margin="0,0,12,0"/>
                             <StackPanel>
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Chart.Occupancy.Title}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Chart.Occupancy.Subtitle}" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"/>
                             </StackPanel>
                        </StackPanel>
                        
                        <lvc:CartesianChart Grid.Row="1" Margin="0,24,0,0"
                                            Series="{Binding OccupancySeries}" 
                                            XAxes="{Binding OccupancyXAxes}"
                                            YAxes="{Binding OccupancyYAxes}" 
                                            TooltipPosition="Top">
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <!-- Right Panel: Retention Focus (Gym) / Revenue by Plan (Salon) -->
                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,0">

                    <!-- Revenue by Plan -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                            </Style>
                        </Border.Style>
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level2" />
                        </Border.Effect>
                        <Grid Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Title with Dropdown -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="{DynamicResource FacilityAccentBrush}" Width="4" Height="18" CornerRadius="2" Margin="0,0,10,0"/>
                                <Button Command="{Binding ToggleRevenueModeCommand}" Tag="{Binding DataContext, RelativeSource={RelativeSource Self}}" Cursor="Hand" Padding="0" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding RevenueBreakdownTitle}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <Path Data="M0,0 L4,4 L8,0" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5" Width="10" Height="6" Margin="8,2,0,0" VerticalAlignment="Center" Stretch="Uniform">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </StackPanel>
                                    <Button.ContextMenu>
                                        <ContextMenu d:DataContext="{d:DesignInstance Type=shell:DashboardViewModel}"
                                                     DataContext="{Binding Data, Source={StaticResource Proxy}}">
                                            <MenuItem Header="{DynamicResource Terminology.Dashboard.Chart.RevenueBreakdown}" 
                                                      Visibility="{Binding IsRestaurantMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                      Command="{Binding SetRevenueModeCommand}" 
                                                      CommandParameter="Plan"/>
                                            <MenuItem Header="{DynamicResource Terminology.Dashboard.Chart.RevenueBreakdownProduct}" 
                                                      Visibility="{Binding IsRestaurantMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                      Command="{Binding SetRevenueModeCommand}" 
                                                      CommandParameter="Product"/>
                                            <MenuItem Header="{DynamicResource Terminology.Dashboard.Chart.RevenueBreakdownMenuItem}" 
                                                      Visibility="{Binding IsRestaurantMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                      Command="{Binding SetRevenueModeCommand}" 
                                                      CommandParameter="MenuItem"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Click">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <BooleanAnimationUsingKeyFrames Storyboard.TargetProperty="ContextMenu.IsOpen">
                                                                <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True"/>
                                                            </BooleanAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Filter Buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Content="{DynamicResource Terminology.Dashboard.Range.Today}" Command="{Binding SetPlanFilterCommand}" CommandParameter="Today" Margin="0,0,6,0" Height="28" Padding="12,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPlanFilter}" Value="Today">
                                                    <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource Terminology.Dashboard.Range.ThisWeek}" Command="{Binding SetPlanFilterCommand}" CommandParameter="This Week" Margin="0,0,6,0" Height="28" Padding="12,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPlanFilter}" Value="This Week">
                                                    <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource Terminology.Dashboard.Range.ThisMonth}" Command="{Binding SetPlanFilterCommand}" CommandParameter="This Month" Height="28" Padding="12,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPlanFilter}" Value="This Month">
                                                    <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>

                            <!-- Plan Revenue List -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding PlanRevenue}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,14">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="6"/>
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding PlanName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}">
                                                            <Run Text="{Binding Count}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.Stat.Sales}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Revenue, StringFormat=C0, ConverterCulture=fr-DZ}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right">
                                                            <Run Text="{Binding Count, StringFormat='{}{0} Sales'}"/>
                                                            <Run Text=" ("/><Run Text="{Binding Percentage, StringFormat='{}{0:N0}'}"/><Run Text="%)"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                                <ProgressBar Grid.Row="1" Value="{Binding Percentage}" Maximum="100" Height="4"
                                                             Background="{DynamicResource SurfaceBg}"
                                                             Foreground="{DynamicResource FacilityAccentBrush}"
                                                             BorderThickness="0" VerticalAlignment="Bottom"
                                                             Margin="0,4,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ========================== -->
        <!-- BUSINESS VIEW (New)        -->
        <!-- ========================== -->
        <Grid Grid.Row="1" Grid.RowSpan="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusinessMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Row 1: Financial Cards -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" /> <!-- Hero -->
                    <ColumnDefinition Width="1*" />   <!-- Revenue -->
                    <ColumnDefinition Width="1*" />   <!-- Expenses -->
                </Grid.ColumnDefinitions>

                <!-- 1. Master Financial Card -->
                <Border Grid.Column="0" Margin="0,0,16,0" CornerRadius="16" Height="170" Background="{DynamicResource FacilitySidebarBrush}">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Modal" />
                    </Border.Effect>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="White" CornerRadius="8" Padding="6" Opacity="0.1">
                                <Path Data="{StaticResource IconFinance}" Stroke="White" Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Business.NetProfitToday}" Foreground="White" Opacity="0.8" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Strings.Shell.DA}" Foreground="White" FontSize="32" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="0,0,4,6"/>
                            <TextBlock Text="{Binding FinancialSummary.NetProfit, StringFormat=N0}" Foreground="White" FontSize="48" FontWeight="Bold" VerticalAlignment="Bottom"/>
                        </StackPanel>
                        
                        <Border Grid.Row="2" Background="{Binding FinancialSummary.NetProfitPercentChange, Converter={StaticResource TrendToBrushConverter}, ConverterParameter='NetProfit_Background'}" CornerRadius="12" HorizontalAlignment="Left" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{Binding FinancialSummary.NetProfitPercentChange, Converter={StaticResource TrendToIconConverter}, ConverterParameter='NetProfit_Icon'}" Stroke="White" StrokeThickness="2" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding FinancialSummary.NetProfitPercentChange, StringFormat='{}{0:F1}% '}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.VsYesterday}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 2. Revenue Card -->
                <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,16,0" Height="170">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2" />
                    </Border.Effect>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource BackgroundBrush}" Width="32" Height="32" CornerRadius="8">
                                <Path Data="{StaticResource IconFinance}" Stroke="{DynamicResource BrandPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Business.Revenue}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="{Binding FinancialSummary.Revenue, StringFormat='{}{0:N2} DA'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="32" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding FinancialSummary.RevenuePercentChange, StringFormat='{}{0:F1}%'}" Foreground="{Binding FinancialSummary.RevenuePercentChange, Converter={StaticResource TrendToTextBrushConverter}, ConverterParameter='Revenue'}" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.VsYesterday}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 3. Expenses Card -->
                <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Height="170">
                    <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2" />
                    </Border.Effect>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource StatusErrorBackground}" Width="32" Height="32" CornerRadius="8">
                                <Path Data="{StaticResource IconFinance}" Stroke="{DynamicResource StatusErrorBrush}" Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Business.Expenses}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="{Binding FinancialSummary.Expenses, StringFormat='{}{0:N2} DA'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="32" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                         <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="{Binding FinancialSummary.ExpensesPercentChange, StringFormat='{}{0:F1}%'}" Foreground="{Binding FinancialSummary.ExpensesPercentChange, Converter={StaticResource TrendToTextBrushConverter}, ConverterParameter='Expenses'}" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.VsYesterday}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 2: Charts & Lists -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.5*" /> <!-- Chart -->
                    <RowDefinition Height="1*" />   <!-- Lists -->
                </Grid.RowDefinitions>

                <!-- Revenue Chart -->
                <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,0,24">
                     <Border.Effect>
                        <StaticResource ResourceKey="Shadow.Level2"/>
                    </Border.Effect>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                             <Border Width="4" Height="24" Background="{DynamicResource BrandPrimaryBrush}" CornerRadius="2" Margin="0,0,12,0"/>
                             <StackPanel>
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Chart.Revenue.Title}" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{DynamicResource Terminology.Dashboard.Chart.Revenue.Subtitle}" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"/>
                             </StackPanel>
                        </StackPanel>
                         <lvc:CartesianChart Grid.Row="1" Margin="0,24,0,0"
                                            Series="{Binding RevenueSeries}" 
                                            XAxes="{Binding RevenueXAxes}"
                                            YAxes="{Binding RevenueYAxes}" 
                                            TooltipPosition="Top"/>
                    </Grid>
                </Border>

                <!-- Bottom Lists -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent Transactions -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,16,0">
                         <Border.Effect>
                            <StaticResource ResourceKey="Shadow.Level1"/>
                        </Border.Effect>
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Transactions.Title}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            
                            <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding RecentTransactions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <Border Background="{DynamicResource BackgroundBrush}" Width="32" Height="32" CornerRadius="16">
                                                     <Path Data="{DynamicResource IconFinance}" Fill="{DynamicResource BrandPrimaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
                                                </Border>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding MemberName}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                </StackPanel>
                                                
                                                <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat='{}{0:N2} DA'}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Top Staff / Performance List -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSalonMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                             <Border.Effect>
                                <StaticResource ResourceKey="Shadow1"/>
                            </Border.Effect>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Background="{DynamicResource FacilityAccentBrush}" Width="4" Height="16" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Terminology.Dashboard.TopPerformingStaff}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="{DynamicResource Terminology.Dashboard.Range.Today}" Command="{Binding SetStaffFilterCommand}" CommandParameter="Today" Margin="0,0,6,0" Height="24" Padding="10,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStaffFilter}" Value="Today">
                                                        <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="{DynamicResource Terminology.Dashboard.Range.ThisWeek}" Command="{Binding SetStaffFilterCommand}" CommandParameter="This Week" Margin="0,0,6,0" Height="24" Padding="10,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStaffFilter}" Value="This Week">
                                                        <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="{DynamicResource Terminology.Dashboard.Range.ThisMonth}" Command="{Binding SetStaffFilterCommand}" CommandParameter="This Month" Height="24" Padding="10,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedStaffFilter}" Value="This Month">
                                                        <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <ScrollViewer Grid.Row="2" Margin="0,12,0,0">
                                    <ItemsControl ItemsSource="{Binding StaffPerformance}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="{DynamicResource BackgroundBrush}" Width="32" Height="32" CornerRadius="16">
                                                         <Path Data="{DynamicResource IconRunner}" Fill="{DynamicResource FacilityAccentBrush}" Width="12" Height="12" Stretch="Uniform"/>
                                                    </Border>
                                                     <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                        <TextBlock Text="{Binding StaffName, Converter={StaticResource TerminologyConverter}}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}">
                                                            <Run Text="{Binding AppointmentCount}"/><Run Text=" "/><Run Text="{DynamicResource Terminology.Dashboard.Stat.Appointments}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding TotalSales, StringFormat='{}{0:N2} DA'}" FontWeight="Bold" Foreground="{DynamicResource StatusSuccessBrush}" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                 </ScrollViewer>
                            </Grid>
                        </Border>

                    <!-- Popular Items / Member Development Card -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16" Margin="0,0,16,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSalonMode}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Effect>
                            <StaticResource ResourceKey="Shadow1"/>
                        </Border.Effect>
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header (Dynamic) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="{DynamicResource StatusSuccessBrush}" Width="4" Height="16" CornerRadius="2" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Strings.Shell.MemberDevelopment}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Chart.PopularItems.Title}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextTertiaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{DynamicResource Strings.Shell.Totalactivememberstrend}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                        <Setter Property="Text" Value="{DynamicResource Terminology.Dashboard.Chart.PopularItems.Subtitle}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- Content (Chart for Gym, List for Restaurant) -->
                            <Grid Grid.Row="1">
                                <!-- Gym: Member Trend Chart -->
                                <lvc:CartesianChart Series="{Binding MemberSeries}" 
                                                  XAxes="{Binding MemberXAxes}"
                                                  YAxes="{Binding MemberYAxes}"
                                                  TooltipPosition="Top">
                                    <lvc:CartesianChart.Style>
                                        <Style TargetType="lvc:CartesianChart">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </lvc:CartesianChart.Style>
                                </lvc:CartesianChart>

                                <!-- Restaurant: Popular Items List -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRestaurantMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>
                                    <ItemsControl ItemsSource="{Binding PopularItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="6"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ItemName}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='{}{0} sold'}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </Grid>
                                                    <ProgressBar Grid.Row="1" Value="{Binding Percentage}" Maximum="100" Height="4" Margin="0,4,0,0"
                                                                 Background="{DynamicResource SurfaceBg}" Foreground="{DynamicResource StatusSuccessBrush}" BorderThickness="0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>


                    <!-- Quick Actions -->
                     <Border Grid.Column="2" Background="{DynamicResource FacilitySidebarBrush}" CornerRadius="16" VerticalAlignment="Stretch">
                         <Border.Effect>
                            <StaticResource ResourceKey="Shadow1"/>
                         </Border.Effect>
                        <Grid Margin="12">
                             <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{DynamicResource Terminology.Dashboard.Business.QuickActions}" FontWeight="Bold" Foreground="White"/>
                            
                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <Button Content="{DynamicResource Terminology.Dashboard.Action.RunPayroll}" 
                                        Command="{Binding RunPayrollCommand}"
                                        Style="{DynamicResource Button.Primary}" 
                                        Margin="0,0,0,4" Height="32"/>
                                <Button Content="{DynamicResource Terminology.Dashboard.QuickActions.PayrollHistory}" 
                                        Command="{Binding OpenPayrollHistoryCommand}"
                                        Style="{DynamicResource Button.Ghost}" Margin="0,0,0,4" Height="32" Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent"/>
                                <Button Content="{DynamicResource Terminology.Dashboard.Action.ExportReport}" 
                                        Command="{Binding ExportReportCommand}"
                                        Style="{DynamicResource Button.Ghost}" Height="32" Background="#20FFFFFF" Foreground="White" BorderBrush="Transparent"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        
        <!-- Loading Overlay -->
        <controls:SkeletonLoader Grid.RowSpan="3" 
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 VerticalAlignment="Top" Height="200" Margin="0,100,0,0"/>

    </Grid>
</UserControl>
