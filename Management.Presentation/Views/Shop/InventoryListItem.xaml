<UserControl x:Class="Management.Presentation.Views.Shop.InventoryListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignWidth="800" d:DesignHeight="70"
             RenderOptions.CachingHint="Cache">

    <UserControl.Resources>
        <converters:StockToBrushConverter x:Key="StockToBrushConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="0,0,0,12">
        <!-- Shadow Border -->
        <Border CornerRadius="16" Background="White" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1"/>

        <!-- Content Border -->
        <Border x:Name="RowBorder" 
                CornerRadius="16" 
                Padding="16,12" 
                BorderThickness="0">
        


        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <!-- Hover Animation -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.005" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.005" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    
                    <!-- Active/Selected State -->
                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                          <Setter Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                          <Setter Property="BorderThickness" Value="2"/>
                         <Setter Property="TextBlock.Foreground" Value="White"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        
        <Border.RenderTransform>
            <ScaleTransform CenterX="400" CenterY="35"/>
        </Border.RenderTransform>

        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{Binding ViewDetailsCommand}"/>
        </Border.InputBindings>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>  <!-- Selection Checkbox -->
                <ColumnDefinition Width="60"/>  <!-- Image/Icon -->
                <ColumnDefinition Width="2*" /> <!-- Name/SKU -->
                <ColumnDefinition Width="1*" /> <!-- Category -->
                <ColumnDefinition Width="1*" /> <!-- Price -->
                <ColumnDefinition Width="120"/> <!-- Stock Pill -->
                <ColumnDefinition Width="60"/> <!-- Actions -->
            </Grid.ColumnDefinitions>

            <!-- 0. Selection Checkbox -->
            <CheckBox Grid.Column="0" 
                      IsChecked="{Binding IsSelected}" 
                      Style="{StaticResource CircularSelectionCheckBoxStyle}"
                      VerticalAlignment="Center" 
                      HorizontalAlignment="Center"
                      Visibility="{Binding DataContext.IsSelectionMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- 1. Product Icon -->
            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="8" Background="{DynamicResource SurfaceBg}" HorizontalAlignment="Left">
                <Path Data="{StaticResource IconShop}" 
                      Fill="{DynamicResource TextSecondaryBrush}" 
                      Stretch="Uniform" 
                      Width="16" Height="16" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"/>
            </Border>

            <!-- 2. Name & SKU -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="{Binding Name}" 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Border}}" 
                           TextTrimming="CharacterEllipsis"/>
                
                <TextBlock Text="{Binding SKU}" 
                           FontSize="12" 
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,2,0,0">
                     <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Foreground" Value="#E0F7FA"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- 3. Category -->
            <TextBlock Grid.Column="3" 
                       Text="{Binding Category}" 
                       VerticalAlignment="Center" 
                       FontSize="13" 
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Border}}"/>

            <!-- 4. Price -->
            <TextBlock Grid.Column="4" 
                       Text="{Binding Price, StringFormat='{}{0:N2} DA'}" 
                       VerticalAlignment="Center" 
                       FontWeight="Bold" 
                       FontSize="13" 
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Border}}"/>

            <!-- 5. Stock Status Pill -->
            <Border Grid.Column="5" 
                    Background="{DynamicResource SurfaceBg}" 
                    CornerRadius="12" 
                    Padding="12,4" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Left">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/> 
                         <Style.Triggers>
                             <!-- Low Stock Warning Color -->
                            <DataTrigger Binding="{Binding StockLevel}" Value="Critical">
                                <Setter Property="Background" Value="{DynamicResource StatusErrorBrush}"/><!-- Using Error Brush for Critical -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="{Binding StockLevel, Converter={StaticResource StockToBrushConverter}}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StockQuantity, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Shop.StockCount'}" 
                               FontSize="12" 
                               FontWeight="Medium" 
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            
            <!-- 6. Actions -->
            <Button Grid.Column="6" 
                    Command="{Binding ModifyProductCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Cursor="Hand">
                <Path Data="{StaticResource IconEdit}">
                    <Path.Style>
                        <Style TargetType="Path" BasedOn="{StaticResource Style.Icon.Micro}">
                            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Fill" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
            </Button>

        </Grid>
    </Border>
    </Grid>
</UserControl>
