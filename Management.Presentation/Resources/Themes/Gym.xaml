<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- GYM THEME SEMANTIC MAPPING -->
    
    <SolidColorBrush x:Key="Brush.Window.Background" Color="{StaticResource Color.Background.Static}"/>
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Gray.200}"/>
    <SolidColorBrush x:Key="Brush.Surface.Background" Color="{StaticResource Color.Gray.50}"/>
    <Color x:Key="Color.Brand.Primary">#5B8AB8</Color> <!-- blue accent -->
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="{StaticResource Color.Brand.Primary}"/>
    
    <LinearGradientBrush x:Key="Brush.Sidebar.Background" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F172A" Offset="0.0"/>
        <GradientStop Color="#1E293B" Offset="1.0"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Brush.Sidebar.Foreground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Sidebar.Foreground.Muted" Color="#94A3B8"/>

    <LinearGradientBrush x:Key="Brush.Brand.Signature" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4F46E5" Offset="0"/>
        <GradientStop Color="#06B6D4" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Brush.Text.PrimaryReversed" Color="#FFFFFF"/>

</ResourceDictionary>
