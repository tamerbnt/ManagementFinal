<UserControl x:Class="Management.Presentation.Views.Registrations.RegistrationListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:local="clr-namespace:Management.Presentation.Views.Registrations"
             mc:Ignorable="d" 
             d:DesignHeight="88" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NameToBrushConverter x:Key="NameToBrushConverter"/>
        <converters:NameToInitialConverter x:Key="NameToInitialConverter"/>
    </UserControl.Resources>

    <UserControl.Template>
        <ControlTemplate TargetType="UserControl">
            <Grid Margin="0,0,0,12">
                <!-- Single Content Border with Shadow -->
                <Border x:Name="RowBorder" 
                        Background="{DynamicResource CardBackgroundBrush}" 
                        CornerRadius="16" 
                        Padding="16"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        RenderOptions.CachingHint="Cache">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" 
                                      Command="{Binding ViewDetailsCommand}"/>
                    </Border.InputBindings>
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>  <!-- 0: Avatar/Check -->
                            <ColumnDefinition Width="*"/>   <!-- 1: Name/Email -->
                            <ColumnDefinition Width="Auto"/> <!-- 2: Source -->
                            <ColumnDefinition Width="Auto"/> <!-- 3: Status -->
                            <ColumnDefinition Width="Auto"/> <!-- 4: Received At -->
                            <ColumnDefinition Width="Auto"/> <!-- 5: Actions -->
                        </Grid.ColumnDefinitions>
...

                    <!-- 1. Avatar & Checkbox (Identity Area) -->
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.ColumnSpan="2">
                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                  Style="{StaticResource CircularSelectionCheckBoxStyle}"
                                  VerticalAlignment="Center" 
                                  Margin="0,0,16,0"/>
                        
                        <Grid x:Name="AvatarContainer" VerticalAlignment="Center">
                            <Ellipse Width="40" Height="40" x:Name="AvatarPlaceholder" 
                                     Fill="{Binding FullName, Converter={StaticResource NameToBrushConverter}}"/>
                            <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialConverter}}" 
                                       x:Name="AvatarInitial"
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       FontSize="16"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="{Binding FullName}" x:Name="NameText" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding Email}" x:Name="EmailText" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 2. Source -->
                    <TextBlock Grid.Column="2" x:Name="SourceText" Text="{Binding Source}" 
                               VerticalAlignment="Center" FontWeight="Medium" 
                               Foreground="{DynamicResource BrandPrimaryBrush}" Margin="24,0"/>

                    <!-- 3. Status -->
                    <Border Grid.Column="3" x:Name="StatusBorder" Padding="8,4" CornerRadius="12" 
                            Background="{DynamicResource SurfaceBg}" VerticalAlignment="Center" Margin="0,0,24,0">
                        <TextBlock Text="{Binding Status, Converter={StaticResource EnumToLocalizedDescriptionConverter}}" x:Name="StatusText" Foreground="{DynamicResource StatusSuccessBrush}" 
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <!-- 4. Received At -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Width="100">
                        <TextBlock Text="{DynamicResource Terminology.Registrations.List.Received}" x:Name="ReceivedLabel" Style="{StaticResource Micro}" 
                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding CreatedAt, StringFormat='\{0:MMM dd, HH:mm\}'}" 
                                   x:Name="ReceivedDate" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- 5. Actions -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="24,0,8,0">
                        <Button Style="{StaticResource IconButtonStyle}" 
                                Command="{Binding ViewDetailsCommand}">
                            <Path x:Name="ViewIcon" Data="{StaticResource IconEye}" 
                                  Style="{StaticResource Style.Icon.Micro}" 
                                  Stroke="{DynamicResource BrandPrimaryBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            </Grid>
                
            <ControlTemplate.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.005" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.005" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter TargetName="RowBorder" Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter TargetName="RowBorder" Property="BorderThickness" Value="2"/>
                    <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter TargetName="EmailText" Property="Foreground" Value="{DynamicResource OnAccentSecondary}"/>
                    <Setter TargetName="SourceText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter TargetName="StatusBorder" Property="Background" Value="{DynamicResource OnAccentSecondary}"/>
                    <Setter TargetName="StatusText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter TargetName="ReceivedLabel" Property="Foreground" Value="{DynamicResource OnAccentSecondary}"/>
                    <Setter TargetName="ReceivedDate" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter TargetName="AvatarPlaceholder" Property="Fill" Value="{DynamicResource OnAccentSecondary}"/>
                    <Setter TargetName="AvatarInitial" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter TargetName="ViewIcon" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>
