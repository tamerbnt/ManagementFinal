<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
        APPLE 2025 MOTION SYSTEM
        
        Primary Curve: Cubic EaseOut (Quick entrance, gentle deceleration)
    -->

    <!-- ============================================================= -->
    <!-- 1. EASING FUNCTIONS                                           -->
    <!-- ============================================================= -->
    <CubicEase x:Key="EaseOutPrimary" EasingMode="EaseOut"/>

    <!-- ============================================================= -->
    <!-- 2. DURATION TOKENS (Standardized)                             -->
    <!-- ============================================================= -->
    
    <!-- Micro (120ms): Button presses, Checkbox toggles -->
    <Duration x:Key="DurationMicro">0:0:0.120</Duration>
    
    <!-- Small (180ms): Hover lifts, Icon fills -->
    <Duration x:Key="DurationSmall">0:0:0.180</Duration>
    
    <!-- Standard (220ms): Focus rings, Universal UI movement -->
    <Duration x:Key="DurationStandard">0:0:0.220</Duration>
    
    <!-- Medium (300ms): Slide-ins, Dropdowns, Content expansion -->
    <Duration x:Key="DurationMedium">0:0:0.300</Duration>
    
    <!-- Screen (350ms): Navigation transitions, Modal entrances -->
    <Duration x:Key="DurationScreen">0:0:0.350</Duration>
    <Duration x:Key="DurationScreenTransition">0:0:0.350</Duration>

    <!-- Compat / Aliases -->
    <Duration x:Key="DurationModal">0:0:0.350</Duration>

    <!-- ============================================================= -->
    <!-- 3. GLOBAL ANIMATIONS (Storyboards)                            -->
    <!-- ============================================================= -->

    <!-- 
        Skeleton Shimmer Animation
        Target: LinearGradientBrush inside a Skeleton Rectangle
    -->
    <Storyboard x:Key="SkeletonShimmerAnimation" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="(Brush.RelativeTransform).(TranslateTransform.X)"
                         From="-1" To="1"
                         Duration="0:0:1.5"
                         RepeatBehavior="Forever"/>
    </Storyboard>

    <!-- 
        VIEW ENTRANCE ANIMATION (Section 11.2)
        Action: Subtle FadeIn + Lift (20px) 
        Target: Main ContentControl or UserControl.Grid
    -->
    <Storyboard x:Key="ViewEntranceAnimation">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationStandard}">
            <DoubleAnimation.EasingFunction>
                <StaticResource ResourceKey="EaseOutPrimary"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="20" To="0"
                         Duration="{StaticResource DurationStandard}">
            <DoubleAnimation.EasingFunction>
                <StaticResource ResourceKey="EaseOutPrimary"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 
        PANEL SLIDE-IN (RIGHT)
        Action: Slide from Right (400px -> 0)
    -->
    <Storyboard x:Key="PanelSlideInRight">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         From="400" To="0"
                         Duration="{StaticResource DurationMedium}">
            <DoubleAnimation.EasingFunction>
                <StaticResource ResourceKey="EaseOutPrimary"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1"
                         Duration="{StaticResource DurationSmall}"/>
    </Storyboard>

    <!-- 
        PANEL SLIDE-OUT (RIGHT)
        Action: Slide to Right (0 -> 400px)
    -->
    <Storyboard x:Key="PanelSlideOutRight">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         To="400"
                         Duration="{StaticResource DurationMedium}">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseIn"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         To="0"
                         Duration="{StaticResource DurationSmall}"/>
    </Storyboard>

</ResourceDictionary>