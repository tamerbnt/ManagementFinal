<UserControl x:Class="Management.Presentation.Views.Shop.ProductDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Shop"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="400"
             Background="{DynamicResource CardBackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StockToBrushConverter x:Key="StockToBrushConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- 1. Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <Button Style="{StaticResource IconButtonStyle}" 
                    HorizontalAlignment="Right" 
                    Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=local:ShopView}}"
                    Margin="0,-8,-8,0">
                <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextTertiaryBrush}" Style="{StaticResource Style.Icon.Small}"/>
            </Button>

            <!-- Icon -->
            <Border Width="80" Height="80" 
                    CornerRadius="40" 
                    Background="{DynamicResource SurfaceBg}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
                <Path Data="{StaticResource IconShoppingBag}" 
                      Fill="{DynamicResource TextSecondaryBrush}" 
                      Stretch="Uniform" 
                      Width="32" Height="32"
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"/>
            </Border>

            <!-- Name (View Mode) -->
            <TextBlock Text="{Binding Name}" 
                       Style="{StaticResource Title2}" 
                       HorizontalAlignment="Center" 
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
            
            <!-- Name (Edit Mode) -->
            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource UnderlineTextBox}" 
                     HorizontalAlignment="Stretch"
                     FontSize="18" FontWeight="Bold"
                     TextAlignment="Center"
                     Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- SKU Badge -->
            <Border Background="{DynamicResource SurfaceBg}" Padding="12,4" CornerRadius="12" HorizontalAlignment="Center" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Terminology.Shop.Detail.SkuPrefix}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBlock Text="{Binding Sku}" Style="{StaticResource Micro}" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 2. Content -->
        <ScrollViewer Grid.Row="1" Margin="0,0,-8,0" Padding="0,0,8,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Quick Stats Grid (View Only) -->
                <Grid Margin="0,0,0,24" Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Terminology.Shop.Detail.StockLevel}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding StockQuantity}" Style="{StaticResource Title3}" 
                                   Foreground="{Binding StockLevel, Converter={StaticResource StockToBrushConverter}}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Terminology.Shop.Detail.Price}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} DA'}" Style="{StaticResource Title3}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Separator Background="{DynamicResource SeparatorStroke}" Margin="0,0,0,24" Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>

                <!-- Inventory Management Fields -->
                <TextBlock Text="{DynamicResource Terminology.Shop.Detail.InventorySettings}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,16"/>

                <!-- Edit Grid -->
                <Grid Margin="0,0,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 1: Price & Stock -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,16">
                        <TextBlock Text="{DynamicResource Terminology.Shop.Detail.Price}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        
                        <!-- View -->
                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} DA'}" Style="{StaticResource Body}"
                                   Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        <!-- Edit -->
                        <TextBox Text="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource UnderlineTextBox}"
                                 Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                     <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,16">
                        <TextBlock Text="{DynamicResource Terminology.Shop.Detail.StockQuantity}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         <!-- View -->
                        <TextBlock Text="{Binding StockQuantity}" Style="{StaticResource Body}"
                                   Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                         <!-- Edit -->
                        <TextBox Text="{Binding StockQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource UnderlineTextBox}"
                                 Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Row 2: Category & Reorder -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,16">
                        <TextBlock Text="{DynamicResource Terminology.Shop.Detail.Category}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <!-- View -->
                        <TextBlock Text="{Binding Category}" Style="{StaticResource Body}"
                                   Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        <!-- Edit -->
                        <TextBox Text="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource UnderlineTextBox}"
                                 Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                     <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,16">
                        <TextBlock Text="{DynamicResource Terminology.Shop.Detail.ReorderLevel}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         <!-- View -->
                        <TextBlock Text="{Binding ReorderLevel}" Style="{StaticResource Body}"
                                   Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                         <!-- Edit -->
                        <TextBox Text="{Binding ReorderLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource UnderlineTextBox}"
                                 Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>

                <!-- Description -->
                <TextBlock Text="{DynamicResource Terminology.Shop.Detail.Description}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource SurfaceBg}" CornerRadius="8" Padding="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                     <StackPanel>
                        <TextBlock Text="{Binding Description}" Style="{StaticResource Body}" TextWrapping="Wrap"
                                   Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        
                        <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource UnderlineTextBox}" 
                                 MinHeight="80" 
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 3. Actions Footer -->
        <Border Grid.Row="2" Padding="0,24,0,0" Background="{DynamicResource CardBackgroundBrush}">
            <Grid>


                <!-- Edit Mode: Save / Cancel -->
                <Grid Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:ShopView}, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="{DynamicResource Terminology.Shop.Action.SaveChanges}" 
                            Style="{StaticResource PrimaryButton}" 
                            Height="44"
                            Margin="0,0,6,0"
                            Command="{Binding DataContext.SaveProductCommand, RelativeSource={RelativeSource AncestorType=local:ShopView}}"/>
                    
                    <Button Grid.Column="1" Content="{DynamicResource Terminology.Global.Cancel}" 
                            Style="{StaticResource SecondaryButton}" 
                            Height="44"
                            Margin="6,0,0,0"
                            Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=local:ShopView}}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
