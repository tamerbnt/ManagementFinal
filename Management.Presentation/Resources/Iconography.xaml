    <!-- 
        APPLE 2025 ICONOGRAPHY SYSTEM
        Style: Lucide Line Art (Outline 2px)
        Uniformity: Round Caps, Round Joins
        Brand: "Razor" Illustration System
    -->

    <!-- ============================================================= -->
    <!-- 1. ICON BASE STYLES                                           -->
    <!-- All icons must inherit from this to ensure crisp rendering    -->
    <!-- ============================================================= -->
    
    <Style x:Key="IconBase" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Sizing Presets -->
    <Style x:Key="Style.Icon.Micro" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
    </Style>

    <Style x:Key="Style.Icon.Small" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
    </Style>

    <Style x:Key="Style.Icon.Standard" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
    </Style>

    <Style x:Key="Style.Icon.Large" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <Style x:Key="Style.Icon.Hero" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="StrokeThickness" Value="3"/> <!-- Proportional scaling -->
    </Style>

