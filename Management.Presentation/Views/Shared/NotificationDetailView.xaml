<UserControl x:Class="Management.Presentation.Views.Shared.NotificationDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <!-- Modal Container -->
    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="{DynamicResource SizeModalWidth}"
            Padding="{DynamicResource PaddingModal}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <StackPanel>
            <!-- 1. Type Icon -->
            <Grid Margin="{DynamicResource MarginHeaderBottom}">
                <!-- Icon Container -->
                <Border Width="64" Height="64" CornerRadius="16" HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Notification.Type}" Value="Success">
                                    <Setter Property="Background" Value="{DynamicResource StatusSuccessBackground}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Notification.Type}" Value="Error">
                                    <Setter Property="Background" Value="{DynamicResource StatusErrorBackground}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Notification.Type}" Value="Warning">
                                    <Setter Property="Background" Value="{DynamicResource StatusWarningBackground}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Notification.Type}" Value="Info">
                                    <Setter Property="Background" Value="{DynamicResource StatusInfoBackground}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    
                    <Path Width="32" Height="32" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Notification.Type}" Value="Success">
                                        <Setter Property="Fill" Value="{DynamicResource StatusSuccessBrush}"/>
                                        <Setter Property="Data" Value="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Notification.Type}" Value="Error">
                                        <Setter Property="Fill" Value="{DynamicResource StatusErrorBrush}"/>
                                        <Setter Property="Data" Value="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Notification.Type}" Value="Warning">
                                        <Setter Property="Fill" Value="{DynamicResource StatusWarningBrush}"/>
                                        <Setter Property="Data" Value="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Notification.Type}" Value="Info">
                                        <Setter Property="Fill" Value="{DynamicResource BrandPrimaryBrush}"/>
                                        <Setter Property="Data" Value="M11,9H13V7H11V9M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Border>
            </Grid>

            <!-- 2. Title -->
            <TextBlock Text="{Binding Notification.Title, FallbackValue='Notification Details'}"
                       Style="{DynamicResource Title2}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="{DynamicResource MarginHeaderBottom}"/>

            <!-- 3. Timestamp -->
            <TextBlock Text="{Binding Notification.Timestamp, Converter={StaticResource RelativeTimeConverter}}"
                       Style="{DynamicResource Caption}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- 4. Message -->
            <ScrollViewer MaxHeight="240" 
                          VerticalScrollBarVisibility="Auto"
                          Margin="{DynamicResource MarginSectionBottom}">
                <TextBlock Text="{Binding Notification.Message}"
                           Style="{DynamicResource Body}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </ScrollViewer>

            <!-- 5. Action Button -->
            <Button Content="{DynamicResource Strings.Restaurant.Close}"
                    Command="{Binding CloseCommand}"
                    Style="{DynamicResource PrimaryButton}"
                    MinWidth="{DynamicResource SizeButtonMinWidth}"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
