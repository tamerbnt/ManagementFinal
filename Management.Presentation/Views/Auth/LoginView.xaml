<UserControl x:Class="Management.Presentation.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Management.Presentation.ViewModels"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:auth="clr-namespace:Management.Presentation.Views.Auth"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}"
             d:DesignHeight="768" d:DesignWidth="460"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0.4" To="0.8" Duration="0:0:0.8"
                                 AutoReverse="True"/>
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- ════════════════════════════════════════════════════════════
         FORM CONTAINER — full-height, padded, vertically centered
         ════════════════════════════════════════════════════════════ -->
    <Grid>
        <!-- ════════════════════════════════════════════════════════════
             MAIN FORM — Hidden during initialization
             ════════════════════════════════════════════════════════════ -->
        <StackPanel VerticalAlignment="Top"
                    Margin="40,32,40,40"
                    Visibility="{Binding IsInitializingApp, Converter={StaticResource InverseBooleanToVisibilityConverter}}">

            <!-- ─────────────────────────────────────────────────
                 ROW 1 — TITAN BRAND + "No account?" block
                 ───────────────────────────────────────────────── -->
            <Grid Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Hero Brand Logo - 64px height for maximum luxury impact -->
                <Image Grid.Column="0" 
                       Source="/Assets/luxurya_header_logo.png"
                       Height="64"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Stretch="Uniform"
                       ToolTip="Luxurya Management System"/>

                <!-- Right: No account? / Contact admin -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="No account?"
                               FontSize="11" Foreground="#9CA3AF"
                               HorizontalAlignment="Right"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               FontFamily="Segoe UI Variable Display, Segoe UI">
                        <Hyperlink Foreground="#0EA5E9"
                                   TextDecorations="{x:Null}"
                                   Command="{Binding ForgotPasswordCommand}">
                            Contact admin
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- ─────────────────────────────────────────────────
                 ROW 2 — "Sign in" H1 TITLE
                 ───────────────────────────────────────────────── -->
            <TextBlock Text="Sign in"
                       FontSize="40" FontWeight="ExtraBold"
                       Foreground="#0F172A"
                       Margin="0,0,0,12"
                       FontFamily="Segoe UI Variable Display, Segoe UI"/>

            <!-- ─────────────────────────────────────────────────
                 ROW 3 — EXPANSION MODE BANNER (conditional)
                 ───────────────────────────────────────────────── -->
            <Border Background="{DynamicResource FacilityAccentDimBrush}"
                    BorderBrush="{DynamicResource FacilityAccentBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="14,10" Margin="0,0,0,16"
                    Visibility="{Binding IsExpansionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"
                          Fill="{DynamicResource FacilityAccentBrush}"
                          Width="14" Height="14" Stretch="Uniform"
                          Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ExpansionMessage}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- ─────────────────────────────────────────────────
                 ROW 4 — EMAIL ADDRESS FIELD
                 ───────────────────────────────────────────────── -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Email Address"
                           FontSize="12" FontWeight="Medium"
                           Foreground="#374151" Margin="0,0,0,4"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>

                <Border CornerRadius="10"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1.5"
                        Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Envelope icon -->
                        <Path Grid.Column="0"
                              Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"
                              Fill="#D1D5DB"
                              Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Text Input -->
                        <TextBox Grid.Column="1"
                                 x:Name="EmailInput"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#111827"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,12,0"
                                 CaretBrush="#0EA5E9"
                                 FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ─────────────────────────────────────────────────
                 ROW 5 — PASSWORD FIELD
                 ───────────────────────────────────────────────── -->
            <StackPanel Margin="0,0,0,16">
                <!-- Label row: "Password" left + "Forgot password?" right -->
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Password"
                               FontSize="12" FontWeight="Medium"
                               Foreground="#374151"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="12">
                        <Hyperlink Command="{Binding ForgotPasswordCommand}"
                                   Foreground="#0EA5E9"
                                   FontWeight="SemiBold"
                                   TextDecorations="{x:Null}">
                            Forgot password?
                        </Hyperlink>
                    </TextBlock>
                </Grid>

                <Border CornerRadius="10"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1.5"
                        Height="48">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>

                        <!-- Lock icon -->
                        <Path Grid.Column="0"
                              Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.11,13 12,13A2,2 0 0,0 10,15C10,16.11 10.89,17 12,17M18,8H17V6A5,5 0 0,0 12,1A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M9,6A3,3 0 0,1 12,3A3,3 0 0,1 15,6V8H9V6Z"
                              Fill="#D1D5DB"
                              Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Password / TextBox overlay -->
                        <Grid Grid.Column="1">
                            <PasswordBox x:Name="PasswordInput"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#111827"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="#0EA5E9"
                                         FontFamily="Segoe UI Variable Display, Segoe UI"/>
                            <TextBox x:Name="PasswordTextBox"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#111827"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="#0EA5E9"
                                     Visibility="Collapsed"
                                     FontFamily="Segoe UI Variable Display, Segoe UI"/>
                        </Grid>

                        <!-- Eye toggle button -->
                        <Button Grid.Column="2"
                                Click="TogglePasswordVisibility_Click"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Width="32" Height="32" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid Width="18" Height="18">
                                <Path x:Name="EyeOpenIcon"
                                      Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
                                      Fill="#D1D5DB" Stretch="Uniform"/>
                                <Path x:Name="EyeClosedIcon"
                                      Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.22 16.38,18.7L16.81,19.13L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.76 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z"
                                      Fill="#D1D5DB" Stretch="Uniform" Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                    </Grid>
                </Border>
            </StackPanel>

            <!-- ─────────────────────────────────────────────────
                 ROW 6 — SELECT FACILITY
                 ───────────────────────────────────────────────── -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Select Facility"
                           FontSize="12" FontWeight="Medium"
                           Foreground="#374151" Margin="0,0,0,8"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>

                <ListBox ItemsSource="{Binding AvailableFacilities}"
                         SelectedItem="{Binding SelectedFacility}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="3"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border"
                                                Background="#F9FAFB"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1.5"
                                                CornerRadius="10"
                                                Margin="0,0,6,0"
                                                Height="64"
                                                Cursor="Hand"
                                                ToolTip="{Binding Name}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <!-- Selected state -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush"
                                                        Value="{DynamicResource FacilityAccentBrush}"/>
                                                <Setter TargetName="border" Property="Background"
                                                        Value="{DynamicResource FacilityAccentDimBrush}"/>
                                            </Trigger>
                                            <!-- Hover state -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background"
                                                        Value="{DynamicResource Brush.Surface.Hover}"/>
                                            </Trigger>
                                            <!-- Hover on selected -->
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="border" Property="Background"
                                                        Value="{DynamicResource FacilityAccentDimBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Margin="8,0">
                                <Path x:Name="Icon"
                                      Fill="#9CA3AF"
                                      Width="18" Height="18" Stretch="Uniform"
                                      Margin="0,0,0,4"
                                      HorizontalAlignment="Center"/>
                                <TextBlock x:Name="Text"
                                           Text="{Binding Name}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#9CA3AF"
                                           HorizontalAlignment="Center"
                                           FontFamily="Segoe UI Variable Display, Segoe UI"/>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <!-- Icon Data Triggers by type -->
                                <DataTrigger Binding="{Binding IconKey}" Value="Icon.Dumbbell">
                                    <Setter TargetName="Icon" Property="Data"
                                            Value="M20.57,14.86L22,13.43L20.57,12L17,15.57L8.43,7L12,3.43L10.57,2L9.14,3.43L7.71,2L5.57,4.14L4.14,2.71L2.71,4.14L4.14,5.57L2,7.71L3.43,9.14L2,10.57L3.43,12L7,8.43L15.57,17L12,20.57L13.43,22L14.86,20.57L16.29,22L18.43,19.86L19.86,21.29L21.29,19.86L19.86,18.43L22,16.29L20.57,14.86Z"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IconKey}" Value="Icon.Scissors">
                                    <Setter TargetName="Icon" Property="Data"
                                            Value="M6,2C6,2 6,3 7,3C7,3 10,6 10,6L13,3C13,3 13,2 14,2C15.5,2 16,3 16,3C16,3 13,6.5 13,6.5L18,11.5L20.5,9C20.5,9 21.5,10 21.5,11.5C21.5,12 21,12 21,12L16,17C16,17 14,19 14,20.5C14,22 13,23 11.5,23C10,23 9,21.5 9,20.5C9,19 11,17 11,17L12,16L7,11C7,11 6,13 6,13C6,13 2,13 2,11.5C2,10 3,9 3,9L5.5,6.5L2,3C2,3 2.5,2 4,2C5,2 6,2 6,2M10,8.5L8.5,10L10,11.5L11.5,10L10,8.5Z"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IconKey}" Value="Icon.Utensils">
                                    <Setter TargetName="Icon" Property="Data"
                                            Value="M11,9H9V2H7V9H5V2H3V9C3,11.12 4.66,12.84 6.75,12.97V22H9.25V12.97C11.34,12.84 13,11.12 13,9V2H11V9M16,6V14H18.5V22H21V2C18.24,2 16,4.24 16,6Z"/>
                                </DataTrigger>
                                <!-- Selected state: accent color for icon + text -->
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="Icon" Property="Fill"
                                            Value="{DynamicResource FacilityAccentBrush}"/>
                                    <Setter TargetName="Text" Property="Foreground"
                                            Value="{DynamicResource FacilityAccentBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- ─────────────────────────────────────────────────
                 ROW 7 — REMEMBER DEVICE CHECKBOX
                 ───────────────────────────────────────────────── -->
            <CheckBox Content="Remember device"
                      IsChecked="{Binding RememberMe}"
                      Foreground="#6B7280"
                      FontSize="13"
                      FontFamily="Segoe UI Variable Display, Segoe UI"
                      VerticalContentAlignment="Center"
                      Margin="0,0,0,20"/>

            <!-- ─────────────────────────────────────────────────
                 ROW 8 — ERROR STATE
                 ───────────────────────────────────────────────── -->
            <Border Background="{StaticResource StatusErrorBackground}"
                    BorderBrush="{DynamicResource Brush.Danger}"
                    BorderThickness="1" CornerRadius="10" Padding="12,10"
                    Margin="0,0,0,12"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Path Data="M13,13H11V7H13M13,17H11V15H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"
                          Fill="{DynamicResource Brush.Danger}"
                          Width="14" Height="14" Stretch="Uniform"
                          VerticalAlignment="Top" Margin="0,2,0,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource Brush.Danger}"
                               FontSize="12" TextWrapping="Wrap" Margin="8,0,0,0"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>
                </Grid>
            </Border>

            <!-- ─────────────────────────────────────────────────
                 ROW 9 — APP INIT LOADING STATE
                 ───────────────────────────────────────────────── -->
            <StackPanel Visibility="{Binding IsInitializingApp, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,0,0,12">
                <TextBlock Text="{Binding AppInitializationStatus}"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,6"
                           FontFamily="Segoe UI Variable Display, Segoe UI"/>
                <ProgressBar IsIndeterminate="True" Height="3"
                             Foreground="{DynamicResource Brush.Accent.Primary}"
                             Background="{DynamicResource Brush.Border.Subtle}"
                             BorderThickness="0"/>
            </StackPanel>

            <!-- ─────────────────────────────────────────────────
                 ROW 10 — SIGN IN BUTTON + "POWERED BY" ROW
                 ───────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sign In Button (partial width) -->
                <Button x:Name="SignInButton"
                        Click="SignInButton_Click"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordInput}"
                        Width="162" Height="46"
                        IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="#E5E7EB"
                                    CornerRadius="10"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="btnText"
                                               Text="Sign In"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#9CA3AF"
                                               FontFamily="Segoe UI Variable Display, Segoe UI"/>
                                    <!-- Chevron icon -->
                                    <Path x:Name="btnChevron"
                                          Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                          Fill="#9CA3AF"
                                          Width="10" Height="10" Stretch="Uniform"
                                          Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <!-- Busy indicator -->
                                    <ProgressBar x:Name="busyBar"
                                                 IsIndeterminate="True"
                                                 Width="50" Height="3"
                                                 Background="Transparent"
                                                 Foreground="White"
                                                 BorderThickness="0"
                                                 Visibility="Collapsed"
                                                 Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Enabled state: accent background -->
                                <Trigger Property="IsEnabled" Value="True">
                                    <Setter TargetName="border" Property="Background"
                                            Value="{DynamicResource FacilityAccentBrush}"/>
                                    <Setter TargetName="btnText" Property="Foreground" Value="White"/>
                                    <Setter TargetName="btnChevron" Property="Fill" Value="White"/>
                                </Trigger>
                                <!-- Disabled state: gray -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                                    <Setter TargetName="btnText" Property="Foreground" Value="#9CA3AF"/>
                                    <Setter TargetName="btnChevron" Property="Fill" Value="#9CA3AF"/>
                                </Trigger>
                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <!-- Press animation -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="0.97" Duration="0:0:0.05"/>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 To="0.97" Duration="0:0:0.05"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="1.0" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 To="1.0" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <!-- Busy state -->
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter TargetName="btnText" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="btnChevron" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="busyBar" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- "Powered by From Scratch" (right of button) -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,0">
                    <TextBlock Text="Powered by"
                               FontSize="10" Foreground="#6B7280" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    
                    <!-- Premium Brand Signature: Centralized and moved to the left -->
                    <Border Width="110" Height="80" 
                            Background="#111827"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0"
                            ToolTip="Powered by From Scratch">
                        <Border.OpacityMask>
                            <ImageBrush ImageSource="/Assets/from_scratch_logo.png" 
                                        Stretch="Uniform" 
                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border.OpacityMask>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>



                <!-- ════════════════════════════════════════════════════════════
                     SKELETON LOADER — Visible during initialization
                     ════════════════════════════════════════════════════════════ -->
                <auth:LoginSkeletonView x:Name="SkeletonContainer"
                                          VerticalAlignment="Top"
                                          Margin="40,20,40,40"
                                          Visibility="{Binding IsInitializingApp, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <!-- Grid is closed at 546 -->
    </Grid>

</UserControl>
