<UserControl x:Class="Management.Presentation.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sections="clr-namespace:Management.Presentation.Views.Dashboard.Sections"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="1080" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

	<UserControl.Resources>
		<converters:WindowWidthToMarginConverter x:Key="WindowWidthToMarginConverter"/>
        
		<converters:IntToVisibilityConverter x:Key="ZeroIsVisibleConverter" />
	</UserControl.Resources>

	<!-- Standard Screen Fade-In -->
	<UserControl.Triggers>
		<EventTrigger RoutedEvent="Loaded">
			<BeginStoryboard>
				<Storyboard>
					<DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="{StaticResource DurationScreenTransition}">
						<DoubleAnimation.EasingFunction>
							<CubicEase EasingMode="EaseOut"/>
						</DoubleAnimation.EasingFunction>
					</DoubleAnimation>
				</Storyboard>
			</BeginStoryboard>
		</EventTrigger>
	</UserControl.Triggers>

	<Grid>
		<!-- Root Layout with Fixed Margins for Sequoia Feel -->
		<Grid Margin="{StaticResource MarginPage}">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<!-- Header -->
				<RowDefinition Height="Auto"/>
				<!-- Metrics -->
				<RowDefinition Height="*"/>
				<!-- Split Content -->
			</Grid.RowDefinitions>

			<!-- 1. Header & Global Actions -->
			<Grid Grid.Row="0" Margin="{StaticResource MarginSectionBottom}">
				<TextBlock Text="{DynamicResource TerminologyDashboardLabel}"
                           Style="{StaticResource Title1}"
                           AutomationProperties.HeadingLevel="Level1"
                           IsHitTestVisible="True"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

				<!-- Print Report Button (Top Right) -->
				<Button Content="{DynamicResource TerminologyPrintReportLabel}"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Right"
                        Command="{Binding PrintReportCommand}">
					<Button.ContentTemplate>
						<DataTemplate>
							<StackPanel Orientation="Horizontal">
								<Path Data="{StaticResource IconPrinter}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Style="{StaticResource IconSmall}"
                                      Margin="{StaticResource MarginIconRight}"/>
								<TextBlock Text="{DynamicResource TerminologyPrintReportLabel}"/>
							</StackPanel>
						</DataTemplate>
					</Button.ContentTemplate>
				</Button>
			</Grid>

			<!-- 2. Metrics Overview Section -->
			<!-- Handles its own internal responsive layout (4x1 or 2x2) -->
			<sections:MetricsOverviewSection Grid.Row="1"
                                             Margin="{StaticResource MarginSectionBottom}"/>

			<!-- 3. Split Content Area (60% / 40%) -->
			<Grid Grid.Row="2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="60*"/>
					<ColumnDefinition Width="40*"/>
				</Grid.ColumnDefinitions>

				<!-- Left Column: Recent Registrations / Activity -->
				<sections:RecentRegistrationsSection Grid.Column="0"
                                                     Margin="{StaticResource MarginColumnRight}"/>

				<!-- Right Column: Occupancy Chart & Quick Actions -->
				<sections:OccupancyChartSection Grid.Column="1"
                                                Margin="{StaticResource MarginColumnLeft}"/>
			</Grid>
		</Grid>

		<!-- 4. Empty State Overlay -->
		<!-- Visible when TotalMembers == 0. Z-Index is naturally higher as last child. -->
		<Grid Background="{DynamicResource WindowBg}"
              Visibility="{Binding TotalMembers, Converter={StaticResource ZeroIsVisibleConverter}}">

			<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
				<!-- Illustration Background with Polka Dots -->
				<Grid Width="256" Height="256" Margin="{StaticResource MarginSectionBottom}"
                      IsHitTestVisible="False">
                    <!-- Corrected: Using global pattern resource logic if available, OR recreating locally with dynamic brushes -->
					<!-- Polka Dot Pattern Background -->
					<Rectangle Fill="{DynamicResource IllustrationBackgroundBrush}" RadiusX="24" RadiusY="24"/>
					<Rectangle RadiusX="24" RadiusY="24">
						<Rectangle.Fill>
							<DrawingBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
								<DrawingBrush.Drawing>
									<GeometryDrawing Brush="{DynamicResource FacilityAccentBrush}" Geometry="M10,10 A3,3 0 1,1 10,10.01 Z">
										<GeometryDrawing.Pen>
											<Pen Thickness="0"/>
										</GeometryDrawing.Pen>
									</GeometryDrawing>
								</DrawingBrush.Drawing>
							</DrawingBrush>
						</Rectangle.Fill>
						<Rectangle.OpacityMask>
							<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
								<GradientStop Color="Transparent" Offset="0"/>
								<GradientStop Color="{StaticResource ColorSurfaceDim}" Offset="1"/>
							</LinearGradientBrush>
						</Rectangle.OpacityMask>
					</Rectangle>
					
					<!-- Line-Art Icon -->
					<Path Data="{StaticResource IconDumbbellIllustration}"
						  Stroke="{DynamicResource TextPrimaryBrush}"
						  StrokeThickness="2"
						  Fill="Transparent"
						  Stretch="Uniform"
						  Width="128"
						  Height="128"
						  HorizontalAlignment="Center"
						  VerticalAlignment="Center"
						  Opacity="0.6"/>
				</Grid>

				<!-- Primary Message -->
				<TextBlock Text="{Binding WelcomeMessage}"
                           Style="{StaticResource Title2}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="{StaticResource MarginTextBottom}"/>

				<!-- Secondary Message -->
				<TextBlock Text="{Binding EmptyStateMessage}"
                           Style="{StaticResource Body}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="{StaticResource MarginSectionBottom}"/>

				<!-- Hero CTA -->
				<Button Content="{Binding AddButtonText}"
                        Style="{StaticResource PrimaryButtonLarge}"
                        Width="240"
                        Command="{Binding AddMemberCommand}"/>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>