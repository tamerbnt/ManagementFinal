<UserControl x:Class="Management.Presentation.Views.Members.MembersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:local="clr-namespace:Management.Presentation.Views.Members"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Members"
             xmlns:enums="clr-namespace:Management.Domain.Enums;assembly=Management.Domain"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Polymorphic Templates / Local logic only -->
        <Style x:Key="LocalSearchTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="40,0,10,0"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <Grid>
                                <!-- Search Icon -->
                                <Path x:Name="SearchIcon"
                                      Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                      Fill="{DynamicResource FacilityAccentBrush}" 
                                      Width="16" Height="16" 
                                      HorizontalAlignment="Left" 
                                      Margin="14,0,0,0" 
                                      VerticalAlignment="Center"/>

                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                
                                <!-- Placeholder -->
                                <TextBlock x:Name="Placeholder" 
                                           Text="{DynamicResource Terminology.TopBar.SearchPlaceholder}" 
                                           Foreground="{DynamicResource TextSecondaryBrush}" 
                                           VerticalAlignment="Center" 
                                           Margin="40,0,0,0" 
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"
                                           FontSize="13"/>
                                
                                <!-- Loading Spinner -->
                                <Path x:Name="LoadingSpinner"
                                      Visibility="Collapsed"
                                      Data="M12,4V2A10,10 0 0,0 2,12H4A8,8 0 0,1 12,4Z"
                                      Fill="{DynamicResource FacilityAccentBrush}"
                                      Width="16" Height="16"
                                      HorizontalAlignment="Right"
                                      Margin="0,0,10,0"
                                      VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter TargetName="LoadingSpinner" Property="Visibility" Value="Visible"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="SpinSearch">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0" To="360" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="SpinSearch"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width" To="400" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CircleEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width" To="250" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CircleEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- Liquid Layout Header -->
        <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 1. Header & Primary Actions -->
            <Grid Grid.Row="0" Margin="{StaticResource MarginSectionBottom}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconMembers}" 
                          Style="{StaticResource Style.Icon.Large}" 
                          Stroke="{DynamicResource TextPrimaryBrush}"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Terminology.Global.Header.Members}" 
                               Style="{StaticResource Title1}" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Primary Action: Add Member -->
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding OpenAddMemberCommand}"
                            Margin="{StaticResource MarginMediumRight}">
                        <StackPanel Orientation="Horizontal" Margin="4,0">
                            <Path Data="{StaticResource IconPlus}" 
                                   Stroke="White"
                                   Style="{StaticResource Style.Icon.Small}"
                                   Margin="{StaticResource MarginIconRight}"/>
                            <TextBlock Text="{DynamicResource Terminology.Members.AddMember}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Secondary Action: Print -->
                    <Button Command="{Binding PrintReportCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Background" Value="{DynamicResource Brush.Surface.Secondary}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                                <Setter Property="Padding" Value="16,8"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Brush.Surface.Hover}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" Margin="4,0">
                            <Path Data="{StaticResource IconPrinter}" 
                                   Fill="{DynamicResource Brush.Text.Primary}"
                                   Style="{StaticResource Style.Icon.Small}"
                                   Margin="{StaticResource MarginIconRight}"/>
                            <TextBlock Text="{DynamicResource Terminology.Global.Action.PrintList}" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        

        <!-- 2. Controls Area (Row 1) -->
        <Grid Grid.Row="1" Margin="{StaticResource MarginSectionBottom}">

            <!-- A. Filter Bar (Default State) -->
            <Grid Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                <StackPanel Orientation="Horizontal">
                    <!-- Filter Bar Container -->
                    <Border Background="{DynamicResource Brush.Neutral.White}" CornerRadius="{DynamicResource Corner.MD}" Padding="4" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="{DynamicResource Terminology.Global.Filter.All}" 
                                         IsChecked="{Binding SelectedFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:MemberFilterStatus.All}}" 
                                         GroupName="StatusFilterGroup"
                                         Style="{StaticResource TogglePillStyle}"/>
                            <RadioButton Content="{DynamicResource Terminology.Global.Filter.Active}" 
                                         IsChecked="{Binding SelectedFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:MemberFilterStatus.Active}}" 
                                         GroupName="StatusFilterGroup"
                                         Style="{StaticResource TogglePillStyle}"/>
                            <RadioButton Content="{DynamicResource Terminology.Global.Filter.Expiring}" 
                                         IsChecked="{Binding SelectedFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:MemberFilterStatus.Expiring}}" 
                                         GroupName="StatusFilterGroup"
                                         Style="{StaticResource TogglePillStyle}"/>
                            <RadioButton Content="{DynamicResource Terminology.Global.Filter.Expired}" 
                                         IsChecked="{Binding SelectedFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:MemberFilterStatus.Expired}}" 
                                         GroupName="StatusFilterGroup"
                                         Style="{StaticResource TogglePillStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Local Search Box (Visually identical to Top Bar) -->
                    <TextBox x:Name="LocalMemberSearchBox"
                             Style="{StaticResource LocalSearchTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="16,0,0,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoadMembersCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>
                
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Command="{Binding SwitchViewModeCommand}" 
                            CommandParameter="{x:Static vm:MemberViewMode.Grid}"
                            Style="{StaticResource IconButtonStyle}" 
                            ToolTip="{DynamicResource Terminology.Members.View.Grid}" Margin="0,0,8,0">
                        <Path Data="{StaticResource IconDashboard}">
                            <Path.Style>
                                <Style TargetType="Path" BasedOn="{StaticResource Style.Icon.Small}">
                                    <Setter Property="Fill" Value="{DynamicResource TextTertiaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewMode}" Value="{x:Static vm:MemberViewMode.Grid}">
                                            <Setter Property="Fill" Value="{DynamicResource BrandPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Command="{Binding SwitchViewModeCommand}" 
                            CommandParameter="{x:Static vm:MemberViewMode.List}"
                            Style="{StaticResource IconButtonStyle}" 
                            ToolTip="{DynamicResource Terminology.Members.View.List}">
                        <Path Data="{StaticResource IconMenu}">
                            <Path.Style>
                                <Style TargetType="Path" BasedOn="{StaticResource Style.Icon.Small}">
                                    <Setter Property="Fill" Value="{DynamicResource TextTertiaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewMode}" Value="{x:Static vm:MemberViewMode.List}">
                                            <Setter Property="Fill" Value="{DynamicResource BrandPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                </StackPanel>
            </Grid>


            <!-- B. Multi-Selection Context Bar (Overlay State) -->
            <!-- Uses Global Shadow Level 3 & Colors -->
            <Border Background="{DynamicResource FacilityAccentBrush}"
                    CornerRadius="12"
                    Height="{StaticResource SizeSelectionBarHeight}"
                    Padding="24,16"
                    Effect="{DynamicResource Shadow3}"
                    Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibilityConverter}}"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform Y="-80"/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Border.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Count -->
                        <ColumnDefinition Width="*"/>
                        <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Actions -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Close -->
                    </Grid.ColumnDefinitions>

                    <!-- Selected Count & Select All -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding SelectAll}"
                                  Style="{StaticResource CircularSelectionCheckBoxStyle}"
                                  Margin="0,0,16,0">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                        
                        <TextBlock Text="{Binding SelectedCount, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Members.Selected'}" 
                                   Style="{StaticResource Title3}" 
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextOnAccentBrush}"/>
                    </StackPanel>

                    <!-- Bulk Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Renew: Secondary Button -->
                        <Button Content="{DynamicResource Terminology.Global.Action.RenewAll}" 
                                Command="{Binding RenewSelectedCommand}"
                                Style="{StaticResource SecondaryButton}"
                                BorderBrush="{DynamicResource TextOnDarkBrush}"
                                Foreground="{DynamicResource TextOnDarkBrush}"
                                Margin="{StaticResource MarginSmallRight}"/>

                        <!-- Delete: Premium FAB Style (Resized to 40px to fit 80px bar with 16px padding) -->
                        <Button Command="{Binding DeleteSelectedCommand}"
                                ToolTip="{DynamicResource Terminology.Members.DeleteSelection}"
                                Width="40" Height="40"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid x:Name="Root">
                                        <Ellipse Fill="{DynamicResource StatusErrorBrush}" Effect="{DynamicResource Shadow2}"/>
                                        <Path Data="{StaticResource IconDelete}" 
                                              Stroke="White" 
                                              StrokeThickness="2"
                                              Width="18" Height="18"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.1" ScaleY="1.1" CenterX="20" CenterY="20"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="20" CenterY="20"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Clear Selection -->
                    <Button Grid.Column="3"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ClearSelectionCommand}"
                            Foreground="{DynamicResource TextOnAccentBrush}"
                            Margin="{StaticResource MarginMediumLeft}">
                        <Path Data="{StaticResource IconClose}" 
                              Fill="{DynamicResource TextOnDarkBrush}" 
                              Style="{StaticResource Style.Icon.Standard}"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- 3. Content Area (Row 2): Liquid Layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/> <!-- List Column -->
                <ColumnDefinition Width="Auto"/> <!-- Drawer Column -->
            </Grid.ColumnDefinitions>

            <!-- A. Interactive List -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <ListBox x:Name="MembersListBox" Grid.Row="0"
                         ItemsSource="{Binding FilteredMembers}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,0,12,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.CacheLength="2,2"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     ScrollViewer.CanContentScroll="True"
                     SelectedItem="{Binding SelectedMember, Mode=TwoWay}"
                     Visibility="{Binding ViewMode, Converter={StaticResource EqualToVisibilityConverter}, ConverterParameter={x:Static vm:MemberViewMode.List}}">
                
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="RowBorder" 
                            Background="White" 
                            CornerRadius="16" 
                            Padding="16"
                            Margin="4,4,4,12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            RenderOptions.CachingHint="Cache">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" 
                                          Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=local:MembersView}}" 
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>  <!-- 0: Avatar -->
                                <ColumnDefinition Width="*"/>   <!-- 1: Name/ID -->
                                <ColumnDefinition Width="Auto"/> <!-- 2: Plan -->
                                <ColumnDefinition Width="Auto"/> <!-- 3: Status -->
                                <ColumnDefinition Width="Auto"/> <!-- 4: Balance -->
                                <ColumnDefinition Width="Auto"/> <!-- 5: Actions -->
                            </Grid.ColumnDefinitions>

                            <!-- Identity & Checkbox -->
                            <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.ColumnSpan="2" Margin="16,0,0,0">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                           Style="{StaticResource CircularSelectionCheckBoxStyle}"
                                           VerticalAlignment="Center" 
                                           Margin="0,0,16,0"/>
                                
                                <Grid x:Name="AvatarContainer" VerticalAlignment="Center">
                                    <Ellipse Width="40" Height="40" x:Name="AvatarPlaceholder" 
                                             Fill="{Binding FullName, Converter={StaticResource NameToBrushConverter}}"/>
                                    <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialConverter}}" 
                                               x:Name="AvatarInitial"
                                               Foreground="White" 
                                               FontWeight="Bold" 
                                               FontSize="16"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="{Binding FullName}" x:Name="NameText" FontWeight="Bold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                    <TextBlock Text="{Binding CardId, Converter={StaticResource StringFormatConverter}, ConverterParameter='Terminology.Members.IdPrefix'}" x:Name="IdText" Style="{StaticResource Caption}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Plan -->
                            <TextBlock Grid.Column="2" x:Name="PlanText" Text="{Binding MembershipPlanName}" VerticalAlignment="Center" FontWeight="Medium" Foreground="{DynamicResource BrandPrimaryBrush}" Margin="24,0"/>

                            <!-- Status -->
                            <Border Grid.Column="3" x:Name="StatusBorder" Padding="8,4" CornerRadius="12" VerticalAlignment="Center" Margin="0,0,24,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource StatusSuccessBackground}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:MemberStatus.Expired}">
                                                <Setter Property="Background" Value="{DynamicResource StatusErrorBackground}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status, Converter={StaticResource EnumToLocalizedDescriptionConverter}}" x:Name="StatusText" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusSuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:MemberStatus.Expired}">
                                                    <Setter Property="Foreground" Value="{DynamicResource StatusErrorBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>


                            <!-- Balance -->
                            <TextBlock Grid.Column="4" x:Name="BalanceText" Text="{Binding Balance, StringFormat={}{0:N2} DA}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}" Width="80" TextAlignment="Right"/>

                            <!-- Actions -->
                            <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="24,0,16,0">
                                <Button Style="{StaticResource IconButtonStyle}" 
                                        Command="{Binding DataContext.DeleteSingleMemberCommand, RelativeSource={RelativeSource AncestorType=local:MembersView}}" 
                                        CommandParameter="{Binding}"
                                        Margin="0,0,8,0"
                                        ToolTip="{DynamicResource Terminology.Members.DeleteMember}">
                                    <Path x:Name="TrashIcon" Data="{StaticResource IconDelete}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource StatusErrorBrush}"/>
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" 
                                        Command="{Binding DataContext.EditMemberCommand, RelativeSource={RelativeSource AncestorType=local:MembersView}}" 
                                        CommandParameter="{Binding}">
                                    <Path x:Name="EditIcon" Data="{StaticResource IconEdit}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource BrandPrimaryBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                        
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.005" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.005" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="RowBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- ACTIVE / CLICKED STATE (IGNITION) - Priority 1 -->
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="RowBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="Transparent"/>
                                <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="IdText" Property="Foreground" Value="{DynamicResource OnAccentSecondary}"/>
                                <Setter TargetName="PlanText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="BalanceText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="StatusBorder" Property="Background" Value="{DynamicResource OnAccentSecondary}"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="AvatarPlaceholder" Property="Fill" Value="{DynamicResource OnAccentSecondary}"/>
                                <Setter TargetName="AvatarInitial" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="TrashIcon" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="EditIcon" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="TrashIcon" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="EditIcon" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                </ListBox>

                <!-- Load More Button (List View) -->
                <Button Grid.Row="1" 
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadMoreCommand}"
                        Visibility="{Binding HasMoreItems, Converter={StaticResource BoolToVisibilityConverter}}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconPlus}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource BrandPrimaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource Terminology.Global.Action.LoadMore}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Grid View Layout -->
            <Grid Grid.Column="0" Visibility="{Binding ViewMode, Converter={StaticResource EqualToVisibilityConverter}, ConverterParameter={x:Static vm:MemberViewMode.Grid}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding FilteredMembers}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,0,12,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True"
                     SelectedItem="{Binding SelectedMember, Mode=TwoWay}"
                     Visibility="{Binding ViewMode, Converter={StaticResource EqualToVisibilityConverter}, ConverterParameter={x:Static vm:MemberViewMode.Grid}}">
                
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="GridCard" 
                            Background="White" 
                            CornerRadius="20" 
                            Padding="20"
                            Margin="0,0,20,20"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                             RenderOptions.CachingHint="Cache"
                            Width="260"> <!-- Fixed width for Grid cards -->
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" 
                                          Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=local:MembersView}}" 
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>

                        <StackPanel>
                            <!-- Card Header: Avatar & Status -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Grid x:Name="AvatarContainer" Grid.Column="0">
                                    <Ellipse Width="48" Height="48" x:Name="AvatarPlaceholder" 
                                             Fill="{Binding FullName, Converter={StaticResource NameToBrushConverter}}"/>
                                    <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialConverter}}" 
                                               Foreground="White" FontWeight="Bold" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <Border Grid.Column="2" VerticalAlignment="Top" Padding="8,4" CornerRadius="10" Background="{DynamicResource StatusSuccessBackground}" x:Name="StatusBadge">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource EnumToLocalizedDescriptionConverter}}" Foreground="{DynamicResource StatusSuccessBrush}" FontSize="10" FontWeight="Bold" x:Name="StatusText"/>
                                </Border>
                            </Grid>

                            <!-- Card Content -->
                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4" x:Name="NameTextGrid"/>
                            <TextBlock Text="{Binding MembershipPlanName}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource BrandPrimaryBrush}" x:Name="PlanTextGrid"/>
                            
                            <Separator Background="{DynamicResource Brush.Border.Subtle}" Margin="0,16" BorderThickness="0" Height="1"/>
                            
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Terminology.Members.Balance}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding Balance, StringFormat={}{0:N2} DA}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" x:Name="BalanceTextGrid"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                    <Button Style="{StaticResource IconButtonStyle}" 
                                            Command="{Binding DataContext.EditMemberCommand, RelativeSource={RelativeSource AncestorType=local:MembersView}}" 
                                            CommandParameter="{Binding}">
                                        <Path Data="{StaticResource IconEdit}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource BrandPrimaryBrush}" x:Name="EditIconGrid"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                        
                    <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GridCard" Property="BorderBrush" Value="{DynamicResource BrandPrimaryBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GridCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="GridCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GridCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="GridCard" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="GridCard" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="NameTextGrid" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="PlanTextGrid" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="BalanceTextGrid" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource OnAccentSecondary}"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter TargetName="EditIconGrid" Property="Stroke" Value="{DynamicResource CardBackgroundBrush}"/>
                                 <Setter TargetName="GridCard" Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                </ListBox>

                <!-- Load More Button (Grid View) -->
                <Button Grid.Row="1" 
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadMoreCommand}"
                        Visibility="{Binding HasMoreItems, Converter={StaticResource BoolToVisibilityConverter}}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconPlus}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource BrandPrimaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource Terminology.Global.Action.LoadMore}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- B. Member Detail Drawer -->
            <Border Grid.Column="1" 
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}" 
                    Background="White" 
                    CornerRadius="32,0,0,32"
                    Effect="{StaticResource Shadow3}"
                    Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource BorderBrush}">
                <Border.RenderTransform>
                    <TranslateTransform X="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=local:MembersView}, Path=ActualWidth}"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetailPanelOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <local:MemberDetailPanel DataContext="{Binding SelectedMember}"/>
            </Border>

            <!-- Skeleton Loader State (Row version) -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                  IsHitTestVisible="False">
                <ListBox ItemsSource="{Binding {x:Static sys:String.Empty}, Converter={StaticResource RangeConverter}, ConverterParameter=8}"
                          Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" Height="72" Margin="0,0,0,12">
                                <Border Style="{StaticResource ShimmerPlaceholderStyle}" Margin="16"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- 4. Delete Confirmation Overlay (Modal) -->
        <!-- Z-Index High, spans entire view -->
        <Grid Grid.RowSpan="3" 
              Visibility="{Binding IsDeleteConfirmationVisible, Converter={StaticResource BoolToVisibilityConverter}}"
              Panel.ZIndex="100">
            <!-- Backdrop -->
            <Border Background="Transparent"/>

            
            <!-- Modal Card -->
            <Border Background="White" 
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    CornerRadius="24"
                    Padding="32"
                    Effect="{DynamicResource Shadow3}">
                <StackPanel>
                    <!-- Icon -->
                    <Border Width="64" Height="64" CornerRadius="32" Background="{DynamicResource StatusErrorBackground}" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Path Data="{StaticResource IconDelete}" Stroke="{DynamicResource StatusErrorBrush}" StrokeThickness="2" Width="32" Height="32" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Text="{DynamicResource Terminology.Members.DeleteModal.Title}" 
                               Style="{StaticResource Title2}" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,12"/>
                    
                    <TextBlock Text="{DynamicResource Terminology.Members.DeleteModal.Message}" 
                               Style="{StaticResource Body}" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Center" 
                               TextWrapping="Wrap"
                               Margin="0,0,0,32"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" 
                                Content="{DynamicResource Terminology.Global.Cancel}" 
                                Command="{Binding CancelDeleteCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                        
                        <Button Grid.Column="2" 
                                Content="{DynamicResource Terminology.Global.Delete}" 
                                Command="{Binding DeleteConfirmedCommand}"
                                Style="{StaticResource DestructiveButtonStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
