<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary Source="/Resources/Colors.xaml"/>
	</ResourceDictionary.MergedDictionaries>

	<!-- System color resources for high contrast -->
	<SolidColorBrush x:Key="SystemWindowTextBrush" Color="{x:Static SystemColors.WindowTextColor}"/>

	<!-- BASE TEXT STYLE -->
	<Style x:Key="BaseTextBlockStyle" TargetType="TextBlock">
		<Setter Property="FontFamily" Value="Segoe UI Variable Display,Segoe UI Variable,Segoe UI,Arial"/>
		<Setter Property="Foreground" Value="#1A1A1A"/>
		<Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
		<Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
		<Setter Property="UseLayoutRounding" Value="True"/>
		<Setter Property="SnapsToDevicePixels" Value="True"/>
		<Style.Triggers>
			<DataTrigger Binding="{Binding Source={x:Static SystemParameters.HighContrast}, Path=.}" Value="True">
				<Setter Property="Foreground" Value="{StaticResource SystemWindowTextBrush}"/>
			</DataTrigger>
		</Style.Triggers>
	</Style>

	<!-- HEADINGS -->
	<Style x:Key="Hero" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="64"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="LineHeight" Value="76.8"/>
	</Style>

	<Style x:Key="HeroLive" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="96"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="LineHeight" Value="100"/>
	</Style>

	<Style x:Key="LargeValue" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="52"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="LineHeight" Value="62.4"/>
	</Style>

	<Style x:Key="Title1" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="36"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="LineHeight" Value="50.4"/>
	</Style>

	<Style x:Key="Title2" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="28"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="LineHeight" Value="39.2"/>
	</Style>

	<Style x:Key="Title3" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="20"/>
		<Setter Property="FontWeight" Value="Medium"/>
		<Setter Property="LineHeight" Value="28"/>
	</Style>

	<!-- BODY CONTENT -->
	<Style x:Key="Body" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="17"/>
		<Setter Property="FontWeight" Value="Regular"/>
		<Setter Property="LineHeight" Value="23.8"/>
	</Style>

	<Style x:Key="BodyMedium" TargetType="TextBlock" BasedOn="{StaticResource Body}">
		<Setter Property="FontWeight" Value="Medium"/>
	</Style>

	<Style x:Key="BodySecondary" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="15"/>
		<Setter Property="FontWeight" Value="Regular"/>
		<Setter Property="LineHeight" Value="21"/>
		<Setter Property="Foreground" Value="#666666"/>
	</Style>

	<!-- UTILITY & METADATA -->
	<Style x:Key="Caption" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="FontWeight" Value="Regular"/>
		<Setter Property="LineHeight" Value="19.6"/>
		<Setter Property="Foreground" Value="#666666"/>
	</Style>

	<Style x:Key="SmallCaption" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="13"/>
		<Setter Property="FontWeight" Value="Regular"/>
		<Setter Property="LineHeight" Value="18.2"/>
		<Setter Property="Foreground" Value="#757575"/>
	</Style>

	<Style x:Key="Micro" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="LineHeight" Value="16.8"/>
		<Setter Property="Foreground" Value="#666666"/>
	</Style>

</ResourceDictionary>