<UserControl x:Class="Management.Presentation.Views.Auth.LicenseEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="560"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="{StaticResource SurfaceBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Premium Top Bar Branding -->
        <Border Grid.Row="0" Height="80" Padding="40,20" Background="{StaticResource SurfaceBg}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="32" Height="32" Margin="0,0,16,0">
                    <Ellipse Fill="{DynamicResource FacilityAccentBrush}" Opacity="0.1"/>
                    <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" 
                          Fill="{DynamicResource FacilityAccentBrush}" 
                          Width="18" Height="18" Stretch="Uniform"/>
                </Grid>
                <StackPanel>
                    <TextBlock Text="LUXURYA" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{DynamicResource Strings.Auth.LuxuryaActivation}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="500" Margin="60,40">
                
                <!-- Large Premium Title -->
                <TextBlock Text="{DynamicResource Strings.Auth.InitialActivation}" 
                           FontSize="42" FontWeight="Black" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>
                
                <TextBlock Text="{DynamicResource Strings.Auth.Enteryouruniquelicensekey}" 
                           FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" 
                           TextWrapping="Wrap" LineHeight="24"
                           Margin="0,0,0,48" Opacity="0.8"/>

                <!-- License Input Section -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="{DynamicResource Strings.Auth.LICENSEIDENTIFIER}" 
                               FontSize="11" FontWeight="Bold" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               Margin="0,0,0,12"/>
                    
                    <TextBox x:Name="LicenseKeyBox"
                             Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                             Height="64" Padding="20,0" 
                             VerticalContentAlignment="Center"
                             FontSize="18" FontWeight="Medium"
                             Style="{StaticResource PremiumTextBoxStyle}"
                             Tag="{DynamicResource Strings.Auth.Placeholder.LicenseKey}"/>

                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="#FF5252" FontSize="12" 
                               Margin="0,8,0,0" 
                               Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Action Button -->
                <Button Command="{Binding ActivateCommand}"
                        Content="{DynamicResource Strings.Auth.Action.ActivateWorkspace}"
                        Height="64" FontSize="18" FontWeight="Bold"
                        Style="{StaticResource PremiumPrimaryButtonStyle}"
                        Margin="0,16,0,24"/>

                <!-- Hardware ID Helper -->
                <Border Background="{DynamicResource SurfaceBgSubtle}" 
                        CornerRadius="12" Padding="20" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="HARDWARE IDENTIFIER" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" Opacity="0.6"/>
                        <Grid>
                            <TextBlock Text="{Binding HardwareId}" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.9"/>
                            <Button HorizontalAlignment="Right" Content="COPY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource FacilityAccentBrush}" Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand" Command="{Binding CopyHardwareIdCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Branding -->
        <Border Grid.Row="2" Padding="40,24" Background="{StaticResource SurfaceBg}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Opacity="0.5">
                    <TextBlock Text="POWERED BY" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="FROM SCRATCH" FontSize="10" FontWeight="Black" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="v1.2.0-STABLE" HorizontalAlignment="Right" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.4" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
