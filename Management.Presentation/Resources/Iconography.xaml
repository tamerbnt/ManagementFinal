<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
        APPLE 2025 ICONOGRAPHY SYSTEM
        Style: Lucide Line Art (Outline 2px)
        Uniformity: Round Caps, Round Joins
        Brand: "Razor" Illustration System
    -->

    <!-- ============================================================= -->
    <!-- 1. ICON BASE STYLES                                           -->
    <!-- All icons must inherit from this to ensure crisp rendering    -->
    <!-- ============================================================= -->
    
    <Style x:Key="IconBase" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Sizing Presets -->
    <Style x:Key="IconMicro" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
    </Style>

    <Style x:Key="IconSmall" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
    </Style>

    <Style x:Key="IconStandard" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
    </Style>

    <Style x:Key="IconLarge" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <Style x:Key="IconHero" TargetType="Path" BasedOn="{StaticResource IconBase}">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="StrokeThickness" Value="3"/> <!-- Proportional scaling -->
    </Style>

    <!-- ============================================================= -->
    <!-- 2. BRAND PATTERN BRUSHES (For Illustrations)                  -->
    <!-- ============================================================= -->
    
    <!-- Polka Dots (Facility Accent) -->
    <VisualBrush x:Key="PatternPolkaDots" TileMode="Tile" Viewport="0,0,10,10" ViewportUnits="Absolute">
        <VisualBrush.Visual>
            <Ellipse Width="2" Height="2" Fill="{DynamicResource FacilityAccentBrush}"/>
        </VisualBrush.Visual>
    </VisualBrush>

    <!-- Stripes (Facility Accent) -->
    <VisualBrush x:Key="PatternStripes" TileMode="Tile" Viewport="0,0,10,10" ViewportUnits="Absolute">
        <VisualBrush.Visual>
            <Path Data="M0,10 L10,0" Stroke="{DynamicResource FacilityAccentBrush}" StrokeThickness="1" StrokeEndLineCap="Square"/>
        </VisualBrush.Visual>
    </VisualBrush>

