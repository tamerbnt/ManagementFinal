<UserControl x:Class="Management.Presentation.Views.Settings.DevicesSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Settings"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="700">
    <Grid>
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="{DynamicResource Terminology.Settings.Apparatus.Status}" 
                       Style="{DynamicResource Title2}" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,24"/>

            <ItemsControl ItemsSource="{Binding LocalDevices}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{DynamicResource GlassCardStyle}"
                                Width="300"
                                Margin="0,0,16,16"
                                Padding="20">
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Icon and Name -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Grid Width="40" Height="40">
                                        <Ellipse Fill="{DynamicResource FacilityAccentDimBrush}"/>
                                        <Path HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Style>
                                                <!-- Using DynamicResource for base icon style -->
                                                <Style TargetType="Path" BasedOn="{StaticResource Style.Icon.Standard}">
                                                    <Setter Property="Stroke" Value="{DynamicResource FacilityAccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="RFID">
                                                            <Setter Property="Data" Value="{StaticResource IconMembers}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Printer">
                                                            <Setter Property="Data" Value="{StaticResource IconPrinter}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Turnstile">
                                                            <Setter Property="Data" Value="{StaticResource IconDoor}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Style="{DynamicResource Title3}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                                                    <Setter Property="Text" Value="{DynamicResource Terminology.Settings.Apparatus.Disconnected}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource StatusErrorBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Text" Value="{DynamicResource Terminology.Settings.Apparatus.Connected}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource StatusSuccessBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Divider -->
                                <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource SeparatorStroke}" Margin="0,4"/>

                                <!-- Error Message (if any) -->
                                <TextBlock Grid.Row="2" 
                                           Text="{Binding LastError}"
                                           TextWrapping="Wrap"
                                           Style="{DynamicResource Caption}"
                                           Foreground="{DynamicResource StatusErrorBrush}"
                                           Height="32"
                                           Visibility="{Binding LastError, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- Test Button -->
                                <Button Grid.Row="4" 
                                        Content="{DynamicResource Terminology.Settings.Apparatus.Test}"
                                        Command="{Binding TestCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalAlignment="Stretch"
                                        Style="{DynamicResource Button.Ghost}">
                                    <Button.Resources>
                                        <!-- Nested Style for Trigger handling while keeping the base GhostButton -->
                                        <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Content" Value="{DynamicResource Terminology.Settings.Apparatus.Testing}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
