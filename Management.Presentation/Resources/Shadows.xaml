<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
        APPLE 2025 DEPTH SYSTEM - REFACTORED FOR PERFORMANCE
        
        Shadows have been disabled to improve rendering performance.
        Elevation is now achieved through BorderBrush and BorderThickness.
    -->

    <x:Null x:Key="Shadow1" />
    <x:Null x:Key="Shadow2" />
    <x:Null x:Key="Shadow3" />
    <x:Null x:Key="Shadow4" />
    <x:Null x:Key="ShadowGlow" />

</ResourceDictionary>
