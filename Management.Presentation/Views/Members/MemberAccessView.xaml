<UserControl x:Class="Management.Presentation.Views.Members.MemberAccessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="450">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:MultiplyValueConverter x:Key="MultiplyValueConverter"/>
    </UserControl.Resources>

    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}"
            Padding="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource Brush.Surface.Card}">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Visual Result Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- 1. Result Indicator Bar -->
            <Border Grid.Row="0" Height="8" CornerRadius="12,12,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource Brush.Status.Success}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAccessGranted}" Value="False">
                                <Setter Property="Background" Value="{DynamicResource Brush.Status.Error}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding AccessStatus}" Value="Warning">
                                <Setter Property="Background" Value="{DynamicResource Brush.Status.Warning}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <Border Grid.Row="1" Padding="32">
                <StackPanel>
                    <!-- 2. Status Icon & Label -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border Width="80" Height="80" CornerRadius="40" Opacity="0.1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Status.Success}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAccessGranted}" Value="False">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Status.Error}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        
                        <Path HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path.Style>
                                <Style TargetType="Path" BasedOn="{StaticResource Style.Icon.Hero}">
                                    <Setter Property="Data" Value="{StaticResource IconCheck}"/>
                                    <Setter Property="Stroke" Value="{DynamicResource Brush.Status.Success}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAccessGranted}" Value="False">
                                            <Setter Property="Data" Value="{StaticResource IconClose}"/>
                                            <Setter Property="Stroke" Value="{DynamicResource Brush.Status.Error}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Grid>

                    <TextBlock Text="{Binding StatusMessage}" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Title2}">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Success}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAccessGranted}" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Error}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AccessStatus}" Value="Warning">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Warning}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="{Binding FailureReason}" 
                               Style="{StaticResource Text.Caption}" 
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               HorizontalAlignment="Center"
                               Visibility="{Binding FailureReason, Converter={StaticResource NullToVis}}"
                               Margin="0,0,0,24"/>

                    <!-- 3. Member Info (If available) -->
                    <StackPanel Visibility="{Binding Member, Converter={StaticResource NullToVis}}">
                        <Separator Margin="0,0,0,24" Background="{DynamicResource Brush.Separator}"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Avatar -->
                            <Border Width="56" Height="56" CornerRadius="28" Background="{DynamicResource Brush.Surface.Muted}" Margin="0,0,16,0">
                                <Grid>
                                    <Path Data="{StaticResource IconMembers}" Style="{StaticResource Style.Icon.Medium}" Stroke="{DynamicResource Brush.Text.Secondary}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Visibility="{Binding Member.ProfileImageUrl, Converter={StaticResource NullToVis}, ConverterParameter=Inverse}"/>
                                    <Image Source="{Binding Member.ProfileImageUrl}" Stretch="UniformToFill" Panel.ZIndex="1">
                                        <Image.Clip>
                                            <EllipseGeometry Center="28,28" RadiusX="28" RadiusY="28"/>
                                        </Image.Clip>
                                    </Image>
                                </Grid>
                            </Border>

                            <!-- Details -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Member.FullName}" Style="{StaticResource Text.Body.Bold}" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                <TextBlock Text="{Binding Member.MembershipPlanName}" Style="{StaticResource Text.Caption}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Expires in: " Style="{StaticResource Text.Caption.Small}" Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                                    <TextBlock Text="{Binding RemainingDays, StringFormat='{}{0} days'}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Caption.Small}">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RemainingDays}" Value="0">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Error}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AccessStatus}" Value="Warning">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Warning}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- 4. Anonymous Scan -->
                    <StackPanel Visibility="{Binding Member, Converter={StaticResource NullToVis}, ConverterParameter=Inverse}" 
                                HorizontalAlignment="Center" Margin="0,24,0,0">
                        <TextBlock Text="{Binding CardId, StringFormat='Card ID: {0}'}" 
                                   Style="{StaticResource Text.Caption}" 
                                   Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
