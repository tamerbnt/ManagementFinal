<UserControl x:Class="Management.Presentation.Views.Settings.MembershipPlanEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Settings"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d" 
             d:DesignWidth="400" d:DesignHeight="800">

    <Border Padding="24">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Form -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,32">
                <Border Width="64" Height="64" 
                        Background="{DynamicResource Brush.Brand.Primary.Fade}" 
                        CornerRadius="32" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,16">
                    <Path Data="{StaticResource Icon.Sliders}" 
                          Style="{DynamicResource Style.Icon.Large}" 
                          Stroke="{DynamicResource Brush.Brand.Primary}" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Border>
                <TextBlock Foreground="{DynamicResource Brush.Text.Primary}"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Title2}">
                            <Setter Property="Text" Value="{DynamicResource Terminology.Settings.Editor.Title.Add}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource Terminology.Settings.Editor.Title.Edit}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{DynamicResource Terminology.Settings.Editor.Title}" 
                           Style="{DynamicResource Text.Caption}" 
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 2. Form Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,24" Padding="0,0,12,0">
                <StackPanel>
                    <!-- Plan Name -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="{DynamicResource Terminology.Settings.Editor.PlanName}" Style="{DynamicResource FormLabel}" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource Input.Apple}"/>
                    </StackPanel>

                    <!-- Price & Duration -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="{DynamicResource Terminology.Settings.Editor.PriceUSD}" Style="{DynamicResource FormLabel}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Price}" Style="{DynamicResource Input.Apple}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{DynamicResource Terminology.Settings.Editor.DurationDays}" Style="{DynamicResource FormLabel}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding DurationDays}" Style="{DynamicResource Input.Apple}"/>
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2" Margin="0,0,0,24">
                        <CheckBox Content="{DynamicResource Terminology.Settings.Editor.SessionPack}" IsChecked="{Binding IsSessionPack}" Style="{DynamicResource CheckBox.Modern}"/>
                        <CheckBox Content="{DynamicResource Terminology.Settings.Editor.IsActive}" IsChecked="{Binding IsActive}" Style="{DynamicResource CheckBox.Modern}"/>
                    </UniformGrid>

                    <!-- Gender Rules -->
                    <StackPanel Margin="0,0,0,32">
                        <TextBlock Text="{DynamicResource Terminology.Settings.Editor.GenderRestriction}" Style="{DynamicResource FormLabel}" Margin="0,0,0,8"/>
                        <ComboBox SelectedIndex="{Binding GenderRule}" Style="{StaticResource Input.ComboBox}" IsEditable="False">
                            <ComboBoxItem Content="{DynamicResource Terminology.Settings.Editor.Gender.Unrestricted}"/>
                            <ComboBoxItem Content="{DynamicResource Terminology.Settings.Editor.Gender.Male}"/>
                            <ComboBoxItem Content="{DynamicResource Terminology.Settings.Editor.Gender.Female}"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Scheduling -->
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Settings.Editor.AccessSchedule}" Style="{DynamicResource FormLabel}" VerticalAlignment="Center"/>
                            <Button Command="{Binding AddWindowCommand}" Content="{DynamicResource Terminology.Settings.Editor.AddWindow}" HorizontalAlignment="Right" Style="{DynamicResource GhostButton}"/>
                        </Grid>
                        
                        <ItemsControl ItemsSource="{Binding ScheduleWindows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}" 
                                            CornerRadius="12" 
                                            Padding="16" 
                                            Margin="0,0,0,12"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Day Selector -->
                                            <ComboBox Grid.Column="0" Margin="0,0,16,0" SelectedIndex="{Binding DayOfWeek}" Style="{StaticResource Input.ComboBox}" IsEditable="False">
                                                <ComboBoxItem Content="{DynamicResource Terminology.Days.Sunday}"/>
                                                <ComboBoxItem Content="{DynamicResource Terminology.Days.Monday}"/>
                                                <ComboBoxItem Content="{DynamicResource Terminology.Days.Tuesday}"/>
                                                <ComboBoxItem Content="{DynamicResource Terminology.Days.Wednesday}"/>
                                                <ComboBoxItem Content="{DynamicResource Terminology.Days.Thursday}"/>
                                                <ComboBoxItem Content="{DynamicResource Terminology.Days.Friday}"/>
                                                <ComboBoxItem Content="{DynamicResource Terminology.Days.Saturday}"/>
                                            </ComboBox>

                                            <TextBox Grid.Column="1" Text="{Binding StartTime}" Margin="0,0,8,0" Style="{DynamicResource Input.Apple}" Tag="09:00"/>
                                            <TextBox Grid.Column="2" Text="{Binding EndTime}" Margin="8,0,0,0" Style="{DynamicResource Input.Apple}" Tag="17:00"/>

                                            <Button Command="{Binding DataContext.RemoveWindowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Content="Ã—" 
                                                    FontSize="20" 
                                                    FontWeight="Bold"
                                                    Grid.Column="3" 
                                                    Margin="16,0,0,0" 
                                                    Style="{DynamicResource IconButtonStyle}" 
                                                    Foreground="{DynamicResource Brush.Functional.Error}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 3. Footer -->
            <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,16,0,0">
                <Button Command="{Binding SaveCommand}" Content="{DynamicResource Terminology.Settings.Editor.SaveChanges}" Style="{DynamicResource PrimaryButton}" Height="40" Margin="0,0,0,12"/>
                <Button Command="{Binding CancelCommand}" Content="{DynamicResource Terminology.Settings.Editor.Cancel}" Style="{DynamicResource GhostButton}" Height="40"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
