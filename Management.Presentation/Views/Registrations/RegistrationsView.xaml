<UserControl x:Class="Management.Presentation.Views.Registrations.RegistrationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:local="clr-namespace:Management.Presentation.Views.Registrations"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Registrations"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Shared converters used from App.xaml -->
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 1. Header & Primary Actions -->
            <RowDefinition Height="Auto"/>
            <!-- 2. Controls Area (Filters) -->
            <RowDefinition Height="*"/>
            <!-- 3. Content Area (List) -->
        </Grid.RowDefinitions>

        <!-- 1. Header & Global Actions (Aligned with Members) -->
        <Grid Grid.Row="0" Margin="{StaticResource MarginSectionBottom}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Path Data="{StaticResource IconRegistrations}" 
                      Style="{StaticResource Style.Icon.Large}" 
                      Stroke="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,12,0"/>
                <TextBlock Text="{DynamicResource Terminology.Global.Header.Registrations}" 
                           Style="{StaticResource Title1}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                
                <!-- Count Badge (Optional, but looks nice like in the image) -->
                <Border Background="{DynamicResource StatusErrorBrush}"
                        CornerRadius="14"
                        Padding="8,2"
                        MinHeight="20"
                        Margin="12,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding WebsiteRequests.Count, Converter={StaticResource IntToVisibilityConverter}}">
                    <TextBlock Text="{Binding WebsiteRequests.Count}"
                               Style="{StaticResource Micro}"
                               Foreground="{DynamicResource TextOnAccentBrush}"
                               FontWeight="Bold"/>
                </Border>
            </StackPanel>

            <!-- Soft Action: Print Button -->
            <Button Grid.Column="1" Command="{Binding PrintReportCommand}" Style="{StaticResource SecondaryButton}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconPrinter}" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Style="{StaticResource Style.Icon.Small}"
                          Margin="{StaticResource MarginIconRight}"/>
                    <TextBlock Text="{DynamicResource Terminology.Registrations.Action.Print}" FontWeight="Medium"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 2. Controls Area (Row 1) - Aligned with Members -->
        <Grid Grid.Row="1" Margin="{StaticResource MarginSectionBottom}">
            
            <!-- A. Filter Bar (Simplistic for Website Requests Only) -->
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <!-- Status Filter Container -->
                    <Border Background="{DynamicResource SurfaceBg}" CornerRadius="12" Padding="4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <!-- WEBSITE REQUESTS TAB -->
                            <RadioButton GroupName="StatusFilterGroup"
                                         IsChecked="True" 
                                         Style="{StaticResource TogglePillStyle}"
                                         IsHitTestVisible="False">
                                <StackPanel Orientation="Horizontal" Margin="-10,0">
                                    <TextBlock Text="Website Requests" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource StatusErrorBrush}"
                                            CornerRadius="10"
                                            Padding="6,0"
                                            MinHeight="20"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding PendingWebsiteCount, Converter={StaticResource IntToVisibilityConverter}}">
                                        <TextBlock Text="{Binding PendingWebsiteCount}"
                                                   Style="{StaticResource Micro}"
                                                   Foreground="{DynamicResource TextOnAccentBrush}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>


        <!-- 3. Content Area (Row 2) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Website Requests List View (Always Shown) -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding WebsiteRequests}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,0,12,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SurfaceBg}" 
                                CornerRadius="12" 
                                Padding="16,12" 
                                Margin="0,0,0,8" 
                                BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 1. User Info -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{Binding FullName}" Style="{StaticResource Body}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='dd MMM yyyy HH:mm'}" Style="{StaticResource BodySmall}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        <!-- Source Badge -->
                                        <Border Background="{DynamicResource SurfaceBgElevated}" CornerRadius="4" Padding="4,2" Margin="8,0,0,0">
                                            <TextBlock Text="Web" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 2. Contact Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{Binding PhoneNumber}" Style="{StaticResource BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding Email}" Style="{StaticResource BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                
                                <!-- 3. Gender & Facility -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{Binding Gender}" Style="{StaticResource BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                    <!-- Facility Slug Badge -->
                                    <Border Background="{DynamicResource BrandSecondaryBrush}" Opacity="0.1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" MinWidth="40">
                                        <TextBlock Text="{Binding FacilitySlug}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BrandPrimaryBrush}" TextAlignment="Center"/>
                                    </Border>
                                </StackPanel>

                                <!-- 4. Desired Plan -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="Desired Plan" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding DesiredPlan}" Style="{StaticResource BodySmall}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" MaxHeight="34" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- 5. Actions -->
                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Confirm" 
                                            Command="{Binding DataContext.ConfirmWebsiteRequestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SuccessButtonStyle}" 
                                            Margin="0,0,8,0"
                                            Padding="16,6"/>
                                    
                                    <Button Content="Reject" 
                                            Command="{Binding DataContext.RejectWebsiteRequestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DestructiveButtonStyle}"
                                            Padding="16,6"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>
    </Grid>
</UserControl>
