<UserControl x:Class="Management.Presentation.Views.Members.MemberAccessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="450">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:MultiplyValueConverter x:Key="MultiplyValueConverter"/>
    </UserControl.Resources>

    <Border CornerRadius="28" 
            Background="{DynamicResource SurfaceBg}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Width="460"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Effect="{StaticResource Shadow3}">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Illustrations -->
                <RowDefinition Height="Auto"/> <!-- Status Text -->
                <RowDefinition Height="Auto"/> <!-- Member Info -->
                <RowDefinition Height="Auto"/> <!-- Warning/Failure Info -->
            </Grid.RowDefinitions>

            <!-- Manual Close Button -->
            <Button Style="{StaticResource Button.Ghost}" 
                    Command="{Binding CloseAsyncCommand}"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"
                    Margin="16"
                    Padding="8"
                    Panel.ZIndex="10">
                <Path Data="{StaticResource IconClose}" 
                      Style="{StaticResource Style.Icon.Small}" 
                      Stroke="{DynamicResource TextTertiaryBrush}"/>
            </Button>

            <!-- 1. Illustration Header -->
            <Border Grid.Row="0" Padding="0,48,0,24">
                <Grid>
                    <Image Width="120" Height="120" 
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" Value="pack://application:,,,/Resources/Images/access_granted_illustration.png"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAccessGranted}" Value="False">
                                        <Setter Property="Source" Value="pack://application:,,,/Resources/Images/access_denied_illustration.png"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    
                    <!-- Status Ring -->
                    <Ellipse Width="160" Height="160" StrokeThickness="4" Opacity="0.1">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Stroke" Value="{DynamicResource Brush.Success}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAccessGranted}" Value="False">
                                        <Setter Property="Stroke" Value="{DynamicResource Brush.Danger}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>
            </Border>

            <!-- 2. Status Text -->
            <StackPanel Grid.Row="1" Margin="0,0,0,32">
                <TextBlock Text="{Binding StatusMessage}" 
                           HorizontalAlignment="Center"
                           FontSize="24">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Title2}">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Success}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAccessGranted}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AccessStatus}" Value="Warning">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- 3. Member Info Card -->
            <Border Grid.Row="2" 
                    Margin="32,0,32,32" 
                    Background="{DynamicResource Brush.Surface.Secondary}" 
                    CornerRadius="20" 
                    Padding="24"
                    Visibility="{Binding Member, Converter={StaticResource NullToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Grid Grid.Column="0" Margin="0,0,20,0">
                        <Ellipse Width="64" Height="64" Fill="{Binding Member.FullName, Converter={StaticResource NameToBrushConverter}}"/>
                        <TextBlock Text="{Binding Member.FullName, Converter={StaticResource NameToInitialConverter}}" 
                                   Foreground="White" FontWeight="Bold" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        
                        <Image Source="{Binding Member.ProfileImageUrl}" Stretch="UniformToFill" Width="64" Height="64">
                            <Image.Clip>
                                <EllipseGeometry Center="32,32" RadiusX="32" RadiusY="32"/>
                            </Image.Clip>
                        </Image>
                    </Grid>

                    <!-- Details -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Member.FullName}" Style="{StaticResource BodyBold}" FontSize="18" Foreground="{DynamicResource Brush.Text.Primary}"/>
                        
                        <Border Background="{DynamicResource FacilityAccentDimBrush}" 
                                HorizontalAlignment="Left" 
                                CornerRadius="8" 
                                Padding="8,4" 
                                Margin="0,6,0,8">
                            <TextBlock Text="{Binding Member.MembershipPlanName}" 
                                       FontSize="11" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource FacilityAccentBrush}"/>
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconClock}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,6,0"/>
                            <TextBlock Text="Expiration: " Style="{StaticResource BodySmall}" Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                            <TextBlock Text="{Binding RemainingDays, StringFormat='{}{0} days'}" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BodySmall}">
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RemainingDays}" Value="0">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 4. Warning / Failure Section -->
            <Border Grid.Row="3" 
                    Margin="32,0,32,32" 
                    Padding="16" 
                    CornerRadius="12" 
                    Background="{DynamicResource Brush.Surface.Muted}"
                    Visibility="{Binding FailureReason, Converter={StaticResource NullToVis}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Path Data="{StaticResource IconAlert}" Style="{StaticResource Style.Icon.Micro}" Stroke="{DynamicResource Brush.Danger}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding FailureReason}" 
                               Style="{StaticResource BodySmall}" 
                               Foreground="{DynamicResource Brush.Danger}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="340"/>
                </StackPanel>
            </Border>

            <!-- Anonymous Card ID (If no member) -->
            <TextBlock Grid.Row="2" 
                       Text="{Binding CardId, StringFormat='Card ID: {0}'}" 
                       Style="{StaticResource BodySmall}" 
                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,48"
                       Visibility="{Binding Member, Converter={StaticResource NullToVis}, ConverterParameter=Inverse}"/>

        </Grid>
    </Border>
</UserControl>
