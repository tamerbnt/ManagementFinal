    <!-- ============================================================= -->
    <!-- 5. BRAND ILLUSTRATIONS (Razor Series)                         -->
    <!-- ============================================================= -->

    <!-- Security Character (License/Auth) -->
    <!-- Two-part geometry (Fill vs Outline) to be combined in View -->
    <Geometry x:Key="ArtCharacterSecurityOutline">M 12,2 C 16,2 20,5 20,10 V 16 H 4 V 10 C 4,5 8,2 12,2 Z
                                                     M 12,16 V 22 M 10,22 H 14
                                                     M 8,10 H 6 M 16,10 H 18</Geometry>
    
    <!-- Use with Fill="{StaticResource PatternPolkaDots}" -->
    <Geometry x:Key="ArtCharacterSecurityFill">M 12,2 C 16,2 20,5 20,10 V 16 H 4 V 10 C 4,5 8,2 12,2 Z</Geometry>

</ResourceDictionary>