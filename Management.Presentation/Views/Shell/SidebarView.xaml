<UserControl x:Class="Management.Presentation.Views.Shell.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Shell"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="260">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ResourceKeyToIconConverter x:Key="ResourceKeyToIconConverter"/>
        
        <!-- Sidebar Navigation Button Style (COINEST Floating) -->
        <Style x:Key="SidebarNavigationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="{DynamicResource Corner.LG}"> <!-- Tokenized Rounds -->
                            <ContentPresenter x:Name="Presenter" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <ContentPresenter.RenderTransform>
                                    <TranslateTransform X="0" Y="0"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Presenter" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="4" Duration="{StaticResource DurationStandard}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Presenter" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="{StaticResource DurationStandard}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border x:Name="SidebarBorder" 
            Background="{DynamicResource FacilitySidebarBrush}"
            CornerRadius="{DynamicResource Corner.XL}"
            BorderThickness="1,1,0,0"
            BorderBrush="{DynamicResource Brush.Surface.Glass.Standard}"> <!-- Tokenized Highlight -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/> <!-- Breathing Room -->
                <RowDefinition Height="Auto"/> <!-- Logo Area -->
                <RowDefinition Height="*"/> <!-- Navigation Track -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
                <RowDefinition Height="24"/> <!-- Bottom Space -->
            </Grid.RowDefinitions>

            <!-- LOGO AREA (Interactive Engine Brand) -->
            <Button Grid.Row="1" Command="{Binding ToggleSidebarCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavigationButtonStyle}">
                        <Setter Property="Margin" Value="16,0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <Setter Property="Margin" Value="8,0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Grid>
                    <!-- Expanded State -->
                    <StackPanel x:Name="ExpandedLogo" Orientation="Vertical" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Glowing Logo Container -->
                        <Border x:Name="ExpandedLogoBorder" Width="48" Height="48" CornerRadius="{DynamicResource Corner.MD}" HorizontalAlignment="Center"
                                Background="{DynamicResource FacilityAccentGradient}">
                            <Border.Effect>
                                <!-- Enhanced Identity Glow (Standardized to History Row behavior) -->
                                <DropShadowEffect Color="{DynamicResource FacilityAccentShadowColor}" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <Path Data="M18,15C18,15 15,15 12.5,19C10,23 8,23 6,23C4,23 2,21 2,18C2,15 5,12 8,12C11,12 11,15 11,15C11,15 14,15 16,11C18,7 21,7 23,7C25,7 27,9 27,12C27,15 24,18 21,18C18,18 18,15 18,15Z" 
                                  Fill="{DynamicResource Brush.Neutral.White}" Stretch="Uniform" Margin="12"/>
                        </Border>

                        <TextBlock Text="{DynamicResource Strings.Auth.TITAN}" FontWeight="Bold" Foreground="{DynamicResource Brush.Neutral.White}" FontSize="16"
                                   HorizontalAlignment="Center" Margin="0,8,0,0">
                             <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource FacilityAccentColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                             </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <!-- Collapsed State -->
                    <Border x:Name="CollapsedLogo" 
                            Width="44" Height="44" CornerRadius="{DynamicResource Corner.MD}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource FacilityAccentGradient}">
                        <Border.Effect>
                             <!-- Stronger Identity Glow for Collapsed State -->
                            <DropShadowEffect Color="{DynamicResource FacilityAccentShadowColor}" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="M18,15C18,15 15,15 12.5,19C10,23 8,23 6,23C4,23 2,21 2,18C2,15 5,12 8,12C11,12 11,15 11,15C11,15 14,15 16,11C18,7 21,7 23,7C25,7 27,9 27,12C27,15 24,18 21,18C18,18 18,15 18,15Z" 
                              Fill="{DynamicResource Brush.Neutral.White}" Width="20" Height="20" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Button>

            <!-- NAVIGATION (COINEST Floating Pillars) -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <!-- SELECTION RAIL (Fluid Motion Layer) -->
                <Canvas x:Name="SelectionRail" IsHitTestVisible="False" Margin="0,0">
                    <!-- GLOWING BLUE PILL INDICATOR -->
                    <Border x:Name="FluidIndicator">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="IndicatorTransform" Y="0"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Width" Value="248"/>
                                <Setter Property="Height" Value="64"/>
                                <Setter Property="Margin" Value="6,0"/>
                                <Setter Property="CornerRadius" Value="{DynamicResource Corner.LG}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <Setter Property="Width" Value="52"/>
                                        <Setter Property="Margin" Value="10,0"/>
                                        <Setter Property="CornerRadius" Value="{DynamicResource Corner.XL}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="SelectionStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition From="*" To="*" GeneratedDuration="0:0:0.4">
                                        <VisualTransition.GeneratedEasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </VisualTransition.GeneratedEasingFunction>
                                    </VisualTransition>
                                </VisualStateGroup.Transitions>

                                <VisualState x:Name="State0">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="0" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State1">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="64" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State2">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="128" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State3">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="192" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State4">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="256" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State5">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="320" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State6">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="384" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="State7">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndicatorTransform" Storyboard.TargetProperty="Y" To="448" Duration="0"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <i:Interaction.Triggers>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="0">
                                <i:GoToStateAction StateName="State0"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="1">
                                <i:GoToStateAction StateName="State1"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="2">
                                <i:GoToStateAction StateName="State2"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="3">
                                <i:GoToStateAction StateName="State3"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="4">
                                <i:GoToStateAction StateName="State4"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="5">
                                <i:GoToStateAction StateName="State5"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="6">
                                <i:GoToStateAction StateName="State6"/>
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding ActiveIndex}" Value="7">
                                <i:GoToStateAction StateName="State7"/>
                            </i:DataTrigger>
                        </i:Interaction.Triggers>
                        
                        <!-- CoachPro Style: Solid Identity Pill -->
                        <Border.Background>
                            <DynamicResource ResourceKey="FacilityAccentGradient"/>
                        </Border.Background>
                        
                        <Border.BorderThickness>0</Border.BorderThickness>

                        <Border.Effect>
                            <!-- Soft Identity Shadow (Standardized Glow) -->
                            <DropShadowEffect Color="{DynamicResource FacilityAccentShadowColor}" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                        </Border.Effect>
                        
                        <!-- No internal dot for CoachPro style, just solid gradient -->
                    </Border>
                </Canvas>

                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Floating Container -->
                            <Border x:Name="NavItemBorder" Background="Transparent" CornerRadius="{DynamicResource Corner.LG}" Margin="6,0" Height="64">
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarNavigationButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                    <Setter Property="ToolTip" Value="{Binding DisplayName}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Path x:Name="IconPath" Grid.Column="0"
                                              Data="{Binding IconKey, Converter={StaticResource ResourceKeyToIconConverter}}"
                                              Fill="{DynamicResource Brush.Sidebar.Text.Inactive}"
                                              Width="20" Height="20" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        
                                        <TextBlock x:Name="LabelText" Grid.Column="1" 
                                                   Text="{Binding DisplayName}" 
                                                   VerticalAlignment="Center" Margin="4,0,16,0"
                                                   Foreground="{DynamicResource Brush.Sidebar.Text.Inactive}"
                                                   FontSize="14" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                            <Setter Property="Opacity" Value="0"/>
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <!-- REMOVED TextGlow to fix ghosting/blur issues -->
                                        </TextBlock>
                                    </Grid>
                                </Button>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <!-- Using semi-transparent background for hover -->
                                    <Setter TargetName="NavItemBorder" Property="Background" Value="{DynamicResource Brush.Sidebar.Hover}"/> 
                                </Trigger>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Brush.Sidebar.Text.Active}"/>
                                    <Setter TargetName="LabelText" Property="Foreground" Value="{DynamicResource Brush.Sidebar.Text.Active}"/>
                                    <Setter TargetName="LabelText" Property="FontWeight" Value="SemiBold"/>
                                    <!-- NO TEXT EFFECT -> FIXES GHOSTING -->
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
            
            <!-- SEPARATOR -->
            <Rectangle Grid.Row="2" VerticalAlignment="Bottom" Height="1" Margin="16,12" Opacity="0.2">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="White" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- FOOTER (Clean Bottom Action) -->
            <StackPanel Grid.Row="3" Margin="0,0,0,8">
                <!-- Change Facility Button -->
                <Border x:Name="FacilityItem" Background="Transparent" CornerRadius="{DynamicResource Corner.LG}" Margin="6,4,6,0" Height="64">
                    <Button Style="{StaticResource SidebarNavigationButtonStyle}" Command="{Binding ChangeFacilityCommand}">
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Path x:Name="FacilityIcon" Grid.Column="0"
                                  Data="{StaticResource Icon.Storefront}"
                                  Fill="{DynamicResource Brush.Sidebar.Text.Inactive}"
                                  Width="20" Height="20" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>

                            <TextBlock x:Name="FacilityText" Grid.Column="1" 
                                       Text="{DynamicResource Terminology.Sidebar.ChangeFacility}" 
                                       VerticalAlignment="Center" Margin="4,0,16,0"
                                       Foreground="{DynamicResource Brush.Sidebar.Text.Inactive}"
                                       FontSize="14" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
