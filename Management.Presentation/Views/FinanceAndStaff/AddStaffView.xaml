<UserControl x:Class="Management.Presentation.Views.FinanceAndStaff.AddStaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="500">

    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="550"
            Padding="{DynamicResource PaddingModal}"
            VerticalAlignment="Center"
            MaxHeight="700">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Form -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. Header -->
            <StackPanel Grid.Row="0" Margin="{DynamicResource MarginHeaderBottom}">
                <TextBlock Text="{Binding DialogTitle}" 
                           Style="{DynamicResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Terminology.Staff.Add.Subtitle}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="{DynamicResource MarginTextTop}"/>
            </StackPanel>

            <!-- 2. Form Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <StackPanel Margin="0,0,10,0">
                    <!-- Full Name -->
                    <TextBlock Text="{DynamicResource Terminology.Staff.Add.FullName}" Style="{DynamicResource FormLabel}"/>
                    <TextBox Text="{Binding NewStaff.FullName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource UnderlineTextBox}"
                             Margin="{DynamicResource MarginSmallBottom}"
                             Tag="{DynamicResource Strings.FinanceAndStaff.egSarahConnor}"/>

                    <!-- Phone Number -->
                    <TextBlock Text="{DynamicResource Terminology.Staff.Add.Phone}" Style="{DynamicResource FormLabel}" Margin="{DynamicResource MarginSectionTop}"/>
                    <TextBox Text="{Binding NewStaff.Phone, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource UnderlineTextBox}"
                             Margin="{DynamicResource MarginSmallBottom}"
                             Tag="+1 555 019 2834"/>

                    <!-- Email -->
                    <TextBlock Text="{DynamicResource Terminology.Staff.Add.Email}" Style="{DynamicResource FormLabel}" Margin="{DynamicResource MarginSectionTop}"/>
                    <TextBox Text="{Binding NewStaff.Email, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource UnderlineTextBox}"
                             Margin="{DynamicResource MarginSmallBottom}"
                             Tag="{DynamicResource Strings.FinanceAndStaff.sarahexamplecom}"/>

                    <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                        <!-- Password (New) -->
                        <TextBlock Text="{DynamicResource Terminology.Staff.Add.Password}" Style="{DynamicResource FormLabel}" Margin="{DynamicResource MarginSectionTop}"/>
                        <PasswordBox x:Name="StaffPasswordBox" 
                                     Style="{DynamicResource UnderlinePasswordBox}"
                                     behaviors:PasswordBoxHelper.BindPassword="True"
                                     behaviors:PasswordBoxHelper.BoundPassword="{Binding NewStaff.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="{DynamicResource MarginSmallBottom}"/>
                    </StackPanel>



                    <!-- Primary Facility -->
                    <TextBlock Text="{DynamicResource Strings.FinanceAndStaff.PRIMARYFACILITY}" Style="{DynamicResource FormLabel}" Margin="{DynamicResource MarginSectionTop}"/>
                    <ComboBox ItemsSource="{Binding AvailableFacilities}"
                              SelectedItem="{Binding SelectedFacility}"
                              Style="{StaticResource Input.ComboBox}"
                              IsEditable="False"
                              Margin="{DynamicResource MarginSmallBottom}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Role -->
                    <TextBlock Text="{DynamicResource Terminology.Staff.Add.Role}" Style="{DynamicResource FormLabel}" Margin="{DynamicResource MarginSectionTop}"/>
                    <ComboBox ItemsSource="{Binding Roles}"
                              SelectedItem="{Binding NewStaff.Role}" 
                              Style="{StaticResource Input.ComboBox}" 
                              IsEditable="False"
                              Margin="{DynamicResource MarginSmallBottom}"/>

                    <!-- Salary & Payment Day -->
                    <Grid Margin="{DynamicResource MarginSectionTop}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Terminology.Staff.Add.Salary}" Style="{DynamicResource FormLabel}"/>
                            <TextBox Text="{Binding NewStaff.Salary, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{DynamicResource UnderlineTextBox}"
                                     Tag="{DynamicResource Strings.FinanceAndStaff.eg2500}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Terminology.Staff.Add.PaymentDay}" Style="{DynamicResource FormLabel}"/>
                            <TextBox Text="{Binding NewStaff.PaymentDay, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{DynamicResource UnderlineTextBox}"
                                     Tag="1 - 31"/>
                        </StackPanel>
                    </Grid>

                    <!-- Permissions -->
                    <TextBlock Text="{DynamicResource Terminology.Staff.Add.Permissions}" Style="{DynamicResource FormLabel}" Margin="{DynamicResource MarginSectionTop}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="{DynamicResource Terminology.Staff.Add.CreateAccount}" 
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding NewStaff.Permissions[0].IsGranted}"
                                  Style="{DynamicResource ToggleSwitchStyle}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- 3. Footer Actions -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="32">
                
                <Button Content="{DynamicResource Terminology.Global.Cancel}" 
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource SecondaryButton}"
                        Width="100" Margin="0,0,12,0"/>

                <Button Content="{Binding ActionButtonText}" 
                        Command="{Binding SaveCommand}"
                        CommandParameter="{Binding ElementName=StaffPasswordBox}"
                        Style="{DynamicResource PrimaryButton}"
                        Width="200"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
