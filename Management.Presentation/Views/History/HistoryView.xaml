<UserControl x:Class="Management.Presentation.Views.History.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:local="clr-namespace:Management.Presentation.Views.History"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <converters:IntToVisibilityConverter x:Key="ZeroIsVisibleConverter" />

        <!-- 
            POLYMORPHIC TEMPLATES (Section 28.6)
            Maps ViewModel types to their specific "Card" visual components.
        -->
        <DataTemplate DataType="{x:Type vm:AccessEventItemViewModel}">
            <local:AccessEventList />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PaymentEventItemViewModel}">
            <local:PaymentHistoryList />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ReservationEventItemViewModel}">
            <local:ReservationHistoryList />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Filter Bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- 1. Header & Print Action -->
        <Grid Grid.Row="0" Margin="{StaticResource MarginPageHeader}">
            <TextBlock Text="{DynamicResource TerminologyHistoryLabel}" 
                       Style="{StaticResource Title1}" 
                       AutomationProperties.HeadingLevel="Level1"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>

            <!-- Print Button (Section 43) -->
            <Button Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right"
                    Command="{Binding PrintReportCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconPrinter}" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Style="{StaticResource IconSmall}"
                          Margin="{StaticResource MarginIconRight}"/>
                    <TextBlock Text="{DynamicResource TerminologyPrintHistoryLabel}"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 2. Filter Bar (Section 28.3) -->
        <Grid Grid.Row="1" Margin="{StaticResource MarginPageContent}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Search -->
                <ColumnDefinition Width="24"/>
                <!-- Gap -->
                <ColumnDefinition Width="Auto"/>
                <!-- Date Picker -->
                <ColumnDefinition Width="*"/>
                <!-- Spacer -->
                <ColumnDefinition Width="Auto"/>
                <!-- Export -->
            </Grid.ColumnDefinitions>

            <!-- A. Search Box (Fluid) -->
            <Border Grid.Column="0"
                    MinWidth="{StaticResource SizeInputMinWidth}"
                    MaxWidth="{StaticResource SizeSearchBarWidth}"
                    Height="{StaticResource SizeInputHeight}"
                    Background="{DynamicResource SurfaceBg}"
                    CornerRadius="{StaticResource RadiusSearchBar}"
                    KeyboardNavigation.TabIndex="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Path Grid.Column="0"
                          Data="{StaticResource IconSearch}"
                          Fill="{DynamicResource TextTertiaryBrush}"
                          Style="{StaticResource IconStandard}"
                          Margin="{StaticResource MarginInputIcon}"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource UnderlineTextBox}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             Tag="Search events by name, ID, type..."/>
                </Grid>
            </Border>

            <!-- B. Date Range Picker (Global Component) -->
            <!-- 
                Uses 'DateRangePickerButtonStyle' defined in Components.xaml 
                Encapsulates the "Fake Input" look, Calendar Icon, and Chevron.
            -->
            <Button Grid.Column="2"
                    Style="{StaticResource DateRangePickerButtonStyle}"
                    Content="{Binding DateRangeText, FallbackValue={DynamicResource TerminologySelectDatesLabel}}"
                    Command="{Binding SelectDateRangeCommand}"
                    KeyboardNavigation.TabIndex="2"/>

            <!-- C. Export Button -->
            <Button Grid.Column="4"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ExportCommand}"
                    KeyboardNavigation.TabIndex="3">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconExport}" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Style="{StaticResource IconSmall}"
                          Margin="{StaticResource MarginIconRight}"/>
                    <TextBlock Text="{DynamicResource TerminologyExportLabel}"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 3. Timeline List (Row 2) -->
        <Grid Grid.Row="2" Margin="{StaticResource MarginPageContent}">

            <!-- Grouped ListBox -->
            <ListBox ItemsSource="{Binding HistoryEventsView}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                     ScrollViewer.CanContentScroll="True">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRingStyle}"/>
                        <Setter Property="Margin" Value="{StaticResource MarginListVertical}"/>
                        <!-- Gap between items -->
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <!-- Group Headers (Date Labels) -->
                <!-- Uses Global DataTemplate 'TimelineGroupHeaderTemplate' -->
                <ListBox.GroupStyle>
                    <GroupStyle HeaderTemplate="{StaticResource TimelineGroupHeaderTemplate}"/>
                </ListBox.GroupStyle>
            </ListBox>

            <!-- Empty State Overlay -->
            <Grid Visibility="{Binding HistoryEvents.Count, Converter={StaticResource ZeroIsVisibleConverter}}"
                  IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,64">
                    <Path Data="{StaticResource IconHistory}"
                          Fill="{StaticResource IllustrationBackgroundBrush}"
                          Width="256" Height="256"
                          Stretch="Uniform"
                          Margin="{StaticResource MarginSectionBottom}"
                          HorizontalAlignment="Center"/>

                    <TextBlock Text="{DynamicResource TerminologyNoHistoryYetLabel}" 
                               Style="{StaticResource Title2}" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center"
                               Margin="{StaticResource MarginTextBottom}"/>
                    <TextBlock Text="{DynamicResource TerminologyActivityEventsRecordedLabel}" 
                               Style="{StaticResource Body}" 
                               Foreground="{DynamicResource TextTertiaryBrush}" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>