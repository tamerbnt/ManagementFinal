<UserControl x:Class="Management.Presentation.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Management.Presentation.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:LoginViewModel}">
    <Border Background="{DynamicResource SurfaceBg}" 
            CornerRadius="{StaticResource RadiusCardLarge}" 
            Width="400" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            Padding="40">
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource FacilityAccentColor}" Opacity="0.15" BlurRadius="40" ShadowDepth="0"/>
        </Border.Effect>

        <StackPanel>
            <!-- Expansion Header (Schema 3) -->
            <Border Background="{DynamicResource FacilityAccentBrush}" 
                    CornerRadius="8" 
                    Padding="12,8" 
                    Margin="0,0,0,24"
                    Visibility="{Binding IsExpansionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{DynamicResource IconAlert}" 
                          Style="{DynamicResource IconMicro}" 
                          Stroke="{DynamicResource OnAccentPrimary}" 
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ExpansionMessage}" 
                               Style="{DynamicResource Micro}" 
                               Foreground="{DynamicResource OnAccentPrimary}"
                               VerticalAlignment="Center" 
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Header -->
            <TextBlock Text="Welcome Back" 
                       Style="{DynamicResource Title1}" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,8"/>
            <TextBlock Text="Sign in to your account" 
                       Style="{DynamicResource Body}" 
                       Foreground="{DynamicResource TextSecondaryBrush}" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,32"/>

            <!-- Email -->
            <TextBlock Text="EMAIL ADDRESS" Style="{DynamicResource Micro}" Margin="0,0,0,8"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{DynamicResource UnderlineTextBox}" 
                     Margin="0,0,0,24"/>

            <!-- Password -->
            <TextBlock Text="PASSWORD" Style="{DynamicResource Micro}" Margin="0,0,0,8"/>
            <PasswordBox Style="{DynamicResource UnderlinePasswordBox}" 
                         Margin="0,0,0,24"
                         x:Name="PasswordInput">
            </PasswordBox>

            <!-- Remember Me & Forgot Password -->
            <Grid Margin="0,0,0,24">
                <CheckBox Content="Remember me" 
                          IsChecked="{Binding RememberMe}"
                          HorizontalAlignment="Left"/>
                
                <Button Content="Forgot Password?" 
                        Command="{Binding ForgotPasswordCommand}"
                        Style="{DynamicResource LinkButtonStyle}"
                        HorizontalAlignment="Right"/>
            </Grid>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" 
                       Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Foreground="{DynamicResource StatusErrorBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <!-- Login Button -->
            <Button Content="Sign In" 
                    Command="{Binding LoginCommand}" 
                    CommandParameter="{Binding ElementName=PasswordInput}"
                    Style="{DynamicResource PrimaryButton}" 
                    Height="40"/>

            <!-- Loading Indicator -->
             <Border Height="4" Margin="0,16,0,0" CornerRadius="2" ClipToBounds="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1A1A" Offset="0"/>
                        <GradientStop Color="#2A2A2A" Offset="0.5"/>
                        <GradientStop Color="#1A1A1A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                 <Border.Triggers>
                     <EventTrigger RoutedEvent="Loaded">
                         <BeginStoryboard>
                             <Storyboard RepeatBehavior="Forever">
                                 <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)" From="0.3" To="1" Duration="0:0:0.8" AutoReverse="True"/>
                             </Storyboard>
                         </BeginStoryboard>
                     </EventTrigger>
                 </Border.Triggers>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
