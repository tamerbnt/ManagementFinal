<Window x:Class="Management.Presentation.Views.Diagnostic.DiagnosticView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Diagnostic"
        mc:Ignorable="d"
        Title="{DynamicResource Strings.Diagnostic.SystemDiagnostic}" 
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="{StaticResource Safe.Background}"
        WindowStyle="None"
        ResizeMode="NoResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                          GlassFrameThickness="-1"
                          CornerRadius="1"
                          ResizeBorderThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- SAFE STYLES: These are self-contained to ensure the window works even if App.xaml styles fail -->
        <SolidColorBrush x:Key="Safe.Background" Color="#0F172A" />
        <SolidColorBrush x:Key="Safe.Surface" Color="#1E293B" />
        <SolidColorBrush x:Key="Safe.Text.Primary" Color="#F8FAFC" />
        <SolidColorBrush x:Key="Safe.Text.Secondary" Color="#94A3B8" />
        <SolidColorBrush x:Key="Safe.Accent" Color="#38BDF8" />
        <SolidColorBrush x:Key="Safe.Error" Color="#F87171" />
        <SolidColorBrush x:Key="Safe.Border" Color="#334155" />

        <Style x:Key="SafeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Safe.Accent}" />
            <Setter Property="Foreground" Value="{StaticResource Safe.Background}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Safe.Background}" BorderBrush="{StaticResource Safe.Border}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{DynamicResource Strings.Diagnostic.CRITICALERRORDETECTED}" 
                           Foreground="{StaticResource Safe.Error}" 
                           FontSize="12" FontWeight="Bold" />
                <TextBlock Text="{DynamicResource Strings.Diagnostic.DiagnosticRecoveryMode}" 
                           Foreground="{StaticResource Safe.Text.Primary}" 
                           FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                <TextBlock Text="{DynamicResource Strings.Diagnostic.Somethingwentwrongbutweve}" 
                           Foreground="{StaticResource Safe.Text.Secondary}" 
                           FontSize="14" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Error Details -->
            <Border Grid.Row="1" Background="{StaticResource Safe.Surface}" CornerRadius="8" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Category/Severity Badge -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="#334155" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding LastError.Category, FallbackValue='UI'}" 
                                           Foreground="{StaticResource Safe.Text.Primary}" FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <Border Background="#991B1B" CornerRadius="4" Padding="8,4" Margin="8,0,0,0">
                                <TextBlock Text="{Binding LastError.Severity, FallbackValue='Fatal'}" 
                                           Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Strings.Diagnostic.Message}" Foreground="{StaticResource Safe.Text.Secondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding LastError.Message, FallbackValue='A critical error occurred while initializing the application.'}" 
                                   Foreground="{StaticResource Safe.Text.Primary}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <TextBlock Text="{DynamicResource Strings.Diagnostic.TechnicalDetails}" Foreground="{StaticResource Safe.Text.Secondary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Border Background="{StaticResource Safe.Background}" Padding="12" CornerRadius="4">
                            <TextBlock Text="{Binding LastError.StackTrace, FallbackValue='No stack trace available.'}" 
                                       Foreground="#94A3B8" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="{DynamicResource Strings.Diagnostic.CopyDebugInfo}" 
                        Command="{Binding CopyToClipboardCommand}"
                        Background="Transparent"
                        Foreground="{StaticResource Safe.Text.Secondary}"
                        BorderThickness="1" BorderBrush="{StaticResource Safe.Border}"
                        Padding="16,8" Margin="0,0,12,0" />

                <Button Content="{DynamicResource Strings.Diagnostic.RestartApplication}" 
                        Command="{Binding RestartApplicationCommand}"
                        Style="{StaticResource SafeButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
