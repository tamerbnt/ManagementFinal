<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <!-- No local merges needed as they are handled in App.xaml or via DynamicResource resolution -->
    </ResourceDictionary.MergedDictionaries>

    <!-- 
        TITAN UI KIT (Apple 2025)
        - Buttons: 12px Radius, Scale Interaction, Facility Glow
        - Inputs: Apple Underline Style, Heartbeat Feedback
        - Cards: 20px Radius, Hover Lift
        - DataGrid: Premium styling, no vertical lines
    -->

    <!-- ============================================================= -->
    <!-- 1. BUTTONS & INTERACTIVE BASE                                 -->
    <!-- ============================================================= -->

    <!-- Base Button Style -->
    <Style x:Key="BaseButtonStyle" TargetType="ButtonBase">
        <Setter Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource OnAccentPrimary}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Height" Value="{StaticResource SizeButtonHeight}"/>
        <Setter Property="Padding" Value="24,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ButtonBase">
                    <Grid>
                        <!-- Main Visual -->
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource RadiusButton}"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">

                            <!-- Transform Group for Animation -->
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Border.RenderTransform>

                            <!-- Shadow / Glow Logic -->
                            <!-- Uses ElevationColor for Dark Mode Glow -->
                            <Border.Effect>
                                <DropShadowEffect x:Name="PART_Shadow"
                                                  BlurRadius="12"
                                                  ShadowDepth="3"
                                                  Opacity="0.12"
                                                  Direction="270"
                                                  Color="{DynamicResource ElevationColor}"/>
                            </Border.Effect>

                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Focus Ring -->
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource FacilityAccentBrush}"
                                BorderThickness="2"
                                CornerRadius="{StaticResource RadiusButton}"
                                Margin="-4"
                                Opacity="0"
                                SnapsToDevicePixels="True"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Keyboard Focus -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>

                        <!-- Pressed Animation (Scale down) -->
                        <Trigger Property="IsPressed" Value="True">
                             <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_Border" 
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" 
                                                         To="0.96" Duration="{StaticResource DurationMicro}">
                                            <DoubleAnimation.EasingFunction>
                                                <StaticResource ResourceKey="EaseOutPrimary"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="PART_Border" 
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" 
                                                         To="0.96" Duration="{StaticResource DurationMicro}">
                                            <DoubleAnimation.EasingFunction>
                                                <StaticResource ResourceKey="EaseOutPrimary"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_Border" 
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" 
                                                         To="1" Duration="{StaticResource DurationMicro}"/>
                                        <DoubleAnimation Storyboard.TargetName="PART_Border" 
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" 
                                                         To="1" Duration="{StaticResource DurationMicro}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary Button -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}"/>

    <!-- Secondary / Ghost Button -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/> 
        <Setter Property="BorderThickness" Value="0"/>
        <!-- Ghost buttons usually have no shadow unless hovered/active if desired, but spec says "Secondary/Ghost Buttons: Background is transparent". Keeping simple. -->
        <Setter Property="Effect" Value="{x:Null}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
               <Setter Property="Background" Value="{DynamicResource FacilityAccentDimBrush}"/>
               <!-- Optional: Add text color change if needed, but TextPrimary handles light/dark swap -->
               <!-- <Setter Property="Foreground" Value="{DynamicResource FacilityAccentBrush}"/> -->
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Width" Value="{StaticResource SizeTopBarIconButton}"/>
        <Setter Property="Height" Value="{StaticResource SizeTopBarIconButton}"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- Sidebar Navigation Button -->
    <Style x:Key="SidebarNavigationButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="48"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource FacilityAccentDimBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Destructive Button (Red/Error) -->
    <Style x:Key="DestructiveButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource StatusErrorBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================= -->
    <!-- 2. INPUTS & FORMS (Apple Underline)                           -->
    <!-- ============================================================= -->

    <Style x:Key="UnderlineTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="Height" Value="{StaticResource SizeInputHeight}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0,0,0,4"/>
        <Setter Property="AutomationProperties.HelpText" Value="{Binding Path=Tag, RelativeSource={RelativeSource Self}}"/>
        <Setter Property="AutomationProperties.Name" Value="{Binding Path=Tag, RelativeSource={RelativeSource Self}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <!-- Bottom Border Line -->
                        <Border x:Name="BorderVisual" 
                                BorderThickness="0,0,0,2" 
                                BorderBrush="{DynamicResource SeparatorStroke}" 
                                SnapsToDevicePixels="True" 
                                UseLayoutRounding="True"
                                VerticalAlignment="Bottom" Height="2"/>

                        <!-- Focus Highlighter (Animated) -->
                        <Border x:Name="FocusVisual" 
                                BorderThickness="0,0,0,2" 
                                BorderBrush="{DynamicResource FacilityAccentBrush}" 
                                SnapsToDevicePixels="True" 
                                UseLayoutRounding="True"
                                VerticalAlignment="Bottom" Height="2"
                                Opacity="0">
                             <Border.RenderTransform>
                                 <ScaleTransform ScaleX="0" CenterX="0.5" CenterY="1"/> <!-- Expands from center -->
                             </Border.RenderTransform>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0,0,24,4" VerticalAlignment="Center"/>

                        <!-- "Saved" Heartbeat Indicator -->
                        <TextBlock x:Name="SavedIndicator" 
                                   Text="✓" 
                                   Foreground="{DynamicResource FacilityAccentBrush}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Opacity="0"
                                   Margin="0,0,0,4"/> 
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Focus State Animation -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusVisual" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource DurationMicro}"/>
                                        <DoubleAnimation Storyboard.TargetName="FocusVisual" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="{StaticResource DurationStandard}">
                                            <DoubleAnimation.EasingFunction>
                                                <StaticResource ResourceKey="EaseOutPrimary"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusVisual" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource DurationMicro}"/>
                                        <DoubleAnimation Storyboard.TargetName="FocusVisual" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="{StaticResource DurationMicro}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        
                        <!-- TODO: Bind Opacity of SavedIndicator to an IsSaved property via DataTrigger or AttachedProperty if available. 
                             For now, the structure supports the requirement. -->
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================= -->
    <!-- 3. PREMIUM CARDS (Surface + Lift)                             -->
    <!-- ============================================================= -->

    <Style x:Key="StandardCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SeparatorStroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCardStandard}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingCard}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        
        <!-- Default Shadow (Level 1) -->
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Direction="270" Color="{DynamicResource ElevationColor}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InteractiveCardStyle" TargetType="Border" BasedOn="{StaticResource StandardCardStyle}">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Cursor" Value="Hand"/>
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- Hover Lift (-4px) -->
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                                             To="-4" Duration="{StaticResource DurationStandard}">
                                <DoubleAnimation.EasingFunction>
                                    <StaticResource ResourceKey="EaseOutPrimary"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <!-- Shadow Intensify -->
                            <!-- Note: Direct Effect property animation can be tricky in Styles without dedicated Storyboard targeting. 
                                 Simpler approach: Swap effect or animate Opacity if targeted. 
                                 For robustness in Style, we trust the TranslateTransform visual cue mostly. -->
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                                             To="0" Duration="{StaticResource DurationStandard}">
                                <DoubleAnimation.EasingFunction>
                                    <StaticResource ResourceKey="EaseOutPrimary"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GlobalModalContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingModal}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusModal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SeparatorStroke}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="48" ShadowDepth="12" Opacity="0.25" Direction="270" Color="{DynamicResource ElevationColor}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================= -->
    <!-- 4. PREMIUM DATAGRID                                           -->
    <!-- ============================================================= -->

    <Style x:Key="PremiumDataGridStyle" TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SeparatorStroke}"/>
        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        <Setter Property="RowHeight" Value="72"/> <!-- Fixed Height -->
        <Setter Property="HeadersVisibility" Value="Column"/>
        
        <Setter Property="CellStyle">
            <Setter.Value>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="16,0" Background="Transparent" SnapsToDevicePixels="True">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>

        <Setter Property="RowStyle">
            <Setter.Value>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridRow">
                                <Border x:Name="DGR_Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        SnapsToDevicePixels="True">
                                    <Grid>
                                        <!-- Selection Indicator Bar (Far Left) -->
                                        <Border x:Name="SelectionBar" 
                                                Width="4" HorizontalAlignment="Left" 
                                                Background="{DynamicResource FacilityAccentBrush}" 
                                                Visibility="Collapsed"/>
                                        
                                        <!-- Content -->
                                        <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="DGR_Border" Property="Background" Value="{DynamicResource FacilityAccentDimBrush}"/> <!-- 15% Opacity built into brush potentially, or set Opacity here if needed -->
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="SelectionBar" Value="Visible" Property="Visibility"/>
                                        <Setter TargetName="DGR_Border" Value="{DynamicResource SurfaceBg}" Property="Background"/>
                                    </Trigger>
                                    <!-- High Contrast / Keyboard Focus -->
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter TargetName="DGR_Border" Value="{DynamicResource FacilityAccentDimBrush}" Property="BorderBrush"/>
                                        <Setter TargetName="DGR_Border" Value="1" Property="BorderThickness"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>

        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                    <Setter Property="Height" Value="48"/>
                    <Setter Property="Padding" Value="16,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridColumnHeader">
                                <Border Background="Transparent" Padding="{TemplateBinding Padding}" BorderBrush="{DynamicResource SeparatorStroke}" BorderThickness="0,0,0,1">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================= -->
    <!-- 5. GLOBAL SKELETON SHIMMER                                    -->
    <!-- ============================================================= -->

    <Style x:Key="ShimmerPlaceholderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <LinearGradientBrush.GradientStops>
                        <!-- Base Color (Theme Aware) -->
                        <GradientStop Color="#0A808080" Offset="0"/>
                        <GradientStop Color="#20FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#0A808080" Offset="1"/>
                    </LinearGradientBrush.GradientStops>
                    <!-- Matrix Transform for Animation (Moving the gradient) -->
                    <LinearGradientBrush.RelativeTransform>
                        <TranslateTransform X="-1.0"/>
                    </LinearGradientBrush.RelativeTransform>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.RelativeTransform).(TranslateTransform.X)"
                                         From="-1" To="1" Duration="0:0:1.5"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================= -->
    <!-- 6. TOP NOTIFICATION BANNER                                    -->
    <!-- ============================================================= -->

    <Style x:Key="TopNotificationBannerStyle" TargetType="Border">
        <Setter Property="Width" Value="600"/>
        <Setter Property="MinHeight" Value="64"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBg}"/> <!-- Or dedicated Notification Bg -->
        <Setter Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="0,32,0,0"/> <!-- Offset from top -->
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.2" Direction="270" Color="{DynamicResource ElevationColor}"/>
            </Setter.Value>
        </Setter>
        <!-- Animation logic handled by View/ViewModel visibility triggers or behaviors usually, 
             but style defines the premium look (Radius 24, Width 600). -->
    </Style>

</ResourceDictionary>