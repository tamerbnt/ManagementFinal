<UserControl x:Class="Management.Presentation.Views.Restaurant.SelectTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:res="clr-namespace:Management.Presentation.Resources"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:Management.Presentation.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Border Style="{DynamicResource GlobalModalContainerStyle}"
            Width="600"
            Padding="32"
            VerticalAlignment="Center">

        <i:Interaction.Behaviors>
            <behaviors:ModalEntranceBehavior IsOpen="True"/>
        </i:Interaction.Behaviors>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Table Grid -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{DynamicResource Terminology.Restaurant.Order.SelectTable}" 
                           Style="{DynamicResource Title2}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Terminology.Restaurant.Order.SelectAvailableTable}" 
                           Style="{DynamicResource Body}" 
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,16"/>

                <!-- Section Filters -->
                <ListBox ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection}"
                         HorizontalAlignment="Center"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <RadioButton Content="{Binding}"
                                                     IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                     Style="{DynamicResource TogglePillStyle}"
                                                     GroupName="RestaurantSections"
                                                     Margin="4,0"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>

            <!-- Table List -->
            <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto">
                <ListBox ItemsSource="{Binding FilteredTables}"
                         SelectedItem="{Binding SelectedTable}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" Margin="4"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="TableBorder" 
                                                Background="{DynamicResource SurfaceBg}" 
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Padding="16"
                                                Margin="8">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                                            </Border.Effect>
                                            <Grid VerticalAlignment="Center">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{DynamicResource Strings.Restaurant.TABLE}" 
                                                               FontSize="10" 
                                                               FontWeight="Bold" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}" 
                                                               HorizontalAlignment="Center"
                                                               Opacity="0.6"/>
                                                    <TextBlock Text="{Binding TableNumber}" 
                                                               FontSize="32" 
                                                               FontWeight="Bold" 
                                                               Foreground="{DynamicResource TextPrimaryBrush}" 
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding MaxSeats, StringFormat='Seats: {0}'}" 
                                                               FontSize="12" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}" 
                                                               HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="TableBorder" Property="BorderBrush" Value="{DynamicResource FacilitySidebarBrush}"/>
                                                <Setter TargetName="TableBorder" Property="BorderThickness" Value="2"/>
                                                <Setter TargetName="TableBorder" Property="Background" Value="{DynamicResource FacilitySidebarBrush}"/>
                                                <Setter TargetName="TableBorder" Property="Opacity" Value="0.1"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <!-- Overlay logic for selected state -->
                                                <Setter TargetName="TableBorder" Property="Background" Value="{DynamicResource FacilitySidebarBrush}"/>
                                                <!-- We'll use a semi-transparent version in reality, for now solid is fine -->
                                            </MultiTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TableBorder" Property="BorderBrush" Value="{DynamicResource FacilitySidebarBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
                <Button Content="{DynamicResource Terminology.Restaurant.Order.Action.Cancel}" 
                        Command="{Binding CancelCommand}"
                        Style="{DynamicResource SecondaryButton}"
                        Width="100" Margin="0,0,12,0"/>
                <Button Content="{DynamicResource Terminology.Restaurant.Order.StartOrder}" 
                        Command="{Binding StartOrderCommand}"
                        Style="{DynamicResource PrimaryButton}"
                        Width="180"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
