<UserControl x:Class="Management.Presentation.Views.Registrations.RegistrationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:local="clr-namespace:Management.Presentation.Views.Registrations"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="ZeroIsVisibleConverter" />
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Bulk Action Bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- 1. Header & Global Actions -->
        <Grid Grid.Row="0" Margin="48,0,48,24">

            <!-- Left: Title Group -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource TerminologyRegistrationsLabel}" 
                           Style="{StaticResource Title1}" 
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginTextTop}">
                    <TextBlock Text="{DynamicResource TerminologyPendingLeadsLabel}" 
                               Style="{StaticResource BodySecondary}" 
                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <!-- Count Badge -->
                    <!-- FIX: Removed hardcoded Height="20", used MinHeight/Padding for sizing -->
                    <Border Background="{DynamicResource StatusErrorBrush}"
                            CornerRadius="{StaticResource RadiusPill}"
                            Padding="8,2"
                            MinHeight="{StaticResource SizeBadgeMinHeight}"
                            Margin="{StaticResource MarginSmallLeft}"
                            VerticalAlignment="Center"
                            Visibility="{Binding Registrations.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <TextBlock Text="{Binding Registrations.Count}"
                                   Style="{StaticResource Micro}"
                                   Foreground="{DynamicResource TextOnAccentBrush}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Right: Print Action -->
            <Button Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Command="{Binding PrintReportCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconPrinter}" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Style="{StaticResource IconSmall}"
                          Margin="{StaticResource MarginIconRight}"/>
                    <TextBlock Text="{DynamicResource TerminologyPrintReportLabel}"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 2. Bulk Action Context Bar (Section 27.5) -->
        <!-- FIX: Added Opacity to simulate the spec's 90% requirement -->
        <Border Grid.Row="1"
                Background="{DynamicResource FacilityAccentBrush}"
                Opacity="0.95" 
                CornerRadius="{StaticResource RadiusCardStandard}"
                Height="{StaticResource SizeSelectionBarHeight}"
                Padding="{StaticResource PaddingCardCompact}"
                Effect="{StaticResource Shadow3}"
                Margin="48,0,48,24"
                Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibilityConverter}}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Count -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Actions -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Close -->
                </Grid.ColumnDefinitions>

                <!-- Selected Count -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconCheckCircle}" 
                          Fill="{DynamicResource TextOnAccentBrush}" 
                          Style="{StaticResource IconSmall}" 
                          Margin="{StaticResource MarginSmallRight}"/>
                    <TextBlock Text="{Binding SelectedCount, StringFormat={DynamicResource TerminologySelectionCountFormat}}" 
                               Style="{StaticResource Title3}" 
                               Foreground="{DynamicResource TextOnAccentBrush}"/>
                </StackPanel>

                <!-- Bulk Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Approve All (Green) -->
                    <!-- Note: Uses global SuccessButtonStyle -->
                    <Button Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding ApproveSelectedCommand}"
                            Margin="{StaticResource MarginSmallRight}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconCheck}" 
                                  Fill="{DynamicResource TextOnAccentBrush}" 
                                  Style="{StaticResource IconSmall}"
                                  Margin="{StaticResource MarginIconRight}"/>
                            <TextBlock Text="{DynamicResource TerminologyApproveAllLabel}"/>
                        </StackPanel>
                    </Button>

                    <!-- Decline All (Red) -->
                    <Button Style="{StaticResource DestructiveButtonStyle}"
                            Command="{Binding DeclineSelectedCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconClose}" 
                                  Fill="{DynamicResource TextOnAccentBrush}" 
                                  Style="{StaticResource IconSmall}"
                                  Margin="{StaticResource MarginIconRight}"/>
                            <TextBlock Text="{DynamicResource TerminologyDeclineAllLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Clear Selection -->
                <Button Grid.Column="3"
                        Style="{StaticResource IconButtonStyle}"
                        Command="{Binding ClearSelectionCommand}"
                        Foreground="{DynamicResource TextOnAccentBrush}"
                        Margin="{StaticResource MarginMediumLeft}">
                    <Path Data="{StaticResource IconClose}" 
                          Fill="{DynamicResource TextOnAccentBrush}" 
                          Style="{StaticResource IconStandard}"/>
                </Button>
            </Grid>
        </Border>

        <!-- 3. Content Area (Row 2) -->
        <Grid Grid.Row="2" Margin="48,0">

            <!-- Registration List -->
            <ListBox ItemsSource="{Binding Registrations}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRingStyle}"/>
                        <Setter Property="Margin" Value="{StaticResource MarginCardGap}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <local:RegistrationListItem />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Celebration Empty State (Section 27.6) -->
            <Grid Visibility="{Binding Registrations.Count, Converter={StaticResource ZeroIsVisibleConverter}}"
                  IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,64">
                    <Path Data="{StaticResource IconCelebration}"
                          Fill="{DynamicResource FacilityAccentBrush}"
                          Width="64" Height="64"
                          Stretch="Uniform"
                          Margin="{StaticResource MarginSectionBottom}"
                          HorizontalAlignment="Center"/>

                    <TextBlock Text="{DynamicResource TerminologyAllCaughtUpLabel}" 
                               Style="{StaticResource Title2}" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center"
                               Margin="{StaticResource MarginTextBottom}"/>

                    <TextBlock Text="{DynamicResource TerminologyNoPendingRegistrationsLabel}" 
                               Style="{StaticResource Body}" 
                               Foreground="{DynamicResource TextTertiaryBrush}" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>