<UserControl x:Class="Management.Presentation.Views.FinanceAndStaff.FinancialReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1440"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:TrendToBrushConverter x:Key="TrendToBrushConverter"/>
    </UserControl.Resources>

    <!-- Scrollable Root -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  >
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource GlobalScrollBarStyle}"/>
        </ScrollViewer.Resources>

        <StackPanel Margin="{StaticResource MarginPage}">

            <!-- 1. HERO REVENUE CARD (Section 29.3) -->
            <!-- Uses ElevatedCardLevel3Style for highest elevation -->
            <Border Style="{StaticResource ElevatedCardLevel3Style}"
                    Height="{StaticResource SizeHeroCardHeight}"
                    Padding="{StaticResource PaddingHeroCard}"
                    Margin="{StaticResource MarginSectionBottom}"
                    AutomationProperties.Name="Monthly Revenue Overview">
                <Grid>
                    <!-- Global Sparkline Component -->
                    <!-- DataContext bound to VM property holding point collection -->
                    <ContentControl Style="{StaticResource GlobalRevenueSparkline}"
                                    DataContext="{Binding RevenueHistoryPoints}"
                                    VerticalAlignment="Bottom"
                                    Margin="0,20"/>

                    <StackPanel VerticalAlignment="Center">
                        <!-- Label -->
                        <TextBlock Text="{DynamicResource TerminologyWeeklyRevenueLabel}" 
                                   Style="{StaticResource Micro}" 
                                   Foreground="{DynamicResource TextTertiaryBrush}"  
                                   FontWeight="Bold"/>


                        <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginTextTop}">
                            <!-- Value (96pt Hero via Global Style) -->
                            <TextBlock Text="{Binding MonthlyRevenue, StringFormat='{}{0:C0}'}" 
                                       Style="{StaticResource HeroLive}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="{StaticResource MarginMediumRight}"/>

                            <!-- Growth Indicator -->
                            <Border Background="{Binding RevenueTrend, Converter={StaticResource TrendToBrushConverter}, ConverterParameter=Opacity}"
                                    CornerRadius="{StaticResource RadiusPill}"
                                    Padding="{StaticResource PaddingPill}"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="?" 
                                               Foreground="{Binding RevenueTrend, Converter={StaticResource TrendToBrushConverter}}"
                                               FontWeight="Bold"
                                               Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding RevenueGrowthPercentage, StringFormat='{}{0}%'}" 
                                               Style="{StaticResource Body}"
                                               Foreground="{Binding RevenueTrend, Converter={StaticResource TrendToBrushConverter}}"
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. KEY METRICS GRID -->
            <UniformGrid Columns="3" Rows="2" Margin="{StaticResource MarginSectionBottom}">
                <!-- Metric 1: MRR -->
                <Border Style="{StaticResource ElevatedCardStyle}" 
                        Height="{StaticResource SizeStatTileHeight}"
                        Padding="{StaticResource PaddingCard}"
                        Margin="{StaticResource MarginCardGap}">
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding MRR, StringFormat='{}{0:C0}'}" Style="{StaticResource Title1}"/>
                        <TextBlock Text="{DynamicResource TerminologyMRRLabel}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Metric 2: ARPU -->
                <Border Style="{StaticResource ElevatedCardStyle}" 
                        Height="{StaticResource SizeStatTileHeight}"
                        Padding="{StaticResource PaddingCard}"
                        Margin="{StaticResource MarginCardGap}">
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding ARPU, StringFormat='{}{0:C0}'}" Style="{StaticResource Title1}"/>
                        <TextBlock Text="{DynamicResource TerminologyARPULabel}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Metric 3: Churn Rate -->
                <Border Style="{StaticResource ElevatedCardStyle}" 
                        Height="{StaticResource SizeStatTileHeight}"
                        Padding="{StaticResource PaddingCard}"
                        Margin="{StaticResource MarginCardGap}">
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding ChurnRate, StringFormat='{}{0}%'}" 
                                   Style="{StaticResource Title1}" 
                                   Foreground="{DynamicResource StatusErrorBrush}"/>
                        <TextBlock Text="{DynamicResource TerminologyChurnRateLabel}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Metric 4: New Members -->
                <Border Style="{StaticResource ElevatedCardStyle}" 
                        Height="{StaticResource SizeStatTileHeight}"
                        Padding="{StaticResource PaddingCard}"
                        Margin="{StaticResource MarginCardGap}">
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding NewMembersCount}" 
                                   Style="{StaticResource Title1}" 
                                   Foreground="{DynamicResource StatusSuccessBrush}"/>
                        <TextBlock Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{DynamicResource Terminology.Financial.New}"/>
                            <Run Text=" "/>
                            <Run Text="{DynamicResource TerminologyPluralLabel}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Metric 5: Total Members -->
                <Border Style="{StaticResource ElevatedCardStyle}" 
                        Height="{StaticResource SizeStatTileHeight}"
                        Padding="{StaticResource PaddingCard}"
                        Margin="{StaticResource MarginCardGap}">
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding TotalMembersCount}" Style="{StaticResource Title1}"/>
                        <TextBlock Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="{DynamicResource Terminology.Financial.Total}"/>
                            <Run Text=" "/>
                            <Run Text="{DynamicResource TerminologyPluralLabel}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Metric 6: Payment Success -->
                <Border Style="{StaticResource ElevatedCardStyle}" 
                        Height="{StaticResource SizeStatTileHeight}"
                        Padding="{StaticResource PaddingCard}"
                        Margin="{StaticResource MarginCardGap}">
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding PaymentSuccessRate, StringFormat='{}{0}%'}" Style="{StaticResource Title1}"/>
                        <TextBlock Text="{DynamicResource TerminologyPaymentSuccessLabel}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 3. CHARTS AREA (Split 60/40) -->
            <Grid Margin="{StaticResource MarginSectionBottom}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="40*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Revenue Trend -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource TerminologyRevenueTrendLabel}" Style="{StaticResource Title3}" Margin="{StaticResource MarginHeaderBottom}"/>
                    <Border Style="{StaticResource ElevatedCardStyle}" Height="{StaticResource SizeChartHeightLarge}">
                        <!-- Global Bar Chart Component -->
                        <ContentControl Style="{StaticResource GlobalBarChart}"
                                        DataContext="{Binding MonthlyRevenueChartData}"
                                        Padding="{StaticResource PaddingCard}"/>
                    </Border>
                </StackPanel>

                <!-- Right: Payment Methods -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource TerminologyPaymentMethodsLabel}" Style="{StaticResource Title3}" Margin="{StaticResource MarginHeaderBottom}"/>
                    <Border Style="{StaticResource ElevatedCardStyle}" Height="{StaticResource SizeChartHeightLarge}">
                        <!-- Global Donut Chart Component -->
                        <ContentControl Style="{StaticResource GlobalDonutChart}"
                                        DataContext="{Binding PaymentMethodsChartData}"
                                        Padding="{StaticResource PaddingCard}"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 4. FAILED PAYMENTS LIST -->
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="{StaticResource MarginHeaderBottom}">
                    <TextBlock Text="{DynamicResource TerminologyFailedPaymentsLabel}" Style="{StaticResource Title3}"/>
                    <Border Background="{DynamicResource StatusErrorBrush}" 
                            CornerRadius="{StaticResource RadiusPill}" 
                            Padding="{StaticResource PaddingPill}" 
                            MinHeight="{StaticResource SizeBadgeMinHeight}"
                            Margin="{StaticResource MarginSmallLeft}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding FailedPayments.Count}" 
                                   Style="{StaticResource Micro}" 
                                   Foreground="{DynamicResource CardBackgroundBrush}" 
                                   FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding FailedPayments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBg}"
                                    BorderThickness="0,0,0,1"
                                    Padding="{StaticResource PaddingCardList}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Avatar -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Info -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Amount -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Action -->
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0" 
                                             Width="{StaticResource SizeAvatarSmall}" 
                                             Height="{StaticResource SizeAvatarSmall}"
                                             Fill="{DynamicResource AccentBrush}"
                                             Margin="{StaticResource MarginCardRight}"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding MemberName}" Style="{StaticResource BodyMedium}"/>
                                        <TextBlock Text="{Binding FailureReason}" Style="{StaticResource Caption}" Foreground="{DynamicResource StatusErrorBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding Amount, StringFormat='{}{0:N2} DA'}" 
                                               Style="{StaticResource BodyMedium}" 
                                               Foreground="{DynamicResource StatusErrorBrush}"
                                               VerticalAlignment="Center"
                                               Margin="{StaticResource MarginMediumRight}"/>

                                    <Button Grid.Column="3" 
                                            Content="{DynamicResource TerminologyRetryLabel}" 
                                            Style="{StaticResource ButtonCompactSecondary}" 
                                            Command="{Binding DataContext.RetryPaymentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
