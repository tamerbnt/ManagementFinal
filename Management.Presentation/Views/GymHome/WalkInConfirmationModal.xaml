<UserControl x:Class="Management.Presentation.Views.GymHome.WalkInConfirmationModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.GymHome"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:GymHomeViewModel}"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <!-- Modal Container -->
    <Border Style="{DynamicResource GlobalModalContainerStyle}" 
            CornerRadius="{DynamicResource RadiusModal}"
            Padding="32"
            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid>
            <Grid.RowDefinitions>
                <!-- 0: Header -->
                <RowDefinition Height="Auto"/>
                <!-- 1: Plan Selection List (takes remaining space, allowing scrolling) -->
                <RowDefinition Height="*"/>
                <!-- 2: Quantity Selector -->
                <RowDefinition Height="Auto"/>
                <!-- 3: Total Price Summary -->
                <RowDefinition Height="Auto"/>
                <!-- 4: Actions (Buttons) -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
                <Border Width="64" Height="64" CornerRadius="32" Background="{DynamicResource PrimaryBrush}" Margin="0,0,0,16">
                    <Path Data="{DynamicResource IconRunner}" 
                          Fill="White" 
                          Width="32" Height="32" 
                          Stretch="Uniform" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource Terminology.GymHome.WalkIn.Title}" Style="{DynamicResource Title2}" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Terminology.GymHome.WalkIn.Subtitle}" Style="{DynamicResource Body}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Plan Selection List -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Plans}" 
                     SelectedItem="{Binding SelectedPlan}"
                     BorderThickness="0"
                     Background="Transparent"
                     Margin="0,0,0,24">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" 
                                            CornerRadius="14" 
                                            BorderThickness="1.5" 
                                            BorderBrush="{DynamicResource SeparatorStroke}"
                                            Background="{DynamicResource SurfaceBgSecondary}"
                                            Padding="16"
                                            Margin="0,0,0,10"
                                            Cursor="Hand">
                                        <Grid Background="Transparent"> <!-- Explicit transparent background for hit testing -->
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Radio/Check Indicator -->
                                            <Border x:Name="IndicatorBorder"
                                                    Grid.Column="0" 
                                                    Width="22" Height="22" 
                                                    CornerRadius="11" 
                                                    BorderThickness="2" 
                                                    BorderBrush="{DynamicResource TextTertiaryBrush}"
                                                    Margin="0,0,16,0"
                                                    VerticalAlignment="Center">
                                                <Ellipse x:Name="CheckMark" 
                                                         Width="12" Height="12" 
                                                         Fill="{DynamicResource PrimaryBrush}"
                                                         Visibility="Collapsed"/>
                                            </Border>

                                            <!-- Content -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="NameText" Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="DurationText" Text="{Binding DurationDescription}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Price -->
                                            <TextBlock x:Name="PriceText" 
                                                       Grid.Column="2" 
                                                       Text="{Binding Price, StringFormat='{}{0:N2} DA'}" 
                                                       FontSize="16"
                                                       FontWeight="ExtraBold" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="Transparent"/>
                                            <Setter TargetName="ItemBorder" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                        <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="0"/> <!-- Facility Accent -->
                                                        <GradientStop Color="{DynamicResource FacilityAccentColor}" Offset="1"/> <!-- Facility Accent -->
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="CheckMark" Property="Fill" Value="White"/>
                                            <Setter TargetName="ItemBorder" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.4" Color="{DynamicResource FacilityAccentColor}"/>
                                                </Setter.Value>
                                            </Setter>
                                            <!-- Invert text colors for readability on dark background -->
                                            <Setter TargetName="NameText" Property="Foreground" Value="White"/>
                                            <Setter TargetName="DurationText" Property="Foreground" Value="{DynamicResource OnAccentSecondary}"/>
                                            <Setter TargetName="PriceText" Property="Foreground" Value="White"/>
                                            <Setter TargetName="IndicatorBorder" Property="BorderBrush" Value="White"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2"/>
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource FacilityAccentBrush}"/>
                                        </DataTrigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SurfaceBg}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Quantity Selector -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBgSecondary}" 
                    CornerRadius="16" 
                    Padding="20"
                    Margin="0,0,0,24"
                    BorderBrush="{DynamicResource SeparatorStroke}"
                    BorderThickness="1">
                <DockPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Terminology.GymHome.WalkIn.Quantity}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{DynamicResource Terminology.GymHome.WalkIn.QuantityDesc}" Style="{DynamicResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding DecrementGuestCountCommand}" 
                                Style="{DynamicResource SecondaryButton}" 
                                Width="36" Height="36" Padding="0"
                                FontSize="18" FontWeight="Bold"
                                Content="-"/>
                        
                        <TextBlock Text="{Binding GuestCount}" 
                                   Width="44" 
                                   TextAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   FontSize="20" 
                                   FontWeight="ExtraBold"
                                   Foreground="{DynamicResource FacilityAccentBrush}"/>
                        
                        <Button Command="{Binding IncrementGuestCountCommand}" 
                                Style="{DynamicResource SecondaryButton}" 
                                Width="36" Height="36" Padding="0"
                                FontSize="18" FontWeight="Bold"
                                Content="+"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Total Price Summary -->
            <Border Grid.Row="3"
                    Background="{DynamicResource SurfaceBg}" 
                    CornerRadius="12" 
                    Padding="16" 
                    Margin="0,16,0,0">
                <Grid>
                    <TextBlock Text="{DynamicResource Terminology.GymHome.WalkIn.GrandTotal}" VerticalAlignment="Center" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource FacilityAccentBrush}"/>
                    <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0:N2} DA'}" 
                               HorizontalAlignment="Right" 
                               VerticalAlignment="Center" 
                               FontWeight="Bold" 
                               FontSize="20" 
                               Foreground="{DynamicResource FacilityAccentBrush}"/>
                </Grid>
            </Border>

            <!-- Actions -->
            <Grid Grid.Row="4" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="2*"/> <!-- More space for the long confirm button -->
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" 
                        Command="{Binding CancelCommand}" 
                        IsCancel="True"
                        Style="{DynamicResource GhostButton}" 
                        Content="{DynamicResource Terminology.Global.Cancel}"/>
                        
                <Button Grid.Column="2" 
                        Command="{Binding ConfirmWalkInCommand}" 
                        Style="{DynamicResource PrimaryButton}" 
                        IsDefault="True"
                        Content="{DynamicResource Terminology.GymHome.WalkIn.Action.Confirm}"
                        Padding="16,8"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
