<UserControl x:Class="Management.Presentation.Views.Settings.SettingsModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Management.Presentation.Views.Settings"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Settings"
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="960">
    <UserControl.Resources>
        <ResourceDictionary>
            <!-- No local MergedDictionaries - using global App.xaml resources -->
            
            <!-- Specific DataTemplates for Lazy Loading -->
            <DataTemplate x:Key="AccountTemplate">
                <local:AccountSectionView/>
            </DataTemplate>

            <DataTemplate x:Key="MembershipPlansTemplate">
                <local:PlanSectionView 
                    ItemsSource="{Binding MembershipPlans}" 
                    Title="{DynamicResource TerminologyMembershipPlansLabel}"
                    AddPlanCommand="{Binding AddMembershipPlanCommand}"
                    EditPlanCommand="{Binding EditMembershipPlanCommand}"
                    DeletePlanCommand="{Binding DeleteMembershipPlanCommand}"/>
            </DataTemplate>

            <DataTemplate x:Key="WalkInPlansTemplate">
                <local:PlanSectionView 
                    ItemsSource="{Binding WalkInPlans}" 
                    Title="{DynamicResource Terminology.Settings.WalkInPlans}"
                    AddPlanCommand="{Binding AddWalkInPlanCommand}"
                    EditPlanCommand="{Binding EditWalkInPlanCommand}"
                    DeletePlanCommand="{Binding DeleteWalkInPlanCommand}"/>
            </DataTemplate>

            <DataTemplate x:Key="ServicesTemplate">
                <local:ServiceSectionView 
                    ItemsSource="{Binding SalonServices}" 
                    Title="{DynamicResource Terminology.Salon.Services.Title}"
                    AddServiceCommand="{Binding AddSalonServiceCommand}"
                    EditServiceCommand="{Binding EditSalonServiceCommand}"
                    DeleteServiceCommand="{Binding DeleteSalonServiceCommand}"/>
            </DataTemplate>

            <DataTemplate x:Key="AppearanceTemplate">
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="{DynamicResource Terminology.Settings.Appearance}" 
                               Style="{DynamicResource Title2}" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,24"/>

                    <!-- Language Selector -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="{DynamicResource Terminology.Settings.Language}" Style="{DynamicResource Title3}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Terminology.Settings.LanguageDesc}" Style="{DynamicResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <ComboBox ItemsSource="{Binding SupportedLanguages}"
                                   SelectedItem="{Binding SelectedLanguage}"
                                   IsEditable="False"
                                   DisplayMemberPath="NativeName" Width="300" HorizontalAlignment="Left" Style="{DynamicResource Input.ComboBox}"/>
                    </StackPanel>

                    <!-- Theme Selector -->
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Terminology.Settings.Theme}" Style="{DynamicResource Title3}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Terminology.Settings.ThemeDesc}" Style="{DynamicResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <ComboBox Width="300" HorizontalAlignment="Left" Style="{DynamicResource Input.ComboBox}" IsEditable="False" SelectedIndex="0">
                            <ComboBoxItem Content="{DynamicResource Terminology.Settings.Theme.Light}"/>
                            <ComboBoxItem Content="{DynamicResource Terminology.Settings.Theme.Dark}"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="ApparatusTemplate">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                    <StackPanel>
                        <!-- Local Peripherals (The 3 Cards) -->
                        <local:DevicesSectionView DataContext="{Binding}" Margin="0,0,0,40" />
                        
                        <!-- Authorized Remote Machines -->
                        <local:DeviceManagementView DataContext="{Binding DeviceManagement}"/>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>

            <DataTemplate x:Key="BackupsTemplate">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Data Backups" 
                                   Style="{DynamicResource Title2}" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Manage your database backups to ensure data safety." 
                                   Style="{DynamicResource Caption}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,32"/>

                        <!-- Backup Status Card -->
                        <Border Background="{DynamicResource ComponentBg}" 
                                CornerRadius="16" 
                                Padding="24"
                                BorderBrush="{DynamicResource SeparatorStroke}"
                                BorderThickness="1"
                                Margin="0,0,0,24">
                            <StackPanel>
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Backup Location" Style="{DynamicResource Title3}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding BackupFolderPath}" Style="{DynamicResource BodySmall}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" 
                                            Content="Open Folder" 
                                            Style="{DynamicResource Button.Ghost}"
                                            Command="{Binding OpenBackupFolderCommand}"/>
                                </Grid>

                                <Separator Background="{DynamicResource SeparatorStroke}" Margin="0,0,0,24"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Last Backup Date" Style="{DynamicResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding LastBackupDateDisplay}" Style="{DynamicResource BodyMedium}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Last Backup Size" Style="{DynamicResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding LastBackupSizeDisplay}" Style="{DynamicResource BodyMedium}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Actions -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Create Backup Now" 
                                    Style="{DynamicResource Button.Primary}"
                                    Command="{Binding CreateBackupNowCommand}"
                                    Width="200" Height="48"
                                    Margin="0,0,16,0"/>
                            
                            <Border Background="#1A3498DB" CornerRadius="12" Padding="16,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon.CheckCircle}" Fill="#3498DB" Style="{StaticResource Style.Icon.Small}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Automatic 7-day retention active" Foreground="#3498DB" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <TextBlock Text="A backup is automatically created once per day when the application starts." 
                                   Style="{DynamicResource Caption}" 
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,16,0,0"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <!-- Overlay Background (Darker Navy, Lower Opacity) -->
            <Border Background="{DynamicResource OverlayBackdropBrush}" Opacity="0.2">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.CloseSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/> 
                </Border.InputBindings>
            </Border>
            
            <!-- Modal Content (Large Radius, Subtle Depth) -->
            <Border Background="{DynamicResource SurfaceBg}"
                    CornerRadius="24"
                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.8}" 
                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.8}"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource SeparatorStroke}"
                BorderThickness="1"
                ClipToBounds="True">
            <Border.Style>
                <Style TargetType="Border">
                    <!-- High-performance depth effect without DropShadowEffect -->
                    <Setter Property="BorderBrush" Value="#26000000"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- GLOBAL CLOSE BUTTON -->
                <Button Grid.Column="1"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Style="{DynamicResource IconButtonStyle}"
                        Command="{Binding DataContext.CloseSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Margin="0,16,16,0"
                        Panel.ZIndex="100"
                        Cursor="Hand"> 
                    <Path Data="{DynamicResource IconClose}"
                          Fill="{DynamicResource TextSecondaryBrush}"
                          Style="{DynamicResource Style.Icon.Small}"/>
                </Button>


                <!-- SIDEBAR (Floating Island) -->
                <Border Grid.Column="0" 
                        Background="{DynamicResource FacilitySidebarBrush}"
                        CornerRadius="16"
                        Margin="12,12,0,12"
                        BorderBrush="#1A000000"
                        BorderThickness="0,0,1,1">
                    <Grid Margin="20,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,32">
                            <Path Data="{DynamicResource IconSettings}" 
                                  Style="{DynamicResource Style.Icon.Large}" 
                                  Stroke="White"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Terminology.Settings}" 
                                       Style="{DynamicResource Title2}" 
                                       Foreground="White"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Navigation Items -->
                        <StackPanel Grid.Row="1">
                            <!-- Shared Button Style with Active Indicator -->
                            <StackPanel.Resources>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Sidebar.Text.Inactive}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="16,0"/>
                                    <Setter Property="Height" Value="48"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
                                                    <Grid.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Grid.RenderTransform>
                                                    <Border x:Name="Border" 
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="12"
                                                            Padding="{TemplateBinding Padding}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border x:Name="ActivePill" 
                                                                    Grid.Column="0"
                                                                    Width="4" Height="18"
                                                                    Background="{DynamicResource FacilityAccentBrush}"
                                                                    CornerRadius="2"
                                                                    Margin="-16,0,12,0"
                                                                    Visibility="Collapsed">
                                                                <Border.RenderTransform>
                                                                    <TranslateTransform X="-10"/>
                                                                </Border.RenderTransform>
                                                            </Border>
                                                            <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource Brush.Sidebar.Hover}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="RootGrid" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                     To="0.96" Duration="{StaticResource DurationQuick}"/>
                                                                    <DoubleAnimation Storyboard.TargetName="RootGrid" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                     To="0.96" Duration="{StaticResource DurationQuick}"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="RootGrid" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                     To="1" Duration="{StaticResource DurationQuick}"/>
                                                                    <DoubleAnimation Storyboard.TargetName="RootGrid" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                     To="1" Duration="{StaticResource DurationQuick}"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                <Binding Path="DataContext.SelectedTab" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                <Binding Path="CommandParameter" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource FacilityAccentBrush}"/>
                                                        <Setter TargetName="ActivePill" Property="Visibility" Value="Collapsed"/>
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ActivePill" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                                     From="-10" To="0" Duration="0:0:0.18">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <QuarticEase EasingMode="EaseOut"/>
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                    <Binding Path="DataContext.SelectedTab" RelativeSource="{RelativeSource Self}"/>
                                                    <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Resources>



                            <!-- Account Tab -->
                            <Button Command="{Binding SelectTabCommand}" CommandParameter="Account">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconMembers}" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Style="{StaticResource Style.Icon.Small}"
                                          Margin="0,0,12,0"/>
                                    <TextBlock Text="{DynamicResource Terminology.Settings.AccountNew}" 
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Membership Plans Tab -->
                            <Button Command="{Binding SelectTabCommand}" 
                                    CommandParameter="MembershipPlans"
                                    Visibility="{Binding ShowMembershipPlans, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconTag}" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Style="{StaticResource Style.Icon.Small}"
                                          Margin="0,0,12,0"/>
                                    <TextBlock Text="{DynamicResource Terminology.Settings.MembershipPlans}" 
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Walk-In Plans Tab -->
                            <Button Command="{Binding SelectTabCommand}" 
                                    CommandParameter="WalkInPlans"
                                    Visibility="{Binding ShowWalkInPlans, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconRunner}" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Style="{StaticResource Style.Icon.Small}"
                                          Margin="0,0,12,0"/>
                                    <TextBlock Text="{DynamicResource Terminology.Settings.WalkInPlans}" 
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Salon Services Tab -->
                            <Button Command="{Binding SelectTabCommand}" 
                                    CommandParameter="Services"
                                    Visibility="{Binding ShowSalonServices, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconSalon}" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Style="{StaticResource Style.Icon.Small}"
                                          Margin="0,0,12,0"/>
                                    <TextBlock Text="{DynamicResource Terminology.Salon.Services.Title}" 
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>


                            <!-- Appearance Tab -->
                            <Button Command="{Binding SelectTabCommand}" CommandParameter="Appearance">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconMoon}" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Style="{StaticResource Style.Icon.Small}"
                                          Margin="0,0,12,0"/>
                                    <TextBlock Text="{DynamicResource Terminology.Settings.Appearance}" 
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Apparatus Tab -->
                            <Button Command="{Binding SelectTabCommand}" CommandParameter="Apparatus">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Icon.Sliders}" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Style="{StaticResource Style.Icon.Small}"
                                          Margin="0,0,12,0"/>
                                    <TextBlock Text="{DynamicResource Terminology.Settings.Apparatus}" 
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Backups Tab -->
                            <Button Command="{Binding SelectTabCommand}" CommandParameter="Backups">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Icon.Copy}" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Style="{StaticResource Style.Icon.Small}"
                                          Margin="0,0,12,0"/>
                                    <TextBlock Text="Backups" 
                                               Style="{StaticResource BodyMedium}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="32,32,40,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1">
                        <!-- ContentControl for Lazy Loading Content -->
                        <ContentControl Content="{Binding}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="ContentTemplate" Value="{StaticResource AccountTemplate}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="MembershipPlans">
                                            <Setter Property="ContentTemplate" Value="{StaticResource MembershipPlansTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="WalkInPlans">
                                            <Setter Property="ContentTemplate" Value="{StaticResource WalkInPlansTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="Services">
                                            <Setter Property="ContentTemplate" Value="{StaticResource ServicesTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="Appearance">
                                            <Setter Property="ContentTemplate" Value="{StaticResource AppearanceTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="Apparatus">
                                            <Setter Property="ContentTemplate" Value="{StaticResource ApparatusTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="Backups">
                                            <Setter Property="ContentTemplate" Value="{StaticResource BackupsTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </Grid>
                </Grid>

                <!-- DRAWER OVERLAY (Side Panel) - Extended across both columns -->
                <Border x:Name="DrawerOverlay" 
                        Grid.Column="0" Grid.ColumnSpan="2"
                        Background="Black" 
                        Opacity="0"
                        Panel.ZIndex="99"
                        CornerRadius="24">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0.4" Duration="{StaticResource DurationNormal}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="{StaticResource DurationNormal}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Button Style="{DynamicResource Button.Ghost}"
                            Command="{Binding CloseDrawerCommand}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Opacity="0"
                            Cursor="Arrow"/>
                </Border>

                <Border x:Name="Drawer" 
                        Grid.Column="1"
                        HorizontalAlignment="Right" 
                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource MultiplyValueConverter}, ConverterParameter=0.45}" 
                        Background="White" 
                        BorderBrush="#1A000000" 
                        BorderThickness="1,0,0,0"
                        Panel.ZIndex="100"
                        CornerRadius="0,24,24,0"
                        ClipToBounds="True">
                    <Border.RenderTransform>
                        <TranslateTransform X="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=local:SettingsModalView}, Path=ActualWidth}"/>
                    </Border.RenderTransform>
                    <Border.CacheMode>
                        <BitmapCache EnableClearType="True" RenderAtScale="1.5" SnapsToDevicePixels="True"/>
                    </Border.CacheMode>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                 To="0" Duration="{StaticResource DurationNormal}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                 To="480" Duration="{StaticResource DurationNormal}">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ContentControl Content="{Binding CurrentDrawerContent}">
                        <ContentControl.Resources>
                            <!-- Map ViewModel to View -->
                            <DataTemplate DataType="{x:Type vm:MembershipPlanEditorViewModel}"> 
                                <local:MembershipPlanEditorView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:SalonServiceEditorViewModel}"> 
                                <local:SalonServiceEditorView/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ScrollViewer>
</UserControl>
