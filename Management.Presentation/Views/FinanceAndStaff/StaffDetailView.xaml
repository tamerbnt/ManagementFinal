<UserControl x:Class="Management.Presentation.Views.FinanceAndStaff.StaffDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:Management.Presentation.Converters"
             xmlns:local="clr-namespace:Management.Presentation.Views.FinanceAndStaff"
             xmlns:vm="clr-namespace:Management.Presentation.ViewModels.Finance"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="400"
             Background="{DynamicResource SurfaceBg}">

    <UserControl.Resources>
        <converters:NameToBrushConverter x:Key="NameToBrushConverter"/>
        <converters:NameToInitialConverter x:Key="NameToInitialConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="ZeroIsVisibleConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Stats -->
            <RowDefinition Height="*"/>    <!-- Content/Tabs -->
        </Grid.RowDefinitions>

        <!-- 1. Profile Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <Grid x:Name="DetailAvatar">
                <Ellipse Width="80" Height="80" HorizontalAlignment="Center"
                         Fill="{Binding FullName, Converter={StaticResource NameToBrushConverter}}"/>
                <TextBlock Text="{Binding FullName, Converter={StaticResource NameToInitialConverter}}" 
                           Style="{StaticResource Title1}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           Foreground="White"/>
            </Grid>
            <StackPanel x:Name="NameContainer" Margin="0,12,0,4" HorizontalAlignment="Center">
                <TextBlock Text="{Binding FullName}" Style="{StaticResource Title2}"
                           Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                <!-- Editing Name (Placeholder) -->
                <TextBox Text="{Binding FullName, Mode=TwoWay}" Style="{StaticResource Input.Field}" Width="250"
                         Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
            
            <ContentControl Content="{Binding Role}" 
                            Style="{StaticResource GlobalRoleBadgeStyle}" 
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0"/>

        </StackPanel>

        <!-- 2. Stats Grid (Mock Data Match) -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,24">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource Terminology.Staff.Detail.Joined}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding HireDate, StringFormat='{}{0:yyyy}'}" Style="{StaticResource Title3}" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource Terminology.Staff.Detail.Permissions}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Permissions.Count}" Style="{StaticResource Title3}" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource Terminology.Staff.Detail.Status}" Style="{StaticResource Micro}" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding EmploymentStatus}" Style="{StaticResource Title3}" HorizontalAlignment="Center" Foreground="{DynamicResource BrandPrimaryBrush}"/>
            </StackPanel>
        </UniformGrid>

        <!-- 3. Tabs -->
        <TabControl Grid.Row="2" Style="{StaticResource PremiumTabControl}">
            <TabItem Header="{DynamicResource Terminology.Staff.Tab.Overview}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="{DynamicResource Terminology.Members.Detail.ContactInfo}" Style="{StaticResource Title3}" Margin="0,0,0,12"/>
                        
                        <!-- Email -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Members.Detail.Email}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding Email}" Style="{StaticResource Body}"
                                       Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                            <TextBox Text="{Binding Email, Mode=TwoWay}" Style="{StaticResource Input.Field}"
                                     Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                        
                        <!-- Phone -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Members.Detail.Phone}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding PhoneNumber}" Style="{StaticResource Body}"
                                       Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                            <TextBox Text="{Binding Phone, Mode=TwoWay}" Style="{StaticResource Input.Field}"
                                     Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                        
                        <!-- Hire Date -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource Terminology.Staff.Detail.Joined}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding HireDate, StringFormat='{}{0:MMM dd, yyyy}'}" Style="{StaticResource Body}"/>
                        </StackPanel>

                        <!-- Salary & Payment Day -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource Terminology.Staff.Detail.Salary}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                <TextBlock Text="{Binding Salary, StringFormat='{}{0:N2} DA'}" Style="{StaticResource Body}"
                                           Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                <TextBox Text="{Binding Salary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input.Field}"
                                         Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource Terminology.Staff.Detail.PayDay}" Style="{StaticResource Caption}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                <TextBlock Text="{Binding PaymentDay}" Style="{StaticResource Body}"
                                           Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                <TextBox Text="{Binding PaymentDay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource Input.Field}"
                                         Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            

        </TabControl>

        
        <!-- Top Right Close Button -->
        <Button Width="32" Height="32" 
                Style="{StaticResource IconButtonStyle}" 
                Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}}"
                HorizontalAlignment="Right" VerticalAlignment="Top" Grid.Row="0">
            <Path Data="{StaticResource IconClose}" Stroke="{DynamicResource TextTertiaryBrush}" Width="12" Height="12" Stretch="Uniform"/>
        </Button>

        <!-- Edit Actions Bar (Floating Footer) -->
        <Border Grid.Row="2" VerticalAlignment="Bottom" Background="White" CornerRadius="16" Padding="16,12" Margin="0,0,0,12"
                Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{DynamicResource Terminology.Global.Cancel}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                        Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}}"/>
                <Button Grid.Column="1" Content="{DynamicResource Terminology.Members.Action.SaveChanges}" Style="{StaticResource PrimaryButton}"
                        Command="{Binding DataContext.SaveStaffCommand, RelativeSource={RelativeSource AncestorType=local:FinanceAndStaffView}}"/>
            </Grid>
        </Border>
        


    </Grid>
</UserControl>
