<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Typography -->
    <FontFamily x:Key="Font.Primary">Segoe UI, Inter, Arial</FontFamily>

    <!-- Colors: Inherited from Colors.xaml -->
    <!-- Brushes -->
    <!-- Removed duplicate/legacy keys managed by Branding.Gym.xaml
    <SolidColorBrush x:Key="Brush.Brand.Primary" Color="{StaticResource Color.Brand.Primary}" />
    <SolidColorBrush x:Key="Brush.Brand.Primary.Deep" Color="{StaticResource Color.Brand.Primary.Deep}" />
    -->
    <SolidColorBrush x:Key="Brush.Background.Static" Color="#F1F5F9" />
    <SolidColorBrush x:Key="Brush.Window.Background" Color="#F1F5F9" />
    <SolidColorBrush x:Key="Brush.Surface.Glass" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface.Glass.Standard" Color="#33FFFFFF" /> <!-- 20% Alpha Tint -->
    <SolidColorBrush x:Key="Brush.Surface.Glass.Eco" Color="#E61E293B" /> <!-- 90% Opacity #1E293B -->
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#1A1A1A" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#6B7280" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="#E5E7EB" />
    <SolidColorBrush x:Key="Brush.Neutral.White" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface.Secondary" Color="#F8FAFC" />
    <SolidColorBrush x:Key="Brush.Surface.Hover" Color="#14000000" />
    <SolidColorBrush x:Key="Brush.Border.Primary" Color="#0078D4" />
    <SolidColorBrush x:Key="Brush.Success" Color="#10B981" />
    <SolidColorBrush x:Key="Brush.Success.Dim" Color="#10B981" Opacity="0.1" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#EF4444" />
    <SolidColorBrush x:Key="Brush.Danger.Dim" Color="#EF4444" Opacity="0.1" />
    <SolidColorBrush x:Key="Brush.Shadow.Depth" Color="#1A000000" />
    <SolidColorBrush x:Key="Brush.Accent.Primary" Color="#5B8AB8" />

    <!-- Sidebar Brushes -->
    <SolidColorBrush x:Key="Brush.Sidebar.Background" Color="#0F172A" />
    <SolidColorBrush x:Key="Brush.Sidebar.Text.Inactive" Color="#94A3B8" />
    <SolidColorBrush x:Key="Brush.Sidebar.Text.Active" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Sidebar.Accent.Blue" Color="#3B82F6" />
    <SolidColorBrush x:Key="Brush.Sidebar.Accent.Cyan" Color="#0EA5E9" />
    <SolidColorBrush x:Key="Brush.Sidebar.Accent.Teal" Color="#06B6D4" />
    <SolidColorBrush x:Key="Brush.Sidebar.Separator" Color="#334155" />
    <SolidColorBrush x:Key="Brush.Sidebar.Hover" Color="#0FFFFFFF" />

</ResourceDictionary>
